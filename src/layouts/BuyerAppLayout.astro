---
import Header from '../components/Header.astro';
import BottomNav from '../components/BottomNav.astro';
import { getBuyerShellState } from '../lib/ui/buyerShell';
import Layout from './Layout.astro';

interface Props {
    title?: string;
    description?: string;
}

const { title, description } = Astro.props;
const { wishlistCount, profileIncomplete } = await getBuyerShellState(Astro.cookies, Astro.request);
const currentPath = Astro.url.pathname;
---

<Layout title={title} description={description}>
    <slot name="head" slot="head" />
    <Header currentPath={currentPath} wishlistCount={wishlistCount} profileIncomplete={profileIncomplete} />
    <slot name="afterHeader" />
    <slot />
    <BottomNav currentPath={currentPath} wishlistCount={wishlistCount} profileIncomplete={profileIncomplete} />
</Layout>