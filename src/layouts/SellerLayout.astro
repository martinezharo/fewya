---
import Layout from './Layout.astro';
import SellerSidebar from '../components/seller/SellerSidebar.astro';
import Icon from '../components/icons/Icon.astro';
import { strings } from '../lib/core/i18n';
import { createSupabaseAuthClient } from '../lib/core/auth';

interface Props {
    title?: string;
    description?: string;
    shopSlug?: string;
    shopId?: string;
}

const { title, description, shopSlug, shopId } = Astro.props;
const currentPath = Astro.url.pathname;

let stripeStatus: 'not_connected' | 'pending' | 'ready' = 'not_connected';
let activeIncidents = 0;
let pendingOrdersCount = 0;

if (shopId) {
    const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
    const { data: paymentAccount } = await supabase
        .from('shop_payment_accounts')
        .select('stripe_account_id, charges_enabled, payouts_enabled, details_submitted')
        .eq('shop_id', shopId)
        .maybeSingle();

    if (paymentAccount?.stripe_account_id) {
        if (paymentAccount.charges_enabled && paymentAccount.payouts_enabled && paymentAccount.details_submitted) {
            stripeStatus = 'ready';
        } else {
            stripeStatus = 'pending';
        }
    }

    const { count: incidentsCount } = await supabase
        .from('orders')
        .select('id', { count: 'exact', head: true })
        .eq('shop_id', shopId)
        .eq('status', 'incident');

    activeIncidents = incidentsCount ?? 0;

    const { count: pendingCount } = await supabase
        .from('orders')
        .select('id', { count: 'exact', head: true })
        .eq('shop_id', shopId)
        .in('status', ['paid', 'processing']);

    pendingOrdersCount = pendingCount ?? 0;
}
---

<Layout title={title} description={description}>
    <div class="flex h-dvh overflow-hidden bg-bg">
        <SellerSidebar currentPath={currentPath} shopSlug={shopSlug} stripeStatus={stripeStatus} activeIncidents={activeIncidents} pendingOrdersCount={pendingOrdersCount} />

        <div class="flex flex-col flex-1 min-w-0 overflow-hidden">
            <!-- Mobile top bar (hidden on lg+) -->
            <header class="flex items-center h-14 px-4 border-b border-border shrink-0 bg-surface lg:hidden">
                <button
                    id="seller-mobile-menu-toggle"
                    class="flex items-center justify-center w-9 h-9 -ml-1.5 rounded-lg text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors"
                    aria-label={strings.sellerSidebarOpenLabel}
                    aria-expanded="false"
                    aria-controls="seller-sidebar"
                >
                    <Icon name="menu" size={20} />
                </button>
                <a href="/sell" class="ml-2 font-semibold text-sm text-text-primary tracking-tight">
                    {strings.sellerBrandName}
                </a>
            </header>

            <!-- Scrollable page content -->
            <main class="flex-1 overflow-y-auto">
                <slot />
            </main>
        </div>
    </div>
</Layout>

<script>
    function initMobileToggle() {
        const btn = document.getElementById('seller-mobile-menu-toggle');
        if (!btn) return;

        btn.addEventListener('click', () => {
            window.openSellerSidebar?.();
            btn.setAttribute('aria-expanded', 'true');
        });

        // Reset aria-expanded when sidebar closes via backdrop/close btn
        document.getElementById('seller-sidebar-backdrop')?.addEventListener('click', () => {
            btn.setAttribute('aria-expanded', 'false');
        });
        document.getElementById('seller-sidebar-close-btn')?.addEventListener('click', () => {
            btn.setAttribute('aria-expanded', 'false');
        });
    }

    document.addEventListener('astro:page-load', initMobileToggle);
    if (document.readyState !== 'loading') initMobileToggle();
    else document.addEventListener('DOMContentLoaded', initMobileToggle);
</script>
