---
import Layout from './Layout.astro';
import SellerSidebar from '../components/seller/SellerSidebar.astro';
import PushPrompt from '../components/notifications/PushPrompt.astro';
import Icon from '../components/icons/Icon.astro';
import { createSupabaseAuthClient } from '../lib/core/auth';
import { validateProductCompleteness } from '../lib/products/productValidation';
import { isProfileComplete } from '../lib/core/validation';
import { ORDER_STATUS } from '../lib/orders/orderStatus';

interface Props {
    title?: string;
    description?: string;
    shopSlug?: string;
    shopId?: string;
}

const { t } = Astro.locals;
const { title, description, shopSlug, shopId } = Astro.props;
const currentPath = Astro.url.pathname;

let stripeStatus: 'not_connected' | 'pending' | 'ready' = 'not_connected';
let activeIncidents = 0;
let pendingOrdersCount = 0;
let deliveryFailedCount = 0;
let incompleteProductsCount = 0;
let sellerDetailsIncomplete = false;

if (shopId) {
    const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
    const { data: { user } } = await supabase.auth.getUser();

    if (user) {
        const { data: profile } = await supabase
            .from('profiles')
            .select('first_name, last_name, phone, address_street, address_number, address_postal_code, address_city, address_province, address_country')
            .eq('id', user.id)
            .maybeSingle();
        sellerDetailsIncomplete = !isProfileComplete(profile ?? {}).complete;
    }

    const { data: paymentAccount } = await supabase
        .from('shop_payment_accounts')
        .select('stripe_account_id, charges_enabled, payouts_enabled, details_submitted')
        .eq('shop_id', shopId)
        .maybeSingle();

    if (paymentAccount?.stripe_account_id) {
        if (paymentAccount.charges_enabled && paymentAccount.payouts_enabled && paymentAccount.details_submitted) {
            stripeStatus = 'ready';
        } else {
            stripeStatus = 'pending';
        }
    }

    const { count: incidentsCount } = await supabase
        .from('orders')
        .select('id', { count: 'exact', head: true })
        .eq('shop_id', shopId)
        .eq('status', ORDER_STATUS.INCIDENT);

    activeIncidents = incidentsCount ?? 0;

    const { count: pendingCount } = await supabase
        .from('orders')
        .select('id', { count: 'exact', head: true })
        .eq('shop_id', shopId)
        .in('status', [ORDER_STATUS.PAID, ORDER_STATUS.PROCESSING]);

    pendingOrdersCount = pendingCount ?? 0;

    const { count: failedCount } = await supabase
        .from('orders')
        .select('id', { count: 'exact', head: true })
        .eq('shop_id', shopId)
        .eq('status', ORDER_STATUS.DELIVERY_FAILED);

    deliveryFailedCount = failedCount ?? 0;

    const { data: allProducts } = await supabase
        .from('products')
        .select('id, gallery_images, slug, title, description, category')
        .eq('shop_id', shopId);

    const { data: allVariants } = await supabase
        .from('product_variants')
        .select('id, price, stock, weight_kg, length_cm, width_cm, height_cm, shipping_cost, product_id')
        .in('product_id', (allProducts ?? []).map((p: any) => p.id));

    let incompleteCount = 0;
    for (const product of (allProducts ?? []) as any[]) {
        const productVariants = (allVariants ?? []).filter((v: any) => v.product_id === product.id);
        const complete = validateProductCompleteness(product, productVariants).complete;
        if (!complete) incompleteCount++;
    }
    incompleteProductsCount = incompleteCount;
}
---

<Layout title={title} description={description}>
    <div class="flex h-dvh overflow-hidden bg-bg">
        <SellerSidebar currentPath={currentPath} shopSlug={shopSlug} stripeStatus={stripeStatus} activeIncidents={activeIncidents} pendingOrdersCount={pendingOrdersCount} deliveryFailedCount={deliveryFailedCount} incompleteProductsCount={incompleteProductsCount} sellerDetailsIncomplete={sellerDetailsIncomplete} />

        <div class="flex flex-col flex-1 min-w-0 overflow-hidden">
            <!-- Mobile top bar (hidden on lg+) -->
            <header class="flex items-center h-14 px-4 border-b border-border shrink-0 bg-surface lg:hidden">
                <button
                    id="seller-mobile-menu-toggle"
                    class="flex items-center justify-center w-9 h-9 -ml-1.5 rounded-lg text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors"
                    aria-label={t.sellerSidebarOpenLabel}
                    aria-expanded="false"
                    aria-controls="seller-sidebar"
                >
                    <Icon name="menu" size={20} />
                </button>
                <a href="/sell" class="ml-2 font-semibold text-sm text-text-primary tracking-tight">
                    {t.sellerBrandName}
                </a>
            </header>

            <!-- Payments-inactive warning banner -->
            {stripeStatus !== 'ready' && (
                <div class="flex items-center gap-3 px-4 py-2.5 bg-amber-50 border-b border-amber-200 dark:bg-amber-950/40 dark:border-amber-800 shrink-0">
                    <svg class="shrink-0 text-amber-600 dark:text-amber-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                    <p class="flex-1 text-[13px] text-amber-800 dark:text-amber-200">{t.sellerStripeWarningBanner}</p>
                    <a href="/sell/onboarding" class="shrink-0 text-[13px] font-medium text-amber-700 dark:text-amber-300 underline underline-offset-2 hover:text-amber-900 dark:hover:text-amber-100 transition-colors">
                        {t.sellerStripeWarningCta}
                    </a>
                </div>
            )}

            <!-- Seller details incomplete banner (only when Stripe is already set up) -->
            {stripeStatus === 'ready' && sellerDetailsIncomplete && currentPath !== '/sell/details' && (
                <div class="flex items-center gap-3 px-4 py-2.5 bg-amber-50 border-b border-amber-200 dark:bg-amber-950/40 dark:border-amber-800 shrink-0">
                    <svg class="shrink-0 text-amber-600 dark:text-amber-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                    <p class="flex-1 text-[13px] text-amber-800 dark:text-amber-200">{t.sellerDetailsWarningBanner}</p>
                    <a href="/sell/details" class="shrink-0 text-[13px] font-medium text-amber-700 dark:text-amber-300 underline underline-offset-2 hover:text-amber-900 dark:hover:text-amber-100 transition-colors">
                        {t.sellerDetailsWarningCta}
                    </a>
                </div>
            )}

            <!-- Scrollable page content -->
            <main class="flex-1 overflow-y-auto">
                <slot />
            </main>
        </div>
    </div>
    <PushPrompt />
</Layout>

<script>
    function initMobileToggle() {
        const btn = document.getElementById('seller-mobile-menu-toggle');
        if (!btn) return;

        btn.addEventListener('click', () => {
            window.openSellerSidebar?.();
            btn.setAttribute('aria-expanded', 'true');
        });

        // Reset aria-expanded when sidebar closes via backdrop/close btn
        document.getElementById('seller-sidebar-backdrop')?.addEventListener('click', () => {
            btn.setAttribute('aria-expanded', 'false');
        });
        document.getElementById('seller-sidebar-close-btn')?.addEventListener('click', () => {
            btn.setAttribute('aria-expanded', 'false');
        });
    }

    document.addEventListener('astro:page-load', initMobileToggle);
    if (document.readyState !== 'loading') initMobileToggle();
    else document.addEventListener('DOMContentLoaded', initMobileToggle);
</script>
