---
import Header from '../components/Header.astro';
import BottomNav from '../components/BottomNav.astro';
import ProductHeader from '../components/product/ProductHeader.astro';
import { getBuyerShellState } from '../lib/ui/buyerShell';
import Layout from './Layout.astro';

interface Props {
    title?: string;
    description?: string;
    image?: string;
    ogType?: 'website' | 'article' | 'product';
}

const { title, description, image, ogType } = Astro.props;
const { wishlistCount } = await getBuyerShellState(Astro.cookies, Astro.request);
const currentPath = Astro.url.pathname;
---

<Layout title={title} description={description} image={image} ogType={ogType}>
    <slot slot="structured-data" name="structured-data" />
    <ProductHeader />

    <div class="hidden md:block sticky top-0 z-50">
        <Header currentPath={currentPath} wishlistCount={wishlistCount} />
    </div>

    <slot />
    <slot name="floating" />
    <BottomNav currentPath={currentPath} wishlistCount={wishlistCount} />
</Layout>