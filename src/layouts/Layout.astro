---
import '../styles/global.css';
import { strings } from '../lib/core/i18n';
import { ClientRouter } from 'astro:transitions';
import { SUPABASE_URL } from 'astro:env/server';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article' | 'product';
  noindex?: boolean;
  canonical?: string;
}

const {
  title = strings.siteTitle,
  description = strings.siteDescription,
  image,
  ogType = 'website',
  noindex = false,
  canonical,
} = Astro.props;

const supabaseHost = typeof SUPABASE_URL === 'string' ? new URL(SUPABASE_URL).host : '';
const siteUrl = Astro.site?.toString() ?? `${Astro.url.protocol}//${Astro.url.host}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image ?? new URL('/og-image.svg', siteUrl).toString();
---

<!doctype html>
<html lang="es" class="antialiased no-transitions">
  <head>
    <!-- Theme init: apply before paint to avoid flash -->
    <script is:inline>
      (function () {
        const t = localStorage.getItem('fewya-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = (t === 'system' || !t) ? (prefersDark ? 'dark' : 'light') : t;
        document.documentElement.setAttribute('data-theme', theme);
        const m = document.querySelector('meta[name="theme-color"]');
        if (m) m.setAttribute('content', theme === 'dark' ? '#0B1020' : '#F5F7FF');
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#F5F7FF" />
    <meta name="generator" content={Astro.generator} />
    <slot name="head" />

    <!-- Preconnect to critical 3rd-party origins (limit to 4 for performance) -->
    {supabaseHost && (
      <>
        <link rel="dns-prefetch" href={`https://${supabaseHost}`} />
        <link rel="preconnect" href={`https://${supabaseHost}`} crossorigin />
      </>
    )}
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <script>
      import { registerSW } from 'virtual:pwa-register'
      const w = window as unknown as { __fewyaSW?: boolean };
      if (!w.__fewyaSW) {
        w.__fewyaSW = true;
        const run = () => registerSW({ immediate: true });
        if ('requestIdleCallback' in window) {
          requestIdleCallback(run, { timeout: 2000 });
        } else {
          setTimeout(run, 1000);
        }
      }
    </script>
    <ClientRouter />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:site_name" content={strings.logoText} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <slot name="structured-data" />

    <!-- Fonts: preload + non-blocking stylesheet to avoid render-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Jost:wght@500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Jost:wght@500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Jost:wght@500;600;700&display=swap" />
    </noscript>
  </head>
  <body class="font-sans bg-bg text-text-primary min-h-dvh">
    <slot />
    <script>
      setTimeout(() => { import('../lib/wishlist/wishlist-client'); }, 0);
    </script>
    <script>
      setTimeout(() => { import('../lib/cart/cart-client'); }, 0);
    </script>
    <script>
      import { mountProgressBar } from '../lib/ui/progress-bar';
      import { mountToastRoot } from '../lib/ui/toast';
      import { mountLiveStatus } from '../lib/ui/live-status';

      const PERSIST_IDS = ['fewya-progress', 'fewya-toast-root', 'fewya-live-status'];

      function init() {
        mountProgressBar();
        mountToastRoot();
        mountLiveStatus();
      }

      function runInit() {
        if ('requestIdleCallback' in window) {
          requestIdleCallback(init, { timeout: 2000 });
        } else {
          setTimeout(init, 50);
        }
      }

      runInit();

      document.addEventListener('astro:before-swap', (event) => {
        const newDoc = (event as unknown as { newDocument: Document }).newDocument;
        if (!newDoc?.body) return;
        PERSIST_IDS.forEach((id) => {
          const live = document.getElementById(id);
          const incoming = newDoc.getElementById(id);
          if (incoming) incoming.remove();
          if (live) newDoc.body.appendChild(live.cloneNode(true));
        });
      });

      document.addEventListener('astro:page-load', init);
    </script>
    <script>
      // Remove no-transitions class after first paint to prevent color flash during load
      function enableTransitions() {
        requestAnimationFrame(() => {
          document.documentElement.classList.remove('no-transitions');
        });
      }

      // Disable transitions during SPA page swaps
      document.addEventListener('astro:before-swap', () => {
        document.documentElement.classList.add('no-transitions');
      });

      // Re-enable after page content is rendered
      document.addEventListener('astro:page-load', () => {
        enableTransitions();
      });

      // Initial load: enable after first paint
      if (document.readyState === 'complete') {
        enableTransitions();
      } else {
        window.addEventListener('load', enableTransitions, { once: true });
      }
    </script>
    <script>
      (function () {
        const STORAGE_KEY = 'fewya-theme';
        function applyStoredTheme() {
          const t = localStorage.getItem(STORAGE_KEY);
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = (t === 'system' || !t) ? (prefersDark ? 'dark' : 'light') : t;
          document.documentElement.setAttribute('data-theme', theme);
          const m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute('content', theme === 'dark' ? '#0B1020' : '#F5F7FF');
        }
        // Preserve data-theme before View Transitions swaps the document,
        // so dark: classes never flash light between swap and page-load.
        document.addEventListener('astro:before-swap', (e) => {
          const theme = document.documentElement.getAttribute('data-theme');
          if (theme) (e as any).newDocument.documentElement.setAttribute('data-theme', theme);
        });
        document.addEventListener('astro:page-load', applyStoredTheme);
        applyStoredTheme();
      })();
    </script>
    <script>
      function initWishlistBadge() {
        const w = window as unknown as { __fewyaWishlistBadgeInit?: boolean };
        if (w.__fewyaWishlistBadgeInit) return;
        w.__fewyaWishlistBadgeInit = true;

        window.addEventListener('wishlist-updated', (e: Event) => {
          const { wishlisted } = (e as CustomEvent<{ wishlisted: boolean }>).detail;
          document.querySelectorAll<HTMLElement>('[data-wishlist-badge]').forEach(badge => {
            const current = parseInt(badge.textContent ?? '0') || 0;
            const next = wishlisted ? current + 1 : Math.max(0, current - 1);
            if (next === 0) {
              badge.style.display = 'none';
            } else {
              badge.style.display = '';
              badge.textContent = String(next);
            }
          });
        });
      }
      document.addEventListener('astro:page-load', initWishlistBadge);
      const run = () => {
        if ('requestIdleCallback' in window) {
          requestIdleCallback(initWishlistBadge, { timeout: 3000 });
        } else {
          setTimeout(initWishlistBadge, 100);
        }
      };
      if (document.readyState !== 'loading') run();
      else document.addEventListener('DOMContentLoaded', run);
    </script>
  </body>
</html>
