---
import '../styles/global.css';
import { strings } from '../lib/core/i18n';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = strings.siteTitle,
  description = strings.siteDescription,
} = Astro.props;
---

<!doctype html>
<html lang="es" class="antialiased no-transitions">
  <head>
    <!-- Theme init: apply before paint to avoid flash -->
    <script is:inline>
      (function () {
        const t = localStorage.getItem('fewya-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = (t === 'system' || !t) ? (prefersDark ? 'dark' : 'light') : t;
        document.documentElement.setAttribute('data-theme', theme);
        const m = document.querySelector('meta[name="theme-color"]');
        if (m) m.setAttribute('content', theme === 'dark' ? '#0B1020' : '#F5F7FF');
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#F5F7FF" />
    <meta name="generator" content={Astro.generator} />

    <!-- Stripe checkout preconnect to reduce redirect latency -->
    <link rel="dns-prefetch" href="https://checkout.stripe.com" />
    <link rel="preconnect" href="https://checkout.stripe.com" />
    <script>
      import { registerSW } from 'virtual:pwa-register'
      const w = window as unknown as { __fewyaSW?: boolean };
      if (!w.__fewyaSW) {
        w.__fewyaSW = true;
        registerSW({ immediate: true });
      }
    </script>
    <ClientRouter />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Jost:wght@500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans bg-bg text-text-primary min-h-dvh">
    <slot />
    <script>
      import '../lib/wishlist/wishlist-client';
    </script>
    <script>
      import '../lib/cart/cart-client';
    </script>
    <script>
      import { mountProgressBar } from '../lib/ui/progress-bar';
      import { mountToastRoot } from '../lib/ui/toast';
      import { mountLiveStatus } from '../lib/ui/live-status';

      const PERSIST_IDS = ['fewya-progress', 'fewya-toast-root', 'fewya-live-status'];

      function init() {
        mountProgressBar();
        mountToastRoot();
        mountLiveStatus();
      }

      init();

      document.addEventListener('astro:before-swap', (event) => {
        const newDoc = (event as unknown as { newDocument: Document }).newDocument;
        if (!newDoc?.body) return;
        PERSIST_IDS.forEach((id) => {
          const live = document.getElementById(id);
          const incoming = newDoc.getElementById(id);
          if (incoming) incoming.remove();
          if (live) newDoc.body.appendChild(live.cloneNode(true));
        });
      });

      document.addEventListener('astro:page-load', init);
    </script>
    <script>
      // Remove no-transitions class after first paint to prevent color flash during load
      function enableTransitions() {
        requestAnimationFrame(() => {
          document.documentElement.classList.remove('no-transitions');
        });
      }

      // Disable transitions during SPA page swaps
      document.addEventListener('astro:before-swap', () => {
        document.documentElement.classList.add('no-transitions');
      });

      // Re-enable after page content is rendered
      document.addEventListener('astro:page-load', () => {
        enableTransitions();
      });

      // Initial load: enable after first paint
      if (document.readyState === 'complete') {
        enableTransitions();
      } else {
        window.addEventListener('load', enableTransitions, { once: true });
      }
    </script>
    <script>
      function initWishlistBadge() {
        const w = window as unknown as { __fewyaWishlistBadgeInit?: boolean };
        if (w.__fewyaWishlistBadgeInit) return;
        w.__fewyaWishlistBadgeInit = true;

        window.addEventListener('wishlist-updated', (e: Event) => {
          const { wishlisted } = (e as CustomEvent<{ wishlisted: boolean }>).detail;
          document.querySelectorAll<HTMLElement>('[data-wishlist-badge]').forEach(badge => {
            const current = parseInt(badge.textContent ?? '0') || 0;
            const next = wishlisted ? current + 1 : Math.max(0, current - 1);
            if (next === 0) {
              badge.style.display = 'none';
            } else {
              badge.style.display = '';
              badge.textContent = String(next);
            }
          });
        });
      }
      document.addEventListener('astro:page-load', initWishlistBadge);
      if (document.readyState !== 'loading') initWishlistBadge();
      else document.addEventListener('DOMContentLoaded', initWishlistBadge);
    </script>
  </body>
</html>
