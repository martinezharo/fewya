---
import '../styles/global.css';
import { strings } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = strings.siteTitle,
  description = strings.siteDescription,
} = Astro.props;
---

<!doctype html>
<html lang="es" class="antialiased">
  <head>
    <!-- Theme init: apply before paint to avoid flash -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('shopenn-theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = (t === 'system' || !t) ? (prefersDark ? 'dark' : 'light') : t;
        document.documentElement.setAttribute('data-theme', theme);
        var m = document.querySelector('meta[name="theme-color"]');
        if (m) m.setAttribute('content', theme === 'dark' ? '#0a0a0a' : '#fafafa');
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#fafafa" />
    <meta name="generator" content={Astro.generator} />
    <script>
      import { registerSW } from 'virtual:pwa-register'
      registerSW({ immediate: true })
    </script>

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans bg-bg text-text-primary min-h-dvh">
    <slot />
    <script>
      import '../lib/wishlist-client';
    </script>
    <script>
      import '../lib/cart-client';
    </script>
    <script>
      function initWishlistBadge() {
        window.addEventListener('wishlist-updated', (e: Event) => {
          const { wishlisted } = (e as CustomEvent<{ wishlisted: boolean }>).detail;
          document.querySelectorAll<HTMLElement>('[data-wishlist-badge]').forEach(badge => {
            const current = parseInt(badge.textContent ?? '0') || 0;
            const next = wishlisted ? current + 1 : Math.max(0, current - 1);
            if (next === 0) {
              badge.style.display = 'none';
            } else {
              badge.style.display = '';
              badge.textContent = String(next);
            }
          });
        });
      }
      document.addEventListener('astro:page-load', initWishlistBadge);
      if (document.readyState !== 'loading') initWishlistBadge();
      else document.addEventListener('DOMContentLoaded', initWishlistBadge);
    </script>
  </body>
</html>
