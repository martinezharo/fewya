---
import BuyerAppLayout from '../../layouts/BuyerAppLayout.astro';
import Icon from '../../components/icons/Icon.astro';
import Spinner from '../../components/ui/Spinner.astro';
import { strings } from '../../lib/core/i18n';
import { createSupabaseAuthClient } from '../../lib/core/auth';

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: { user } } = await supabase.auth.getUser();
const isLoggedIn = !!user;
---

<BuyerAppLayout title={strings.cartPageTitle}>

  <main class="min-h-[60dvh] pb-36 md:pb-16" data-is-logged-in={isLoggedIn ? 'true' : 'false'}>
    <div class="max-w-[960px] mx-auto px-4 md:px-10 py-4 md:py-8">
      <!-- Empty state -->
      <div id="cart-empty" class="hidden flex-col items-center justify-center gap-4 pt-20 text-center">
        <Icon name="shopping-cart" size={48} class="text-text-tertiary" />
        <h2 class="text-lg font-semibold text-text-primary">{strings.cartEmpty}</h2>
        <p class="text-sm text-text-secondary">{strings.cartEmptySub}</p>
        <a href="/" class="mt-2 px-6 py-2.5 bg-accent text-bg text-sm font-semibold rounded-lg no-underline hover:bg-accent-hover transition-colors">
          {strings.cartExploreCta}
        </a>
      </div>

      <!-- Cart content (populated by JS) -->
      <div id="cart-content" class="hidden">
        <!-- Desktop header -->
        <div class="hidden md:flex items-center justify-between mb-6">
          <h1 class="text-xl font-bold text-text-primary">{strings.navCart}</h1>
        </div>

        <!-- Shop groups container -->
        <div id="cart-shops" class="flex flex-col gap-6"></div>

        <!-- Desktop checkout bar -->
        <div class="hidden md:flex items-center justify-end gap-6 mt-8 pt-6 border-t border-border-light">
          <div class="flex items-center gap-2">
            <span class="text-sm text-text-secondary">{strings.cartTotal}:</span>
            <span id="cart-total-desktop" class="text-xl font-bold text-text-primary"></span>
          </div>
          <button
            type="button"
            id="checkout-btn-desktop"
            class="px-8 py-3 bg-accent text-bg font-semibold text-sm rounded-lg transition-colors hover:bg-accent-hover active:scale-[0.98]"
          >
            {strings.cartCheckout}
          </button>
        </div>
      </div>

    </div>
  </main>

  <!-- Mobile fixed checkout bar -->
  <div id="cart-checkout-mobile" class="hidden fixed bottom-[calc(64px+env(safe-area-inset-bottom,0px))] left-0 right-0 z-40 md:hidden bg-surface border-t border-border-light px-4 py-3">
    <div class="flex items-center justify-between gap-3">
      <button
        type="button"
        id="checkout-btn-mobile"
        class="flex-1 py-3 bg-accent text-bg font-semibold text-sm rounded-lg transition-colors hover:bg-accent-hover active:scale-[0.98]"
      >
        {strings.cartCheckout}
      </button>
      <span id="cart-total-mobile" class="text-lg font-bold text-text-primary shrink-0"></span>
    </div>
  </div>

  <!-- Delivery Selection Modal -->
  <div id="delivery-modal" class="hidden fixed inset-0 z-[60] bg-black/50 backdrop-blur-sm flex items-end md:items-center justify-center">
    <div class="bg-surface w-full md:w-[520px] md:rounded-2xl rounded-t-2xl max-h-[90dvh] flex flex-col shadow-2xl pb-[env(safe-area-inset-bottom,0px)] md:pb-0">
      <!-- Header -->
      <div class="flex items-center justify-between px-5 py-4 border-b border-border-light shrink-0">
        <h2 id="delivery-modal-title" class="text-lg font-bold text-text-primary">{strings.deliveryTitle}</h2>
        <button type="button" id="delivery-modal-close" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-border-light transition-colors" aria-label={strings.deliveryClose}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>

      <!-- Content -->
      <div id="delivery-modal-content" class="flex-1 overflow-y-auto p-5">
        <!-- Step 1: Delivery type selection -->
        <div id="delivery-step-type" class="flex flex-col gap-3">
          <button type="button" id="delivery-option-home" class="flex items-start gap-4 p-4 rounded-xl border-2 border-border-light hover:border-accent/50 transition-all text-left bg-surface">
            <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <div>
              <p class="font-semibold text-text-primary text-sm">{strings.deliveryHome}</p>
              <p class="text-xs text-text-secondary mt-0.5">{strings.deliveryHomeDesc}</p>
            </div>
            <div class="delivery-check hidden ml-auto self-center w-5 h-5 rounded-full bg-accent flex items-center justify-center">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
          </button>

          <button type="button" id="delivery-option-pickup" class="flex items-start gap-4 p-4 rounded-xl border-2 border-border-light hover:border-accent/50 transition-all text-left bg-surface">
            <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="font-semibold text-text-primary text-sm">{strings.deliveryPickup}</p>
              <p class="text-xs text-text-secondary mt-0.5">{strings.deliveryPickupDesc}</p>
            </div>
            <div class="delivery-check hidden ml-auto self-center w-5 h-5 rounded-full bg-accent flex items-center justify-center">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
          </button>
        </div>

        <!-- Step 2: Pickup point search & selection -->
        <div id="delivery-step-pickup" class="hidden flex-col gap-4">
          <button type="button" id="delivery-back-to-type" class="self-start text-xs text-text-secondary hover:text-text-primary transition-colors flex items-center gap-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            {strings.deliveryBack}
          </button>

          <div class="flex gap-2">
            <input
              type="text"
              id="pickup-address"
              placeholder="Dirección de búsqueda"
              class="flex-1 px-3 py-2.5 bg-surface border border-border-light rounded-lg text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent"
            />
            <button type="button" id="pickup-search-btn" class="px-4 py-2.5 bg-accent text-bg text-sm font-semibold rounded-lg hover:bg-accent-hover transition-colors shrink-0 disabled:opacity-50 disabled:cursor-not-allowed">
              {strings.deliverySearch}
            </button>
          </div>

          <div id="pickup-search-status" class="hidden text-sm text-text-secondary text-center py-4"></div>

          <div id="pickup-points-list" class="flex flex-col gap-2"></div>
        </div>
      </div>

      <!-- Footer -->
      <div id="delivery-modal-footer" class="shrink-0 px-5 py-4 border-t border-border-light">
        <button
          type="button"
          id="delivery-continue-btn"
          class="w-full py-3 bg-accent text-bg font-semibold text-sm rounded-lg transition-colors hover:bg-accent-hover active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed"
          disabled
        >
          {strings.deliveryContinue}
        </button>
      </div>
    </div>
  </div>

  <!-- Checkout Loading Overlay -->
  <div id="checkout-loading" class="hidden fixed inset-0 z-[70] bg-bg/90 backdrop-blur-sm flex-col items-center justify-center gap-4" aria-busy="true" aria-live="polite">
    <Spinner size="lg" label={strings.cartCheckoutRedirecting} class="text-accent" />
    <p class="text-sm font-medium text-text-secondary">{strings.cartCheckoutRedirecting}</p>
  </div>
</BuyerAppLayout>

<script>
  import { cart, type CartItem } from '../../lib/cart/cart';
  import { strings } from '../../lib/core/i18n';
  import { setBusy } from '../../lib/ui/busy';
  import { toast } from '../../lib/ui/toast';
  import { progress } from '../../lib/ui/progress-bar';

  const currencyFormatter = new Intl.NumberFormat('es-ES', {
    style: 'currency',
    currency: 'EUR',
  });

  let isCheckingOut = false;

  // Delivery modal state
  let selectedDeliveryType: 'home' | 'pickup_point' | null = null;
  let selectedPickupPoint: {
    id: string;
    name: string;
    address: string;
    postalCode: string;
    city: string;
    carrier: string;
  } | null = null;

  function renderCart() {
    const items = cart.get();
    const emptyEl = document.getElementById('cart-empty');
    const contentEl = document.getElementById('cart-content');
    const checkoutMobile = document.getElementById('cart-checkout-mobile');

    if (items.length === 0) {
      emptyEl?.classList.remove('hidden');
      emptyEl?.classList.add('flex');
      contentEl?.classList.add('hidden');
      contentEl?.classList.remove('block');
      checkoutMobile?.classList.add('hidden');
      return;
    }

    emptyEl?.classList.add('hidden');
    emptyEl?.classList.remove('flex');
    contentEl?.classList.remove('hidden');
    contentEl?.classList.add('block');
    checkoutMobile?.classList.remove('hidden');

    const grouped = cart.groupedByShop();
    const shopsContainer = document.getElementById('cart-shops');
    if (!shopsContainer) return;
    shopsContainer.innerHTML = '';

    let grandTotal = 0;

    grouped.forEach(({ shopName, shopSlug, items: shopItems }) => {
      const shopTotal = shopItems.reduce((sum, item) => sum + item.price * item.quantity, 0);
      const shopShipping = Math.max(...shopItems.map(i => i.shippingCost));
      const shopTotalWithShipping = shopTotal + shopShipping;
      grandTotal += shopTotalWithShipping;

      const shopSection = document.createElement('div');
      shopSection.className = 'bg-surface rounded-xl border border-border-light overflow-hidden';

      // Shop header
      const header = document.createElement('div');
      header.className = 'flex items-center justify-between px-4 py-3 border-b border-border-light';
      const shippingText = shopShipping === 0 ? strings.freeShipping : currencyFormatter.format(shopShipping);
      header.innerHTML = `
        <a href="/${escapeHtml(shopSlug)}" class="text-sm font-semibold text-text-primary no-underline hover:underline">${escapeHtml(shopName)}</a>
        <div class="flex items-center gap-1.5 text-xs text-text-secondary">
          <span>${strings.cartShipping}</span>
          <span class="font-semibold text-text-primary">${shippingText}</span>
        </div>
      `;
      shopSection.appendChild(header);

      // Items
      shopItems.forEach(item => {
        shopSection.appendChild(createItemRow(item));
      });

      // Shop footer — subtotal
      const footer = document.createElement('div');
      footer.className = 'flex items-center justify-between px-4 py-3 border-t border-border-light bg-border-light/30';
      const itemCount = shopItems.reduce((s, i) => s + i.quantity, 0);
      const itemLabel = itemCount === 1 ? strings.cartProductSingular : strings.cartProductPlural;
      footer.innerHTML = `
        <span class="text-xs text-text-secondary">${itemCount} ${itemLabel} · ${strings.cartShippingIncluded}</span>
        <span class="text-sm font-bold text-text-primary">${shopTotalWithShipping.toFixed(2)}${strings.currency}</span>
      `;
      shopSection.appendChild(footer);

      shopsContainer.appendChild(shopSection);
    });

    // Update totals
    const totalStr = `${grandTotal.toFixed(2)}${strings.currency}`;
    const totalDesktop = document.getElementById('cart-total-desktop');
    const totalMobile = document.getElementById('cart-total-mobile');
    if (totalDesktop) totalDesktop.textContent = totalStr;
    if (totalMobile) totalMobile.textContent = totalStr;
  }

  function createItemRow(item: CartItem): HTMLElement {
    const row = document.createElement('div');
    row.className = 'flex items-center gap-3 px-4 py-3 border-b border-border-light last:border-b-0';
    row.dataset.cartItemVariant = item.variantId;

    const productUrl = `/${item.shopSlug}/${item.productSlug}`;
    const inStock = item.stock > 0;
    const lineTotal = (item.price * item.quantity).toFixed(2);
    const qtyExceedsStock = item.quantity > item.stock;
    const stockDeficit = qtyExceedsStock ? item.quantity - item.stock : 0;

    row.innerHTML = `
      <a href="${escapeHtml(productUrl)}" class="shrink-0 w-16 h-16 md:w-20 md:h-20 rounded-lg overflow-hidden">
        <img src="${escapeHtml(item.image)}" alt="${escapeAttr(item.title)}" class="w-full h-full object-cover" loading="lazy" />
      </a>
      <div class="flex-1 min-w-0 flex flex-col gap-1">
        <a href="${escapeHtml(productUrl)}" class="text-sm font-medium text-text-primary no-underline hover:underline line-clamp-1">${escapeHtml(item.title)}</a>
        ${item.variantName ? `<span class="text-xs text-text-secondary">${escapeHtml(item.variantName)}</span>` : ''}
        <span class="text-xs font-medium ${inStock ? 'text-green-600 dark:text-green-400' : 'text-red-500 dark:text-red-400'}">${inStock ? strings.productInStock : strings.productOutOfStock}</span>
        ${qtyExceedsStock ? `
          <span class="text-xs font-medium text-red-500 dark:text-red-400 flex items-center gap-1">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            No hay suficiente stock. Quita ${stockDeficit} o más.
          </span>
        ` : ''}
        <div class="flex items-center gap-0.5 mt-0.5">
          <button type="button" data-cart-minus="${item.variantId}" class="w-7 h-7 flex items-center justify-center rounded-md text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors" aria-label="${strings.productQtyDecrease}" ${!inStock ? 'disabled' : ''}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
          </button>
          <span class="w-8 text-center text-sm font-medium text-text-primary select-none">${item.quantity}</span>
          <button type="button" data-cart-plus="${item.variantId}" class="w-7 h-7 flex items-center justify-center rounded-md text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors" aria-label="${strings.productQtyIncrease}" ${!inStock || qtyExceedsStock ? 'disabled' : ''}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
          </button>
          <button type="button" data-cart-remove="${item.variantId}" class="w-7 h-7 flex items-center justify-center rounded-md text-text-tertiary hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors ml-1" aria-label="${strings.cartRemove}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
          </button>
        </div>
      </div>
      <span class="text-sm font-bold text-text-primary shrink-0">${lineTotal}${strings.currency}</span>
    `;

    // Event listeners for quantity buttons
    row.querySelector(`[data-cart-minus="${item.variantId}"]`)?.addEventListener('click', () => {
      cart.updateQuantity(item.variantId, item.quantity - 1);
      renderCart();
    });

    row.querySelector(`[data-cart-plus="${item.variantId}"]`)?.addEventListener('click', () => {
      if (item.quantity < item.stock && item.stock > 0) {
        cart.updateQuantity(item.variantId, item.quantity + 1);
        renderCart();
      }
    });

    row.querySelector(`[data-cart-remove="${item.variantId}"]`)?.addEventListener('click', () => {
      cart.remove(item.variantId);
      renderCart();
    });

    return row;
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function escapeAttr(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  // ===== Delivery Modal =====
  const deliveryModal = document.getElementById('delivery-modal');
  const stepType = document.getElementById('delivery-step-type');
  const stepPickup = document.getElementById('delivery-step-pickup');
  const optionHome = document.getElementById('delivery-option-home');
  const optionPickup = document.getElementById('delivery-option-pickup');
  const btnClose = document.getElementById('delivery-modal-close');
  const btnContinue = document.getElementById('delivery-continue-btn') as HTMLButtonElement | null;
  const btnBack = document.getElementById('delivery-back-to-type');
    const inputAddress = document.getElementById('pickup-address') as HTMLInputElement | null;
    const btnSearch = document.getElementById('pickup-search-btn') as HTMLButtonElement | null;
  const searchStatus = document.getElementById('pickup-search-status');
  const pointsList = document.getElementById('pickup-points-list');

  function openDeliveryModal() {
    selectedDeliveryType = null;
    selectedPickupPoint = null;
    updateDeliveryUI();
    stepType?.classList.remove('hidden');
    stepType?.classList.add('flex');
    stepPickup?.classList.add('hidden');
    stepPickup?.classList.remove('flex');
    if (inputAddress) inputAddress.value = '';
    if (pointsList) pointsList.innerHTML = '';
    if (searchStatus) {
      searchStatus.classList.add('hidden');
      searchStatus.textContent = '';
    }
    deliveryModal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeDeliveryModal() {
    deliveryModal?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function updateDeliveryUI() {
    // Update checkmarks
    optionHome?.querySelector('.delivery-check')?.classList.toggle('hidden', selectedDeliveryType !== 'home');
    optionHome?.classList.toggle('border-accent', selectedDeliveryType === 'home');
    optionHome?.classList.toggle('border-border-light', selectedDeliveryType !== 'home');

    optionPickup?.querySelector('.delivery-check')?.classList.toggle('hidden', selectedDeliveryType !== 'pickup_point');
    optionPickup?.classList.toggle('border-accent', selectedDeliveryType === 'pickup_point');
    optionPickup?.classList.toggle('border-border-light', selectedDeliveryType !== 'pickup_point');

    // Enable/disable continue button
    if (!btnContinue) return;
    if (selectedDeliveryType === 'home') {
      btnContinue.disabled = false;
      btnContinue.textContent = strings.deliveryContinue;
    } else if (selectedDeliveryType === 'pickup_point' && selectedPickupPoint) {
      btnContinue.disabled = false;
      btnContinue.textContent = strings.deliveryContinue;
    } else {
      btnContinue.disabled = true;
      btnContinue.textContent = strings.deliveryContinue;
    }
  }

  function selectDeliveryType(type: 'home' | 'pickup_point') {
    selectedDeliveryType = type;
    selectedPickupPoint = null;
    updateDeliveryUI();

    if (type === 'pickup_point') {
      stepType?.classList.add('hidden');
      stepType?.classList.remove('flex');
      stepPickup?.classList.remove('hidden');
      stepPickup?.classList.add('flex');
      // Preload postal code from profile
      preloadAddress();
    }
  }

  async function preloadAddress() {
    if (!inputAddress || !searchStatus || !btnSearch) return;

    searchStatus.textContent = strings.deliveryLoadingAddress;
    searchStatus.classList.remove('hidden');
    inputAddress.disabled = true;
    btnSearch.disabled = true;

    try {
      const res = await fetch('/api/me/address');
      if (res.ok) {
        const data = await res.json() as { fullAddress?: string | null };
        if (data.fullAddress) {
          inputAddress.value = data.fullAddress;
        }
      }
    } catch {
      // ignore
    } finally {
      inputAddress.disabled = false;
      btnSearch.disabled = false;
      if (inputAddress.value.trim().length >= 5) {
        await searchPickupPoints();
      } else {
        searchStatus.classList.add('hidden');
      }
    }
  }

  async function searchPickupPoints() {
    if (!inputAddress || !searchStatus || !pointsList || !btnSearch) return;
    const address = inputAddress.value.trim();
    if (!address || address.length < 5) {
      searchStatus.textContent = 'Introduce una dirección válida';
      searchStatus.classList.remove('hidden');
      return;
    }

    searchStatus.textContent = strings.deliverySearching;
    searchStatus.classList.remove('hidden');
    pointsList.innerHTML = '';
    btnSearch.disabled = true;
    btnSearch.textContent = '...';

    try {
      const res = await fetch(`/api/sendcloud/service-points?address=${encodeURIComponent(address)}&country=ES`);
      const data = await res.json() as any;

      if (!res.ok || !data.points) {
        searchStatus.textContent = strings.deliverySearchError;
        return;
      }

      if ((data.points as any[]).length === 0) {
        searchStatus.textContent = strings.deliveryNoResults;
        return;
      }

      searchStatus.classList.add('hidden');
      renderPickupPoints(data.points as any[]);
    } catch {
      searchStatus.textContent = strings.deliverySearchError;
    } finally {
      btnSearch.disabled = false;
      btnSearch.textContent = strings.deliverySearch;
    }
  }

  function renderPickupPoints(points: Array<{
    id: number;
    name: string;
    street: string;
    houseNumber: string;
    postalCode: string;
    city: string;
    carrier: string;
    distance?: number;
    formattedOpeningTimes: Record<string, string[]>;
  }>) {
    if (!pointsList) return;
    pointsList.innerHTML = '';

    points.forEach((point) => {
      const fullAddress = `${point.street} ${point.houseNumber}, ${point.postalCode} ${point.city}`;
      const isSelected = selectedPickupPoint?.id === String(point.id);
      const distanceText = point.distance ? strings.deliveryDistance.replace('{distance}', `${(point.distance / 1000).toFixed(1)} km`) : '';

      // Build opening hours summary (today + tomorrow)
      const today = new Date().getDay();
      const todayHours = point.formattedOpeningTimes[String(today)]?.join(', ') || 'Cerrado';

      const card = document.createElement('button');
      card.type = 'button';
      card.className = `w-full text-left p-3 rounded-xl border-2 transition-all ${isSelected ? 'border-accent bg-accent/5' : 'border-border-light hover:border-accent/30 bg-surface'}`;

      card.innerHTML = `
        <div class="flex items-start justify-between gap-2">
          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold text-text-primary">${escapeHtml(point.name)}</p>
            <p class="text-xs text-text-secondary mt-0.5">${escapeHtml(fullAddress)}</p>
            <div class="flex items-center gap-2 mt-1.5">
              <span class="text-[10px] uppercase tracking-wider font-medium px-1.5 py-0.5 rounded bg-border-light text-text-secondary">${escapeHtml(point.carrier)}</span>
              ${distanceText ? `<span class="text-xs text-text-secondary">${escapeHtml(distanceText)}</span>` : ''}
            </div>
            <p class="text-xs text-text-tertiary mt-1">${escapeHtml(strings.deliveryOpeningHours)}: ${escapeHtml(todayHours)}</p>
          </div>
          ${isSelected ? `<div class="shrink-0 w-5 h-5 rounded-full bg-accent flex items-center justify-center mt-0.5"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>` : ''}
        </div>
      `;

      card.addEventListener('click', () => {
        selectedPickupPoint = {
          id: String(point.id),
          name: point.name,
          address: fullAddress,
          postalCode: point.postalCode,
          city: point.city,
          carrier: point.carrier,
        };
        renderPickupPoints(points);
        updateDeliveryUI();
      });

      pointsList.appendChild(card);
    });
  }

  async function proceedToCheckout() {
    if (isCheckingOut) return;
    if (!selectedDeliveryType) return;

    const items = cart.get();
    if (items.length === 0) return;

    isCheckingOut = true;

    const checkoutBtnMobile = document.getElementById('checkout-btn-mobile') as HTMLButtonElement | null;
    const checkoutBtnDesktop = document.getElementById('checkout-btn-desktop') as HTMLButtonElement | null;
    const checkoutLoading = document.getElementById('checkout-loading');

    setBusy(checkoutBtnMobile, true, { label: strings.cartCheckoutRedirecting });
    setBusy(checkoutBtnDesktop, true, { label: strings.cartCheckoutRedirecting });
    if (btnContinue) btnContinue.disabled = true;

    checkoutLoading?.classList.remove('hidden');
    checkoutLoading?.classList.add('flex');
    document.body.style.overflow = 'hidden';
    progress.start();

    let success = false;

    const deliveryPayload = selectedDeliveryType === 'pickup_point' && selectedPickupPoint
      ? {
          type: 'pickup_point' as const,
          pickupPointId: selectedPickupPoint.id,
          pickupPointName: selectedPickupPoint.name,
          pickupPointAddress: selectedPickupPoint.address,
          pickupPointPostalCode: selectedPickupPoint.postalCode,
          pickupPointCity: selectedPickupPoint.city,
          pickupPointCarrier: selectedPickupPoint.carrier,
        }
      : { type: 'home' as const };

    try {
      const res = await fetch('/api/cart/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items: items.map(i => ({
            variantId: i.variantId,
            quantity: i.quantity,
          })),
          delivery: deliveryPayload,
        }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({} as { error?: string; redirectTo?: string })) as {
          error?: string;
          redirectTo?: string;
        };
        if (res.status === 401) {
          toast.error(strings.cartLoginRequired);
        } else if (data.redirectTo) {
          window.location.href = data.redirectTo;
          success = true;
        } else {
          toast.error(data.error || strings.cartCheckoutError);
        }
        return;
      }

      const data = await res.json().catch(() => ({} as { checkoutUrl?: string; error?: string })) as {
        checkoutUrl?: string;
        error?: string;
      };

      if (!data.checkoutUrl) {
        toast.error(data.error || strings.cartCheckoutError);
        return;
      }

      success = true;
      window.location.href = data.checkoutUrl;
    } catch {
      toast.error(strings.toastErrorNetwork);
    } finally {
      if (!success) {
        isCheckingOut = false;
        progress.fail();
        checkoutLoading?.classList.add('hidden');
        checkoutLoading?.classList.remove('flex');
        document.body.style.overflow = '';
        setBusy(checkoutBtnMobile, false);
        setBusy(checkoutBtnDesktop, false);
        if (btnContinue) btnContinue.disabled = false;
      }
    }
  }

  function handleCheckout() {
    const items = cart.get();
    if (items.length === 0) return;
    const main = document.querySelector('main');
    const isLoggedIn = main?.dataset.isLoggedIn === 'true';
    if (!isLoggedIn) {
      window.location.href = '/login?redirect_to=/cart';
      return;
    }
    openDeliveryModal();
  }

  async function refreshStockFromServer() {
    const items = cart.get();
    if (items.length === 0) return;
    try {
      const res = await fetch('/api/cart/freshness', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ variantIds: items.map((i) => i.variantId) }),
      });
      if (!res.ok) return;
      const data = await res.json() as { items?: Array<{ variantId: string; stock: number; price: number; shippingCost: number; isAvailable: boolean }> };
      if (!data.items?.length) return;
      const result = cart.applyFreshness(data.items);
      if (result.removedVariantIds.length || result.cappedVariantIds.length || result.repricedVariantIds.length) {
        renderCart();
        if (result.removedVariantIds.length) {
          toast.error(strings.apiCheckoutProductUnavailable);
        } else if (result.cappedVariantIds.length) {
          toast.error(strings.cartStockExceededToast);
        }
      }
    } catch {
      // Silent — keep stale data rather than blocking the UI.
    }
  }

  function init() {
    renderCart();
    refreshStockFromServer();

    const checkoutBtnMobile = document.getElementById('checkout-btn-mobile');
    if (checkoutBtnMobile && !checkoutBtnMobile.hasAttribute('data-checkout-listener')) {
      checkoutBtnMobile.setAttribute('data-checkout-listener', 'true');
      checkoutBtnMobile.addEventListener('click', handleCheckout);
    }

    const checkoutBtnDesktop = document.getElementById('checkout-btn-desktop');
    if (checkoutBtnDesktop && !checkoutBtnDesktop.hasAttribute('data-checkout-listener')) {
      checkoutBtnDesktop.setAttribute('data-checkout-listener', 'true');
      checkoutBtnDesktop.addEventListener('click', handleCheckout);
    }

    // Modal listeners
    btnClose?.addEventListener('click', closeDeliveryModal);
    deliveryModal?.addEventListener('click', (e) => {
      if (e.target === deliveryModal) closeDeliveryModal();
    });

    optionHome?.addEventListener('click', () => selectDeliveryType('home'));
    optionPickup?.addEventListener('click', () => selectDeliveryType('pickup_point'));

    btnBack?.addEventListener('click', () => {
      stepPickup?.classList.add('hidden');
      stepPickup?.classList.remove('flex');
      stepType?.classList.remove('hidden');
      stepType?.classList.add('flex');
      selectedPickupPoint = null;
      updateDeliveryUI();
    });

    if (btnContinue && !btnContinue.hasAttribute('data-continue-listener')) {
      btnContinue.setAttribute('data-continue-listener', 'true');
      btnContinue.addEventListener('click', () => {
        closeDeliveryModal();
        proceedToCheckout();
      });
    }

    btnSearch?.addEventListener('click', searchPickupPoints);
    inputAddress?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') searchPickupPoints();
    });
  }

  document.addEventListener('astro:page-load', init);
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
</script>
