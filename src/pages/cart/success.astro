---
import BuyerAppLayout from '../../layouts/BuyerAppLayout.astro';
const { t } = Astro.locals;

---

<BuyerAppLayout title={t.cartSuccessPageTitle}>
    <main class="min-h-[60dvh] px-4 py-8 md:py-12">
        <div class="max-w-xl mx-auto rounded-3xl border border-border-light bg-surface p-6 md:p-8 text-center">
            <div id="checkout-success-loading" class="flex flex-col items-center gap-4">
                <div class="h-12 w-12 rounded-full border-4 border-border-light border-t-accent animate-spin"></div>
                <div class="space-y-2">
                    <h1 class="text-xl font-semibold text-text-primary">{t.cartSuccessLoading}</h1>
                    <p class="text-sm text-text-secondary">{t.cartSuccessSubtitle}</p>
                </div>
            </div>

            <div id="checkout-success-done" class="hidden flex-col items-center gap-4">
                <div class="w-16 h-16 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                    <span class="text-3xl">✓</span>
                </div>
                <div class="space-y-2">
                    <h1 class="text-2xl font-semibold text-text-primary">{t.cartSuccessTitle}</h1>
                    <p class="text-sm text-text-secondary">{t.cartSuccessSubtitle}</p>
                </div>
                <div class="rounded-2xl border border-border-light bg-border-light/30 px-4 py-3 min-w-56">
                    <p class="text-xs uppercase tracking-[0.18em] text-text-tertiary">{t.cartSuccessOrderNumber}</p>
                    <p id="checkout-success-order-id" class="mt-1 text-lg font-semibold text-text-primary"></p>
                    <p id="checkout-success-order-count" class="mt-1 text-xs text-text-secondary"></p>
                </div>
                <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
                    <a href="/me/orders" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent text-bg font-semibold text-sm no-underline hover:bg-accent-hover transition-colors">
                        {t.cartSuccessOrdersCta}
                    </a>
                    <a href="/" class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-border-light text-text-primary font-semibold text-sm no-underline hover:bg-border-light transition-colors">
                        {t.cartSuccessContinueCta}
                    </a>
                </div>
            </div>

            <div id="checkout-success-error" class="hidden flex-col items-center gap-4">
                <div class="w-16 h-16 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
                    <span class="text-3xl">!</span>
                </div>
                <div class="space-y-2">
                    <h1 class="text-2xl font-semibold text-text-primary">{t.cartSuccessErrorTitle}</h1>
                    <p id="checkout-success-error-text" class="text-sm text-text-secondary">{t.cartSuccessErrorSubtitle}</p>
                </div>
                <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
                    <a href="/me/orders" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent text-bg font-semibold text-sm no-underline hover:bg-accent-hover transition-colors">
                        {t.cartSuccessOrdersCta}
                    </a>
                    <a href="/cart" class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-border-light text-text-primary font-semibold text-sm no-underline hover:bg-border-light transition-colors">
                        {t.cartCancelReturnCta}
                    </a>
                </div>
            </div>
        </div>
    </main>
</BuyerAppLayout>

<script>
    import { cart } from '../../lib/cart/cart';
    import { getClientT } from '../../lib/core/i18n';
const t = getClientT();

    let confirmationStarted = false;

    function showState(state: 'loading' | 'success' | 'error', message?: string, orderInfo?: { publicId?: string; orderCount?: number }) {
        const loadingEl = document.getElementById('checkout-success-loading');
        const successEl = document.getElementById('checkout-success-done');
        const errorEl = document.getElementById('checkout-success-error');
        const orderIdEl = document.getElementById('checkout-success-order-id');
        const orderCountEl = document.getElementById('checkout-success-order-count');
        const errorTextEl = document.getElementById('checkout-success-error-text');

        loadingEl?.classList.toggle('hidden', state !== 'loading');
        loadingEl?.classList.toggle('flex', state === 'loading');
        successEl?.classList.toggle('hidden', state !== 'success');
        successEl?.classList.toggle('flex', state === 'success');
        errorEl?.classList.toggle('hidden', state !== 'error');
        errorEl?.classList.toggle('flex', state === 'error');

        if (orderInfo?.publicId && orderIdEl) {
            orderIdEl.textContent = orderInfo.publicId;
        }

        if (orderInfo?.orderCount && orderCountEl) {
            orderCountEl.textContent = `${orderInfo.orderCount} pedido${orderInfo.orderCount > 1 ? 's' : ''}`;
        }

        if (message && errorTextEl) {
            errorTextEl.textContent = message;
        }
    }

    async function confirmCheckout() {
        if (confirmationStarted) {
            return;
        }

        confirmationStarted = true;
        showState('loading');

        const currentUrl = new URL(window.location.href);
        const sessionId = currentUrl.searchParams.get('session_id');

        if (!sessionId) {
            showState('error', t.apiCheckoutConfirmationError);
            return;
        }

        try {
            const response = await fetch(`/api/cart/checkout/confirm?session_id=${encodeURIComponent(sessionId)}`);
            const data = await response.json().catch(() => ({} as { error?: string; orders?: Array<{ public_id: string }> })) as {
                error?: string;
                orders?: Array<{ public_id: string }>;
            };

            if (!response.ok) {
                throw new Error(data.error || t.apiCheckoutConfirmationError);
            }

            cart.clear();
            currentUrl.searchParams.delete('session_id');
            window.history.replaceState({}, '', currentUrl.pathname + currentUrl.search + currentUrl.hash);

            const firstOrder = data.orders?.[0];
            showState('success', undefined, {
                publicId: firstOrder?.public_id,
                orderCount: data.orders?.length ?? 1,
            });
        } catch (error: unknown) {
            const message = error instanceof Error ? error.message : t.apiCheckoutConfirmationError;
            showState('error', message);
        }
    }

    document.addEventListener('astro:page-load', confirmCheckout);
    if (document.readyState !== 'loading') confirmCheckout();
    else document.addEventListener('DOMContentLoaded', confirmCheckout);
</script>