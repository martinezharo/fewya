---
import SellerLayout from '../../layouts/SellerLayout.astro';
import { createSupabaseAuthClient } from '../../lib/auth';
import { strings } from '../../lib/i18n';

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: sessionData } = await supabase.auth.getSession();
const user = sessionData?.session?.user;

if (!user) return Astro.redirect('/sell');

const { data: profile } = await supabase
    .from('profiles')
    .select('is_seller')
    .eq('id', user.id)
    .single();

if (!profile?.is_seller) return Astro.redirect('/sell');

const { data: shop } = await supabase
    .from('shops')
    .select(`
        id,
        slug,
        shop_payment_accounts (
            stripe_account_id,
            charges_enabled,
            payouts_enabled,
            details_submitted
        )
    `)
    .eq('owner_id', user.id)
    .maybeSingle();

if (!shop) return Astro.redirect('/sell/onboarding');

const paymentAccountRaw = Array.isArray((shop as any).shop_payment_accounts)
    ? (shop as any).shop_payment_accounts[0]
    : (shop as any).shop_payment_accounts;

const isStripeReady = Boolean(
    paymentAccountRaw?.stripe_account_id
    && paymentAccountRaw?.charges_enabled
    && paymentAccountRaw?.payouts_enabled
    && paymentAccountRaw?.details_submitted
);
---

<SellerLayout title="Dashboard — Shopenn Seller" shopSlug={shop?.slug}>
    <div class="p-6 lg:p-10">
        <h1 class="text-2xl font-semibold tracking-tight text-text-primary mb-6">{strings.sellerNavDashboard}</h1>
        {isStripeReady ? (
            <div class="p-8 rounded-2xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-center">
                <p class="text-green-800 dark:text-green-300 font-medium text-lg">{strings.sellerDashboardStripeReady}</p>
            </div>
        ) : (
            <div class="p-8 rounded-2xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800">
                <h2 class="text-lg font-semibold text-amber-900 dark:text-amber-200">{strings.sellerDashboardStripePendingTitle}</h2>
                <p class="mt-2 text-sm text-amber-800 dark:text-amber-300 max-w-2xl">{strings.sellerDashboardStripePendingSubtitle}</p>
                <a href="/sell/shop" class="mt-5 inline-flex items-center justify-center px-5 py-2.5 rounded-full bg-neutral-900 text-white dark:bg-white dark:text-neutral-900 text-sm font-medium no-underline hover:scale-[1.02] transition-transform">
                    {strings.sellerDashboardStripeCta}
                </a>
            </div>
        )}
    </div>
</SellerLayout>
