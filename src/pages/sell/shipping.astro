---
import SellerLayout from '../../layouts/SellerLayout.astro';
import ShippingEditorPanel from '../../components/seller/ShippingEditorPanel.astro';
import Icon from '../../components/icons/Icon.astro';

import { createSupabaseAuthClient } from '../../lib/core/auth';
import { normalizeShippingPlatforms } from '../../lib/shipping/shippingPlatform';
const { t } = Astro.locals;

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: sessionData } = await supabase.auth.getSession();
const user = sessionData?.session?.user;

if (!user) return Astro.redirect('/sell');

const { data: profile } = await supabase
    .from('profiles')
    .select('is_seller')
    .eq('id', user.id)
    .single();

if (!profile?.is_seller) return Astro.redirect('/sell');

const { data: shop } = await supabase
    .from('shops')
    .select('id, name, slug, default_weight_kg, default_length_cm, default_width_cm, default_height_cm, default_shipping_cost, shipping_carriers')
    .eq('owner_id', user.id)
    .maybeSingle();

if (!shop) return Astro.redirect('/sell/onboarding');

const defaults = {
    weight_kg: shop.default_weight_kg ?? null,
    length_cm: shop.default_length_cm ?? null,
    width_cm: shop.default_width_cm ?? null,
    height_cm: shop.default_height_cm ?? null,
    shipping_cost: shop.default_shipping_cost ?? null,
    carriers: normalizeShippingPlatforms(shop.shipping_carriers),
};
---

<SellerLayout title={t.sellerShippingPageTitle} shopSlug={shop.slug} shopId={shop.id}>
    <div class="max-w-3xl mx-auto px-4 py-8 lg:py-12">
        <div class="mb-8">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-tertiary">{shop.name}</p>
            <h1 class="mt-2 text-2xl font-semibold tracking-tight text-text-primary">{t.sellerShippingTitle}</h1>
            <p class="mt-1 text-sm text-text-secondary">{t.sellerShippingSubtitle}</p>
        </div>

        <div class="rounded-3xl border border-border bg-surface shadow-sm">

            <!-- Envío por defecto -->
            <section class="p-6 md:p-8 space-y-6">
                <div>
                    <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary mb-1">
                        <Icon name="truck" size={15} class="text-text-tertiary" />
                        <span>{t.sellerSettingsShippingSection}</span>
                    </div>
                    <p class="text-sm text-text-secondary pl-[23px]">{t.sellerSettingsShippingSubtitle}</p>
                </div>

                <ShippingEditorPanel
                    idPrefix="settings"
                    weight={defaults.weight_kg}
                    length={defaults.length_cm}
                    width={defaults.width_cm}
                    height={defaults.height_cm}
                    shippingCost={defaults.shipping_cost}
                />

                <!-- Plataformas de envío -->
                <div class="pt-6 border-t border-border space-y-4" id="carriers-group">
                    <div>
                        <p class="text-sm font-semibold text-text-primary">{t.sellerSettingsCarriersSection}</p>
                        <p class="mt-1 text-sm text-text-secondary">{t.sellerSettingsCarriersSubtitle}</p>
                    </div>

                    <div class="space-y-2.5">
                        <label class="flex items-center justify-between gap-4 p-4 rounded-2xl border border-border bg-bg cursor-pointer">
                            <div class="min-w-0">
                                <p class="text-sm font-medium text-text-primary">{t.sellerSettingsCarrierInpostLabel}</p>
                                <p class="text-xs text-text-secondary">{t.sellerSettingsCarrierInpostDesc}</p>
                            </div>
                            <input type="checkbox" data-carrier="inpost" class="peer sr-only" checked={defaults.carriers.includes('inpost')} />
                            <span class="relative shrink-0 w-11 h-6 rounded-full bg-border-light peer-checked:bg-accent transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-5 after:h-5 after:rounded-full after:bg-white after:shadow-sm after:transition-transform peer-checked:after:translate-x-5"></span>
                        </label>

                        <label class="flex items-center justify-between gap-4 p-4 rounded-2xl border border-border bg-bg cursor-pointer">
                            <div class="min-w-0">
                                <p class="text-sm font-medium text-text-primary">{t.sellerSettingsCarrierCorreosLabel}</p>
                                <p class="text-xs text-text-secondary">{t.sellerSettingsCarrierCorreosDesc}</p>
                            </div>
                            <input type="checkbox" data-carrier="correos" class="peer sr-only" checked={defaults.carriers.includes('correos')} />
                            <span class="relative shrink-0 w-11 h-6 rounded-full bg-border-light peer-checked:bg-accent transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-5 after:h-5 after:rounded-full after:bg-white after:shadow-sm after:transition-transform peer-checked:after:translate-x-5"></span>
                        </label>
                    </div>

                    <p id="carriers-error" class="hidden text-xs font-medium text-red-500">{t.sellerSettingsCarriersAtLeastOne}</p>
                </div>

                <div class="flex items-center justify-end pt-2">
                    <button
                        type="button"
                        id="save-shipping-btn"
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-accent text-bg font-medium text-sm hover:bg-accent-hover active:scale-[0.98] transition-all"
                    >
                        <span data-busy-label>{t.sellerSettingsSave}</span>
                    </button>
                </div>
            </section>

        </div>
    </div>
</SellerLayout>

<script>
    import { getClientT } from '../../lib/core/i18n';
    import { runSubmit } from '../../lib/ui/submit';
    import { initShippingEditor } from '../../lib/ui/shipping-editor';
const t = getClientT();

    function initShippingPage() {
        const panel = document.querySelector<HTMLElement>('.shipping-editor-panel');
        const saveBtn = document.getElementById('save-shipping-btn') as HTMLButtonElement | null;

        if (!panel || !saveBtn || saveBtn.dataset.bound === 'true') return;

        initShippingEditor(panel);

        // Shipping platform toggles: keep at least one active.
        const carrierInputs = Array.from(document.querySelectorAll<HTMLInputElement>('#carriers-group [data-carrier]'));
        const carriersError = document.getElementById('carriers-error');

        const readCarriers = () => carrierInputs.filter((i) => i.checked).map((i) => i.dataset.carrier as string);

        carrierInputs.forEach((input) => {
            input.addEventListener('change', () => {
                if (readCarriers().length === 0) {
                    // Block deselecting the last platform.
                    input.checked = true;
                    carriersError?.classList.remove('hidden');
                } else {
                    carriersError?.classList.add('hidden');
                }
            });
        });

        saveBtn.dataset.bound = 'true';
        saveBtn.addEventListener('click', async () => {
            const weightInput = panel.querySelector<HTMLInputElement>('[data-field="weight"]');
            const lengthInput = panel.querySelector<HTMLInputElement>('[data-field="length"]');
            const widthInput = panel.querySelector<HTMLInputElement>('[data-field="width"]');
            const heightInput = panel.querySelector<HTMLInputElement>('[data-field="height"]');
            const shippingInput = panel.querySelector<HTMLInputElement>('[data-field="shipping-cost"]');

            const carriers = readCarriers();
            if (carriers.length === 0) {
                carriersError?.classList.remove('hidden');
                return;
            }
            carriersError?.classList.add('hidden');

            const payload = {
                default_weight_kg: weightInput?.value === '' ? null : parseFloat(weightInput?.value ?? ''),
                default_length_cm: lengthInput?.value === '' ? null : parseFloat(lengthInput?.value ?? ''),
                default_width_cm: widthInput?.value === '' ? null : parseFloat(widthInput?.value ?? ''),
                default_height_cm: heightInput?.value === '' ? null : parseFloat(heightInput?.value ?? ''),
                default_shipping_cost: shippingInput?.value === '' ? null : parseFloat(shippingInput?.value ?? ''),
                shipping_carriers: carriers,
            };

            await runSubmit({
                button: saveBtn,
                busyLabel: t.sellerSettingsSaving,
                action: () => fetch('/api/sell/settings/shipping', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                }),
                successMsg: t.settingsSavedToast,
                errorFallback: t.sellerSettingsSaveError,
            });
        });
    }

    document.addEventListener('astro:page-load', initShippingPage);
    if (document.readyState !== 'loading') initShippingPage();
    else document.addEventListener('DOMContentLoaded', initShippingPage);
</script>
