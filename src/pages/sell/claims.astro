---
import SellerLayout from '../../layouts/SellerLayout.astro';
import Icon from '../../components/icons/Icon.astro';
import { strings } from '../../lib/core/i18n';
import { createSupabaseAuthClient } from '../../lib/core/auth';

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const {
    data: { user },
} = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/sell');
}

const { data: profile } = await supabase
    .from('profiles')
    .select('is_seller')
    .eq('id', user.id)
    .single();

if (!profile?.is_seller) {
    return Astro.redirect('/sell');
}

const { data: shop } = await supabase
    .from('shops')
    .select('id, name, slug')
    .eq('owner_id', user.id)
    .maybeSingle();

if (!shop) {
    return Astro.redirect('/sell/onboarding');
}

const { data: ordersData } = await supabase
    .from('orders')
    .select(`
        id,
        public_id,
        status,
        total_amount,
        created_at,
        buyer_email,
        shipping_full_name,
        order_items (
            quantity,
            product_variants (
                variant_name,
                variant_image,
                shipping_cost,
                products (
                    title,
                    gallery_images
                )
            )
        ),
        order_incidents (
            description,
            photos,
            created_at
        )
    `)
    .eq('shop_id', shop.id)
    .eq('status', 'incident')
    .order('created_at', { ascending: false });

interface ClaimOrder {
    orderId: string;
    publicId: string;
    createdAt: Date;
    buyerEmail: string | null;
    buyerName: string | null;
    incidentDescription: string;
    incidentPhotos: string[];
    incidentCreatedAt: Date;
    firstProductTitle: string;
    firstProductImage: string;
    itemCount: number;
    totalAmount: number;
    shippingAmount: number;
    refundAmount: number;
}

const claims: ClaimOrder[] = (ordersData ?? []).map((order: any) => {
    const rawItems = order.order_items ?? [];
    let itemCount = 0;
    let firstProductTitle = strings.fallbackProductName;
    let firstProductImage = '';
    let shippingAmount = 0;

    for (const oi of rawItems) {
        const rawVariant = oi.product_variants;
        const variant = Array.isArray(rawVariant) ? rawVariant[0] : rawVariant;
        if (!variant) continue;

        const rawProduct = variant.products;
        const product = Array.isArray(rawProduct) ? rawProduct[0] : rawProduct;
        if (!product) continue;

        const qty = Number(oi.quantity ?? 0);
        if (qty <= 0) continue;

        const variantShipping = Number(variant.shipping_cost ?? 0);
        if (variantShipping > shippingAmount) shippingAmount = variantShipping;

        itemCount += qty;
        if (!firstProductImage) {
            firstProductTitle = product.title ?? strings.fallbackProductName;
            firstProductImage = variant.variant_image || product.gallery_images?.[0] || '';
        }
    }

    const rawIncidents = order.order_incidents;
    const incident = Array.isArray(rawIncidents) ? rawIncidents[0] : rawIncidents;
    const totalAmount = Number(order.total_amount ?? 0);
    const refundAmount = Math.max(0, totalAmount - shippingAmount);

    return {
        orderId: order.id,
        publicId: order.public_id,
        createdAt: new Date(order.created_at),
        buyerEmail: order.buyer_email ?? null,
        buyerName: order.shipping_full_name ?? null,
        incidentDescription: incident?.description ?? '',
        incidentPhotos: incident?.photos ?? [],
        incidentCreatedAt: incident?.created_at ? new Date(incident.created_at) : new Date(order.created_at),
        firstProductTitle,
        firstProductImage,
        itemCount,
        totalAmount,
        shippingAmount,
        refundAmount,
    };
});

const dateFormatter = new Intl.DateTimeFormat('es-ES', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
});

const currencyFormatter = new Intl.NumberFormat('es-ES', {
    style: 'currency',
    currency: 'EUR',
});
---

<SellerLayout title={strings.incidentPanelTitle} shopSlug={shop.slug} shopId={shop.id}>
    <div class="p-6 lg:p-10">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-tertiary">{shop.name}</p>
            <h1 class="mt-2 text-2xl font-semibold tracking-tight text-text-primary">
                {strings.incidentPanelTitle}
            </h1>
            <p class="mt-2 text-sm text-text-secondary">
                Revisa las incidencias reportadas por tus compradores.
            </p>
        </div>

        {claims.length > 0 ? (
            <div class="mt-8 flex flex-col gap-4">
                {claims.map((claim) => (
                    <article class="rounded-3xl border border-border bg-surface p-5 sm:p-6 shadow-sm flex flex-col gap-5">
                        <div class="flex items-start gap-4">
                            <div class="h-14 w-14 sm:h-16 sm:w-16 shrink-0 overflow-hidden rounded-2xl border border-border-light bg-border-light">
                                {claim.firstProductImage ? (
                                    <img src={claim.firstProductImage} alt={claim.firstProductTitle} class="h-full w-full object-cover" loading="lazy" />
                                ) : (
                                    <div class="flex h-full w-full items-center justify-center text-text-tertiary">
                                        <Icon name="package" size={20} />
                                    </div>
                                )}
                            </div>
                            <div class="min-w-0 flex-1">
                                <div class="flex items-center gap-2 flex-wrap">
                                    <span class="shrink-0 inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400">
                                        {strings.orderStatusIncident}
                                    </span>
                                    <span class="text-[11px] font-bold uppercase tracking-[0.12em] text-text-secondary">
                                        #{claim.publicId}
                                    </span>
                                </div>
                                <p class="mt-1 text-sm font-semibold text-text-primary truncate">
                                    {claim.itemCount > 1 ? `${claim.itemCount} ${strings.ordersItemsPlural}` : claim.firstProductTitle}
                                </p>
                                <p class="text-xs text-text-secondary mt-0.5">
                                    {claim.buyerName || claim.buyerEmail || strings.profileAnonymous}
                                    {' · '}
                                    {dateFormatter.format(claim.incidentCreatedAt)}
                                </p>
                            </div>
                        </div>

                        <div class="p-4 rounded-2xl bg-red-50 dark:bg-red-900/20 border border-red-100 dark:border-red-800">
                            <p class="text-[11px] font-semibold uppercase tracking-wider text-red-700 dark:text-red-400 mb-2">
                                {strings.incidentPanelDescriptionLabel}
                            </p>
                            <p class="text-sm text-red-800 dark:text-red-300 leading-relaxed whitespace-pre-line">
                                {claim.incidentDescription}
                            </p>
                        </div>

                        {claim.incidentPhotos.length > 0 && (
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-wider text-text-secondary mb-2">
                                    {strings.incidentPanelPhotosLabel}
                                </p>
                                <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-2">
                                    {claim.incidentPhotos.map((photo) => (
                                        <a
                                            href={photo}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="block aspect-square rounded-xl overflow-hidden border border-border-light bg-border-light hover:opacity-90 transition-opacity"
                                        >
                                            <img src={photo} alt="Evidencia" class="w-full h-full object-cover" loading="lazy" />
                                        </a>
                                    ))}
                                </div>
                            </div>
                        )}

                        <div class="flex flex-wrap items-center justify-end gap-3 pt-2 border-t border-border-light">
                            <div class="text-xs text-text-secondary tabular-nums mr-auto">
                                <span class="font-semibold text-text-primary">{currencyFormatter.format(claim.refundAmount)}</span>
                                <span class="text-text-tertiary"> · {strings.cartShipping}: {claim.shippingAmount > 0 ? currencyFormatter.format(claim.shippingAmount) : strings.ordersFreeShipping}</span>
                            </div>
                            <button
                                type="button"
                                class="open-refund-modal-btn inline-flex items-center gap-1.5 px-4 py-2 text-xs font-semibold rounded-xl bg-red-600 text-white hover:bg-red-700 active:scale-95 transition-all"
                                data-order-id={claim.orderId}
                            >
                                <Icon name="credit-card" size={13} />
                                {strings.sellerIncidentRefundBtn}
                            </button>
                        </div>

                        <div
                            class="refund-modal hidden fixed inset-0 z-[100] flex items-end sm:items-center justify-center bg-black/40 backdrop-blur-sm p-0 sm:p-4"
                            data-order-id={claim.orderId}
                            data-total={claim.totalAmount}
                            data-shipping={claim.shippingAmount}
                            data-product={claim.refundAmount}
                        >
                            <div class="w-full max-w-md rounded-t-2xl sm:rounded-2xl border border-border bg-surface p-5 shadow-xl max-h-[90vh] overflow-y-auto">
                                <div class="flex items-start justify-between gap-3">
                                    <div>
                                        <h3 class="text-base font-semibold text-text-primary">{strings.sellerIncidentRefundConfirmTitle}</h3>
                                        <p class="mt-1 text-sm text-text-secondary">{strings.sellerIncidentRefundConfirmBody}</p>
                                    </div>
                                    <button type="button" class="close-refund-modal-btn shrink-0 p-1.5 rounded-lg hover:bg-border-light transition-colors text-text-secondary">
                                        <Icon name="x" size={18} />
                                    </button>
                                </div>

                                <div class="mt-5 flex flex-col gap-2">
                                    <label class="refund-option group relative flex items-start gap-3 rounded-2xl border border-border-light bg-bg/40 p-3 cursor-pointer transition-all hover:border-border has-[input:checked]:border-accent has-[input:checked]:bg-accent/5">
                                        <input type="radio" name={`refund-type-${claim.orderId}`} value="full" class="refund-type-input mt-1 accent-accent" />
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center justify-between gap-2">
                                                <span class="text-sm font-semibold text-text-primary">{strings.refundTypeFullTitle}</span>
                                                <span class="text-sm font-bold text-text-primary tabular-nums">{currencyFormatter.format(claim.totalAmount)}</span>
                                            </div>
                                            <p class="mt-0.5 text-xs text-text-secondary leading-snug">{strings.refundTypeFullDesc}</p>
                                        </div>
                                    </label>

                                    <label class="refund-option group relative flex items-start gap-3 rounded-2xl border border-border-light bg-bg/40 p-3 cursor-pointer transition-all hover:border-border has-[input:checked]:border-accent has-[input:checked]:bg-accent/5">
                                        <input type="radio" name={`refund-type-${claim.orderId}`} value="product" class="refund-type-input mt-1 accent-accent" checked />
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center justify-between gap-2">
                                                <span class="text-sm font-semibold text-text-primary">{strings.refundTypeProductTitle}</span>
                                                <span class="text-sm font-bold text-text-primary tabular-nums">{currencyFormatter.format(claim.refundAmount)}</span>
                                            </div>
                                            <p class="mt-0.5 text-xs text-text-secondary leading-snug">{strings.refundTypeProductDesc}</p>
                                        </div>
                                    </label>

                                    <label class="refund-option group relative flex items-start gap-3 rounded-2xl border border-border-light bg-bg/40 p-3 cursor-pointer transition-all hover:border-border has-[input:checked]:border-accent has-[input:checked]:bg-accent/5">
                                        <input type="radio" name={`refund-type-${claim.orderId}`} value="partial" class="refund-type-input mt-1 accent-accent" />
                                        <div class="flex-1 min-w-0">
                                            <span class="text-sm font-semibold text-text-primary">{strings.refundTypePartialTitle}</span>
                                            <p class="mt-0.5 text-xs text-text-secondary leading-snug">{strings.refundTypePartialDesc}</p>
                                            <div class="partial-input-wrap hidden mt-3">
                                                <label class="block text-[11px] font-semibold uppercase tracking-wider text-text-secondary mb-1.5">
                                                    {strings.refundPartialInputLabel}
                                                </label>
                                                <div class="relative">
                                                    <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-sm font-medium text-text-tertiary">€</span>
                                                    <input
                                                        type="number"
                                                        step="0.01"
                                                        min="0.01"
                                                        max={claim.totalAmount}
                                                        class="partial-amount-input w-full rounded-xl border border-border bg-surface pl-7 pr-3 py-2 text-sm text-text-primary tabular-nums shadow-sm outline-none ring-accent focus:ring-2 transition-shadow"
                                                        placeholder="0.00"
                                                    />
                                                </div>
                                                <p class="mt-1.5 text-[11px] text-text-tertiary tabular-nums">
                                                    {strings.refundPartialMaxHint.replace('{amount}', currencyFormatter.format(claim.totalAmount))}
                                                </p>
                                                <p class="partial-error hidden mt-1.5 text-[11px] text-red-600">{strings.sellerIncidentRefundInvalidPartial}</p>
                                            </div>
                                        </div>
                                    </label>
                                </div>

                                <div class="mt-5 flex items-center justify-between rounded-xl border border-border-light bg-bg/60 px-4 py-3">
                                    <span class="text-sm font-semibold text-text-primary">{strings.refundSummaryLabel}</span>
                                    <span class="refund-summary-amount text-base font-bold text-red-600 dark:text-red-400 tabular-nums">
                                        {currencyFormatter.format(claim.refundAmount)}
                                    </span>
                                </div>

                                <div class="mt-5 flex gap-2 justify-end">
                                    <button type="button" class="close-refund-modal-btn px-3 py-1.5 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors">
                                        {strings.sellerIncidentRefundDismiss}
                                    </button>
                                    <button
                                        type="button"
                                        class="confirm-refund-btn px-3 py-1.5 text-sm font-semibold rounded-lg bg-red-600 text-white hover:bg-red-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                        data-order-id={claim.orderId}
                                    >
                                        {strings.sellerIncidentRefundConfirmCta}
                                    </button>
                                </div>
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        ) : (
            <section class="mt-8 flex min-h-[360px] flex-col items-center justify-center rounded-[32px] border border-dashed border-border bg-surface px-6 py-12 text-center">
                <div class="flex h-16 w-16 items-center justify-center rounded-full border border-border text-text-tertiary">
                    <Icon name="check" size={26} />
                </div>
                <h2 class="mt-5 text-xl font-semibold tracking-tight text-text-primary">
                    {strings.incidentPanelEmpty}
                </h2>
                <p class="mt-2 max-w-md text-sm text-text-secondary">
                    {strings.incidentPanelEmptySub}
                </p>
            </section>
        )}
    </div>
</SellerLayout>

<script>
    import { strings } from '../../lib/core/i18n';
    import { runSubmit, SubmitError } from '../../lib/ui/submit';

    const currencyFormatter = new Intl.NumberFormat('es-ES', {
        style: 'currency',
        currency: 'EUR',
    });

    type RefundType = 'full' | 'product' | 'partial';

    function getModalState(modal: HTMLElement) {
        const total = Number(modal.dataset.total || 0);
        const shipping = Number(modal.dataset.shipping || 0);
        const product = Number(modal.dataset.product || 0);
        const selected = (modal.querySelector<HTMLInputElement>('.refund-type-input:checked')?.value || 'product') as RefundType;
        const partialInput = modal.querySelector<HTMLInputElement>('.partial-amount-input');
        const partial = partialInput ? Number(partialInput.value || 0) : 0;
        let amount = 0;
        if (selected === 'full') amount = total;
        else if (selected === 'product') amount = product;
        else amount = partial;
        return { total, shipping, product, selected, partial, amount };
    }

    function updateSummary(modal: HTMLElement) {
        const { selected, amount, total } = getModalState(modal);
        const summary = modal.querySelector<HTMLElement>('.refund-summary-amount');
        const partialWrap = modal.querySelector<HTMLElement>('.partial-input-wrap');
        const partialError = modal.querySelector<HTMLElement>('.partial-error');
        const confirmBtn = modal.querySelector<HTMLButtonElement>('.confirm-refund-btn');

        if (partialWrap) partialWrap.classList.toggle('hidden', selected !== 'partial');
        if (partialError && selected !== 'partial') partialError.classList.add('hidden');

        const isValid = selected === 'partial'
            ? amount > 0 && amount <= total
            : amount > 0;

        if (summary) summary.textContent = isValid ? currencyFormatter.format(amount) : currencyFormatter.format(0);
        if (confirmBtn) confirmBtn.disabled = !isValid;
    }

    document.querySelectorAll<HTMLElement>('.refund-modal').forEach((modal) => {
        modal.querySelectorAll<HTMLInputElement>('.refund-type-input').forEach((input) => {
            input.addEventListener('change', () => {
                updateSummary(modal);
                if (input.value === 'partial') {
                    modal.querySelector<HTMLInputElement>('.partial-amount-input')?.focus();
                }
            });
        });

        const partialInput = modal.querySelector<HTMLInputElement>('.partial-amount-input');
        partialInput?.addEventListener('input', () => updateSummary(modal));

        updateSummary(modal);
    });

    document.querySelectorAll<HTMLButtonElement>('.open-refund-modal-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            const orderId = btn.dataset.orderId;
            if (!orderId) return;
            const modal = document.querySelector<HTMLElement>(`.refund-modal[data-order-id="${orderId}"]`);
            if (modal) {
                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }
        });
    });

    document.querySelectorAll<HTMLButtonElement>('.close-refund-modal-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            const modal = btn.closest('.refund-modal');
            if (modal) {
                modal.classList.add('hidden');
                document.body.style.overflow = '';
            }
        });
    });

    document.querySelectorAll('.refund-modal').forEach((modal) => {
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                modal.classList.add('hidden');
                document.body.style.overflow = '';
            }
        });
    });

    document.querySelectorAll<HTMLButtonElement>('.confirm-refund-btn').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
            e.preventDefault();
            const orderId = btn.dataset.orderId;
            if (!orderId) return;
            const modal = btn.closest<HTMLElement>('.refund-modal');
            if (!modal) return;

            const state = getModalState(modal);
            if (state.selected === 'partial') {
                if (!(state.partial > 0) || state.partial > state.total) {
                    modal.querySelector<HTMLElement>('.partial-error')?.classList.remove('hidden');
                    modal.querySelector<HTMLInputElement>('.partial-amount-input')?.focus();
                    return;
                }
            }

            const result = await runSubmit({
                button: btn,
                action: async () => {
                    const res = await fetch('/api/orders/refund-incident', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            orderId,
                            refundType: state.selected,
                            partialAmount: state.selected === 'partial' ? state.partial : undefined,
                        }),
                    });
                    const data = await res.json() as { success?: boolean; error?: string };
                    if (!data.success) throw new SubmitError(data.error || strings.sellerIncidentRefundError);
                    return data;
                },
                successMsg: strings.sellerIncidentRefundSuccess,
            });
            if (result.ok) {
                window.setTimeout(() => window.location.reload(), 800);
            }
        });
    });
</script>
