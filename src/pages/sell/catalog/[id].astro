---
import SellerLayout from '../../../layouts/SellerLayout.astro';
import ProductForm from '../../../components/seller/ProductForm.astro';
import { createSupabaseAuthClient } from '../../../lib/core/auth';

import type { ProductVariant } from '../../../lib/core/types';
const { t } = Astro.locals;

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: sessionData } = await supabase.auth.getSession();
const user = sessionData?.session?.user;

if (!user) return Astro.redirect('/sell');

const { data: profile } = await supabase
    .from('profiles')
    .select('is_seller')
    .eq('id', user.id)
    .single();

if (!profile?.is_seller) return Astro.redirect('/sell');

const { data: shop } = await supabase
    .from('shops')
    .select('id, name, slug, default_weight_kg, default_length_cm, default_width_cm, default_height_cm, default_shipping_cost')
    .eq('owner_id', user.id)
    .maybeSingle();

if (!shop) return Astro.redirect('/sell/onboarding');

const productId = Astro.params.id;
if (!productId) return Astro.redirect('/sell/catalog');

const { data: product } = await supabase
    .from('products')
    .select('*, variants:product_variants(*)')
    .eq('id', productId)
    .eq('shop_id', shop.id)
    .maybeSingle();

if (!product) return Astro.redirect('/sell/catalog');

const typedProduct = product as any;
const variants: ProductVariant[] = typedProduct.variants || [];

const shippingDefaults = {
    weight_kg: shop.default_weight_kg,
    length_cm: shop.default_length_cm,
    width_cm: shop.default_width_cm,
    height_cm: shop.default_height_cm,
    shipping_cost: shop.default_shipping_cost,
};
---

<SellerLayout title={`${t.sellerProductEditTitle} — Fewya Seller`} shopSlug={shop.slug} shopId={shop.id}>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-10 py-4 lg:py-8">
        <ProductForm
            mode="edit"
            shopId={shop.slug}
            product={{
                id: typedProduct.id,
                title: typedProduct.title,
                slug: typedProduct.slug,
                description: typedProduct.description,
                category: typedProduct.category,
                brand: typedProduct.brand,
                gallery_images: typedProduct.gallery_images,
                is_active: typedProduct.is_active,
                specifications: typedProduct.specifications,
            }}
            variants={variants}
            shippingDefaults={shippingDefaults}
        />
    </div>
</SellerLayout>
