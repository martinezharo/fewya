---
import Layout from '../../../layouts/Layout.astro';
import { createSupabaseAuthClient } from '../../../lib/core/auth';
import ShopForm from '../../../components/seller/ShopForm.astro';
import { strings } from '../../../lib/core/i18n';
import { getStripeClient, getStripeAccountStatus } from '../../../lib/payments/stripe';
import { createSupabaseAdminClient } from '../../../lib/core/supabase-admin';

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: sessionData } = await supabase.auth.getSession();
const user = sessionData?.session?.user;

if (!user) {
    return Astro.redirect('/sell');
}

const { data: profile } = await supabase
    .from('profiles')
    .select('is_seller')
    .eq('id', user.id)
    .single();

if (!profile?.is_seller) {
    return Astro.redirect('/sell');
}

const stripeReturnParam = Astro.url.searchParams.get('stripe');

// Check if they already have a shop
const { data: existingShop } = await supabase
    .from('shops')
    .select('id, contact_email')
    .eq('owner_id', user.id)
    .maybeSingle();

// If shop exists, check stripe status
let stripeReady = false;
let showStripeStep = false;

if (existingShop) {
    const { data: paymentAccount } = await supabase
        .from('shop_payment_accounts')
        .select('charges_enabled, payouts_enabled, details_submitted, onboarding_completed_at')
        .eq('shop_id', existingShop.id)
        .maybeSingle();

    stripeReady = paymentAccount?.charges_enabled === true
        && paymentAccount?.payouts_enabled === true
        && paymentAccount?.details_submitted === true;

    if (stripeReady) {
        // Everything done, redirect to shop dashboard
        return Astro.redirect('/sell/shop');
    }

    // Shop exists but Stripe not ready → show Stripe step directly
    showStripeStep = true;

    // If returning from Stripe, sync status
    if (stripeReturnParam === 'return' || stripeReturnParam === 'refresh') {
        try {
            const stripe = getStripeClient();
            const { data: existingAccount } = await supabase
                .from('shop_payment_accounts')
                .select('stripe_account_id')
                .eq('shop_id', existingShop.id)
                .maybeSingle();

            if (existingAccount?.stripe_account_id) {
                const account = await stripe.accounts.retrieve(existingAccount.stripe_account_id);
                const status = getStripeAccountStatus(account);
                const adminClient = createSupabaseAdminClient();
                await adminClient.rpc('upsert_shop_payment_account', {
                    p_actor_id: user.id,
                    p_shop_id: existingShop.id,
                    p_stripe_account_id: status.stripeAccountId,
                    p_charges_enabled: status.chargesEnabled,
                    p_payouts_enabled: status.payoutsEnabled,
                    p_details_submitted: status.detailsSubmitted,
                });
                stripeReady = status.isReady;
                if (stripeReady) {
                    return Astro.redirect('/sell/shop');
                }
            }
        } catch {
            // Ignore sync errors, user can retry
        }
    }
}

if (Astro.request.method === 'POST') {
    const formData = await Astro.request.formData();
    const name = formData.get('name')?.toString() || '';
    const slug = formData.get('slug')?.toString() || '';
    const description = formData.get('description')?.toString();
    const profile_img = formData.get('profile_img')?.toString() || user.user_metadata?.avatar_url;
    const banner_img = formData.get('banner_img')?.toString() || null;
    const accent_color = formData.get('accent_color')?.toString() || '#000000';
    const contact_email = formData.get('contact_email')?.toString() || user.email;
    const whatsapp = formData.get('whatsapp')?.toString() || null;
    const location = formData.get('location')?.toString() || null;

    // Check slug uniqueness manually to give a proper response
    const { data: slugCheck } = await supabase.from('shops').select('id').eq('slug', slug).maybeSingle();
    
    if (slugCheck) {
        return new Response(JSON.stringify({ error: strings.sellerOnboardingUrlInUse }), { status: 400 });
    }

    const { error } = await supabase.from('shops').insert({
        owner_id: user.id,
        name,
        slug,
        description,
        profile_img,
        banner_img,
        accent_color,
        contact_email,
        whatsapp,
        location,
        is_active: true
    });

    if (error) {
        return new Response(JSON.stringify({ error: error.message }), { status: 500 });
    }

    return new Response(JSON.stringify({ success: true }), { status: 200 });
}
---

<Layout title={`${strings.sellerOnboardingTitle} - Fewya`}>
    <div class="max-w-2xl mx-auto px-4 py-8 md:py-16 min-h-[calc(100vh-80px)] flex flex-col justify-center">
        <h1 class="text-3xl font-semibold tracking-tight text-text-primary mb-8">{strings.sellerOnboardingTitle}</h1>
        
        <form id="onboarding-form" method="POST" class={`bg-surface p-6 md:p-8 rounded-3xl border border-border shadow-sm relative overflow-hidden ${showStripeStep ? 'hidden' : ''}`}>
            <!-- Progress Bar -->
            <div class="absolute top-0 left-0 w-full h-1 bg-border-light">
                <div id="progress-bar" class="h-full bg-accent transition-all duration-300" style={`width: ${showStripeStep ? '100%' : '25%'}`}></div>
            </div>

            <ShopForm mode="onboarding" shopData={{ contact_email: user.email }} />

            <!-- Messages -->
            <div id="error-message" class="text-red-500 font-medium text-sm mt-6 hidden p-4 bg-red-50 dark:bg-red-900/20 rounded-xl"></div>
        </form>

        <!-- Step 4: Stripe (outside form) -->
        <div id="step-4" class={`step bg-surface p-6 md:p-8 rounded-3xl border border-border shadow-sm relative overflow-hidden mt-4 ${showStripeStep ? '' : 'hidden'}`}>
            <div class="absolute top-0 left-0 w-full h-1 bg-border-light">
                <div class="h-full bg-accent w-full transition-all duration-300"></div>
            </div>

            <h2 class="font-medium text-text-primary text-xl mb-1">{strings.sellerOnboardingStep4Title}</h2>
            <p class="text-sm text-text-tertiary mb-6 font-normal">{strings.sellerOnboardingStep4Subtitle}</p>

            <div class="space-y-6">
                <div class="flex items-start gap-4 p-4 rounded-2xl bg-bg border border-border">
                    <div class="w-10 h-10 shrink-0 rounded-xl bg-[#625afa] flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z"/>
                        </svg>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm text-text-secondary">{strings.sellerOnboardingStep4Description}</p>
                    </div>
                </div>

                <!-- Stripe status indicator -->
                <div id="stripe-status" class={`flex items-center gap-3 p-4 rounded-2xl border ${stripeReady ? 'bg-green-50 dark:bg-green-900/10 border-green-200 dark:border-green-900/30' : 'bg-bg border-border'}`}>
                    <div class={`w-2.5 h-2.5 rounded-full ${stripeReady ? 'bg-green-500' : 'bg-amber-500'}`}></div>
                    <span class={`text-sm font-medium ${stripeReady ? 'text-green-700 dark:text-green-400' : 'text-text-secondary'}`}>
                        {stripeReady ? strings.sellerOnboardingStripeStatusReady : strings.sellerOnboardingStripeStatusPending}
                    </span>
                </div>

                <!-- Action buttons -->
                <div class="flex flex-col sm:flex-row gap-3">
                    <button type="button" id="stripe-connect-btn" class="flex-1 px-6 py-2.5 bg-[#625afa] text-white font-medium rounded-full shadow-sm hover:opacity-90 transition-opacity flex items-center justify-center gap-2">
                        <span id="stripe-connect-text">{stripeReady ? strings.sellerOnboardingStripeConnectCta : strings.sellerOnboardingStripeConnectCta}</span>
                        <svg id="stripe-connect-spinner" class="animate-spin h-4 w-4 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </button>
                    <button type="button" id="skip-stripe-btn" class="px-6 py-2.5 bg-bg text-text-secondary border border-border font-medium rounded-full hover:bg-border-light transition">
                        {strings.sellerOnboardingSkipStripe}
                    </button>
                </div>

                <div id="stripe-error" class="text-red-500 font-medium text-sm hidden p-4 bg-red-50 dark:bg-red-900/20 rounded-xl"></div>

                <!-- Stripe return notification -->
                {stripeReturnParam === 'return' && stripeReady && (
                    <div class="p-4 rounded-2xl bg-green-50 dark:bg-green-900/10 border border-green-200 dark:border-green-900/30">
                        <p class="text-sm text-green-700 dark:text-green-400 font-medium">{strings.sellerStripeReturnReady}</p>
                    </div>
                )}
                {stripeReturnParam === 'return' && !stripeReady && (
                    <div class="p-4 rounded-2xl bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-900/30">
                        <p class="text-sm text-amber-700 dark:text-amber-400 font-medium">{strings.sellerStripeReturnPending}</p>
                    </div>
                )}
                {stripeReturnParam === 'refresh' && (
                    <div class="p-4 rounded-2xl bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-900/30">
                        <p class="text-sm text-amber-700 dark:text-amber-400 font-medium">{strings.sellerStripeReturnPending}</p>
                    </div>
                )}


            </div>
        </div>
    </div>
</Layout>

<script>
    import { strings } from '../../../lib/core/i18n';

    const initOnboarding = () => {
        type OnboardingResponse = {
            success?: boolean;
            error?: string;
        };

        type StripeConnectResponse = {
            url?: string;
            ready?: boolean;
            error?: string;
        };

        const steps = document.querySelectorAll<HTMLElement>('.step');
        const nextBtns = document.querySelectorAll<HTMLButtonElement>('.next-btn');
        const prevBtns = document.querySelectorAll<HTMLButtonElement>('.prev-btn');
        const progressBar = document.getElementById('progress-bar');
        const form = document.getElementById('onboarding-form');
        const submitBtn = document.getElementById('submit-btn');
        const submitText = document.getElementById('submit-text');
        const submitSpinner = document.getElementById('submit-spinner');
        const errorMessage = document.getElementById('error-message');

        if (!form) return;

        const updateProgress = (step: number) => {
            if (progressBar instanceof HTMLElement) {
                progressBar.style.width = `${(step / 4) * 100}%`;
            }
        };

        const showStep4 = () => {
            steps.forEach((step) => step.classList.add('hidden'));
            if (form) {
                form.classList.add('hidden');
            }
            const step4 = document.getElementById('step-4');
            if (step4) {
                step4.classList.remove('hidden');
                step4.classList.add('step');
            }
            if (progressBar instanceof HTMLElement) {
                progressBar.style.width = '100%';
            }
        };

        nextBtns.forEach((btn) => {
            btn.addEventListener('click', (event: Event) => {
                const currentButton = event.currentTarget;
                if (!(currentButton instanceof HTMLButtonElement)) {
                    return;
                }

                const currentStep = currentButton.closest('.step');
                const inputs = currentStep?.querySelectorAll<HTMLInputElement>('input[required]');
                let isValid = true;

                inputs?.forEach((input) => {
                    if (!input.value.trim()) {
                        input.classList.add('border-red-500');
                        isValid = false;
                    } else {
                        input.classList.remove('border-red-500');
                    }
                });

                if (!isValid) {
                    return;
                }

                const nextStepId = currentButton.dataset.next;
                document.querySelectorAll<HTMLElement>('.step').forEach((step) => step.classList.add('hidden'));
                document.getElementById(`step-${nextStepId}`)?.classList.remove('hidden');
                updateProgress(parseInt(nextStepId || '1', 10));
            });
        });

        prevBtns.forEach((btn) => {
            btn.addEventListener('click', (event: Event) => {
                const currentButton = event.currentTarget;
                if (!(currentButton instanceof HTMLButtonElement)) {
                    return;
                }

                const prevStepId = currentButton.dataset.prev;
                document.querySelectorAll<HTMLElement>('.step').forEach((step) => step.classList.add('hidden'));
                document.getElementById(`step-${prevStepId}`)?.classList.remove('hidden');
                updateProgress(parseInt(prevStepId || '1', 10));
            });
        });

        if (form instanceof HTMLFormElement) {
            form.addEventListener('submit', async (event: SubmitEvent) => {
                event.preventDefault();

                if (submitBtn instanceof HTMLButtonElement) {
                    submitBtn.disabled = true;
                }
                submitText?.classList.add('hidden');
                submitSpinner?.classList.remove('hidden');
                errorMessage?.classList.add('hidden');

                try {
                    const formData = new FormData(form);
                    const response = await fetch('/sell/onboarding', {
                        method: 'POST',
                        body: formData
                    });
                    const data = await response.json() as OnboardingResponse;

                    if (!response.ok) {
                        throw new Error(data.error || strings.sellerOnboardingGenericError);
                    }

                    showStep4();
                } catch (error: unknown) {
                    if (errorMessage instanceof HTMLElement) {
                        errorMessage.textContent = error instanceof Error ? error.message : strings.sellerOnboardingGenericError;
                        errorMessage.classList.remove('hidden');
                    }

                    if (submitBtn instanceof HTMLButtonElement) {
                        submitBtn.disabled = false;
                    }
                    submitText?.classList.remove('hidden');
                    submitSpinner?.classList.add('hidden');
                }
            });
        }

        document.querySelectorAll<HTMLInputElement>('input[required]').forEach((input) => {
            input.addEventListener('input', (event: Event) => {
                const target = event.currentTarget;
                if (target instanceof HTMLInputElement) {
                    target.classList.remove('border-red-500');
                }
            });
        });

        // Stripe Connect logic
        const stripeConnectBtn = document.getElementById('stripe-connect-btn');
        const stripeConnectText = document.getElementById('stripe-connect-text');
        const stripeConnectSpinner = document.getElementById('stripe-connect-spinner');
        const stripeError = document.getElementById('stripe-error');
        const skipStripeBtn = document.getElementById('skip-stripe-btn');

        if (stripeConnectBtn) {
            stripeConnectBtn.addEventListener('click', async () => {
                stripeConnectBtn.setAttribute('disabled', 'true');
                if (stripeConnectText) {
                    stripeConnectText.textContent = strings.sellerOnboardingStripeConnecting;
                }
                stripeConnectSpinner?.classList.remove('hidden');
                stripeError?.classList.add('hidden');

                try {
                    const res = await fetch('/api/sell/stripe/connect', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ returnTo: '/sell/onboarding' })
                    });
                    const data = await res.json() as StripeConnectResponse;

                    if (!res.ok || !data.url) {
                        throw new Error(data.error || strings.sellerOnboardingStripeError);
                    }

                    window.location.href = data.url;
                } catch (error: unknown) {
                    if (stripeError instanceof HTMLElement) {
                        stripeError.textContent = error instanceof Error ? error.message : strings.sellerOnboardingStripeError;
                        stripeError.classList.remove('hidden');
                    }
                    stripeConnectBtn.removeAttribute('disabled');
                    if (stripeConnectText) {
                        stripeConnectText.textContent = strings.sellerOnboardingStripeConnectCta;
                    }
                    stripeConnectSpinner?.classList.add('hidden');
                }
            });
        }

        if (skipStripeBtn) {
            skipStripeBtn.addEventListener('click', () => {
                window.location.href = '/sell/shop';
            });
        }
    };

    document.addEventListener('astro:page-load', initOnboarding);
    if (document.readyState !== 'loading') initOnboarding();
    else document.addEventListener('DOMContentLoaded', initOnboarding);
</script>
