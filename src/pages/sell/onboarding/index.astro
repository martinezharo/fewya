<Layout title="Configurar Tienda - EWYA">
    <div class="max-w-2xl mx-auto px-4 py-8 md:py-16 min-h-[calc(100vh-80px)] flex flex-col justify-center">
        <h1 class="text-3xl font-semibold tracking-tight text-neutral-900 dark:text-white mb-8">Configura tu tienda</h1>
        
        <form id="onboarding-form" method="POST" class="bg-white dark:bg-neutral-900 p-6 md:p-8 rounded-3xl border border-neutral-200 dark:border-neutral-800 shadow-sm relative overflow-hidden">
            <!-- Progress Bar -->
            <div class="absolute top-0 left-0 w-full h-1 bg-neutral-100 dark:bg-neutral-800">
                <div id="progress-bar" class="h-full bg-neutral-900 dark:bg-white w-1/3 transition-all duration-300"></div>
            </div>

            <ShopForm mode="onboarding" shopData={{ contact_email: user.email }} />

            <!-- Messages -->
            <div id="error-message" class="text-red-500 font-medium text-sm mt-6 hidden p-4 bg-red-50 dark:bg-red-900/20 rounded-xl"></div>
        </form>
    </div>
</Layout>

<script>
    import confetti from 'my-canvas-confetti';

    const steps = document.querySelectorAll('.step');
    const nextBtns = document.querySelectorAll('.next-btn');
    const prevBtns = document.querySelectorAll('.prev-btn');
    const progressBar = document.getElementById('progress-bar');
    
    const updateProgress = (step: number) => {
        if (progressBar) {
            progressBar.style.width = `${(step / 3) * 100}%`;
        }
    };

    nextBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            // Basic validation
            const currentStep = (e.target as HTMLElement).closest('.step');
            const inputs = currentStep?.querySelectorAll('input[required]');
            let isValid = true;
            
            inputs?.forEach((input: any) => {
                if (!input.value.trim()) {
                    input.classList.add('border-red-500');
                    isValid = false;
                } else {
                    input.classList.remove('border-red-500');
                }
            });

            if (!isValid) return;

            const nextStepId = (e.target as HTMLElement).dataset.next;
            steps.forEach(s => s.classList.add('hidden'));
            document.getElementById(`step-${nextStepId}`)?.classList.remove('hidden');
            updateProgress(parseInt(nextStepId || '1'));
        });
    });

    prevBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            const prevStepId = (e.target as HTMLElement).dataset.prev;
            steps.forEach(s => s.classList.add('hidden'));
            document.getElementById(`step-${prevStepId}`)?.classList.remove('hidden');
            updateProgress(parseInt(prevStepId || '1'));
        });
    });

    const form = document.getElementById('onboarding-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const submitText = document.getElementById('submit-text');
    const submitSpinner = document.getElementById('submit-spinner');
    const errorMessage = document.getElementById('error-message');

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (submitBtn) submitBtn.disabled = true;
        if (submitText) submitText.classList.add('hidden');
        if (submitSpinner) submitSpinner.classList.remove('hidden');
        if (errorMessage) errorMessage.classList.add('hidden');

        try {
            const formData = new FormData(form);
            const response = await fetch('/sell/onboarding', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            if (!response.ok) {
                throw new Error(data.error || 'Algo salió mal');
            }

            // Success
            confetti({
                particleCount: 100,
                spread: 70,
                origin: { y: 0.6 },
                colors: ['#000000', '#ffffff', '#666666']
            });

            setTimeout(() => {
                window.location.href = data.redirect;
            }, 1500);

        } catch (error: any) {
            if (errorMessage) {
                errorMessage.textContent = error.message;
                errorMessage.classList.remove('hidden');
            }
            if (submitBtn) submitBtn.disabled = false;
            if (submitText) submitText.classList.remove('hidden');
            if (submitSpinner) submitSpinner.classList.add('hidden');
        }
    });

    // Remove highlight on input
    document.querySelectorAll('input[required]').forEach(input => {
        input.addEventListener('input', (e) => {
            (e.target as HTMLElement).classList.remove('border-red-500');
        });
    });
