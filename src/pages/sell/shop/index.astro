---
import SellerLayout from '../../../layouts/SellerLayout.astro';
import { createSupabaseAuthClient } from '../../../lib/auth';
import ShopForm from '../../../components/seller/ShopForm.astro';
import Icon from '../../../components/icons/Icon.astro';
import { strings } from '../../../lib/i18n';
import { getStripeAccountStatus, getStripeClient } from '../../../lib/stripe';

function one<T>(value: T | T[] | null | undefined): T | null {
    if (Array.isArray(value)) {
        return value[0] ?? null;
    }

    return value ?? null;
}

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: sessionData } = await supabase.auth.getSession();
const user = sessionData?.session?.user;

if (!user) {
    return Astro.redirect('/sell');
}

// Get the shop of the current seller
const { data: shop } = await supabase
    .from('shops')
    .select(`
        *,
        shop_payment_accounts (
            stripe_account_id,
            charges_enabled,
            payouts_enabled,
            details_submitted,
            onboarding_completed_at
        )
    `)
    .eq('owner_id', user.id)
    .single();

if (!shop) {
    return Astro.redirect('/sell/onboarding');
}

let paymentAccount = one((shop as any).shop_payment_accounts);
let stripeNotice: string | null = null;
let stripeNoticeTone: 'success' | 'warning' | null = null;
let stripeSyncError: string | null = null;

const stripeFlow = Astro.url.searchParams.get('stripe');

if ((stripeFlow === 'return' || stripeFlow === 'refresh') && paymentAccount?.stripe_account_id) {
    try {
        const stripe = getStripeClient();
        const account = await stripe.accounts.retrieve(paymentAccount.stripe_account_id);
        const accountStatus = getStripeAccountStatus(account);
        const { data: syncedAccount, error: syncError } = await supabase.rpc('upsert_shop_payment_account', {
            p_shop_id: shop.id,
            p_stripe_account_id: accountStatus.stripeAccountId,
            p_charges_enabled: accountStatus.chargesEnabled,
            p_payouts_enabled: accountStatus.payoutsEnabled,
            p_details_submitted: accountStatus.detailsSubmitted,
        });

        if (syncError) {
            throw syncError;
        }

        paymentAccount = Array.isArray(syncedAccount) ? syncedAccount[0] : syncedAccount;
    } catch (error) {
        stripeSyncError = error instanceof Error ? error.message : strings.sellerStripeError;
    }

    if (stripeFlow === 'return') {
        const isReadyAfterReturn = Boolean(
            paymentAccount?.stripe_account_id
            && paymentAccount?.charges_enabled
            && paymentAccount?.payouts_enabled
            && paymentAccount?.details_submitted
        );

        stripeNotice = isReadyAfterReturn ? strings.sellerStripeReturnReady : strings.sellerStripeReturnPending;
        stripeNoticeTone = isReadyAfterReturn ? 'success' : 'warning';
    }
}

const isStripeReady = Boolean(
    paymentAccount?.stripe_account_id
    && paymentAccount?.charges_enabled
    && paymentAccount?.payouts_enabled
    && paymentAccount?.details_submitted
);
const hasStripeAccount = Boolean(paymentAccount?.stripe_account_id);
const stripeStatusLabel = isStripeReady
    ? strings.sellerStripeStatusReady
    : hasStripeAccount
        ? strings.sellerStripeStatusPending
        : strings.sellerStripeStatusNotConnected;
const stripeAction = isStripeReady ? 'dashboard' : 'onboarding';
const stripeButtonLabel = isStripeReady
    ? strings.sellerStripeDashboardCta
    : hasStripeAccount
        ? strings.sellerStripeContinueCta
        : strings.sellerStripeConnectCta;

if (Astro.request.method === 'POST') {
    const formData = await Astro.request.formData();
    const name = formData.get('name')?.toString() || '';
    const slug = formData.get('slug')?.toString() || '';
    const description = formData.get('description')?.toString() || '';
    const accent_color = formData.get('accent_color')?.toString() || '#000000';
    const contact_email = formData.get('contact_email')?.toString() || '';
    const whatsapp = formData.get('whatsapp')?.toString() || '';
    const location = formData.get('location')?.toString() || '';

    // Check slug uniqueness if it changed
    if (slug !== shop.slug) {
        const { data: slugCheck } = await supabase.from('shops').select('id').eq('slug', slug).maybeSingle();
        if (slugCheck) {
            return new Response(JSON.stringify({ error: strings.sellerOnboardingUrlInUse }), { status: 400 });
        }
    }

    const { error } = await supabase
        .from('shops')
        .update({
            name,
            slug,
            description,
            accent_color,
            contact_email,
            whatsapp,
            location
        })
        .eq('id', shop.id);

    if (error) {
        return new Response(JSON.stringify({ error: error.message }), { status: 500 });
    }

    return new Response(JSON.stringify({ success: true }), { status: 200 });
}

const profileImg = shop.profile_img || '';
const bannerImg = shop.banner_img || '';
---

<SellerLayout title={`${strings.sellerShopEditTitle} - Shopenn Seller`} shopSlug={shop.slug}>
    <div class="max-w-4xl mx-auto px-4 py-8 lg:py-12">
        <div class="mb-8">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-tertiary">{shop.name}</p>
            <h1 class="mt-2 text-2xl font-semibold tracking-tight text-text-primary">{strings.sellerShopEditTitle}</h1>
        </div>

        {stripeNotice && (
            <div class:list={[
                'mb-6 rounded-2xl border px-4 py-3 text-sm font-medium',
                stripeNoticeTone === 'success'
                    ? 'border-green-300 bg-green-100 text-green-800 dark:border-green-800 dark:bg-green-900/20 dark:text-green-300'
                    : 'border-amber-300 bg-amber-100 text-amber-800 dark:border-amber-800 dark:bg-amber-900/20 dark:text-amber-300'
            ]}>
                {stripeNotice}
            </div>
        )}

        {stripeSyncError && (
            <div class="mb-6 rounded-2xl border border-red-300 bg-red-100 px-4 py-3 text-sm font-medium text-red-800 dark:border-red-800 dark:bg-red-900/20 dark:text-red-300">
                {stripeSyncError}
            </div>
        )}

        <section class="mb-8 rounded-3xl border border-border bg-surface shadow-sm overflow-hidden">
            <!-- Header: Stripe branding + live status indicator -->
            <div class="flex items-center justify-between px-6 md:px-8 pt-6 pb-4">
                <div class="flex items-center gap-2.5">
                    <div class="w-7 h-7 rounded-lg bg-[#625afa]/10 dark:bg-[#625afa]/15 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-[#625afa]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <rect x="2" y="5" width="20" height="14" rx="3"/>
                            <path stroke-linecap="round" d="M2 10h20"/>
                        </svg>
                    </div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-tertiary">Stripe Connect</p>
                </div>
                <!-- Status indicator: dot + label, not a button -->
                <div class="flex items-center gap-2">
                    <span class="relative flex w-2 h-2">
                        {isStripeReady && <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-60"></span>}
                        <span class:list={[
                            'relative inline-flex rounded-full w-2 h-2',
                            isStripeReady ? 'bg-green-500' : hasStripeAccount ? 'bg-amber-400' : 'bg-neutral-400 dark:bg-neutral-600'
                        ]}></span>
                    </span>
                    <span class:list={[
                        'text-xs font-medium',
                        isStripeReady ? 'text-green-600 dark:text-green-400' : hasStripeAccount ? 'text-amber-600 dark:text-amber-400' : 'text-text-tertiary'
                    ]}>
                        {stripeStatusLabel}
                    </span>
                </div>
            </div>

            <!-- Content + action -->
            <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between px-6 md:px-8 pb-6 md:pb-8">
                <div>
                    <h2 class="text-xl font-semibold text-text-primary">{strings.sellerStripeSectionTitle}</h2>
                    <p class="mt-1.5 text-sm text-text-secondary max-w-lg">{strings.sellerStripeSectionSubtitle}</p>
                </div>
                <button
                    type="button"
                    id="stripe-connect-btn"
                    data-action={stripeAction}
                    data-loading-label={strings.sellerStripeConnecting}
                    class="self-start sm:self-auto shrink-0 inline-flex items-center gap-2 px-5 py-2.5 rounded-2xl bg-neutral-900 text-white dark:bg-white dark:text-neutral-900 text-sm font-medium hover:scale-[1.02] transition-transform"
                >
                    {stripeButtonLabel}
                    <svg class="w-3.5 h-3.5 opacity-60" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 13L13 3M13 3H6M13 3v7"/>
                    </svg>
                </button>
            </div>

            <div id="stripe-error-message" class="hidden mx-6 md:mx-8 mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700 dark:border-red-800 dark:bg-red-900/20 dark:text-red-300"></div>
        </section>

        <!-- Banner + Profile Image Section -->
        <form id="edit-shop-form" method="POST" class="space-y-8">
            <section class="rounded-3xl border border-border bg-surface shadow-sm overflow-hidden">
                <!-- Banner -->
                <div class="relative group" id="banner-upload-area">
                    <div class="h-40 md:h-52 overflow-hidden" id="banner-preview-container">
                        <div class="w-full h-full" id="banner-preview">
                            {bannerImg ? (
                                <img src={bannerImg} alt="" class="w-full h-full object-cover" />
                            ) : (
                                <div class="w-full h-full bg-gradient-to-r from-accent/20 to-accent/40 flex items-center justify-center">
                                    <Icon name="image" size={40} class="text-text-tertiary/40" />
                                </div>
                            )}
                        </div>
                    </div>
                    <div class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/30 transition-colors cursor-pointer" id="banner-trigger">
                        <div class="opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center gap-1.5">
                            <Icon name="camera" size={24} class="text-white" />
                            <span class="text-sm text-white font-medium">{strings.sellerShopBannerChange}</span>
                        </div>
                    </div>
                    {bannerImg && (
                        <button type="button" id="banner-remove-btn" class="absolute top-3 right-3 w-8 h-8 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/80" aria-label={strings.sellerShopImageRemove}>
                            <Icon name="x" size={16} />
                        </button>
                    )}
                    <input type="file" id="banner-input" accept="image/jpeg,image/png,image/webp,image/gif" class="hidden" />
                    <p class="absolute bottom-3 right-3 text-xs text-white/70 opacity-0 group-hover:opacity-100 transition-opacity">{strings.sellerShopBannerHint}</p>

                    <!-- Profile Image overlapping banner -->
                    <div class="absolute -bottom-12 left-6 md:left-8">
                        <div class="relative w-24 h-24 rounded-full border-4 border-surface overflow-hidden bg-bg shadow-sm cursor-pointer group/profile" id="profile-upload-area">
                            <div class="w-full h-full flex items-center justify-center" id="profile-preview-inner">
                                {profileImg ? (
                                    <img src={profileImg} alt="" class="w-full h-full object-cover" />
                                ) : (
                                    <div class="w-full h-full flex items-center justify-center bg-border-light">
                                        <Icon name="user" size={28} class="text-text-tertiary" />
                                    </div>
                                )}
                            </div>
                            <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover/profile:opacity-100 transition-opacity">
                                <Icon name="camera" size={20} class="text-white" />
                            </div>
                            <input type="file" id="profile-input" accept="image/jpeg,image/png,image/webp,image/gif" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                            <!-- Auto-save indicator -->
                            <div id="profile-saved-indicator" class="absolute inset-0 bg-green-500/30 flex items-center justify-center opacity-0 transition-opacity pointer-events-none rounded-full">
                                <Icon name="check" size={24} class="text-white drop-shadow" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Auto-save indicator for banner -->
                <div id="banner-saved-indicator" class="hidden mx-6 mt-2 mb-1 px-3 py-1.5 rounded-lg bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-xs font-medium flex items-center gap-1.5">
                    <Icon name="check" size={14} class="text-green-600 dark:text-green-400" />
                    <span>{strings.sellerShopImageSaved}</span>
                </div>

                <!-- Profile label -->
                <div class="pt-14 md:pt-16 px-6 md:px-8 pb-4">
                    <p class="text-sm font-medium text-text-secondary">{strings.sellerShopProfileImgLabel}</p>
                    <p class="text-xs text-text-tertiary mt-0.5">{strings.sellerShopProfileImgHint}</p>
                </div>
            </section>

            <!-- Form Content -->
            <section class="bg-surface p-6 md:p-8 rounded-3xl border border-border shadow-sm">
                <ShopForm mode="edit" shopData={shop} />

                <!-- Messages -->
                <div id="error-message" class="text-red-700 dark:text-red-300 font-medium text-sm mt-6 hidden p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl"></div>
                <div id="success-message" class="text-green-700 dark:text-green-300 font-medium text-sm mt-6 hidden p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl">
                    {strings.sellerShopEditSuccess}
                </div>
            </section>
        </form>
    </div>
</SellerLayout>

<script>
    import { strings } from '../../../lib/i18n';

    type ShopUpdateResponse = {
        success?: boolean;
        error?: string;
    };

    const form = document.getElementById('edit-shop-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const submitText = document.getElementById('submit-text');
    const submitSpinner = document.getElementById('submit-spinner');
    const errorMessage = document.getElementById('error-message');
    const successMessage = document.getElementById('success-message');
    const stripeConnectBtn = document.getElementById('stripe-connect-btn') as HTMLButtonElement | null;
    const stripeErrorMessage = document.getElementById('stripe-error-message');

    type StripeConnectResponse = {
        url?: string;
        ready?: boolean;
        error?: string;
    };

    // Stripe Connect button
    stripeConnectBtn?.addEventListener('click', async () => {
        const action = stripeConnectBtn.dataset.action || 'onboarding';
        const originalText = stripeConnectBtn.textContent || strings.sellerStripeConnectCta;

        stripeConnectBtn.disabled = true;
        stripeConnectBtn.textContent = stripeConnectBtn.dataset.loadingLabel || strings.sellerStripeConnecting;
        stripeErrorMessage?.classList.add('hidden');

        try {
            const response = await fetch('/api/sell/stripe/connect', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action }),
            });

            const data = await response.json().catch(() => ({} as StripeConnectResponse)) as StripeConnectResponse;

            if (!response.ok || !data.url) {
                throw new Error(data.error || strings.sellerStripeError);
            }

            window.location.href = data.url;
        } catch (error: unknown) {
            if (stripeErrorMessage instanceof HTMLElement) {
                stripeErrorMessage.textContent = error instanceof Error ? error.message : strings.sellerStripeError;
                stripeErrorMessage.classList.remove('hidden');
            }
        } finally {
            stripeConnectBtn.disabled = false;
            stripeConnectBtn.textContent = originalText;
        }
    });

    type UploadResponse = { url: string; path?: string; error?: string };

    // --- Image auto-save ---
    const autoSave = async (field: string, value: string | null) => {
        try {
            const body: Record<string, string | null> = {};
            body[field] = value;
            const res = await fetch('/api/sell/shop/update', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body),
            });
            return res.ok;
        } catch {
            return false;
        }
    };

    const showImageSaved = (indicator: HTMLElement | null) => {
        if (!indicator) return;
        indicator.classList.remove('hidden', 'opacity-0');
        indicator.classList.add('opacity-100');
        setTimeout(() => {
            indicator.classList.remove('opacity-100');
            indicator.classList.add('opacity-0');
            setTimeout(() => indicator.classList.add('hidden'), 300);
        }, 2000);
    };

    // Banner upload
    const bannerInput = document.getElementById('banner-input') as HTMLInputElement | null;
    const bannerPreviewContainer = document.getElementById('banner-preview-container');
    const bannerRemoveBtn = document.getElementById('banner-remove-btn');
    const bannerTrigger = document.getElementById('banner-trigger');
    const bannerSavedIndicator = document.getElementById('banner-saved-indicator');

    const uploadImage = async (file: File, type: 'profile' | 'banner'): Promise<{ url: string } | null> => {
        const formData = new FormData();
        formData.append('file', file);
        formData.append('type', type);

        try {
            const res = await fetch('/api/sell/shop/upload', { method: 'POST', body: formData });
            const data = await res.json() as UploadResponse;
            if (!res.ok) {
                const errorMsg = data.error || strings.sellerOnboardingGenericError;
                alert(errorMsg);
                return null;
            }
            return { url: data.url };
        } catch {
            alert(strings.sellerOnboardingGenericError);
            return null;
        }
    };

    bannerTrigger?.addEventListener('click', () => {
        bannerInput?.click();
    });

    bannerInput?.addEventListener('change', async () => {
        if (!bannerInput.files || !bannerInput.files[0]) return;
        const file = bannerInput.files[0];
        bannerInput.value = '';

        const result = await uploadImage(file, 'banner');
        if (!result) return;

        // Update preview
        if (bannerPreviewContainer) {
            const previewDiv = bannerPreviewContainer.querySelector('#banner-preview') as HTMLElement | null;
            if (previewDiv) {
                previewDiv.innerHTML = `<img src="${result.url}" alt="" class="w-full h-full object-cover" />`;
            }
        }

        // Add remove button if not present
        const existingRemoveBtn = document.getElementById('banner-remove-btn');
        if (!existingRemoveBtn) {
            const uploadArea = document.getElementById('banner-upload-area');
            if (uploadArea) {
                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.id = 'banner-remove-btn';
                removeBtn.className = 'absolute top-3 right-3 w-8 h-8 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/80';
                removeBtn.setAttribute('aria-label', strings.sellerShopImageRemove);
                removeBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';
                removeBtn.addEventListener('click', removeBanner);
                uploadArea.appendChild(removeBtn);
            }
        }

        // Auto-save
        const saved = await autoSave('banner_img', result.url);
        if (saved) {
            showImageSaved(bannerSavedIndicator);
        }
    });

    function removeBanner() {
        if (bannerPreviewContainer) {
            const previewDiv = bannerPreviewContainer.querySelector('#banner-preview') as HTMLElement | null;
            if (previewDiv) {
                previewDiv.innerHTML = `<div class="w-full h-full bg-gradient-to-r from-accent/20 to-accent/40 flex items-center justify-center"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-text-tertiary/40"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg></div>`;
            }
        }
        const removeBtn = document.getElementById('banner-remove-btn');
        if (removeBtn) removeBtn.remove();

        // Auto-save removal
        autoSave('banner_img', null);
    }

    bannerRemoveBtn?.addEventListener('click', removeBanner);

    // Profile image upload
    const profileInput = document.getElementById('profile-input') as HTMLInputElement | null;
    const profilePreviewInner = document.getElementById('profile-preview-inner');
    const profileSavedIndicator = document.getElementById('profile-saved-indicator');

    profileInput?.addEventListener('change', async () => {
        if (!profileInput.files || !profileInput.files[0]) return;
        const file = profileInput.files[0];
        profileInput.value = '';

        const result = await uploadImage(file, 'profile');
        if (!result) return;

        // Update preview
        if (profilePreviewInner) {
            profilePreviewInner.innerHTML = `<img src="${result.url}" alt="" class="w-full h-full object-cover" />`;
        }

        // Auto-save
        const saved = await autoSave('profile_img', result.url);
        if (saved) {
            showImageSaved(profileSavedIndicator);
        }
    });

    // Form submission
    form?.addEventListener('submit', async (event: SubmitEvent) => {
        event.preventDefault();
        
        if (submitBtn) submitBtn.disabled = true;
        if (submitText) submitText.classList.add('hidden');
        if (submitSpinner) submitSpinner.classList.remove('hidden');
        if (errorMessage) errorMessage.classList.add('hidden');
        if (successMessage) successMessage.classList.add('hidden');

        try {
            const formData = new FormData(form);
            const response = await fetch('/sell/shop', {
                method: 'POST',
                body: formData
            });

            const data = await response.json() as ShopUpdateResponse;

            if (!response.ok) {
                throw new Error(data.error || strings.sellerShopEditError);
            }

            // Success
            if (successMessage) successMessage.classList.remove('hidden');

            setTimeout(() => {
                if (successMessage) successMessage.classList.add('hidden');
            }, 5000);

        } catch (error: unknown) {
            if (errorMessage) {
                errorMessage.textContent = error instanceof Error ? error.message : strings.sellerShopEditError;
                errorMessage.classList.remove('hidden');
            }
        } finally {
             // Reset UI
             if (submitBtn) submitBtn.disabled = false;
             if (submitText) submitText.classList.remove('hidden');
             if (submitSpinner) submitSpinner.classList.add('hidden');
        }
    });

    // Remove highlight on input
    document.querySelectorAll<HTMLInputElement>('input[required]').forEach(input => {
        input.addEventListener('input', (event: Event) => {
            const target = event.currentTarget;
            if (target instanceof HTMLInputElement) {
                target.classList.remove('border-red-500');
            }
        });
    });
</script>