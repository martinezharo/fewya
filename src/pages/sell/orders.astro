---
import SellerOrderCard from '../../components/orders/SellerOrderCard.astro';
import type { SellerOrderCardData } from '../../components/orders/SellerOrderCard.astro';
import type { SellerOrderItem } from '../../components/orders/SellerOrderCard.astro';
import Icon from '../../components/icons/Icon.astro';
import SellerLayout from '../../layouts/SellerLayout.astro';
import { createSupabaseAuthClient } from '../../lib/auth';
import { strings } from '../../lib/i18n';

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const {
    data: { user },
} = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/sell');
}

const { data: profile } = await supabase
    .from('profiles')
    .select('is_seller')
    .eq('id', user.id)
    .single();

if (!profile?.is_seller) {
    return Astro.redirect('/sell');
}

const { data: shop } = await supabase
    .from('shops')
    .select('id, name, slug')
    .eq('owner_id', user.id)
    .maybeSingle();

if (!shop) {
    return Astro.redirect('/sell/onboarding');
}

const { data: orderItemsData } = await supabase
    .from('order_items')
    .select(`
        quantity,
        price_at_purchase,
        orders (
            id,
            public_id,
            status,
            payment_status,
            created_at,
            buyer_email,
            shipping_full_name,
            shipping_phone,
            shipping_address,
            shipments (
                id,
                packlink_shipment_id,
                carrier_name,
                service_name,
                status,
                tracking_number,
                tracking_url,
                label_url
            )
        ),
        product_variants (
            variant_name,
            variant_image,
            shipping_cost,
            products (
                shop_id,
                title,
                slug,
                gallery_images
            )
        )
    `);

const ordersById = new Map<string, SellerOrderCardData>();

for (const orderItem of orderItemsData ?? []) {
    const rawOrder = (orderItem as any).orders;
    const order = Array.isArray(rawOrder) ? rawOrder[0] : rawOrder;
    if (!order?.id) continue;

    const rawVariant = (orderItem as any).product_variants;
    const variant = Array.isArray(rawVariant) ? rawVariant[0] : rawVariant;
    if (!variant) continue;

    const rawProduct = variant.products;
    const product = Array.isArray(rawProduct) ? rawProduct[0] : rawProduct;
    if (!product || product.shop_id !== shop.id) continue;

    const quantity = Number((orderItem as any).quantity ?? 0);
    if (quantity <= 0) continue;

    const rawShipments = (order as any).shipments;
    const shipment = Array.isArray(rawShipments) ? rawShipments[0] : rawShipments;

    const item: SellerOrderItem = {
        productTitle: product.title ?? strings.fallbackProductName,
        imageUrl: variant.variant_image || product.gallery_images?.[0] || '',
        productSlug: product.slug ?? null,
        variantName: variant.variant_name ?? null,
        quantity,
        unitPrice: Number((orderItem as any).price_at_purchase ?? 0),
        shippingCost: Number(variant.shipping_cost ?? 0),
    };

    const existingOrder = ordersById.get(order.id);

    if (existingOrder) {
        existingOrder.items.push(item);
        existingOrder.itemsSold += item.quantity;
        existingOrder.subtotal += item.quantity * item.unitPrice;
        existingOrder.shipping = Math.max(existingOrder.shipping, item.shippingCost);
        continue;
    }

    ordersById.set(order.id, {
        orderId: order.id,
        publicId: order.public_id,
        status: order.status ?? order.payment_status ?? 'pending',
        createdAt: new Date(order.created_at),
        buyerEmail: order.buyer_email ?? null,
        shippingFullName: order.shipping_full_name ?? null,
        shippingPhone: order.shipping_phone ?? null,
        shippingAddress: order.shipping_address ?? null,
        subtotal: item.quantity * item.unitPrice,
        shipping: item.shippingCost,
        itemsSold: item.quantity,
        items: [item],
        shopSlug: shop.slug,
        hasShipment: !!shipment,
        shipmentId: shipment?.id,
        trackingNumber: shipment?.tracking_number ?? null,
        trackingUrl: shipment?.tracking_url ?? null,
        labelUrl: shipment?.label_url ?? null,
        carrierName: shipment?.carrier_name ?? null,
        serviceName: shipment?.service_name ?? null,
    });
}

const orders = Array.from(ordersById.values()).sort(
    (left, right) => right.createdAt.getTime() - left.createdAt.getTime(),
);

const totalSales = orders.reduce((sum, order) => sum + order.subtotal + order.shipping, 0);
const totalOrders = orders.length;
const totalItemsSold = orders.reduce((sum, order) => sum + order.itemsSold, 0);
const currencyFormatter = new Intl.NumberFormat('es-ES', {
    style: 'currency',
    currency: 'EUR',
});
---

<SellerLayout title={strings.sellerOrdersPageTitle} shopSlug={shop.slug}>
    <div class="p-6 lg:p-10">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-tertiary">{shop.name}</p>
            <h1 class="mt-2 text-2xl font-semibold tracking-tight text-text-primary">
                {strings.sellerOrdersHeading}
            </h1>
            <p class="mt-2 text-sm text-text-secondary">{strings.sellerOrdersIntro}</p>
        </div>

        {orders.length > 0 ? (
            <>
                <div class="mt-8 grid gap-3 sm:grid-cols-3">
                    <section class="rounded-[28px] border border-border bg-surface p-5 shadow-sm">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-text-tertiary">
                            {strings.sellerOrdersSummarySales}
                        </p>
                        <p class="mt-3 text-2xl font-semibold tracking-tight text-text-primary tabular-nums">
                            {currencyFormatter.format(totalSales)}
                        </p>
                    </section>

                    <section class="rounded-[28px] border border-border bg-surface p-5 shadow-sm">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-text-tertiary">
                            {strings.sellerOrdersSummaryOrders}
                        </p>
                        <p class="mt-3 text-2xl font-semibold tracking-tight text-text-primary tabular-nums">
                            {totalOrders}
                        </p>
                    </section>

                    <section class="rounded-[28px] border border-border bg-surface p-5 shadow-sm">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-text-tertiary">
                            {strings.sellerOrdersSummaryItems}
                        </p>
                        <p class="mt-3 text-2xl font-semibold tracking-tight text-text-primary tabular-nums">
                            {totalItemsSold}
                        </p>
                    </section>
                </div>

                <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                    <label class="inline-flex cursor-pointer items-center gap-3 select-none">
                        <input
                            id="show-pending-toggle"
                            type="checkbox"
                            class="peer sr-only"
                        />
                        <span class="relative h-6 w-11 rounded-full bg-neutral-200 transition-colors peer-checked:bg-accent dark:bg-neutral-700">
                            <span class="absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-white shadow-sm transition-transform peer-checked:translate-x-5" />
                        </span>
                        <span class="text-sm font-medium text-text-primary">
                            {strings.sellerOrdersFilterShowPending}
                        </span>
                        <span class="hidden text-xs text-text-tertiary sm:inline">
                            {strings.sellerOrdersFilterShowPendingHint}
                        </span>
                    </label>

                    <div class="flex items-center gap-2">
                        <label for="status-filter" class="text-sm font-medium text-text-secondary">
                            {strings.sellerOrdersFilterStatusLabel}
                        </label>
                        <select
                            id="status-filter"
                            class="min-w-[160px] rounded-xl border border-border bg-surface px-3 py-2 text-sm text-text-primary shadow-sm outline-none ring-accent focus:ring-2 transition-shadow cursor-pointer"
                        >
                            <option value="all">{strings.sellerOrdersFilterStatusAll}</option>
                            <option value="pending">{strings.orderStatusPending}</option>
                            <option value="paid">{strings.orderStatusPaid}</option>
                            <option value="processing">{strings.orderStatusProcessing}</option>
                            <option value="shipped">{strings.orderStatusShipped}</option>
                            <option value="delivered">{strings.orderStatusDelivered}</option>
                            <option value="cancelled">{strings.orderStatusCancelled}</option>
                        </select>
                    </div>
                </div>

                <p id="orders-filter-count" class="mt-3 text-xs text-text-tertiary" />

                <div id="orders-list" class="mt-4 flex flex-col gap-4">
                    {orders.map((order) => (
                        <SellerOrderCard order={order} />
                    ))}
                </div>
            </>
        ) : (
            <section class="mt-8 flex min-h-[360px] flex-col items-center justify-center rounded-[32px] border border-dashed border-border bg-surface px-6 py-12 text-center">
                <div class="flex h-16 w-16 items-center justify-center rounded-full border border-border text-text-tertiary">
                    <Icon name="package" size={26} />
                </div>
                <h2 class="mt-5 text-xl font-semibold tracking-tight text-text-primary">
                    {strings.sellerOrdersEmpty}
                </h2>
                <p class="mt-2 max-w-md text-sm text-text-secondary">
                    {strings.sellerOrdersEmptySub}
                </p>
            </section>
        )}
    </div>

    <script>
        (function () {
            const toggle = document.getElementById('show-pending-toggle') as HTMLInputElement | null;
            const select = document.getElementById('status-filter') as HTMLSelectElement | null;
            const list = document.getElementById('orders-list');
            const countLabel = document.getElementById('orders-filter-count');

            if (!toggle || !select || !list || !countLabel) return;

            const cards = Array.from(list.querySelectorAll<HTMLElement>('[data-order-status]'));
            const total = cards.length;

            function applyFilters() {
                const selectedStatus = select.value;
                const showPending = toggle.checked;

                let visible = 0;

                cards.forEach((card) => {
                    const status = card.dataset.orderStatus || '';

                    let shouldShow = true;

                    if (selectedStatus !== 'all') {
                        shouldShow = status === selectedStatus;
                    } else if (!showPending) {
                        shouldShow = status !== 'pending';
                    }

                    card.style.display = shouldShow ? '' : 'none';
                    if (shouldShow) visible++;
                });

                countLabel.textContent = visible === total
                    ? `Mostrando ${total} pedidos`
                    : `Mostrando ${visible} de ${total} pedidos`;
            }

            toggle.addEventListener('change', applyFilters);
            select.addEventListener('change', applyFilters);

            // Initial state: toggle off, select "all" -> hide pending
            applyFilters();
        })();
    </script>
</SellerLayout>