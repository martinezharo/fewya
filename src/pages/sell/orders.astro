---
import DeferredSellerOrders from '../../components/orders/DeferredSellerOrders.astro';
import SkeletonOrderList from '../../components/ui/SkeletonOrderList.astro';
import SellerLayout from '../../layouts/SellerLayout.astro';
import { createSupabaseAuthClient } from '../../lib/core/auth';
const { t } = Astro.locals;

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const {
    data: { user },
} = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/sell');
}

const { data: profile } = await supabase
    .from('profiles')
    .select('is_seller')
    .eq('id', user.id)
    .single();

if (!profile?.is_seller) {
    return Astro.redirect('/sell');
}

const { data: shop } = await supabase
    .from('shops')
    .select('id, name, slug')
    .eq('owner_id', user.id)
    .maybeSingle();

if (!shop) {
    return Astro.redirect('/sell/onboarding');
}
---

<SellerLayout title={t.sellerOrdersPageTitle} shopSlug={shop.slug} shopId={shop.id}>
    <div class="p-6 lg:p-10">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-tertiary">{shop.name}</p>
            <h1 class="mt-2 text-2xl font-semibold tracking-tight text-text-primary">
                {t.sellerOrdersHeading}
            </h1>
            <p class="mt-2 text-sm text-text-secondary">{t.sellerOrdersIntro}</p>
        </div>

        <DeferredSellerOrders server:defer shopId={shop.id} shopSlug={shop.slug}>
            <div slot="fallback" class="mt-8">
                <SkeletonOrderList count={3} />
            </div>
        </DeferredSellerOrders>
    </div>
</SellerLayout>
