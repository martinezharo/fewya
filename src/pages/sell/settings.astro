---
import SellerLayout from '../../layouts/SellerLayout.astro';
import ThemeSelector from '../../components/settings/ThemeSelector.astro';
import SignOutButton from '../../components/settings/SignOutButton.astro';
import { strings } from '../../lib/core/i18n';
import { createSupabaseAuthClient } from '../../lib/core/auth';

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: sessionData } = await supabase.auth.getSession();
const user = sessionData?.session?.user;

if (!user) return Astro.redirect('/sell');

const { data: profile } = await supabase
    .from('profiles')
    .select('is_seller')
    .eq('id', user.id)
    .single();

if (!profile?.is_seller) return Astro.redirect('/sell');

const { data: shop } = await supabase
    .from('shops')
    .select('id, name, slug, default_weight_kg, default_length_cm, default_width_cm, default_height_cm, default_shipping_cost')
    .eq('owner_id', user.id)
    .maybeSingle();

if (!shop) return Astro.redirect('/sell/onboarding');

const defaults = {
    weight_kg: shop.default_weight_kg ?? '',
    length_cm: shop.default_length_cm ?? '',
    width_cm: shop.default_width_cm ?? '',
    height_cm: shop.default_height_cm ?? '',
    shipping_cost: shop.default_shipping_cost ?? '',
};
---

<SellerLayout title={strings.sellerSettingsPageTitle} shopSlug={shop.slug} shopId={shop.id}>
    <div class="max-w-3xl mx-auto px-4 py-8 lg:py-12">
        <div class="mb-8">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-tertiary">{shop.name}</p>
            <h1 class="mt-2 text-2xl font-semibold tracking-tight text-text-primary">{strings.sellerSettingsTitle}</h1>
        </div>

        <div class="bg-surface p-6 md:p-8 rounded-3xl border border-border shadow-sm space-y-8">
            <!-- Shipping Defaults -->
            <section class="space-y-5">
                <div>
                    <h2 class="text-lg font-medium text-text-primary border-b border-border pb-2">{strings.sellerSettingsShippingSection}</h2>
                    <p class="mt-1.5 text-xs text-text-tertiary">{strings.sellerSettingsShippingSubtitle}</p>
                </div>

                <div class="grid gap-6 sm:grid-cols-2 max-w-2xl">
                    <div>
                        <label for="default-weight" class="block text-sm font-medium text-text-secondary mb-2">
                            {strings.sellerSettingsDefaultWeightLabel}
                        </label>
                        <input
                            type="number"
                            id="default-weight"
                            step="0.001"
                            min="0"
                            value={defaults.weight_kg}
                            class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                            placeholder="0,000"
                        />
                    </div>

                    <div class="sm:col-span-2">
                        <label class="block text-sm font-medium text-text-secondary mb-2">
                            {strings.sellerSettingsDefaultDimensionsLabel}
                        </label>
                        <div class="grid gap-4 sm:grid-cols-3">
                            <div>
                                <label for="default-length" class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerSettingsDefaultLengthLabel}</label>
                                <input
                                    type="number"
                                    id="default-length"
                                    step="0.1"
                                    min="0"
                                    value={defaults.length_cm}
                                    class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                                    placeholder="0"
                                />
                            </div>
                            <div>
                                <label for="default-width" class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerSettingsDefaultWidthLabel}</label>
                                <input
                                    type="number"
                                    id="default-width"
                                    step="0.1"
                                    min="0"
                                    value={defaults.width_cm}
                                    class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                                    placeholder="0"
                                />
                            </div>
                            <div>
                                <label for="default-height" class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerSettingsDefaultHeightLabel}</label>
                                <input
                                    type="number"
                                    id="default-height"
                                    step="0.1"
                                    min="0"
                                    value={defaults.height_cm}
                                    class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                                    placeholder="0"
                                />
                            </div>
                        </div>
                    </div>

                    <div>
                        <label for="default-shipping" class="block text-sm font-medium text-text-secondary mb-2">
                            {strings.sellerSettingsDefaultShippingLabel}
                        </label>
                        <input
                            type="number"
                            id="default-shipping"
                            step="0.01"
                            min="0"
                            value={defaults.shipping_cost}
                            class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                            placeholder="0,00"
                        />
                    </div>
                </div>
            </section>

            <!-- Submit -->
            <div class="flex items-center gap-3 pt-4 border-t border-border">
                <button
                    type="button"
                    id="save-settings-btn"
                    class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-accent text-bg font-medium text-sm hover:scale-[1.02] transition-transform"
                >
                    <span data-busy-label>{strings.sellerSettingsSave}</span>
                </button>
            </div>

            <!-- Appearance -->
            <section class="space-y-5">
                <div>
                    <h2 class="text-lg font-medium text-text-primary border-b border-border pb-2">{strings.settingsAppearanceSection}</h2>
                    <p class="mt-1.5 text-xs text-text-tertiary">{strings.settingsThemeLabel}</p>
                </div>
                <ThemeSelector />
            </section>

            <!-- Account -->
            <section class="space-y-5">
                <div>
                    <h2 class="text-lg font-medium text-text-primary border-b border-border pb-2">{strings.settingsAccountSection}</h2>
                </div>
                <SignOutButton />
            </section>

            <!-- Danger Zone -->
            <section class="space-y-5">
                <div>
                    <h2 class="text-lg font-medium text-red-500 border-b border-red-200 dark:border-red-800 pb-2">{strings.sellerSettingsDeleteShop}</h2>
                </div>
                <p class="text-sm text-text-secondary">{strings.sellerSettingsDeleteShopConfirm}</p>
                <button
                    type="button"
                    id="delete-shop-btn"
                    class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-red-500 text-white font-medium text-sm hover:bg-red-600 transition-colors"
                >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    {strings.sellerSettingsDeleteShop}
                </button>
            </section>
        </div>
    </div>
</SellerLayout>

<div id="delete-dialog" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50">
    <div class="bg-surface rounded-2xl border border-border p-6 mx-4 max-w-sm w-full shadow-xl">
        <p class="text-sm text-text-primary font-medium" id="delete-dialog-text"></p>
        <div class="mt-5 flex justify-end gap-3">
            <button type="button" id="delete-cancel-btn" class="px-4 py-2 rounded-xl text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors">{strings.sellerOnboardingPrev}</button>
            <button type="button" id="delete-confirm-btn" class="px-4 py-2 rounded-xl text-sm font-medium bg-red-500 text-white hover:bg-red-600 transition-colors">{strings.sellerSettingsDeleteShop}</button>
        </div>
    </div>
</div>

<script>
    import { strings } from '../../lib/core/i18n';
    import { runSubmit } from '../../lib/ui/submit';

    function initSettingsPage() {
        const saveBtn = document.getElementById('save-settings-btn') as HTMLButtonElement;

        const weightInput = document.getElementById('default-weight') as HTMLInputElement;
        const lengthInput = document.getElementById('default-length') as HTMLInputElement;
        const widthInput = document.getElementById('default-width') as HTMLInputElement;
        const heightInput = document.getElementById('default-height') as HTMLInputElement;
        const shippingInput = document.getElementById('default-shipping') as HTMLInputElement;

        if (!saveBtn || saveBtn.dataset.bound === 'true') return;
        saveBtn.dataset.bound = 'true';

        saveBtn.addEventListener('click', async () => {
            const payload = {
                default_weight_kg: weightInput.value === '' ? null : parseFloat(weightInput.value),
                default_length_cm: lengthInput.value === '' ? null : parseFloat(lengthInput.value),
                default_width_cm: widthInput.value === '' ? null : parseFloat(widthInput.value),
                default_height_cm: heightInput.value === '' ? null : parseFloat(heightInput.value),
                default_shipping_cost: shippingInput.value === '' ? null : parseFloat(shippingInput.value),
            };

            await runSubmit({
                button: saveBtn,
                busyLabel: strings.sellerSettingsSaving,
                action: () => fetch('/api/sell/settings/shipping', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                }),
                successMsg: strings.settingsSavedToast,
                errorFallback: strings.sellerSettingsSaveError,
            });
        });

        const deleteBtn = document.getElementById('delete-shop-btn') as HTMLButtonElement;
        const dialog = document.getElementById('delete-dialog') as HTMLDivElement;
        const dialogText = document.getElementById('delete-dialog-text') as HTMLParagraphElement;
        const cancelBtn = document.getElementById('delete-cancel-btn') as HTMLButtonElement;
        const confirmBtn = document.getElementById('delete-confirm-btn') as HTMLButtonElement;

        deleteBtn?.addEventListener('click', () => {
            dialogText.textContent = strings.sellerSettingsDeleteShopConfirm;
            dialog.classList.remove('hidden');
            dialog.classList.add('flex');
        });

        cancelBtn?.addEventListener('click', () => {
            dialog.classList.add('hidden');
            dialog.classList.remove('flex');
        });

        confirmBtn?.addEventListener('click', async () => {
            const result = await runSubmit({
                button: confirmBtn,
                action: () => fetch('/api/sell/shop/delete', { method: 'DELETE' }),
                successMsg: strings.sellerSettingsDeleteShopSuccess,
                errorFallback: strings.sellerSettingsDeleteShopError,
            });
            if (result.ok) {
                setTimeout(() => { window.location.href = '/'; }, 1200);
            }
        });
    }

    document.addEventListener('astro:page-load', initSettingsPage);
    if (document.readyState !== 'loading') initSettingsPage();
    else document.addEventListener('DOMContentLoaded', initSettingsPage);
</script>
