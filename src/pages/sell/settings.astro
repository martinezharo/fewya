---
import SellerLayout from '../../layouts/SellerLayout.astro';
import ThemeSelector from '../../components/settings/ThemeSelector.astro';
import SignOutButton from '../../components/settings/SignOutButton.astro';
import ShippingEditorPanel from '../../components/seller/ShippingEditorPanel.astro';
import NotificationsToggle from '../../components/settings/NotificationsToggle.astro';
import Icon from '../../components/icons/Icon.astro';
import { strings } from '../../lib/core/i18n';
import { createSupabaseAuthClient } from '../../lib/core/auth';

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: sessionData } = await supabase.auth.getSession();
const user = sessionData?.session?.user;

if (!user) return Astro.redirect('/sell');

const { data: profile } = await supabase
    .from('profiles')
    .select('is_seller')
    .eq('id', user.id)
    .single();

if (!profile?.is_seller) return Astro.redirect('/sell');

const { data: shop } = await supabase
    .from('shops')
    .select('id, name, slug, default_weight_kg, default_length_cm, default_width_cm, default_height_cm, default_shipping_cost')
    .eq('owner_id', user.id)
    .maybeSingle();

if (!shop) return Astro.redirect('/sell/onboarding');

const defaults = {
    weight_kg: shop.default_weight_kg ?? null,
    length_cm: shop.default_length_cm ?? null,
    width_cm: shop.default_width_cm ?? null,
    height_cm: shop.default_height_cm ?? null,
    shipping_cost: shop.default_shipping_cost ?? null,
};
---

<SellerLayout title={strings.sellerSettingsPageTitle} shopSlug={shop.slug} shopId={shop.id}>
    <div class="max-w-3xl mx-auto px-4 py-8 lg:py-12">
        <div class="mb-8">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-tertiary">{shop.name}</p>
            <h1 class="mt-2 text-2xl font-semibold tracking-tight text-text-primary">{strings.sellerSettingsTitle}</h1>
        </div>

        <div class="rounded-3xl border border-border bg-surface shadow-sm divide-y divide-border">

            <!-- Envío por defecto -->
            <section class="p-6 md:p-8 space-y-6">
                <div>
                    <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary mb-1">
                        <Icon name="truck" size={15} class="text-text-tertiary" />
                        <span>{strings.sellerSettingsShippingSection}</span>
                    </div>
                    <p class="text-sm text-text-secondary pl-[23px]">{strings.sellerSettingsShippingSubtitle}</p>
                </div>

                <ShippingEditorPanel
                    idPrefix="settings"
                    weight={defaults.weight_kg}
                    length={defaults.length_cm}
                    width={defaults.width_cm}
                    height={defaults.height_cm}
                    shippingCost={defaults.shipping_cost}
                />

                <div class="flex items-center justify-end pt-2">
                    <button
                        type="button"
                        id="save-shipping-btn"
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-accent text-bg font-medium text-sm hover:bg-accent-hover active:scale-[0.98] transition-all"
                    >
                        <span data-busy-label>{strings.sellerSettingsSave}</span>
                    </button>
                </div>
            </section>

            <!-- Apariencia -->
            <section class="p-6 md:p-8 space-y-6">
                <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary">
                    <Icon name="sun" size={15} class="text-text-tertiary" />
                    <span>{strings.settingsAppearanceSection}</span>
                </div>
                <ThemeSelector />
            </section>

            <!-- Notificaciones -->
            <section class="p-6 md:p-8 space-y-6">
                <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-text-tertiary"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                    <span>{strings.notifSettingsSection}</span>
                </div>
                <NotificationsToggle />
            </section>

            <!-- Cuenta -->
            <section class="p-6 md:p-8 space-y-6">
                <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary">
                    <Icon name="user" size={15} class="text-text-tertiary" />
                    <span>{strings.settingsAccountSection}</span>
                </div>
                <SignOutButton />
            </section>

            <!-- Zona peligrosa -->
            <section class="p-6 md:p-8 space-y-4">
                <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-red-500">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                    <span>{strings.sellerSettingsDeleteShop}</span>
                </div>
                <p class="text-sm text-text-secondary">{strings.sellerSettingsDeleteShopConfirm}</p>
                <button
                    type="button"
                    id="delete-shop-btn"
                    class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-red-500 text-white font-medium text-sm hover:bg-red-600 active:scale-[0.98] transition-all"
                >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    {strings.sellerSettingsDeleteShop}
                </button>
            </section>

        </div>
    </div>
</SellerLayout>

<div id="delete-dialog" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="bg-surface rounded-2xl border border-border p-6 mx-4 max-w-sm w-full shadow-xl">
        <p class="text-sm text-text-primary font-medium" id="delete-dialog-text"></p>
        <div class="mt-5 flex justify-end gap-3">
            <button type="button" id="delete-cancel-btn" class="px-4 py-2 rounded-xl text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors">{strings.sellerOnboardingPrev}</button>
            <button type="button" id="delete-confirm-btn" class="px-4 py-2 rounded-xl text-sm font-medium bg-red-500 text-white hover:bg-red-600 transition-colors">{strings.sellerSettingsDeleteShop}</button>
        </div>
    </div>
</div>

<script>
    import { strings } from '../../lib/core/i18n';
    import { runSubmit } from '../../lib/ui/submit';
    import { initShippingEditor } from '../../lib/ui/shipping-editor';

    function initSettingsPage() {
        const panel = document.querySelector<HTMLElement>('.shipping-editor-panel');
        const saveBtn = document.getElementById('save-shipping-btn') as HTMLButtonElement | null;

        if (!panel || !saveBtn || saveBtn.dataset.bound === 'true') return;

        initShippingEditor(panel);

        saveBtn.dataset.bound = 'true';
        saveBtn.addEventListener('click', async () => {
            const weightInput = panel.querySelector<HTMLInputElement>('[data-field="weight"]');
            const lengthInput = panel.querySelector<HTMLInputElement>('[data-field="length"]');
            const widthInput = panel.querySelector<HTMLInputElement>('[data-field="width"]');
            const heightInput = panel.querySelector<HTMLInputElement>('[data-field="height"]');
            const shippingInput = panel.querySelector<HTMLInputElement>('[data-field="shipping-cost"]');

            const payload = {
                default_weight_kg: weightInput?.value === '' ? null : parseFloat(weightInput?.value ?? ''),
                default_length_cm: lengthInput?.value === '' ? null : parseFloat(lengthInput?.value ?? ''),
                default_width_cm: widthInput?.value === '' ? null : parseFloat(widthInput?.value ?? ''),
                default_height_cm: heightInput?.value === '' ? null : parseFloat(heightInput?.value ?? ''),
                default_shipping_cost: shippingInput?.value === '' ? null : parseFloat(shippingInput?.value ?? ''),
            };

            await runSubmit({
                button: saveBtn,
                busyLabel: strings.sellerSettingsSaving,
                action: () => fetch('/api/sell/settings/shipping', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                }),
                successMsg: strings.settingsSavedToast,
                errorFallback: strings.sellerSettingsSaveError,
            });
        });

        const deleteBtn = document.getElementById('delete-shop-btn') as HTMLButtonElement | null;
        const dialog = document.getElementById('delete-dialog') as HTMLDivElement | null;
        const dialogText = document.getElementById('delete-dialog-text') as HTMLParagraphElement | null;
        const cancelBtn = document.getElementById('delete-cancel-btn') as HTMLButtonElement | null;
        const confirmBtn = document.getElementById('delete-confirm-btn') as HTMLButtonElement | null;

        deleteBtn?.addEventListener('click', () => {
            if (dialogText) dialogText.textContent = strings.sellerSettingsDeleteShopConfirm;
            dialog?.classList.remove('hidden');
            dialog?.classList.add('flex');
        });

        cancelBtn?.addEventListener('click', () => {
            dialog?.classList.add('hidden');
            dialog?.classList.remove('flex');
        });

        confirmBtn?.addEventListener('click', async () => {
            if (!confirmBtn) return;
            const result = await runSubmit({
                button: confirmBtn,
                action: () => fetch('/api/sell/shop/delete', { method: 'DELETE' }),
                successMsg: strings.sellerSettingsDeleteShopSuccess,
                errorFallback: strings.sellerSettingsDeleteShopError,
            });
            if (result.ok) {
                setTimeout(() => { window.location.href = '/'; }, 1200);
            }
        });
    }

    document.addEventListener('astro:page-load', initSettingsPage);
    if (document.readyState !== 'loading') initSettingsPage();
    else document.addEventListener('DOMContentLoaded', initSettingsPage);
</script>
