---
import Layout from '../../layouts/Layout.astro';
import { createSupabaseAuthClient } from '../../lib/auth';

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: sessionData } = await supabase.auth.getSession();
const user = sessionData?.session?.user;

let isSeller = false;
let hasShop = false;

if (user) {
    const { data: profile } = await supabase
        .from('profiles')
        .select('is_seller')
        .eq('id', user.id)
        .single();
    
    isSeller = profile?.is_seller || false;

    if (isSeller) {
        const { data: shop } = await supabase
            .from('shops')
            .select('id')
            .eq('owner_id', user.id)
            .maybeSingle();
        
        hasShop = !!shop;
    }
}

if (isSeller && hasShop) {
    return Astro.redirect('/sell/dashboard');
}
---

<Layout title="Shopenn - Vender">
    <div class="max-w-4xl mx-auto px-4 py-12">
        {!user ? (
            <div class="text-center rounded-2xl bg-neutral-100 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 p-12">
                <h1 class="text-4xl font-semibold tracking-tight text-neutral-900 dark:text-white mb-4">Vende con nosotros</h1>
                <p class="text-lg text-neutral-600 dark:text-neutral-400 mb-8 max-w-xl mx-auto">
                    Abre tu tienda en minutos. Democratizamos el eCommerce para que vendas de una forma más profesional y directa.
                </p>
                <a 
                    href="/api/auth/login?role=seller&redirect_to=/sell" 
                    class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-neutral-900 text-white dark:bg-white dark:text-neutral-900 font-medium rounded-full shadow-sm hover:scale-105 transition-transform"
                >
                    <svg class="w-5 h-5" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                        <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    Iniciar sesión con Google
                </a>
            </div>
        ) : (
            <div class="text-center rounded-2xl bg-neutral-100 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 p-12">
                <h1 class="text-3xl font-semibold tracking-tight text-neutral-900 dark:text-white mb-4">¡Hola, {user.user_metadata?.full_name?.split(' ')[0] || 'Vendedor'}!</h1>
                <p class="text-lg text-neutral-600 dark:text-neutral-400 mb-8 max-w-xl mx-auto">
                    Estás a un paso de comenzar a vender. Configura tu tienda para publicar tus productos.
                </p>
                <a 
                    href="/sell/onboarding" 
                    class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-neutral-900 text-white dark:bg-white dark:text-neutral-900 font-medium rounded-full shadow-sm hover:scale-105 transition-transform"
                >
                    Configurar mi tienda
                </a>
            </div>
        )}
    </div>
</Layout>