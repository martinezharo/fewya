---
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';
import Icon from '../../components/icons/Icon.astro';
import { createSupabaseAuthClient } from '../../lib/core/auth';
import { strings } from '../../lib/core/i18n';

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: sessionData } = await supabase.auth.getSession();
const user = sessionData?.session?.user;

let isSeller = false;
let hasShop = false;

if (user) {
    const { data: profile } = await supabase
        .from('profiles')
        .select('is_seller')
        .eq('id', user.id)
        .single();

    isSeller = profile?.is_seller || false;

    if (isSeller) {
        const { data: shop } = await supabase
            .from('shops')
            .select('id')
            .eq('owner_id', user.id)
            .maybeSingle();

        hasShop = !!shop;
    }
}

if (isSeller && hasShop) {
    return Astro.redirect('/sell/shop');
}

// Contextual primary CTA: logged-in sellers without a shop go straight to
// onboarding; everyone else signs in with Google (preserves the auth flow).
const isLoggedIn = !!user;
const ctaHref = isLoggedIn
    ? '/sell/onboarding'
    : '/api/auth/login?role=seller&redirect_to=/sell';
const ctaLabel = isLoggedIn
    ? strings.sellerLandingCtaSetup
    : strings.sellerLandingCtaLogin;
const showGoogleIcon = !isLoggedIn;

const brandFeatures = [
    { icon: 'image', title: strings.sellerLandingBrandLogoTitle, body: strings.sellerLandingBrandLogoBody },
    { icon: 'store', title: strings.sellerLandingBrandBannerTitle, body: strings.sellerLandingBrandBannerBody },
    { icon: 'external-link', title: strings.sellerLandingBrandUrlTitle, body: strings.sellerLandingBrandUrlBody },
    { icon: 'sliders', title: strings.sellerLandingBrandColorTitle, body: strings.sellerLandingBrandColorBody },
    { icon: 'file-text', title: strings.sellerLandingBrandSpecsTitle, body: strings.sellerLandingBrandSpecsBody },
] as const;

const easeFeatures = [
    { icon: 'package', title: strings.sellerLandingEaseVariantsTitle, body: strings.sellerLandingEaseVariantsBody },
    { icon: 'truck', title: strings.sellerLandingEaseShippingTitle, body: strings.sellerLandingEaseShippingBody },
    { icon: 'info', title: strings.sellerLandingEaseInfoTitle, body: strings.sellerLandingEaseInfoBody },
    { icon: 'alert-circle', title: strings.sellerLandingEaseClaimsTitle, body: strings.sellerLandingEaseClaimsBody },
] as const;

const steps = [
    { title: strings.sellerLandingStep1Title, body: strings.sellerLandingStep1Body },
    { title: strings.sellerLandingStep2Title, body: strings.sellerLandingStep2Body },
    { title: strings.sellerLandingStep3Title, body: strings.sellerLandingStep3Body },
] as const;

const previewProducts = [
    { name: strings.sellerLandingPreviewProduct1, price: '€89,90', image: '/seller-landing/headphones.webp' },
    { name: strings.sellerLandingPreviewProduct2, price: '€59,90', image: '/seller-landing/earbuds.webp' },
] as const;
---

<Layout title={strings.sellerLandingMetaTitle} description={strings.sellerLandingMetaDescription}>
    <div class="min-h-dvh">
        <!-- Top bar -->
        <header class="max-w-[1100px] mx-auto px-4 md:px-10 pt-6">
            <a
                href="/"
                class="inline-flex items-center gap-1.5 text-sm text-text-secondary hover:text-text-primary transition-colors"
            >
                <Icon name="arrow-left" size={16} />
                {strings.navBackToBuyers}
            </a>
        </header>

        <!-- Hero -->
        <section class="max-w-[1100px] mx-auto px-4 md:px-10 pt-10 pb-16 md:pt-16 md:pb-24">
            <div class="grid items-center gap-10 md:grid-cols-2 md:gap-14">
                <!-- Copy + CTA -->
                <div>
                    <div class="inline-flex items-center gap-2 mb-6">
                        <span class="w-9 h-9 rounded-2xl bg-accent/10 flex items-center justify-center shrink-0">
                            <Logo class="w-5 h-5 text-accent" />
                        </span>
                        <span class="text-sm font-semibold text-text-secondary">{strings.sellerLandingBadge}</span>
                    </div>

                    <h1 class="text-4xl md:text-5xl font-bold tracking-[-0.5px] leading-[1.08] text-text-primary">
                        {strings.sellerLandingHeroTitle}
                    </h1>
                    <p class="mt-5 text-[17px] md:text-lg leading-[1.55] text-text-secondary max-w-xl">
                        {strings.sellerLandingHeroSubtitle}
                    </p>

                    <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-3.5">
                        <a
                            href={ctaHref}
                            class="inline-flex items-center justify-center gap-2.5 px-6 py-3.5 bg-text-primary text-surface rounded-full text-[15px] font-semibold transition-all duration-150 hover:opacity-90 active:scale-[0.98]"
                        >
                            {showGoogleIcon && (
                                <svg class="w-5 h-5" viewBox="0 0 24 24" aria-hidden="true">
                                    <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                                    <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                                    <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                                    <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                                </svg>
                            )}
                            {ctaLabel}
                        </a>
                        <span class="inline-flex items-center gap-2 text-sm font-medium text-text-secondary">
                            <Icon name="check" size={16} class="text-secondary" />
                            {strings.sellerLandingHeroReassurance}
                        </span>
                    </div>
                </div>

                <!-- Faux storefront preview (decorative) -->
                <div class="relative" aria-hidden="true">
                    <div class="bg-surface border border-border-light rounded-2xl shadow-sm overflow-hidden">
                        <!-- Banner -->
                        <div class="h-24 md:h-28 bg-gradient-to-br from-accent/25 to-secondary/20"></div>
                        <!-- Brand row -->
                        <div class="px-5 -mt-7">
                            <div class="flex items-end gap-3">
                                <span class="w-14 h-14 rounded-2xl bg-surface border border-border-light shadow-sm flex items-center justify-center">
                                    <Icon name="headphones" size={28} class="text-accent" />
                                </span>
                                <div class="pb-1">
                                    <p class="text-[15px] font-bold text-text-primary leading-tight">{strings.sellerLandingPreviewBrand}</p>
                                    <p class="text-xs text-text-tertiary">{strings.sellerLandingPreviewUrl}</p>
                                </div>
                                <span class="ml-auto pb-1.5 flex items-center gap-1.5">
                                    <span class="w-3 h-3 rounded-full bg-accent"></span>
                                    <span class="w-3 h-3 rounded-full bg-secondary"></span>
                                </span>
                            </div>
                        </div>
                        <!-- Product tiles -->
                        <div class="grid grid-cols-2 gap-3 p-5 pt-4">
                            {previewProducts.map((product) => (
                                <div class="bg-bg rounded-lg border border-border/60 overflow-hidden">
                                    <div class="aspect-square overflow-hidden">
                                        <img
                                            src={product.image}
                                            alt={product.name}
                                            loading="lazy"
                                            class="w-full h-full object-cover"
                                        />
                                    </div>
                                    <div class="p-2.5">
                                        <p class="text-xs font-medium text-text-primary truncate">{product.name}</p>
                                        <div class="mt-1 flex items-center justify-between">
                                            <span class="text-[13px] font-bold text-text-primary">{product.price}</span>
                                            <span class="inline-flex items-center gap-1 text-[10px] font-semibold text-secondary">
                                                <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
                                                {strings.sellerLandingPreviewInStock}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Keep 100% -->
        <section class="max-w-[1100px] mx-auto px-4 md:px-10 pb-16 md:pb-24">
            <div class="rounded-2xl bg-surface border border-border-light shadow-sm px-6 py-10 md:px-12 md:py-14">
                <div class="grid items-center gap-8 md:grid-cols-[auto_1fr] md:gap-12">
                    <div class="flex items-baseline gap-2">
                        <span class="text-7xl md:text-8xl font-bold tracking-[-2px] text-secondary leading-none">{strings.sellerLandingMoneyAmount}</span>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-secondary uppercase tracking-wide mb-2">{strings.sellerLandingMoneyKicker}</p>
                        <h2 class="text-2xl md:text-3xl font-bold tracking-[-0.4px] text-text-primary">{strings.sellerLandingMoneyTitle}</h2>
                        <p class="mt-3 text-[16px] leading-[1.6] text-text-secondary max-w-2xl">{strings.sellerLandingMoneyBody}</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Your brand -->
        <section class="max-w-[1100px] mx-auto px-4 md:px-10 pb-16 md:pb-24">
            <div class="max-w-2xl mb-10">
                <p class="text-sm font-semibold text-accent uppercase tracking-wide mb-2">{strings.sellerLandingBrandKicker}</p>
                <h2 class="text-2xl md:text-4xl font-bold tracking-[-0.5px] leading-[1.12] text-text-primary">{strings.sellerLandingBrandTitle}</h2>
                <p class="mt-4 text-[16px] md:text-[17px] leading-[1.6] text-text-secondary">{strings.sellerLandingBrandBody}</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {brandFeatures.map((f) => (
                    <div class="bg-surface border border-border-light rounded-2xl p-6 shadow-sm transition-shadow duration-300 hover:shadow-[0_8px_32px_rgba(0,0,0,0.06)] dark:hover:shadow-[0_8px_32px_rgba(0,0,0,0.3)]">
                        <span class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center text-accent mb-4">
                            <Icon name={f.icon} size={22} />
                        </span>
                        <h3 class="text-[16px] font-semibold text-text-primary">{f.title}</h3>
                        <p class="mt-1.5 text-sm leading-[1.55] text-text-secondary">{f.body}</p>
                    </div>
                ))}
            </div>
        </section>

        <!-- Selling without hassle -->
        <section class="max-w-[1100px] mx-auto px-4 md:px-10 pb-16 md:pb-24">
            <div class="max-w-2xl mb-10">
                <p class="text-sm font-semibold text-accent uppercase tracking-wide mb-2">{strings.sellerLandingEaseKicker}</p>
                <h2 class="text-2xl md:text-4xl font-bold tracking-[-0.5px] leading-[1.12] text-text-primary">{strings.sellerLandingEaseTitle}</h2>
                <p class="mt-4 text-[16px] md:text-[17px] leading-[1.6] text-text-secondary">{strings.sellerLandingEaseBody}</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
                {easeFeatures.map((f) => (
                    <div class="flex gap-4 bg-surface border border-border-light rounded-2xl p-6 shadow-sm">
                        <span class="w-12 h-12 shrink-0 rounded-full bg-border-light/60 flex items-center justify-center text-text-primary">
                            <Icon name={f.icon} size={22} />
                        </span>
                        <div>
                            <h3 class="text-[16px] font-semibold text-text-primary">{f.title}</h3>
                            <p class="mt-1.5 text-sm leading-[1.55] text-text-secondary">{f.body}</p>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- How it works -->
        <section class="max-w-[1100px] mx-auto px-4 md:px-10 pb-16 md:pb-24">
            <div class="max-w-2xl mb-10">
                <p class="text-sm font-semibold text-accent uppercase tracking-wide mb-2">{strings.sellerLandingStepsKicker}</p>
                <h2 class="text-2xl md:text-4xl font-bold tracking-[-0.5px] leading-[1.12] text-text-primary">{strings.sellerLandingStepsTitle}</h2>
            </div>
            <div class="grid gap-4 md:grid-cols-3">
                {steps.map((s, i) => (
                    <div class="bg-surface border border-border-light rounded-2xl p-6 shadow-sm">
                        <span class="w-10 h-10 rounded-full bg-accent text-bg flex items-center justify-center text-[15px] font-bold mb-4">{i + 1}</span>
                        <h3 class="text-[16px] font-semibold text-text-primary">{s.title}</h3>
                        <p class="mt-1.5 text-sm leading-[1.55] text-text-secondary">{s.body}</p>
                    </div>
                ))}
            </div>
        </section>

        <!-- Final CTA -->
        <section class="max-w-[1100px] mx-auto px-4 md:px-10 pb-20 md:pb-28">
            <div class="rounded-2xl bg-gradient-to-br from-accent/10 to-secondary/10 border border-border-light px-6 py-12 md:px-12 md:py-16 text-center">
                <h2 class="text-2xl md:text-4xl font-bold tracking-[-0.5px] text-text-primary">{strings.sellerLandingFinalTitle}</h2>
                <p class="mt-3 text-[16px] md:text-[17px] leading-[1.6] text-text-secondary max-w-xl mx-auto">{strings.sellerLandingFinalBody}</p>
                <div class="mt-8 flex flex-col items-center gap-3">
                    <a
                        href={ctaHref}
                        class="inline-flex items-center justify-center gap-2.5 px-7 py-3.5 bg-text-primary text-surface rounded-full text-[15px] font-semibold transition-all duration-150 hover:opacity-90 active:scale-[0.98]"
                    >
                        {showGoogleIcon && (
                            <svg class="w-5 h-5" viewBox="0 0 24 24" aria-hidden="true">
                                <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                                <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                                <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                                <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                            </svg>
                        )}
                        {ctaLabel}
                    </a>
                    <span class="inline-flex items-center gap-2 text-sm font-medium text-text-secondary">
                        <Icon name="check" size={16} class="text-secondary" />
                        {strings.sellerLandingHeroReassurance}
                    </span>
                </div>
            </div>
        </section>
    </div>
</Layout>
