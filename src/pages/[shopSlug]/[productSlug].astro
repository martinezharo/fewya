---
import BuyerDetailLayout from '../../layouts/BuyerDetailLayout.astro';
import Icon from '../../components/icons/Icon.astro';
import WishlistButton from '../../components/WishlistButton.astro';
import ProductGallery from '../../components/product/ProductGallery.astro';
import ShopCard from '../../components/product/ShopCard.astro';
import VariantSelector from '../../components/product/VariantSelector.astro';
import ProductSpecs from '../../components/product/ProductSpecs.astro';
import ProductReviews from '../../components/product/ProductReviews.astro';
import ShopContact from '../../components/product/ShopContact.astro';
import ReportButton from '../../components/product/ReportButton.astro';
import { supabase } from '../../lib/supabase';
import { createSupabaseAuthClient } from '../../lib/auth';
import { isProductComplete } from '../../lib/productValidation';
import { strings } from '../../lib/i18n';
import type { Product, Review, Shop } from '../../lib/types';

const { shopSlug, productSlug } = Astro.params;

const { data: shop } = await supabase
  .from('shops')
  .select('*')
  .eq('slug', shopSlug!)
  .eq('is_active', true)
  .single();

if (!shop) return Astro.redirect('/');

const { data: productData } = await supabase
  .from('products')
  .select('*, variants:product_variants(*)')
  .eq('slug', productSlug!)
  .eq('shop_id', shop.id)
  .eq('is_active', true)
  .single();

if (!productData) return Astro.redirect('/');

const product = { ...productData, shop: shop as Shop } as Product;

if (!isProductComplete(product)) return Astro.redirect('/');

const { data: reviewsData } = await supabase
  .from('reviews')
  .select('*, profile:public_profiles(full_name, avatar_url)')
  .eq('product_id', product.id)
  .order('created_at', { ascending: false });

const reviews = (reviewsData ?? []) as Review[];
const images = product.gallery_images?.length > 0 ? product.gallery_images : ['/placeholder.svg'];

// Sort variants: default first
const sortedVariants = [...(product.variants ?? [])].sort((a, b) =>
  (b.is_default ? 1 : 0) - (a.is_default ? 1 : 0)
);
const activeVariant = sortedVariants[0];
const price = activeVariant?.price ?? 0;
const shippingCost = activeVariant?.shipping_cost ?? 0;
const shippingDisplay = shippingCost === 0 ? 'Envío gratis' : `+${shippingCost.toFixed(2).replace('.', ',')}€ envío`;
const hasVariants = sortedVariants.length > 1;
const activeVariantStock = activeVariant?.stock ?? 0;

// Check wishlist status
const authClient = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: { user } } = await authClient.auth.getUser();
let isWished = false;
if (user) {
  const { data: wishEntry } = await authClient
    .from('wishlist')
    .select('id')
    .eq('profile_id', user.id)
    .eq('product_id', product.id)
    .maybeSingle();
  isWished = !!wishEntry;
}
---

<BuyerDetailLayout title={`${product.title} — ${shop.name}`}>
  <main>
    <!-- Two-column grid on desktop, stacked on mobile -->
    <div class="md:max-w-[1200px] md:mx-auto md:px-10 md:py-8 md:grid md:grid-cols-[1fr_420px] md:gap-12">
      <!-- Gallery -->
      <div class="md:sticky md:top-24 md:self-start">
        <ProductGallery images={images} title={product.title} />
      </div>

      <!-- Product info -->
      <div class="px-4 md:px-0 flex flex-col gap-5 mt-4 md:mt-0">
        <!-- Price row (mobile: 1st, desktop: 2nd) -->
        <div class="flex items-center justify-between order-1 md:order-2">
          <div class="flex items-baseline gap-2">
            <span class="text-xl md:text-2xl font-bold text-text-primary" data-product-price>
              {price.toFixed(2)}{strings.currency}
            </span>
            <span class="text-xs md:text-sm text-text-secondary" data-product-shipping>{shippingDisplay}</span>
          </div>
          <WishlistButton productId={product.id} isWished={isWished} variant="detail" size={22} />
        </div>

        <!-- Title (mobile: 2nd, desktop: 1st) -->
        <h1 class="text-lg md:text-2xl font-semibold md:font-bold text-text-primary leading-tight order-2 md:order-1">
          {product.title}
        </h1>

        <!-- Shop card -->
        <div class="order-3">
          <ShopCard shop={shop as Shop} />
        </div>

        <!-- Stock and Variants -->
        <div class="order-4 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            {hasVariants && (
              <h3 class="text-sm font-semibold text-text-primary">{strings.productVariantsTitle}</h3>
            )}
            <span class={`text-[13px] font-medium ${(activeVariant?.stock ?? 0) > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-500 dark:text-red-400'} ${!hasVariants ? 'ml-auto' : ''}`} data-variant-stock-global>
              {(activeVariant?.stock ?? 0) > 0 ? strings.productInStock : strings.productOutOfStock}
            </span>
          </div>
          <div data-stock-warning-wrapper>
            {activeVariantStock > 0 && activeVariantStock <= 5 && (
              <p class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-amber-100 text-amber-800 border border-amber-200 dark:bg-amber-900/40 dark:text-amber-300 dark:border-amber-800 font-semibold text-xs self-start" data-stock-warning>
                <Icon name="alert-triangle" size={14} />
                <span data-stock-warning-text>{strings.productStockWarning.replace(/\{stock\}/, String(activeVariantStock))}</span>
              </p>
            )}
          </div>

          {hasVariants && (
            <VariantSelector variants={sortedVariants} defaultImage={images[0]} />
          )}
        </div>

        <!-- Add to cart -->
        <div class="flex gap-3 order-5">
          <div class="flex items-center border border-border-light rounded-lg overflow-hidden" data-qty-selector>
            <button
              type="button"
              class="w-10 h-11 flex items-center justify-center text-text-secondary hover:text-text-primary transition-colors"
              data-qty-minus
              aria-label={strings.productQtyDecrease}
            >
              <Icon name="minus" size={18} />
            </button>
            <span class="w-10 text-center text-sm font-medium text-text-primary select-none" data-qty-value>1</span>
            <button
              type="button"
              class="w-10 h-11 flex items-center justify-center text-text-secondary hover:text-text-primary transition-colors"
              data-qty-plus
              aria-label={strings.productQtyIncrease}
            >
              <Icon name="plus" size={18} />
            </button>
          </div>
          <button
            type="button"
            class="flex-1 bg-accent text-bg font-semibold text-sm py-3 rounded-lg transition-colors hover:bg-accent-hover active:scale-[0.98]"
            data-add-to-cart
            data-cart-product-id={product.id}
            data-cart-variant-id={activeVariant?.id ?? ''}
            data-cart-title={product.title}
            data-cart-image={images[0]}
            data-cart-price={String(price)}
            data-cart-stock={String(activeVariant?.stock ?? 0)}
            data-cart-variant-name={activeVariant?.variant_name ?? ''}
            data-cart-shipping={String(activeVariant?.shipping_cost ?? 0)}
            data-cart-shop-id={shop.id}
            data-cart-shop-name={shop.name}
            data-cart-shop-slug={shop.slug}
            data-cart-product-slug={product.slug}
          >
            {strings.productAddToCart}
          </button>
        </div>

        <!-- Specs -->
        <div class="order-6">
          <ProductSpecs
            category={product.category}
            brand={product.brand}
            specifications={product.specifications ?? {}}
          />
        </div>
      </div>
    </div>

    <!-- Full-width sections below the grid -->
    <div class="px-4 md:px-10 md:max-w-[1200px] md:mx-auto mt-8 md:mt-12 space-y-8 pb-24 md:pb-16">
      <!-- Description -->
      {product.description && (
        <div>
          <h3 class="text-base md:text-lg font-semibold text-text-primary mb-2 md:mb-3">
            {strings.productDescription}
          </h3>
          <p class="text-sm md:text-[15px] text-text-secondary leading-relaxed whitespace-pre-line md:max-w-[720px]">
            {product.description}
          </p>
        </div>
      )}



      <!-- Reviews -->
      <div class="md:max-w-[720px]">
        <ProductReviews reviews={reviews} />
      </div>

      <!-- Report -->
      <div class="md:max-w-[240px]">
        <ReportButton />
      </div>
    </div>
  </main>

  <ShopContact slot="floating" email={shop.contact_email} whatsapp={shop.whatsapp} />
</BuyerDetailLayout>

<script>
  import { strings } from '../../lib/i18n';

  document.querySelectorAll('[data-qty-selector]').forEach(selector => {
    const minus = selector.querySelector('[data-qty-minus]');
    const plus = selector.querySelector('[data-qty-plus]');
    const value = selector.querySelector('[data-qty-value]');
    const addBtn = document.querySelector<HTMLButtonElement>('[data-add-to-cart]');
    const stock = parseInt(addBtn?.dataset.cartStock ?? '0', 10);
    let qty = Math.min(1, stock);

    const updateUI = () => {
      if (value) value.textContent = String(qty);
      if (addBtn) addBtn.dataset.cartQty = String(qty);
      if (plus) (plus as HTMLButtonElement).disabled = qty >= stock || stock <= 0;
      if (minus) (minus as HTMLButtonElement).disabled = qty <= 1 || stock <= 0;
      if (addBtn) {
        addBtn.disabled = stock <= 0 || qty < 1;
      }
    };

    plus?.addEventListener('click', () => {
      if (qty < stock) {
        qty++;
        updateUI();
      }
    });

    minus?.addEventListener('click', () => {
      if (qty > 1) {
        qty--;
        updateUI();
      }
    });

    updateUI();
  });

  // Update add-to-cart data when variant changes
  document.addEventListener('variant:change', () => {});
  document.querySelectorAll<HTMLElement>('[data-variant-btn]').forEach(btn => {
    btn.addEventListener('click', () => {
      const addBtn = document.querySelector<HTMLButtonElement>('[data-add-to-cart]');
      if (!addBtn) return;
      const price = btn.dataset.variantPrice ?? '0';
      const stock = parseInt(btn.dataset.variantStock ?? '0', 10);
      const variantImage = btn.dataset.variantImage ?? '';
      const variantShipping = parseFloat(btn.dataset.variantShipping ?? '0') || 0;

      if (btn.dataset.variantId) {
        addBtn.dataset.cartVariantId = btn.dataset.variantId;
      }
      addBtn.dataset.cartPrice = price;
      addBtn.dataset.cartStock = String(stock);
      addBtn.dataset.cartShipping = String(variantShipping);
      if (variantImage) addBtn.dataset.cartImage = variantImage;
      if (btn.querySelector('[data-variant-name]')) {
        addBtn.dataset.cartVariantName = btn.querySelector('[data-variant-name]')?.textContent?.trim() ?? '';
      }

      // Update shipping display
      const shippingEl = document.querySelector('[data-product-shipping]');
      if (shippingEl) {
        const display = variantShipping === 0 ? 'Envío gratis' : `+${variantShipping.toFixed(2).replace('.', ',')}€ envío`;
        shippingEl.textContent = display;
      }

      // Update stock warning badge
      const stockWarningWrapper = document.querySelector<HTMLElement>('[data-stock-warning-wrapper]');
      let stockWarning = document.querySelector<HTMLElement>('[data-stock-warning]');
      if (stock > 0 && stock <= 5) {
        if (!stockWarning && stockWarningWrapper) {
          stockWarningWrapper.innerHTML = `<p class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-amber-100 text-amber-800 border border-amber-200 dark:bg-amber-900/40 dark:text-amber-300 dark:border-amber-800 font-semibold text-xs self-start" data-stock-warning><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg><span data-stock-warning-text></span></p>`;
          stockWarning = stockWarningWrapper.querySelector<HTMLElement>('[data-stock-warning]');
        }
        const stockWarningText = stockWarning?.querySelector<HTMLElement>('[data-stock-warning-text]');
        if (stockWarningText) {
          stockWarningText.textContent = strings.productStockWarning.replace(/\{stock\}/, String(stock));
        }
      } else if (stockWarningWrapper) {
        stockWarningWrapper.innerHTML = '';
      }

      // Cap qty selector to new stock
      const qtySelector = document.querySelector('[data-qty-selector]');
      const minus = qtySelector?.querySelector('[data-qty-minus]');
      const plus = qtySelector?.querySelector('[data-qty-plus]');
      const value = qtySelector?.querySelector('[data-qty-value]');
      let qty = Math.min(parseInt(value?.textContent ?? '1', 10), stock);
      qty = Math.max(1, qty);

      if (value) value.textContent = String(qty);
      if (addBtn) addBtn.dataset.cartQty = String(qty);
      if (plus) (plus as HTMLButtonElement).disabled = qty >= stock || stock <= 0;
      if (minus) (minus as HTMLButtonElement).disabled = qty <= 1 || stock <= 0;
      if (addBtn) addBtn.disabled = stock <= 0 || qty < 1;
    });
  });
</script>
