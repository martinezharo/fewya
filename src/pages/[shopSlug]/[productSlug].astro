---
import BuyerDetailLayout from '../../layouts/BuyerDetailLayout.astro';
import Icon from '../../components/icons/Icon.astro';
import WishlistButton from '../../components/WishlistButton.astro';
import ProductGallery from '../../components/product/ProductGallery.astro';
import ShopCard from '../../components/product/ShopCard.astro';
import VariantSelector from '../../components/product/VariantSelector.astro';
import ProductSpecs from '../../components/product/ProductSpecs.astro';
import ProductReviews from '../../components/product/ProductReviews.astro';
import ShopContact from '../../components/product/ShopContact.astro';
import ReportButton from '../../components/product/ReportButton.astro';
import { supabase } from '../../lib/core/supabase';
import { createSupabaseAuthClient } from '../../lib/core/auth';
import { isProductComplete } from '../../lib/products/productValidation';
import { strings } from '../../lib/core/i18n';
import { getMergedWishlistIds } from '../../lib/wishlist/wishlist';
import type { Product, Review, Shop } from '../../lib/core/types';

const { shopSlug, productSlug } = Astro.params;

const authClient = createSupabaseAuthClient(Astro.cookies, Astro.request);

// Ola 1: shop and user in parallel (independent)
const [shopResult, userResult] = await Promise.all([
  supabase
    .from('shops')
    .select('*')
    .eq('slug', shopSlug!)
    .eq('is_active', true)
    .single(),
  authClient.auth.getUser(),
]);

const shop = shopResult.data;
if (!shop) return Astro.redirect('/');

// Ola 2: product (needs shop.id)
const { data: productData } = await supabase
  .from('products')
  .select('*, variants:product_variants(*)')
  .eq('slug', productSlug!)
  .eq('shop_id', shop.id)
  .eq('is_active', true)
  .single();

if (!productData) return Astro.redirect('/');

const product = { ...productData, shop: shop as Shop } as Product;

if (!isProductComplete(product)) return Astro.redirect('/');

// Ola 3: reviews and wishlist in parallel (both depend on product.id / user)
const userId = userResult.data.user?.id ?? null;
const [reviewsResult, mergedWishlist] = await Promise.all([
  supabase
    .from('reviews')
    .select('id, rating, comment, seller_reply, seller_reply_at, created_at, profile_id, product_id, is_auto, profile:public_profiles(full_name, avatar_url)')
    .eq('product_id', product.id)
    .order('created_at', { ascending: false }),
  getMergedWishlistIds(authClient, Astro.cookies, userId),
]);

const reviews = (reviewsResult.data ?? []) as Review[];
const isWished = mergedWishlist.has(product.id);
const images = product.gallery_images?.length > 0 ? product.gallery_images : ['/placeholder.svg'];

// Sort variants: default first
const sortedVariants = [...(product.variants ?? [])].sort((a, b) =>
  (b.is_default ? 1 : 0) - (a.is_default ? 1 : 0)
);
const activeVariant = sortedVariants[0];
const price = activeVariant?.price ?? 0;
const shippingCost = activeVariant?.shipping_cost ?? 0;
const shippingDisplay = shippingCost === 0 ? strings.freeShipping : `+${shippingCost.toFixed(2).replace('.', ',')}€ envío`;
const hasVariants = sortedVariants.length > 1;
const activeVariantStock = activeVariant?.stock ?? 0;

const productUrl = new URL(Astro.url.pathname, Astro.site ?? `${Astro.url.protocol}//${Astro.url.host}`).toString();
const productImage = images[0] && !images[0].startsWith('/') ? images[0] : new URL(images[0] ?? '/placeholder.svg', productUrl).toString();
const reviewCount = reviews.length;
const ratingSum = reviews.reduce((acc, r) => acc + (r.rating ?? 0), 0);
const avgRating = reviewCount > 0 ? +(ratingSum / reviewCount).toFixed(2) : null;

const productJsonLd = {
  '@context': 'https://schema.org/',
  '@type': 'Product',
  name: product.title,
  description: product.description ?? undefined,
  image: productImage,
  sku: activeVariant?.id,
  brand: product.brand ? { '@type': 'Brand', name: product.brand } : undefined,
  url: productUrl,
  offers: {
    '@type': 'Offer',
    url: productUrl,
    priceCurrency: 'EUR',
    price: price.toFixed(2),
    availability: activeVariantStock > 0 ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
    seller: { '@type': 'Organization', name: shop.name },
  },
  aggregateRating: avgRating != null && reviewCount > 0 ? {
    '@type': 'AggregateRating',
    ratingValue: avgRating,
    reviewCount,
  } : undefined,
};
---

<BuyerDetailLayout
  title={`${product.title} — ${shop.name}`}
  description={product.description ?? undefined}
  image={productImage}
  ogType="product"
>
  <script
    is:inline
    slot="structured-data"
    type="application/ld+json"
    set:html={JSON.stringify(productJsonLd)}
  />
  <main>
    <!-- Two-column grid on desktop, stacked on mobile -->
    <div class="md:max-w-[1200px] md:mx-auto md:px-10 md:py-8 md:grid md:grid-cols-[1fr_420px] md:gap-12">
      <!-- Gallery -->
      <div class="md:sticky md:top-24 md:self-start">
        <ProductGallery images={images} title={product.title} />
      </div>

      <!-- Product info -->
      <div class="px-4 md:px-0 flex flex-col gap-5 mt-4 md:mt-0">
        <!-- Price row (mobile: 1st, desktop: 2nd) -->
        <div class="flex items-center justify-between order-1 md:order-2">
          <div class="flex items-baseline gap-2">
            <span class="text-xl md:text-2xl font-bold text-text-primary" data-product-price>
              {price.toFixed(2)}{strings.currency}
            </span>
            <span class="text-xs md:text-sm text-text-secondary" data-product-shipping>{shippingDisplay}</span>
          </div>
          <WishlistButton productId={product.id} isWished={isWished} variant="detail" size={22} />
        </div>

        <!-- Title (mobile: 2nd, desktop: 1st) -->
        <h1 class="text-lg md:text-2xl font-semibold md:font-bold text-text-primary leading-tight order-2 md:order-1">
          {product.title}
        </h1>

        <!-- Shop card -->
        <div class="order-3">
          <ShopCard shop={shop as Shop} />
        </div>

        <!-- Stock and Variants -->
        <div class="order-4 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            {hasVariants && (
              <h3 class="text-sm font-semibold text-text-primary">{strings.productVariantsTitle}</h3>
            )}
            <span class={`text-[13px] font-medium ${(activeVariant?.stock ?? 0) > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-500 dark:text-red-400'} ${!hasVariants ? 'ml-auto' : ''}`} data-variant-stock-global>
              {(activeVariant?.stock ?? 0) > 0 ? strings.productInStock : strings.productOutOfStock}
            </span>
          </div>
          <div data-stock-warning-wrapper>
            {activeVariantStock > 0 && activeVariantStock <= 5 && (
              <p class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-amber-100 text-amber-800 border border-amber-200 dark:bg-amber-900/40 dark:text-amber-300 dark:border-amber-800 font-semibold text-xs self-start" data-stock-warning>
                <Icon name="alert-triangle" size={14} />
                <span data-stock-warning-text>{strings.productStockWarning.replace(/\{stock\}/, String(activeVariantStock))}</span>
              </p>
            )}
          </div>

          {hasVariants && (
            <VariantSelector variants={sortedVariants} defaultImage={images[0]} />
          )}
        </div>

        <!-- Add to cart -->
        <div class="flex gap-3 order-5">
          <div class="flex items-center border border-border-light rounded-lg overflow-hidden" data-qty-selector>
            <button
              type="button"
              class="w-10 h-11 flex items-center justify-center text-text-secondary hover:text-text-primary transition-colors"
              data-qty-minus
              aria-label={strings.productQtyDecrease}
            >
              <Icon name="minus" size={18} />
            </button>
            <span class="w-10 text-center text-sm font-medium text-text-primary select-none" data-qty-value>1</span>
            <button
              type="button"
              class="w-10 h-11 flex items-center justify-center text-text-secondary hover:text-text-primary transition-colors"
              data-qty-plus
              aria-label={strings.productQtyIncrease}
            >
              <Icon name="plus" size={18} />
            </button>
          </div>
          <button
            type="button"
            class="flex-1 bg-accent text-bg font-semibold text-sm py-3 rounded-lg transition-colors hover:bg-accent-hover active:scale-[0.98]"
            data-add-to-cart
            data-cart-product-id={product.id}
            data-cart-variant-id={activeVariant?.id ?? ''}
            data-cart-title={product.title}
            data-cart-image={images[0]}
            data-cart-price={String(price)}
            data-cart-stock={String(activeVariant?.stock ?? 0)}
            data-cart-variant-name={activeVariant?.variant_name ?? ''}
            data-cart-shipping={String(activeVariant?.shipping_cost ?? 0)}
            data-cart-shop-id={shop.id}
            data-cart-shop-name={shop.name}
            data-cart-shop-slug={shop.slug}
            data-cart-product-slug={product.slug}
          >
            {strings.productAddToCart}
          </button>
        </div>

        <!-- Specs -->
        <div class="order-6">
          <ProductSpecs
            category={product.category}
            brand={product.brand}
            specifications={product.specifications ?? {}}
          />
        </div>
      </div>
    </div>

    <!-- Full-width sections below the grid -->
    <div class="px-4 md:px-10 md:max-w-[1200px] md:mx-auto mt-8 md:mt-12 space-y-8 pb-24 md:pb-16">
      <!-- Description -->
      {product.description && (
        <div>
          <h3 class="text-base md:text-lg font-semibold text-text-primary mb-2 md:mb-3">
            {strings.productDescription}
          </h3>
          <p class="text-sm md:text-[15px] text-text-secondary leading-relaxed whitespace-pre-line md:max-w-[720px]">
            {product.description}
          </p>
        </div>
      )}

      <!-- Reviews -->
      <div class="md:max-w-[720px]">
        <ProductReviews reviews={reviews} shopName={shop.name} />
      </div>

      <!-- Report -->
      <div class="md:max-w-[240px]">
        <ReportButton />
      </div>
    </div>
  </main>

  <ShopContact slot="floating" email={shop.contact_email} whatsapp={shop.whatsapp} />
</BuyerDetailLayout>

<script>
  import { mountProductPage } from '../../lib/ui/product-page';
  mountProductPage();
</script>
