---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import HeroBanner from "../components/HeroBanner.astro";
import ProductGrid from "../components/ProductGrid.astro";
import BottomNav from "../components/BottomNav.astro";
import { supabase } from "../lib/supabase";
import { createSupabaseAuthClient } from "../lib/auth";
import { enrichProductsWithRatings } from "../lib/productUtils";
import type { Product } from "../lib/types";

const { data, error } = await supabase
	.from("products")
	.select("*, shop:shops(*), variants:product_variants(*)")
	.eq("is_active", true)
	.order("created_at", { ascending: false });

const products: Product[] = data ?? [];
await enrichProductsWithRatings(products, supabase);

const authClient = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: { user } } = await authClient.auth.getUser();
const isLoggedIn = !!user;

let wishedProductIds = new Set<string>();
if (user) {
	const { data: wishData } = await authClient
		.from('wishlist')
		.select('product_id')
		.eq('profile_id', user.id);
	wishedProductIds = new Set((wishData ?? []).map((w: any) => w.product_id));
}

---

<Layout>
	<Header />
	<main>
		<HeroBanner isLoggedIn={isLoggedIn} />
		<ProductGrid products={products} wishedProductIds={wishedProductIds} />
	</main>
	<BottomNav />
</Layout>
