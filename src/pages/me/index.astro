---
import BuyerAppLayout from "../../layouts/BuyerAppLayout.astro";
import Icon from "../../components/icons/Icon.astro";
import { strings } from "../../lib/core/i18n";
import { createSupabaseAuthClient } from "../../lib/core/auth";
import { orderStatusLabels } from "../../lib/orders/orderStatus";
import { isProfileComplete } from "../../lib/core/validation";

interface PurchaseGroup {
    orderId: string;
    shopId: string;
    shopName: string;
    date: Date;
    status: string;
    items: { imageUrl: string; productName: string }[];
}

// Auth Server-Side Verification:
const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: { user } } = await supabase.auth.getUser();

// If unauthorized, redirect to login
if (!user) {
    return Astro.redirect('/login?redirect_to=/me');
}

// Fetch profile for completeness check
const { data: profile } = await supabase
    .from('profiles')
    .select('first_name, last_name, phone, address_street, address_number, address_postal_code, address_city, address_province, address_country')
    .eq('id', user.id)
    .single();

const profileCheck = isProfileComplete(profile ?? {});
const profileIncomplete = !profileCheck.complete;

// Fetch real orders data
const { data: ordersData } = await supabase
    .from('orders')
    .select(`
        id,
        created_at,
        status,
        order_items (
            quantity,
            product_variants (
                variant_image,
                products (
                    title,
                    gallery_images,
                    shops (
                        id,
                        name
                    )
                )
            )
        )
    `)
    .eq('buyer_id', user.id)
    .order('created_at', { ascending: false });

const statusColorMap: Record<string, string> = {
    pending: "bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400",
    paid: "bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400",
    processing: "bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400",
    shipped: "bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-400",
    delivered: "bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400",
    confirmed: "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400",
    incident: "bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400",
    cancelled: "bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400",
};

// Group order items by shop and handle quantity
const purchaseGroups: PurchaseGroup[] = [];
if (ordersData) {
    for (const order of ordersData) {
        const itemsByShop = new Map<string, PurchaseGroup>();
        
        for (const item of order.order_items || []) {
            const rawVariant = item.product_variants as any;
            const variant = (Array.isArray(rawVariant) ? rawVariant[0] : rawVariant) as any;
            if (!variant) continue;
            const rawProduct = variant.products as any;
            const product = (Array.isArray(rawProduct) ? rawProduct[0] : rawProduct) as any;
            if (!product) continue;
            
            const shop = Array.isArray(product.shops) ? product.shops[0] : (product.shops || {id:'unknown', name: strings.fallbackShopName});
            if (!shop) continue;

            const imageUrl = variant.variant_image 
                                ? variant.variant_image 
                                : (product.gallery_images?.[0] || '');
            const productName = product.title || strings.fallbackProductName;
            const quantity = item.quantity || 1;

            if (!itemsByShop.has(shop.id)) {
                itemsByShop.set(shop.id, {
                    orderId: order.id,
                    shopId: shop.id,
                    shopName: shop.name,
                    date: new Date(order.created_at),
                    status: order.status,
                    items: []
                });
            }
            
            // Add item 'quantity' times to represent actual count of products bought
            for (let i = 0; i < quantity; i++) {
                itemsByShop.get(shop.id)!.items.push({ imageUrl, productName });
            }
        }
        
        purchaseGroups.push(...Array.from(itemsByShop.values()));
    }
}

// Ensure maximum 5 purchases are displayed
const recentPurchases = purchaseGroups.slice(0, 5);
---

<BuyerAppLayout title={strings.mePageTitle}>
    <main class="w-full max-w-[1400px] mx-auto px-4 md:px-10 pt-6 pb-24 md:pb-16 min-h-[50vh]">
        <h1 class="text-xl md:text-2xl font-bold text-text-primary mb-8">
            {strings.mePageTitle}
        </h1>

        <div class="flex flex-col md:grid md:grid-cols-12 gap-8 md:gap-12 max-w-5xl">
            
            {/* Sección de Compras (Izquierda en Desktop / Top en Móvil) */}
            <section class="col-span-12 md:col-span-7 lg:col-span-8">
                <header class="flex items-center justify-between mb-4">
                    <h2 class="text-[17px] font-semibold text-text-primary">
                        {strings.meLastPurchases}
                    </h2>
                </header>

                {/* Slider horizontal de compras */}
                <div id="purchases-slider" class="w-[100vw] -ml-4 md:w-full md:ml-0 overflow-x-auto scrollbar-hide snap-x snap-mandatory cursor-grab active:cursor-grabbing select-none">
                    <div class="flex gap-4 px-4 md:px-0 min-w-max pb-4">
                        {recentPurchases.map(purchase => {
                            const statusColor = statusColorMap[purchase.status?.toLowerCase() ?? "pending"] ?? statusColorMap.pending;
                            return (
                            <article class="flex-shrink-0 w-32 md:w-40 flex flex-col snap-start">
                                <div class="relative aspect-square w-full rounded-2xl overflow-hidden bg-surface border border-border-light shadow-sm mb-3">
                                    {purchase.items.length === 1 ? (
                                        <img 
                                            src={purchase.items[0].imageUrl} 
                                            alt={purchase.items[0].productName} 
                                            class="w-full h-full object-cover transition-transform duration-300 hover:scale-105 pointer-events-none"
                                            draggable="false"
                                        />
                                    ) : (
                                        <>
                                            <img 
                                                src={purchase.items[0].imageUrl} 
                                                alt={purchase.items[0].productName} 
                                                class="w-full h-full object-cover brightness-[0.4] pointer-events-none"
                                                draggable="false"
                                            />
                                            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                                                <span class="text-white text-2xl font-bold tracking-tight drop-shadow-md">
                                                    {purchase.items.length}
                                                </span>
                                            </div>
                                        </>
                                    )}
                                </div>
                                <div>
                                    <h3 class="text-[14px] font-semibold leading-tight text-text-primary truncate pointer-events-none" title={purchase.shopName}>
                                        {purchase.shopName}
                                    </h3>
                                    <span class={`text-[11px] font-semibold px-2 py-0.5 rounded-full ${statusColor}`}>
                                        {orderStatusLabels[purchase.status?.toLowerCase() as keyof typeof orderStatusLabels] || purchase.status || strings.orderStatusPending}
                                    </span>
                                </div>
                            </article>
                            );
                        })}

                        {/* Tarjeta de Ver Todos */}
                        <div class="flex-shrink-0 w-32 md:w-40 flex flex-col snap-start">
                            <a href="/me/orders" draggable="false" class="group relative aspect-square w-full rounded-2xl flex flex-col items-center justify-center bg-bg border-2 border-dashed border-border-default hover:border-text-primary transition-all duration-200 cursor-pointer mb-3 select-none">
                                <div class="w-10 h-10 rounded-full bg-border-light/50 group-hover:bg-border-light flex items-center justify-center transition-colors mb-2">
                                    <Icon name="chevron-right" class="w-5 h-5 text-text-secondary group-hover:text-text-primary transition-colors" />
                                </div>
                                <span class="text-[13px] font-medium text-text-secondary group-hover:text-text-primary transition-colors px-2 text-center">
                                    {strings.meViewAllOrders}
                                </span>
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            {/* Sección de Menú (Derecha en Desktop / Bottom en Móvil) */}
            <aside class="col-span-12 md:col-span-5 lg:col-span-4 flex flex-col gap-2 relative">
                <nav class="flex flex-col gap-[2px]">
                    <a href="/me/orders" class="flex items-center gap-4 py-4 rounded-xl hover:bg-border-light transition-colors cursor-pointer group px-2 -mx-2">
                        <div class="w-9 h-9 rounded-full bg-surface border border-border-light flex items-center justify-center text-text-secondary group-hover:text-text-primary transition-colors">
                            <Icon name="shopping-cart" size={18} strokeWidth={2} />
                        </div>
                        <span class="flex-1 font-medium text-text-primary text-[15px]">
                            {strings.meMyOrders}
                        </span>
                        <Icon name="chevron-right" size={18} class="text-text-secondary/50 group-hover:text-text-primary transition-colors" />
                    </a>

                    <a href="/me/details" class="flex items-center gap-4 py-4 rounded-xl hover:bg-border-light transition-colors cursor-pointer group px-2 -mx-2 relative">
                        <div class="w-9 h-9 rounded-full bg-surface border border-border-light flex items-center justify-center text-text-secondary group-hover:text-text-primary transition-colors relative">
                            <Icon name="user" size={18} strokeWidth={2} />
                            {profileIncomplete && (
                                <span class="absolute -top-1 -right-1 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[10px] font-bold text-white ring-2 ring-surface">
                                    !
                                </span>
                            )}
                        </div>
                        <span class="flex-1 font-medium text-text-primary text-[15px]">
                            {strings.meMyData}
                        </span>
                        {profileIncomplete && (
                            <span class="text-xs font-medium text-red-500 dark:text-red-400 mr-1">
                                Completa tus datos
                            </span>
                        )}
                        <Icon name="chevron-right" size={18} class="text-text-secondary/50 group-hover:text-text-primary transition-colors" />
                    </a>

                    <a href="/me/settings" class="flex items-center gap-4 py-4 rounded-xl hover:bg-border-light transition-colors cursor-pointer group px-2 -mx-2">
                        <div class="w-9 h-9 rounded-full bg-surface border border-border-light flex items-center justify-center text-text-secondary group-hover:text-text-primary transition-colors">
                            <Icon name="sliders" size={18} strokeWidth={2} />
                        </div>
                        <span class="flex-1 font-medium text-text-primary text-[15px]">
                            {strings.meSettings}
                        </span>
                        <Icon name="chevron-right" size={18} class="text-text-secondary/50 group-hover:text-text-primary transition-colors" />
                    </a>
                </nav>
            </aside>
            
        </div>
    </main>
</BuyerAppLayout>

<style>
    /* Utilidad para esconder el scrollbar */
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none; /* IE and Edge */
        scrollbar-width: none; /* Firefox */
    }
</style>

<script>
    // Lógica para permitir el drag en desktop simulando móvil
    const slider = document.getElementById('purchases-slider');
    let isDown = false;
    let startX: number;
    let scrollLeft: number;

    if (slider) {
        slider.addEventListener('mousedown', (e) => {
            isDown = true;
            slider.style.scrollSnapType = 'none'; // Desactivamos snap al arrastrar
            startX = e.pageX - slider.offsetLeft;
            scrollLeft = slider.scrollLeft;
        });

        slider.addEventListener('mouseleave', () => {
            isDown = false;
            slider.style.scrollSnapType = 'x mandatory';
        });

        slider.addEventListener('mouseup', () => {
            isDown = false;
            slider.style.scrollSnapType = 'x mandatory';
        });

        slider.addEventListener('mousemove', (e) => {
            if (!isDown) return;
            e.preventDefault();
            const x = e.pageX - slider.offsetLeft;
            const walk = (x - startX) * 2; // Velocidad de arrastre
            slider.scrollLeft = scrollLeft - walk;
        });

        // Previene la navegación si se hizo un drag largo (para no provocar clicks accidentales)
        const links = slider.querySelectorAll('a');
        let isDragging = false;

        slider.addEventListener('mousemove', () => {
            if (isDown) isDragging = true;
        });

        slider.addEventListener('mousedown', () => {
            isDragging = false;
        });

        links.forEach(link => {
            link.addEventListener('click', (e) => {
                if (isDragging) {
                    e.preventDefault();
                }
            });
        });
    }
</script>
