---
import BuyerAppLayout from "../../layouts/BuyerAppLayout.astro";
import Icon from "../../components/icons/Icon.astro";
import DeferredBuyerOrders from "../../components/orders/DeferredBuyerOrders.astro";
import SkeletonOrderList from "../../components/ui/SkeletonOrderList.astro";

import { createSupabaseAuthClient } from "../../lib/core/auth";
const { t } = Astro.locals;

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const {
    data: { user },
} = await supabase.auth.getUser();

if (!user) return Astro.redirect("/login?redirect_to=/me/orders");
---

<BuyerAppLayout title={t.ordersPageTitle}>
    <main class="w-full max-w-2xl mx-auto px-4 md:px-6 pt-6 pb-28 md:pb-16 min-h-[50vh]">

        {/* Back + heading */}
        <div class="flex items-center gap-3 mb-6">
            <a
                href="/me"
                class="w-9 h-9 rounded-full flex items-center justify-center hover:bg-border-light transition-colors -ml-1 text-text-secondary hover:text-text-primary"
                aria-label={t.productBack}
            >
                <Icon name="arrow-left" size={20} />
            </a>
            <h1 class="text-xl md:text-2xl font-bold text-text-primary">
                {t.ordersHeading}
            </h1>
        </div>

        <DeferredBuyerOrders server:defer>
            <SkeletonOrderList count={3} slot="fallback" />
        </DeferredBuyerOrders>
    </main>
</BuyerAppLayout>
