---
import BuyerAppLayout from "../../layouts/BuyerAppLayout.astro";
import Icon from "../../components/icons/Icon.astro";
import { strings } from "../../lib/core/i18n";
import { createSupabaseAuthClient } from "../../lib/core/auth";
import { getAllCountries } from "../../lib/shipping/countries";
import { spainProvinces } from "../../lib/shipping/spain-provinces";
import { isProfileComplete } from "../../lib/core/validation";

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login?redirect_to=/me/details');
}

const { data: profile } = await supabase
    .from('profiles')
    .select('first_name, last_name, email, avatar_url, phone, phone_prefix, address_street, address_number, address_floor, address_postal_code, address_city, address_province, address_country')
    .eq('id', user.id)
    .single();

const returnTo = Astro.url.searchParams.get('return_to');
const fromCheckout = Astro.url.searchParams.get('checkout') === '1' && returnTo === '/cart';

const profileCheck = isProfileComplete(profile ?? {});
const profileIncomplete = !profileCheck.complete;

const allCountries = getAllCountries();
const currentCountry = profile?.address_country || 'ES';
const currentPrefix = profile?.phone_prefix || '+34';
const isSpain = currentCountry === 'ES';
---

<BuyerAppLayout title={`${strings.meDataPageTitle} — ${strings.siteTitle}`}>
    <main class="w-full max-w-lg mx-auto px-4 pt-6 pb-28 md:pb-16 min-h-[50vh]">

        {/* Back button + title */}
        <div class="flex items-center gap-3 mb-8">
            <a href="/me" class="w-9 h-9 rounded-full flex items-center justify-center hover:bg-border-light transition-colors -ml-1 text-text-secondary hover:text-text-primary">
                <Icon name="arrow-left" size={20} />
            </a>
            <h1 class="text-xl md:text-2xl font-bold text-text-primary">
                {strings.meDataPageTitle}
            </h1>
        </div>

        {profileIncomplete && (
            <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-4 text-red-800 dark:border-red-800 dark:bg-red-900/20 dark:text-red-300">
                <div class="flex items-start gap-3">
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-red-500 text-[10px] font-bold text-white mt-0.5">!</span>
                    <div>
                        <p class="text-sm font-semibold">{strings.meDataIncompleteNoticeTitle}</p>
                        <p class="mt-1 text-sm">{strings.meDataIncompleteNoticeSubtitle}</p>
                    </div>
                </div>
            </div>
        )}

        {fromCheckout && (
            <div class="mb-6 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-amber-800 dark:border-amber-800 dark:bg-amber-900/20 dark:text-amber-300">
                <p class="text-sm font-semibold">{strings.meDataCheckoutNoticeTitle}</p>
                <p class="mt-1 text-sm">{strings.meDataCheckoutNoticeSubtitle}</p>
            </div>
        )}

        {/* Avatar */}
        <div class="flex flex-col items-center mb-8">
            <div class="relative group">
                <input
                    type="file"
                    id="avatar-input"
                    accept="image/jpeg,image/png,image/webp,image/gif"
                    class="hidden"
                />
                <button
                    type="button"
                    id="avatar-trigger"
                    class="relative w-24 h-24 rounded-full overflow-hidden border-2 border-border-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
                    aria-label={profile?.avatar_url ? strings.meDataAvatarChange : strings.meDataAvatarUpload}
                >
                    <div id="avatar-preview" class="w-full h-full">
                        {profile?.avatar_url ? (
                            <img
                                src={profile.avatar_url}
                                alt={profile?.first_name ?? strings.meDataAvatarNote}
                                class="w-full h-full object-cover"
                            />
                        ) : (
                            <div class="w-full h-full bg-surface flex items-center justify-center text-text-tertiary">
                                <Icon name="user" size={40} />
                            </div>
                        )}
                    </div>
                    <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="text-white text-[11px] font-medium px-2 text-center leading-tight">
                            {profile?.avatar_url ? strings.meDataAvatarChange : strings.meDataAvatarUpload}
                        </span>
                    </div>
                </button>
                {profile?.avatar_url && (
                    <button
                        type="button"
                        id="avatar-remove-btn"
                        class="absolute -top-1 -right-1 w-7 h-7 rounded-full bg-bg border border-border-light text-text-secondary flex items-center justify-center hover:bg-red-50 hover:text-red-500 hover:border-red-200 transition-colors"
                        aria-label={strings.meDataAvatarRemove}
                    >
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                    </button>
                )}
            </div>
            <p id="avatar-status" class="mt-2 text-[13px] text-text-tertiary">{strings.meDataAvatarNote}</p>
            <input type="hidden" name="avatar_url" id="avatar_url" value={profile?.avatar_url ?? ''} />
        </div>

        {/* Form */}
        <form id="profile-form" class="flex flex-col gap-5" novalidate>

            {/* Nombre y Apellidos */}
            <div class="grid grid-cols-2 gap-3">
                <div class="flex flex-col gap-1.5">
                    <label for="first_name" class="text-[13px] font-medium text-text-secondary">
                        Nombre
                    </label>
                    <input
                        id="first_name"
                        name="first_name"
                        type="text"
                        value={profile?.first_name ?? ''}
                        autocomplete="given-name"
                        placeholder="Fernando"
                        maxlength="50"
                        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary placeholder:text-text-tertiary focus:outline-none focus:border-text-primary transition-colors"
                    />
                    <p id="first_name_error" class="hidden text-[12px] text-red-500"></p>
                </div>
                <div class="flex flex-col gap-1.5">
                    <label for="last_name" class="text-[13px] font-medium text-text-secondary">
                        Apellidos
                    </label>
                    <input
                        id="last_name"
                        name="last_name"
                        type="text"
                        value={profile?.last_name ?? ''}
                        autocomplete="family-name"
                        placeholder="Alonso Díaz"
                        maxlength="100"
                        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary placeholder:text-text-tertiary focus:outline-none focus:border-text-primary transition-colors"
                    />
                    <p id="last_name_error" class="hidden text-[12px] text-red-500"></p>
                </div>
            </div>

            {/* Email (read-only) */}
            <div class="flex flex-col gap-1.5">
                <label for="email" class="text-[13px] font-medium text-text-secondary flex items-center gap-2">
                    {strings.meDataEmail}
                </label>
                <input
                    id="email"
                    type="email"
                    value={profile?.email ?? user.email ?? ''}
                    disabled
                    class="w-full rounded-xl border border-border-light bg-surface/50 px-4 py-3 text-[15px] text-text-tertiary cursor-not-allowed select-none"
                />
            </div>

            {/* Teléfono con prefijo */}
            <div class="flex flex-col gap-1.5">
                <label for="phone" class="text-[13px] font-medium text-text-secondary">
                    {strings.meDataPhone}
                </label>
                <div class="flex gap-2">
                    <select
                        id="phone_prefix"
                        name="phone_prefix"
                        autocomplete="tel-country-code"
                        class="shrink-0 w-[130px] rounded-xl border border-border bg-surface px-3 py-3 text-[15px] text-text-primary focus:outline-none focus:border-text-primary transition-colors cursor-pointer appearance-none"
                        style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2712%27 height=%2712%27 viewBox=%270 0 12 12%27%3E%3Cpath fill=%27%23999%27 d=%27M3 4.5L6 7.5l3-3%27/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 8px center; padding-right: 24px;"
                    >
                        {allCountries.map(country => (
                            <option value={country.phonePrefix} selected={currentPrefix === country.phonePrefix}>
                                {country.flag} {country.phonePrefix}
                            </option>
                        ))}
                    </select>
                    <input
                        id="phone"
                        name="phone"
                        type="tel"
                        value={profile?.phone ?? ''}
                        autocomplete="tel"
                        placeholder="612 345 678"
                        class="flex-1 rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary placeholder:text-text-tertiary focus:outline-none focus:border-text-primary transition-colors"
                    />
                </div>
                <p id="phone_error" class="hidden text-[12px] text-red-500"></p>
            </div>

            {/* Calle y Número */}
            <div class="grid grid-cols-3 gap-3">
                <div class="col-span-2 flex flex-col gap-1.5">
                    <label for="address_street" class="text-[13px] font-medium text-text-secondary">
                        Calle
                    </label>
                    <input
                        id="address_street"
                        name="address_street"
                        type="text"
                        value={profile?.address_street ?? ''}
                        autocomplete="address-line1"
                        placeholder="Calle Gran Vía"
                        maxlength="100"
                        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary placeholder:text-text-tertiary focus:outline-none focus:border-text-primary transition-colors"
                    />
                    <p id="address_street_error" class="hidden text-[12px] text-red-500"></p>
                </div>
                <div class="flex flex-col gap-1.5">
                    <label for="address_number" class="text-[13px] font-medium text-text-secondary">
                        Número
                    </label>
                    <input
                        id="address_number"
                        name="address_number"
                        type="text"
                        value={profile?.address_number ?? ''}
                        autocomplete="address-line2"
                        placeholder="42"
                        maxlength="20"
                        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary placeholder:text-text-tertiary focus:outline-none focus:border-text-primary transition-colors"
                    />
                    <p id="address_number_error" class="hidden text-[12px] text-red-500"></p>
                </div>
            </div>

            {/* Piso / Puerta (opcional) */}
            <div class="flex flex-col gap-1.5">
                <label for="address_floor" class="text-[13px] font-medium text-text-secondary">
                    Piso / Puerta <span class="text-text-tertiary font-normal">(opcional)</span>
                </label>
                <input
                    id="address_floor"
                    name="address_floor"
                    type="text"
                    value={profile?.address_floor ?? ''}
                    autocomplete="address-line3"
                    placeholder="3ºB, Portal 2..."
                    maxlength="30"
                    class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary placeholder:text-text-tertiary focus:outline-none focus:border-text-primary transition-colors"
                />
                <p id="address_floor_error" class="hidden text-[12px] text-red-500"></p>
            </div>

            {/* Código Postal y Ciudad */}
            <div class="grid grid-cols-3 gap-3">
                <div class="flex flex-col gap-1.5">
                    <label for="address_postal_code" class="text-[13px] font-medium text-text-secondary">
                        C.P.
                    </label>
                    <input
                        id="address_postal_code"
                        name="address_postal_code"
                        type="text"
                        value={profile?.address_postal_code ?? ''}
                        autocomplete="postal-code"
                        placeholder="28013"
                        maxlength="5"
                        inputmode="numeric"
                        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary placeholder:text-text-tertiary focus:outline-none focus:border-text-primary transition-colors"
                    />
                    <p id="address_postal_code_error" class="hidden text-[12px] text-red-500"></p>
                </div>
                <div class="col-span-2 flex flex-col gap-1.5">
                    <label for="address_city" class="text-[13px] font-medium text-text-secondary">
                        Ciudad
                    </label>
                    <input
                        id="address_city"
                        name="address_city"
                        type="text"
                        value={profile?.address_city ?? ''}
                        autocomplete="address-level2"
                        placeholder="Madrid"
                        maxlength="100"
                        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary placeholder:text-text-tertiary focus:outline-none focus:border-text-primary transition-colors"
                    />
                    <p id="address_city_error" class="hidden text-[12px] text-red-500"></p>
                </div>
            </div>

            {/* País */}
            <div class="flex flex-col gap-1.5">
                <label for="address_country" class="text-[13px] font-medium text-text-secondary">
                    País
                </label>
                <select
                    id="address_country"
                    name="address_country"
                    autocomplete="country"
                    class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary focus:outline-none focus:border-text-primary transition-colors cursor-pointer appearance-none"
                    style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2712%27 height=%2712%27 viewBox=%270 0 12 12%27%3E%3Cpath fill=%27%23999%27 d=%27M3 4.5L6 7.5l3-3%27/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 12px center; padding-right: 32px;"
                >
                    {allCountries.map(country => (
                        <option value={country.code} selected={currentCountry === country.code}>
                            {country.flag} {country.name}
                        </option>
                    ))}
                </select>
            </div>

            {/* Provincia / Estado */}
            <div class="flex flex-col gap-1.5" id="province-container" data-is-spain={isSpain ? 'true' : 'false'}>
                <label for="address_province" class="text-[13px] font-medium text-text-secondary">
                    Provincia
                </label>
                {isSpain ? (
                    <select
                        id="address_province"
                        name="address_province"
                        autocomplete="address-level1"
                        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary focus:outline-none focus:border-text-primary transition-colors cursor-pointer appearance-none"
                        style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2712%27 height=%2712%27 viewBox=%270 0 12 12%27%3E%3Cpath fill=%27%23999%27 d=%27M3 4.5L6 7.5l3-3%27/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 12px center; padding-right: 32px;"
                    >
                        <option value="">Selecciona provincia</option>
                        {spainProvinces.map(province => (
                            <option value={province.name} selected={profile?.address_province === province.name}>
                                {province.name}
                            </option>
                        ))}
                    </select>
                ) : (
                    <input
                        id="address_province"
                        name="address_province"
                        type="text"
                        value={profile?.address_province ?? ''}
                        autocomplete="address-level1"
                        placeholder="Madrid"
                        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary placeholder:text-text-tertiary focus:outline-none focus:border-text-primary transition-colors"
                    />
                )}
                <p id="address_province_error" class="hidden text-[12px] text-red-500"></p>
            </div>

            {/* Submit */}
            <button
                type="submit"
                id="save-btn"
                class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-accent text-bg font-semibold text-[15px] py-3.5 transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed mt-1"
            >
                <span data-busy-label>{strings.meDataSave}</span>
            </button>

        </form>
    </main>
</BuyerAppLayout>

<script>
    import { strings } from '../../lib/core/i18n';
    import { spainProvinces } from '../../lib/shipping/spain-provinces';
    import { validateProfileForm, type ProfileFormData } from '../../lib/core/validation';
    import { toast } from '../../lib/ui/toast';
    import { runSubmit } from '../../lib/ui/submit';
    import { compressImage, AVATAR_PRESET } from '../../lib/ui/imageCompress';

  function initProfileForm() {
    const form = document.getElementById('profile-form') as HTMLFormElement | null;
    if (!form) return;
    const btn = document.getElementById('save-btn') as HTMLButtonElement;
    const countrySelect = document.getElementById('address_country') as unknown as HTMLSelectElement;
    const provinceContainer = document.getElementById('province-container') as unknown as HTMLDivElement;
    const currentUrl = new URL(window.location.href);
    const returnTo = currentUrl.searchParams.get('return_to');
    const fromCheckout = currentUrl.searchParams.get('checkout') === '1' && returnTo === '/cart';

    const errorMessages: Record<string, string> = {
        validationRequired: strings.validationRequired,
        validationNameMinLength: strings.validationNameMinLength,
        validationNameMaxLength: strings.validationNameMaxLength,
        validationLastNameMinLength: strings.validationLastNameMinLength,
        validationLastNameMaxLength: strings.validationLastNameMaxLength,
        validationPhoneFormat: strings.validationPhoneFormat,
        validationPhonePrefixMissing: strings.validationPhonePrefixMissing,
        validationStreetMinLength: strings.validationStreetMinLength,
        validationStreetMaxLength: strings.validationStreetMaxLength,
        validationNumberMaxLength: strings.validationNumberMaxLength,
        validationFloorMaxLength: strings.validationFloorMaxLength,
        validationPostalCodeFormat: strings.validationPostalCodeFormat,
        validationPostalCodeFormatEs: strings.validationPostalCodeFormatEs,
        validationCityMinLength: strings.validationCityMinLength,
        validationCityMaxLength: strings.validationCityMaxLength,
        validationProvinceRequiredEs: strings.validationProvinceRequiredEs,
        validationNameFormat: strings.validationNameFormat,
        validationCityFormat: strings.validationCityFormat,
    };

    function showFieldError(fieldId: string, message: string | null) {
        const errorEl = document.getElementById(`${fieldId}_error`);
        const inputEl = document.getElementById(fieldId);
        if (errorEl && message) {
            errorEl.textContent = message;
            errorEl.classList.remove('hidden');
            inputEl?.classList.add('border-red-500');
            inputEl?.classList.remove('border-border');
        } else if (errorEl) {
            errorEl.classList.add('hidden');
            inputEl?.classList.remove('border-red-500');
            inputEl?.classList.add('border-border');
        }
    }

    function clearAllErrors() {
        const errorFields = ['first_name', 'last_name', 'phone', 'phone_prefix', 'address_street', 'address_number', 'address_floor', 'address_postal_code', 'address_city', 'address_province'];
        errorFields.forEach(field => showFieldError(field, null));
    }

    function getProvinceValue(): string {
        const el = provinceContainer.querySelector('input, select');
        if (el instanceof HTMLInputElement || el instanceof HTMLSelectElement) {
            return el.value || '';
        }
        return '';
    }

    function updateProvinceField() {
        const country = countrySelect.value;
        const isSpain = country === 'ES';
        const currentProvince = getProvinceValue();

        if (isSpain) {
            provinceContainer.innerHTML = `
                <label for="address_province" class="text-[13px] font-medium text-text-secondary">
                    Provincia
                </label>
                <select
                    id="address_province"
                    name="address_province"
                    autocomplete="address-level1"
                    class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary focus:outline-none focus:border-text-primary transition-colors cursor-pointer appearance-none"
                    style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2712%27 height=%2712%27 viewBox=%270 0 12 12%27%3E%3Cpath fill=%27%23999%27 d=%27M3 4.5L6 7.5l3-3%27/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 12px center; padding-right: 32px;"
                >
                    <option value="">Selecciona provincia</option>
                    ${spainProvinces.map(p => `<option value="${p.name}" ${p.name === currentProvince ? 'selected' : ''}>${p.name}</option>`).join('')}
                </select>
                <p id="address_province_error" class="hidden text-[12px] text-red-500"></p>
            `;
        } else {
            provinceContainer.innerHTML = `
                <label for="address_province" class="text-[13px] font-medium text-text-secondary">
                    Provincia / Estado
                </label>
                <input
                    id="address_province"
                    name="address_province"
                    type="text"
                    value="${currentProvince}"
                    autocomplete="address-level1"
                    placeholder="Madrid"
                    class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[15px] text-text-primary placeholder:text-text-tertiary focus:outline-none focus:border-text-primary transition-colors"
                />
                <p id="address_province_error" class="hidden text-[12px] text-red-500"></p>
            `;
        }
    }

    countrySelect.addEventListener('change', updateProvinceField);

    // Avatar upload
    const avatarInput = document.getElementById('avatar-input') as HTMLInputElement | null;
    const avatarTrigger = document.getElementById('avatar-trigger') as HTMLButtonElement | null;
    const avatarPreview = document.getElementById('avatar-preview') as HTMLDivElement | null;
    const avatarRemoveBtn = document.getElementById('avatar-remove-btn') as HTMLButtonElement | null;
    const avatarStatus = document.getElementById('avatar-status') as HTMLParagraphElement | null;
    const avatarHidden = document.getElementById('avatar_url') as HTMLInputElement | null;
    let currentAvatarPath: string | null = null;

    function setAvatarStatus(text: string, type: 'default' | 'success' | 'error' = 'default') {
        if (!avatarStatus) return;
        avatarStatus.textContent = text;
        avatarStatus.className = 'mt-2 text-[13px] ' + (
            type === 'success' ? 'text-green-600' :
            type === 'error' ? 'text-red-500' :
            'text-text-tertiary'
        );
    }

    async function uploadAvatarFile(file: File): Promise<{ url: string; path: string } | null> {
        const compressed = await compressImage(file, AVATAR_PRESET);
        const formData = new FormData();
        formData.append('file', compressed);
        try {
            const res = await fetch('/api/profile/avatar-upload', { method: 'POST', body: formData });
            const data = await res.json() as { url?: string; path?: string; error?: string };
            if (!res.ok) {
                toast.error(data.error || strings.meDataAvatarError);
                return null;
            }
            return { url: data.url!, path: data.path! };
        } catch {
            toast.error(strings.toastErrorNetwork);
            return null;
        }
    }

    async function deleteAvatarFile(path: string): Promise<boolean> {
        try {
            const res = await fetch(`/api/profile/avatar-upload?path=${encodeURIComponent(path)}`, { method: 'DELETE' });
            return res.ok;
        } catch {
            return false;
        }
    }

    async function saveAvatarUrl(url: string | null) {
        try {
            const res = await fetch('/api/profile/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ avatar_url: url }),
            });
            return res.ok;
        } catch {
            return false;
        }
    }

    function updateAvatarPreview(url: string | null) {
        if (!avatarPreview) return;
        if (url) {
            avatarPreview.innerHTML = `<img src="${url}" alt="" class="w-full h-full object-cover" />`;
        } else {
            avatarPreview.innerHTML = `<div class="w-full h-full bg-surface flex items-center justify-center text-text-tertiary"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>`;
        }
        if (avatarHidden) avatarHidden.value = url || '';
    }

    function addRemoveAvatarButton() {
        if (document.getElementById('avatar-remove-btn')) return;
        const container = avatarTrigger?.parentElement;
        if (!container) return;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.id = 'avatar-remove-btn';
        btn.className = 'absolute -top-1 -right-1 w-7 h-7 rounded-full bg-bg border border-border-light text-text-secondary flex items-center justify-center hover:bg-red-50 hover:text-red-500 hover:border-red-200 transition-colors';
        btn.setAttribute('aria-label', strings.meDataAvatarRemove);
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';
        btn.addEventListener('click', removeAvatar);
        container.appendChild(btn);
    }

    function removeRemoveAvatarButton() {
        document.getElementById('avatar-remove-btn')?.remove();
    }

    async function removeAvatar() {
        if (currentAvatarPath) {
            await deleteAvatarFile(currentAvatarPath);
        }
        const saved = await saveAvatarUrl(null);
        if (saved) {
            updateAvatarPreview(null);
            removeRemoveAvatarButton();
            setAvatarStatus(strings.meDataAvatarNote);
            currentAvatarPath = null;
        } else {
            toast.error(strings.meDataSaveError);
        }
    }

    avatarTrigger?.addEventListener('click', () => avatarInput?.click());

    avatarInput?.addEventListener('change', async () => {
        if (!avatarInput.files || !avatarInput.files[0]) return;
        const file = avatarInput.files[0];
        avatarInput.value = '';

        setAvatarStatus(strings.meDataAvatarUploading);
        const result = await uploadAvatarFile(file);
        if (!result) {
            setAvatarStatus(strings.meDataAvatarError, 'error');
            return;
        }

        // Delete previous avatar if exists
        if (currentAvatarPath) {
            await deleteAvatarFile(currentAvatarPath);
        }

        const saved = await saveAvatarUrl(result.url);
        if (saved) {
            updateAvatarPreview(result.url);
            addRemoveAvatarButton();
            setAvatarStatus(strings.meDataAvatarSaved, 'success');
            currentAvatarPath = result.path;
            window.setTimeout(() => setAvatarStatus(strings.meDataAvatarNote), 2000);
        } else {
            setAvatarStatus(strings.meDataSaveError, 'error');
        }
    });

    avatarRemoveBtn?.addEventListener('click', removeAvatar);

    // Extract existing avatar path from current URL if present
    const initialAvatarUrl = avatarHidden?.value || '';
    if (initialAvatarUrl.includes('/avatars/')) {
        const urlObj = new URL(initialAvatarUrl);
        const pathParts = urlObj.pathname.split('/');
        const bucketIndex = pathParts.indexOf('imgs');
        if (bucketIndex !== -1) {
            currentAvatarPath = pathParts.slice(bucketIndex + 1).join('/');
        }
    }

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearAllErrors();

        const provinceEl = form.querySelector('#address_province') as HTMLInputElement | HTMLSelectElement | null;

        const data: ProfileFormData = {
            first_name: (form.querySelector('#first_name') as HTMLInputElement).value,
            last_name: (form.querySelector('#last_name') as HTMLInputElement).value,
            phone: (form.querySelector('#phone') as HTMLInputElement).value,
            phone_prefix: (form.querySelector('#phone_prefix') as unknown as HTMLSelectElement).value,
            address_street: (form.querySelector('#address_street') as HTMLInputElement).value,
            address_number: (form.querySelector('#address_number') as HTMLInputElement).value,
            address_floor: (form.querySelector('#address_floor') as HTMLInputElement).value,
            address_postal_code: (form.querySelector('#address_postal_code') as HTMLInputElement).value,
            address_city: (form.querySelector('#address_city') as HTMLInputElement).value,
            address_province: provinceEl?.value || '',
            address_country: (form.querySelector('#address_country') as unknown as HTMLSelectElement).value,
        };

        const errors = validateProfileForm(data);

        if (errors.length > 0) {
            errors.forEach(err => {
                const translatedMsg = errorMessages[err.message] || err.message;
                showFieldError(err.field, translatedMsg);
            });
            const firstErrorField = errors[0].field;
            const firstInput = form.querySelector(`#${firstErrorField}`) as HTMLElement | null;
            firstInput?.focus();
            return;
        }

        const result = await runSubmit({
            button: btn,
            busyLabel: strings.meDataSaving,
            action: () => fetch('/api/profile/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data),
            }),
            successMsg: fromCheckout ? strings.meDataSaveAndReturnSuccess : strings.profileSavedToast,
            errorFallback: strings.meDataSaveError,
        });
        if (result.ok) {
            window.setTimeout(() => {
                window.location.href = fromCheckout && returnTo ? returnTo : '/me';
            }, 900);
        }
    });

    const inputFields = ['first_name', 'last_name', 'address_street', 'address_postal_code', 'address_city'];
    inputFields.forEach(fieldId => {
        const input = form.querySelector(`#${fieldId}`) as HTMLInputElement | null;
        input?.addEventListener('input', () => {
            showFieldError(fieldId, null);
        });
    });

    if (fromCheckout) {
        const firstNameInput = form.querySelector('#first_name') as HTMLInputElement | null;
        const lastNameInput = form.querySelector('#last_name') as HTMLInputElement | null;
        const phoneInput = form.querySelector('#phone') as HTMLInputElement | null;
        const streetInput = form.querySelector('#address_street') as HTMLInputElement | null;
        const numberInput = form.querySelector('#address_number') as HTMLInputElement | null;
        const postalCodeInput = form.querySelector('#address_postal_code') as HTMLInputElement | null;
        const cityInput = form.querySelector('#address_city') as HTMLInputElement | null;
        const provinceInput = form.querySelector('#address_province') as HTMLInputElement | HTMLSelectElement | null;

        const firstMissingField =
            !firstNameInput?.value.trim() ? firstNameInput :
            !lastNameInput?.value.trim() ? lastNameInput :
            !phoneInput?.value.trim() ? phoneInput :
            !streetInput?.value.trim() ? streetInput :
            !numberInput?.value.trim() ? numberInput :
            !postalCodeInput?.value.trim() ? postalCodeInput :
            !cityInput?.value.trim() ? cityInput :
            !provinceInput?.value.trim() ? provinceInput :
            null;

        firstMissingField?.focus();
    }
  }

  document.addEventListener('astro:page-load', initProfileForm);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProfileForm);
  } else {
    initProfileForm();
  }
</script>
