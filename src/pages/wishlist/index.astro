---
import BuyerAppLayout from "../../layouts/BuyerAppLayout.astro";
import ProductGrid from "../../components/ProductGrid.astro";
import Icon from "../../components/icons/Icon.astro";
import { createSupabaseAuthClient } from "../../lib/auth";
import { supabase } from "../../lib/supabase";
import { enrichProductsWithRatings } from "../../lib/productUtils";
import { strings } from "../../lib/i18n";
import type { Product } from "../../lib/types";

const authClient = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: { user } } = await authClient.auth.getUser();

if (!user) return Astro.redirect('/api/auth/login');

const { data: wishlistData } = await authClient
    .from('wishlist')
    .select('product_id')
    .eq('profile_id', user.id)
    .order('created_at', { ascending: false });

const productIds = (wishlistData ?? []).map((w: any) => w.product_id);

let products: Product[] = [];
if (productIds.length > 0) {
    const { data: productsData } = await supabase
        .from('products')
        .select('*, shop:shops(*), variants:product_variants(*)')
        .in('id', productIds)
        .eq('is_active', true);

    // Preserve wishlist order
    const byId = Object.fromEntries((productsData ?? []).map((p: any) => [p.id, p]));
    products = productIds.map((id: string) => byId[id]).filter(Boolean) as Product[];
    await enrichProductsWithRatings(products, supabase);
}

const wishedProductIds = new Set(productIds);
---

<BuyerAppLayout title={strings.wishlistPageTitle}>

    <main class="min-h-[50vh]">
        <div class="px-4 md:px-10 md:max-w-[1400px] md:mx-auto pt-6 pb-4">
            <h1 class="text-xl md:text-2xl font-bold text-text-primary">{strings.navWishlist}</h1>
        </div>

        {products.length > 0 ? (
            <ProductGrid products={products} wishedProductIds={wishedProductIds} />
        ) : (
            <div class="flex flex-col items-center justify-center text-center px-6 py-20">
                <div class="w-16 h-16 mb-4 text-text-tertiary bg-border-light rounded-full flex items-center justify-center">
                    <Icon name="heart" size={24} />
                </div>
                <h2 class="text-[18px] font-semibold text-text-primary mb-2">
                    {strings.wishlistEmpty}
                </h2>
                <p class="text-[14px] text-text-secondary mb-6">{strings.wishlistEmptySub}</p>
                <a
                    href="/"
                    class="inline-flex items-center px-6 py-2.5 bg-accent text-bg text-sm font-semibold rounded-lg transition-colors hover:bg-accent-hover"
                >
                    {strings.wishlistExploreCta}
                </a>
            </div>
        )}
    </main>
</BuyerAppLayout>
