---
import Icon from "./icons/Icon.astro";
import { strings } from "../lib/strings";
import type { Product } from "../lib/types";

interface Props {
    product: Product;
}

const { product } = Astro.props;

const imageUrl = product.gallery_images?.[0] ?? "/placeholder.svg";
const defaultVariant = product.variants?.find(v => v.is_default);
const price = defaultVariant?.price ?? product.variants?.[0]?.price ?? 0;
const formattedPrice = `${price.toFixed(2)}${strings.currency}`;
const shopName = product.shop?.name ?? "";
const shopSlug = product.shop?.slug ?? "";
const shopAccentColor = product.shop?.accent_color;
const productUrl = (shopSlug && product.slug) ? `/${shopSlug}/${product.slug}` : '#';
---

<article class="flex flex-col bg-surface rounded-md overflow-hidden transition-shadow duration-200 hover:shadow-[0_2px_16px_rgba(0,0,0,0.06)] group">
    <a href={productUrl} class="block aspect-square overflow-hidden">
        <img
            src={imageUrl}
            alt={product.title}
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
            loading="lazy"
            decoding="async"
        />
    </a>

    <div class="flex flex-col gap-1 p-[10px_12px_14px]">
        <div class="flex items-center justify-between">
            <span class="text-base font-bold text-text-primary tracking-[-0.3px]">{formattedPrice}</span>
            <button
                class="flex items-center justify-center w-8 h-8 border-none bg-transparent text-text-tertiary cursor-pointer rounded-full transition-colors duration-150 hover:text-wishlist hover:bg-border-light [-webkit-tap-highlight-color:transparent]"
                aria-label={strings.addToWishlist}
                type="button"
            >
                <Icon name="heart" size={18} />
            </button>
        </div>

        <a href={productUrl} class="text-[13px] font-medium text-text-primary no-underline leading-[1.35] line-clamp-2 hover:underline">
            {product.title}
        </a>

        {
            shopName && (
                <a href={`/${shopSlug}`} class="flex items-center gap-1.5 text-xs text-text-tertiary no-underline mt-0.5 hover:text-text-secondary hover:underline">
                    {shopAccentColor && (
                        <span class="w-[8px] h-[8px] rounded-full inline-block shrink-0" style={{ backgroundColor: shopAccentColor }}></span>
                    )}
                    <span class="truncate">{shopName}</span>
                </a>
            )
        }
    </div>
</article>
