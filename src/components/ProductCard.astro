---
import Icon from "./icons/Icon.astro";
import WishlistButton from "./WishlistButton.astro";

import { optimizeImageUrl } from "../lib/ui/imageOptimize";
import type { Product } from "../lib/core/types";
const { t } = Astro.locals;

interface Props {
    product: Product;
    isWished?: boolean;
    priority?: boolean;
}

const { product, isWished = false, priority = false } = Astro.props;

const rawImageUrl = product.gallery_images?.[0] ?? "/placeholder.svg";
const imageUrl = optimizeImageUrl(rawImageUrl, 400);
const defaultVariant = product.variants?.find(v => v.is_default) ?? product.variants?.[0];
const price = defaultVariant?.price ?? 0;
const shippingCost = defaultVariant?.shipping_cost ?? 0;
const formattedPrice = `${price.toFixed(2)}${t.currency}`;
const isOutOfStock = product.variants?.every(v => (v.stock ?? 0) <= 0) ?? true;
const shopName = product.shop?.name ?? "";
const shopSlug = product.shop?.slug ?? "";
const shopAccentColor = product.shop?.accent_color ?? "#888";
const productUrl = (shopSlug && product.slug) ? `/${shopSlug}/${product.slug}` : '#';
const reviewCount = product.review_count ?? 0;
const reviewAvg = product.review_avg ?? 0;
---

{/* ─── MOBILE: Horizontal layout ─── */}
<article class="md:hidden flex bg-surface rounded-lg overflow-hidden transition-shadow duration-200 hover:shadow-[0_2px_16px_rgba(0,0,0,0.08)] group">
    {/* Left — Image */}
    <div class="relative shrink-0 w-[140px]">
        <a href={productUrl} class="block h-full">
            <div class="py-3 h-full">
                <div class="w-full h-full aspect-square rounded-md bg-skeleton overflow-hidden" data-img-wrap>
                    <img
                        src={imageUrl}
                        alt={product.title}
                        class="w-full h-full object-cover opacity-0 transition duration-300 ease-out group-hover:scale-[1.03]"
                        width="400"
                        height="400"
                        loading={priority ? undefined : "lazy"}
                        fetchpriority={priority ? "high" : undefined}
                        decoding="async"
                        onload="this.classList.remove('opacity-0'); this.closest('[data-img-wrap]')?.classList.remove('bg-skeleton')"
                        onerror="this.setAttribute('src','/placeholder.svg'); this.classList.remove('opacity-0'); this.closest('[data-img-wrap]')?.classList.remove('bg-skeleton')"
                    />
                </div>
            </div>
        </a>
        <WishlistButton productId={product.id} isWished={isWished} variant="overlay" size={16} class="absolute bottom-4 right-2" />
    </div>

    {/* Right — Info */}
    <div class="flex flex-col justify-between flex-1 min-w-0 p-3 gap-1.5">
        <div class="flex flex-col gap-1.5">
            {shopName && (
                <a href={`/${shopSlug}`} class="flex items-center gap-1.5 text-xs text-text-secondary no-underline hover:text-text-primary hover:underline">
                    <span class="w-2 h-2 rounded-full shrink-0" style={{ backgroundColor: shopAccentColor }}></span>
                    <span class="truncate">{shopName}</span>
                </a>
            )}
            <a href={productUrl} class="text-sm font-medium text-text-primary no-underline leading-snug line-clamp-2 hover:underline">
                {product.title}
            </a>
            <div class="flex items-center justify-between gap-2">
                <div class="flex items-center gap-1 text-xs text-text-secondary">
                    {reviewCount > 0 ? (
                        <>
                            <Icon name="star-filled" size={13} class="text-amber-400" />
                            <span>{reviewAvg.toFixed(1)}</span>
                            <span>({reviewCount})</span>
                        </>
                    ) : (
                        <span>{t.noRatings}</span>
                    )}
                </div>
                <span class="text-base font-bold text-text-primary tracking-tight">{formattedPrice}</span>
            </div>
        </div>
        <button
            class="w-full py-2 text-sm font-medium rounded-md bg-accent text-surface cursor-pointer border-none transition-colors duration-150 hover:bg-accent-hover disabled:bg-border-light disabled:text-text-tertiary disabled:cursor-not-allowed"
            disabled={isOutOfStock}
            type="button"
            data-add-to-cart
            data-cart-product-id={product.id}
            data-cart-variant-id={defaultVariant?.id ?? ''}
            data-cart-title={product.title}
            data-cart-image={imageUrl}
            data-cart-price={String(price)}
            data-cart-stock={String(defaultVariant?.stock ?? 0)}
            data-cart-variant-name={defaultVariant?.variant_name ?? ''}
            data-cart-shipping={String(shippingCost)}
            data-cart-shop-id={product.shop?.id ?? ''}
            data-cart-shop-name={shopName}
            data-cart-shop-slug={shopSlug}
            data-cart-product-slug={product.slug}
        >
            <span class="flex items-center justify-center gap-1.5">
                {isOutOfStock ? (
                    <span>{t.productOutOfStock}</span>
                ) : (
                    <>
                        <Icon name="shopping-cart" size={15} />
                        {t.addToCart}
                    </>
                )}
            </span>
        </button>
    </div>
</article>

{/* ─── DESKTOP: Vertical card layout ─── */}
<article class="hidden md:flex flex-col bg-surface rounded-xl overflow-hidden transition-all duration-300 hover:shadow-[0_8px_32px_rgba(0,0,0,0.1)] dark:hover:shadow-[0_8px_32px_rgba(0,0,0,0.3)] group border border-transparent hover:border-border-light/60">
    {/* Image — full width, square */}
    <div class="relative aspect-square overflow-hidden bg-skeleton" data-img-wrap>
        <a href={productUrl} class="block w-full h-full">
            <img
                src={imageUrl}
                alt={product.title}
                class="w-full h-full object-cover opacity-0 transition duration-500 ease-out group-hover:scale-[1.06]"
                width="400"
                height="400"
                loading={priority ? undefined : "lazy"}
                fetchpriority={priority ? "high" : undefined}
                decoding="async"
                onload="this.classList.remove('opacity-0'); this.closest('[data-img-wrap]')?.classList.remove('bg-skeleton')"
                onerror="this.setAttribute('src','/placeholder.svg'); this.classList.remove('opacity-0'); this.closest('[data-img-wrap]')?.classList.remove('bg-skeleton')"
            />
        </a>

        {/* Wishlist button — top right overlay */}
        <WishlistButton productId={product.id} isWished={isWished} variant="overlay" size={16} class="absolute top-3 right-3" />
    </div>

    {/* Info */}
    <div class="flex flex-col gap-2 p-3 flex-1">
        {/* Shop */}
        {shopName && (
            <a href={`/${shopSlug}`} class="flex items-center gap-1.5 text-[11px] text-text-secondary no-underline hover:text-text-primary transition-colors">
                <span class="w-[7px] h-[7px] rounded-full shrink-0" style={{ backgroundColor: shopAccentColor }}></span>
                <span class="truncate font-medium">{shopName}</span>
            </a>
        )}

        {/* Title */}
        <a href={productUrl} class="text-[13px] font-semibold text-text-primary no-underline leading-snug line-clamp-2 hover:underline tracking-[-0.1px] flex-1">
            {product.title}
        </a>

        {/* Rating */}
        <div class="flex items-center gap-1 text-[11px] text-text-secondary">
            {reviewCount > 0 ? (
                <>
                    <Icon name="star-filled" size={12} class="text-amber-400" />
                    <span class="font-medium">{reviewAvg.toFixed(1)}</span>
                    <span>({reviewCount})</span>
                </>
            ) : (
                <span>{t.noRatings}</span>
            )}
        </div>

        {/* Price + Cart */}
        <div class="flex items-center justify-between gap-2 mt-auto pt-1">
            <span class="text-[15px] font-bold text-text-primary tracking-tight">
                {formattedPrice}
            </span>
            <button
                class="flex items-center gap-1.5 px-3 py-1.5 text-[12px] font-semibold rounded-lg bg-accent text-bg cursor-pointer border-none transition-all duration-200 hover:bg-accent-hover active:scale-[0.97] disabled:bg-border-light disabled:text-text-tertiary disabled:cursor-not-allowed [-webkit-tap-highlight-color:transparent]"
                disabled={isOutOfStock}
                type="button"
                data-add-to-cart
                data-cart-product-id={product.id}
                data-cart-variant-id={defaultVariant?.id ?? ''}
                data-cart-title={product.title}
                data-cart-image={imageUrl}
                data-cart-price={String(price)}
                data-cart-stock={String(defaultVariant?.stock ?? 0)}
                data-cart-variant-name={defaultVariant?.variant_name ?? ''}
                data-cart-shipping={String(shippingCost)}
                data-cart-shop-id={product.shop?.id ?? ''}
                data-cart-shop-name={shopName}
                data-cart-shop-slug={shopSlug}
                data-cart-product-slug={product.slug}
            >
                {!isOutOfStock && <Icon name="shopping-cart" size={13} />}
                {isOutOfStock ? t.productOutOfStock : t.addToCart}
            </button>
        </div>
    </div>
</article>
