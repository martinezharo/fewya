---
// Mirrors header of src/components/orders/OrderCard.astro
---

<article class="bg-surface rounded-2xl border border-border-light overflow-hidden" aria-hidden="true">
    <div class="w-full flex items-center gap-4 py-4 px-4 md:py-5 md:px-5">
        <div class="flex-shrink-0 w-16 h-16 md:w-[72px] md:h-[72px] rounded-xl bg-skeleton"></div>
        <div class="flex-1 min-w-0 flex items-start justify-between gap-2">
            <div class="min-w-0 flex flex-col gap-2 flex-1">
                <span class="block bg-skeleton h-4 w-2/3 rounded"></span>
                <span class="block bg-skeleton h-3 w-1/3 rounded"></span>
                <span class="block bg-skeleton h-3 w-1/4 rounded"></span>
            </div>
            <div class="flex flex-col items-end gap-2 flex-shrink-0">
                <span class="block bg-skeleton h-4 w-16 rounded"></span>
                <span class="block bg-skeleton h-4 w-20 rounded-full"></span>
            </div>
        </div>
    </div>
</article>
