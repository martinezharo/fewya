---
import SkeletonOrderCard from "./SkeletonOrderCard.astro";
const { t } = Astro.locals;

interface Props {
    count?: number;
}

const { count = 3 } = Astro.props;
const items = Array.from({ length: count });
---

<div
    class="flex flex-col gap-3 px-4 md:px-6 pb-24 md:pb-12"
    aria-busy="true"
    aria-label={t.loadingOrders}
>
    {items.map(() => <SkeletonOrderCard />)}
</div>
