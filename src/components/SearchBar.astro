---
import Icon from "./icons/Icon.astro";
import { strings } from "../lib/strings";
---

<div class="flex items-center gap-2 w-full px-[14px] py-[10px] bg-border-light rounded-full transition-colors duration-200 focus-within:bg-border">
    <Icon name="search" size={18} class="shrink-0 text-text-tertiary" />
    <input
        type="text"
        placeholder={strings.searchPlaceholder}
        class="flex-1 border-none bg-transparent text-[15px] font-sans text-text-primary outline-none placeholder:text-text-tertiary"
        aria-label={strings.searchPlaceholder}
        disabled
    />
</div>
