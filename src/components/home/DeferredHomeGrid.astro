---
import ProductGrid from "../ProductGrid.astro";
import { supabase } from "../../lib/core/supabase";
import { createSupabaseAuthClient } from "../../lib/core/auth";
import { enrichProductsWithRatings } from "../../lib/products/productUtils";
import { isProductComplete } from "../../lib/products/productValidation";
import { getMergedWishlistIds } from "../../lib/wishlist/wishlist";
import type { Product } from "../../lib/core/types";

interface Props {
    userId?: string | null;
}
const { userId = null } = Astro.props;

// Explicit columns — excludes internal/admin fields while keeping all that
// ProductCard and isProductComplete need (description + variant dimensions required for the filter)
const productsQuery = supabase
    .from("products")
    .select("id, slug, title, description, gallery_images, is_active, created_at, category, brand, shop:shops(id, slug, name, accent_color, payments_active, seller_details_complete, status), variants:product_variants(id, price, stock, shipping_cost, is_default, variant_name, weight_kg, length_cm, width_cm, height_cm)")
    .eq("is_active", true)
    .eq("shop.status", "active")
    .order("created_at", { ascending: false });

// Products and auth in parallel (userId may come from the parent page)
const authClient = createSupabaseAuthClient(Astro.cookies, Astro.request);
const [productsResult, resolvedUserId] = await Promise.all([
    productsQuery,
    userId !== null
        ? Promise.resolve(userId)
        : authClient.auth.getUser().then(r => r.data.user?.id ?? null),
]);

if (productsResult.error) {
    console.error("Error al obtener productos:", productsResult.error);
}

const rawProducts: Product[] = (productsResult.data ?? []) as Product[];
const products = rawProducts.filter(p => p.shop?.status === 'active' && p.shop?.payments_active && p.shop?.seller_details_complete && isProductComplete(p));

// Ratings enrichment and wishlist lookup in parallel
const [, wishedProductIds] = await Promise.all([
    enrichProductsWithRatings(products, supabase),
    getMergedWishlistIds(authClient, Astro.cookies, resolvedUserId),
]);
---

<ProductGrid products={products} wishedProductIds={wishedProductIds} />
