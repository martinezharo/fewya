---
import Icon from "./icons/Icon.astro";
import { createSupabaseAuthClient } from "../lib/auth";
import { getWishlistCount } from "../lib/wishlist";
import { navItems } from "../lib/nav";
import { strings } from "../lib/i18n";

const currentPath = Astro.url.pathname;

const authClient = createSupabaseAuthClient(Astro.cookies, Astro.request);
const { data: { user } } = await authClient.auth.getUser();
const wishlistCount = user ? await getWishlistCount(authClient, user.id) : 0;
---

<nav class="fixed bottom-0 left-0 right-0 z-50 flex justify-around items-center bg-surface border-t border-border-light py-2 pb-[calc(11px+env(safe-area-inset-bottom,0px))] md:hidden" aria-label={strings.navMobileAria}>
    {navItems.map(({ href, label, icon, showBadge, badgeType }) => {
        const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
        const isWishlistBadge = badgeType === 'wishlist';
        const isCartBadge = badgeType === 'cart';
        return (
            <a
                href={href}
                class:list={[
                    'flex flex-col items-center gap-0.5 px-3 py-1 no-underline transition-colors duration-150 active:scale-92 [-webkit-tap-highlight-color:transparent]',
                    isActive ? 'text-text-primary' : 'text-text-tertiary'
                ]}
                aria-label={label}
            >
                <div class="relative">
                    <Icon name={icon} size={22} />
                    {isWishlistBadge && (
                        <span 
                            data-wishlist-badge 
                            class="absolute -top-1.5 -right-1.5 flex h-4 min-w-[16px] items-center justify-center rounded-full bg-accent px-1 text-[10px] font-bold text-bg ring-2 ring-surface"
                            style={wishlistCount === 0 ? "display: none" : ""}
                        >
                            {wishlistCount}
                        </span>
                    )}
                    {isCartBadge && (
                        <span 
                            data-cart-badge 
                            class="absolute -top-1.5 -right-1.5 flex h-4 min-w-[16px] items-center justify-center rounded-full bg-accent px-1 text-[10px] font-bold text-bg ring-2 ring-surface"
                            style="display: none"
                        >
                            0
                        </span>
                    )}
                </div>
                <span class="text-[10px] font-medium tracking-[0.01em]">{label}</span>
            </a>
        );
    })}
</nav>
