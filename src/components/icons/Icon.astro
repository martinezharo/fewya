---
interface Props {
    name:
        | "home"
        | "heart"
        | "heart-filled"
        | "user"
        | "shopping-cart"
        | "store"
        | "search"
        | "tag"
        | "arrow-left"
        | "share"
        | "star"
        | "star-filled"
        | "mail"
        | "message-circle"
        | "flag"
        | "minus"
        | "plus"
        | "chevron-left"
        | "chevron-right"
        | "chevron-down"
        | "x"
        | "whatsapp";
    size?: number;
    class?: string;
    [key: string]: any;
}

const { name, size = 24, class: className = "", ...rest } = Astro.props;
