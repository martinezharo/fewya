---
import { strings } from '../../lib/i18n';
import type { ProductVariant } from '../../lib/types';

interface Props {
  variants: ProductVariant[];
  defaultImage: string;
}

const { variants, defaultImage } = Astro.props;
---

{variants.length > 0 && (
  <div>
    <div class="flex gap-4 overflow-x-auto [&::-webkit-scrollbar]:hidden [scrollbar-width:none] pb-1">
      {variants.map((v, i) => {
        const displayName = v.variant_name || (v.is_default ? 'Estándar' : `Variante ${i + 1}`);
        return (
          <button
            type="button"
            class="flex flex-col items-center gap-1.5 shrink-0"
            data-variant-btn
            data-variant-id={v.id}
            data-variant-price={v.price}
            data-variant-stock={v.stock}
            data-variant-image={v.variant_image || defaultImage}
          >
            <div class={`w-14 h-14 rounded-full overflow-hidden border-[2.5px] transition-all ${i === 0 ? 'border-accent' : 'border-border-light'}`} data-variant-ring>
              <img
                src={v.variant_image ?? defaultImage}
                alt={displayName}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="w-16 overflow-hidden">
              <span
                class={`block text-[11px] font-medium whitespace-nowrap text-center transition-colors ${i === 0 ? 'text-accent' : 'text-text-secondary'}`}
                data-variant-name
              >
                {displayName}
              </span>
            </div>
          </button>
        );
      })}
    </div>
  </div>
)}

<style>
  [data-variant-name].scrolling {
    animation: scroll-text var(--scroll-duration, 5s) ease-in-out infinite;
    width: max-content;
    text-align: left;
  }

  @keyframes scroll-text {
    0%, 15% { transform: translateX(0); }
    42.5%, 57.5% { transform: translateX(var(--scroll-distance, 0px)); }
    85%, 100% { transform: translateX(0); }
  }
</style>

<script>
  import { strings } from '../../lib/i18n';

  // Detect overflow and add scroll animation
  document.querySelectorAll<HTMLElement>('[data-variant-name]').forEach(name => {
    const container = name.parentElement;
    if (!container) return;

    if (name.scrollWidth > container.clientWidth) {
      const distance = -(name.scrollWidth - container.clientWidth);
      name.style.setProperty('--scroll-distance', `${distance}px`);
      name.classList.add('scrolling');
    }
  });

  document.querySelectorAll<HTMLElement>('[data-variant-btn]').forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active state for all buttons
      document.querySelectorAll<HTMLElement>('[data-variant-btn]').forEach(b => {
        const ring = b.querySelector<HTMLElement>('[data-variant-ring]');
        const nameEl = b.querySelector<HTMLElement>('[data-variant-name]');
        if (ring) {
          ring.classList.remove('border-accent');
          ring.classList.add('border-border-light');
        }
        if (nameEl) {
          nameEl.classList.remove('text-accent');
          nameEl.classList.add('text-text-secondary');
        }
      });

      const ring = btn.querySelector<HTMLElement>('[data-variant-ring]');
      const nameEl = btn.querySelector<HTMLElement>('[data-variant-name]');
      if (ring) {
        ring.classList.add('border-accent');
        ring.classList.remove('border-border-light');
      }
      if (nameEl) {
        nameEl.classList.add('text-accent');
        nameEl.classList.remove('text-text-secondary');
      }

      // Update price
      const price = parseFloat(btn.dataset.variantPrice ?? '0');
      document.querySelectorAll('[data-product-price]').forEach(el => {
        el.textContent = `${price.toFixed(2)}${strings.currency}`;
      });

      // Update stock
      const stock = parseInt(btn.dataset.variantStock ?? '0');
      document.querySelectorAll('[data-variant-stock-global]').forEach(el => {
        const inStock = stock > 0;
        el.textContent = inStock ? strings.productInStock : strings.productOutOfStock;
        if (inStock) {
          el.classList.add('text-green-600', 'dark:text-green-400');
          el.classList.remove('text-red-500', 'dark:text-red-400');
        } else {
          el.classList.add('text-red-500', 'dark:text-red-400');
          el.classList.remove('text-green-600', 'dark:text-green-400');
        }
      });

      // Dispatch variant image change event for gallery
      const variantImage = btn.dataset.variantImage;
      if (variantImage) {
        document.dispatchEvent(new CustomEvent('variant:change', {
          detail: { image: variantImage }
        }));
      }
    });
  });
</script>
