---
import Icon from '../icons/Icon.astro';
import { strings } from '../../lib/core/i18n';

interface Props {
  email: string | null;
  whatsapp: string | null;
}

const { email, whatsapp } = Astro.props;
const sanitizedWhatsapp = whatsapp?.replace(/[^0-9]/g, '');
---

{(email || whatsapp) && (
  <div class="fixed bottom-20 right-4 md:bottom-8 md:right-8 z-40 flex flex-col items-end gap-3" data-contact-fab>
    {/* Expandable sub-buttons */}
    <div
      class="flex flex-col items-end gap-3 opacity-0 scale-90 pointer-events-none transition-all duration-200 origin-bottom"
      data-contact-options
    >
      {email && (
        <a
          href={`mailto:${email}`}
          class="w-12 h-12 flex items-center justify-center rounded-full bg-surface shadow-lg border border-border-light text-text-primary transition-colors hover:bg-bg-secondary"
          aria-label={strings.productContactEmail}
        >
          <Icon name="mail" size={20} />
        </a>
      )}
      {sanitizedWhatsapp && (
        <a
          href={`https://wa.me/${sanitizedWhatsapp}`}
          target="_blank"
          rel="noopener noreferrer"
          class="w-12 h-12 flex items-center justify-center rounded-full bg-[#25D366] shadow-lg text-white transition-colors hover:bg-[#20bd5a]"
          aria-label={strings.productContactWhatsapp}
        >
          <Icon name="whatsapp" size={24} />
        </a>
      )}
    </div>

    {/* Main FAB */}
    <button
      type="button"
      class="relative w-14 h-14 rounded-full bg-secondary text-bg shadow-lg flex items-center justify-center transition-all duration-300 hover:bg-secondary-hover active:scale-95 group"
      aria-label={strings.productContact}
      data-contact-toggle
    >
      <Icon name="message-circle" size={26} class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 transition-all duration-300 opacity-100 rotate-0 scale-100" data-fab-icon-open />
      <Icon name="chevron-down" size={28} class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 transition-all duration-300 opacity-0 -rotate-180 scale-50" data-fab-icon-close />
    </button>
  </div>
)}

<script>
  function setContactFabOpen(fab: Element, open: boolean) {
    const options = fab.querySelector('[data-contact-options]');
    const iconOpen = fab.querySelector('[data-fab-icon-open]');
    const iconClose = fab.querySelector('[data-fab-icon-close]');

    if (options) {
      options.classList.toggle('opacity-0', !open);
      options.classList.toggle('scale-90', !open);
      options.classList.toggle('pointer-events-none', !open);
      options.classList.toggle('opacity-100', open);
      options.classList.toggle('scale-100', open);
    }

    if (iconOpen && iconClose) {
      iconOpen.classList.toggle('opacity-100', !open);
      iconOpen.classList.toggle('scale-100', !open);
      iconOpen.classList.toggle('rotate-0', !open);
      iconOpen.classList.toggle('opacity-0', open);
      iconOpen.classList.toggle('scale-50', open);
      iconOpen.classList.toggle('rotate-180', open);

      iconClose.classList.toggle('opacity-0', !open);
      iconClose.classList.toggle('scale-50', !open);
      iconClose.classList.toggle('-rotate-180', !open);
      iconClose.classList.toggle('opacity-100', open);
      iconClose.classList.toggle('scale-100', open);
      iconClose.classList.toggle('rotate-0', open);
    }

    fab.setAttribute('data-open', open ? 'true' : 'false');
  }

  function initContactFabs() {
    document.querySelectorAll('[data-contact-fab]').forEach(fab => {
      if (fab.getAttribute('data-contact-bound') === 'true') return;
      fab.setAttribute('data-contact-bound', 'true');

      const toggle = fab.querySelector('[data-contact-toggle]');
      toggle?.addEventListener('click', () => {
        setContactFabOpen(fab, fab.getAttribute('data-open') !== 'true');
      });
    });
  }

  // Close any open FAB when clicking outside. Registered once for the page session.
  document.addEventListener('click', (e) => {
    document.querySelectorAll('[data-contact-fab][data-open="true"]').forEach(fab => {
      if (!fab.contains(e.target as Node)) {
        setContactFabOpen(fab, false);
      }
    });
  });

  document.addEventListener('astro:page-load', initContactFabs);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactFabs);
  } else {
    initContactFabs();
  }
</script>
