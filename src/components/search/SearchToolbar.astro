---
import Icon from "../icons/Icon.astro";

import type { SearchParams } from "../../lib/products/search";
const { t } = Astro.locals;

interface Props {
    params: SearchParams;
}

const { params } = Astro.props;

let filterCount = 0;
if (params.minPrice !== null) filterCount++;
if (params.maxPrice !== null) filterCount++;
if (params.showOos) filterCount++;

const sortLabels: Record<string, string> = {
    relevance: t.searchSortRelevance,
    alpha: t.searchSortAlpha,
    price: t.searchSortPrice,
    date: t.searchSortDate,
};
const sortLabel = sortLabels[params.sort] || t.searchSortRelevance;
---

<div class="sticky top-[60px] md:top-[68px] z-40 bg-bg border-b border-border-light">
    <div class="flex items-center mx-4 md:max-w-[1400px] md:mx-auto md:px-6 py-3 divide-x divide-border-light relative space-x-0">
        <button 
            type="button" 
            class="flex-1 flex justify-center items-center gap-2 text-[14px] font-medium text-text-secondary transition-colors hover:text-text-primary h-8"
            onclick="document.getElementById('filter-modal')?.showModal()"
        >
            <Icon name="sliders" size={16} />
            <span>{t.searchFilters}</span>
            {filterCount > 0 && (
                <span class="flex items-center justify-center bg-text-primary text-bg text-[10px] font-bold rounded-full w-4 h-4 ml-1">
                    {filterCount}
                </span>
            )}
        </button>
        
        <button 
            type="button" 
            class="flex-1 flex justify-center items-center gap-2 text-[14px] font-medium text-text-secondary transition-colors hover:text-text-primary h-8"
            onclick="document.getElementById('sort-modal')?.showModal()"
        >
            <Icon name="sort-desc" size={16} />
            <span>{sortLabel}</span>
        </button>
    </div>
</div>