---
import Icon from "../icons/Icon.astro";
import { strings } from "../../lib/core/i18n";
import {
    normalizeOrderStatus,
    getStatusBadgeClass,
    getStatusLabel,
    formatOrderDate,
    formatEur,
    getRefundedAmounts,
} from "../../lib/orders/orderCardModel";
import { ORDER_STATUS } from "../../lib/orders/orderStatus";
import HideOrderModal from "./HideOrderModal.astro";
import CancelIncidentModal from "./CancelIncidentModal.astro";
import IncidentModal from "./IncidentModal.astro";
import ReviewModal from "./ReviewModal.astro";

export interface OrderItem {
    productTitle: string;
    imageUrl: string;
    productSlug: string;
    shopSlug: string;
    variantName: string | null;
    quantity?: number;
    unitPrice?: number;
    productId?: string;
}

export interface OrderReview {
    rating: number;
    comment: string | null;
}

export interface OrderCardData {
    orderId: string;
    publicId: string;
    status: string;
    totalAmount: number;
    subtotal: number;
    shipping: number;
    createdAt: Date;
    cancellationReason?: string | null;
    items: OrderItem[];
    hasShipment?: boolean;
    trackingNumber?: string | null;
    trackingUrl?: string | null;
    labelUrl?: string | null;
    carrierName?: string | null;
    incidentDescription?: string | null;
    incidentPhotos?: string[] | null;
    sellerEmail?: string | null;
    refundedAmount?: number | null;
    shippingRetained?: number | null;
    reviews?: Record<string, OrderReview>;
}

interface Props {
    order: OrderCardData;
}

const { order } = Astro.props;

const normalizedStatus = normalizeOrderStatus(order.status);
const statusLabel = getStatusLabel(normalizedStatus);
const statusColor = getStatusBadgeClass(normalizedStatus);

const firstItem = order.items[0];
const itemCount = order.items.reduce((sum, item) => sum + (item.quantity ?? 1), 0);

const dateFormatted = formatOrderDate(order.createdAt);
const totalFormatted = formatEur(order.totalAmount);

const showTracking = order.hasShipment && (order.trackingNumber || order.trackingUrl);
const showActions = normalizedStatus === ORDER_STATUS.DELIVERED;
const showIncident = normalizedStatus === ORDER_STATUS.INCIDENT && order.incidentDescription;
const showCancelIncident = normalizedStatus === ORDER_STATUS.INCIDENT;
const showReview = normalizedStatus === ORDER_STATUS.CONFIRMED && order.items.length > 0;
const { showRefunded, refundedAmountFormatted, shippingRetainedFormatted } = getRefundedAmounts(
    normalizedStatus,
    order.refundedAmount,
    order.shippingRetained,
);
const hasAnyReview = order.items.some(item => item.productId && order.reviews?.[item.productId]);
const showHide = normalizedStatus === ORDER_STATUS.PENDING;
---

<article class="bg-surface rounded-2xl border border-border-light overflow-hidden" data-order-id={order.orderId} data-order-status={normalizedStatus}>
    {/* Public order ID with copy popover */}
    <div class="flex items-center justify-end px-4 pt-3 md:px-5 md:pt-3.5">
        <order-id-popover class="relative inline-flex" data-id={order.publicId}>
            <button
                type="button"
                class="trigger-btn group inline-flex items-center gap-1.5 rounded-md bg-neutral-100 dark:bg-neutral-800 px-2 py-0.5 text-[11px] font-bold uppercase tracking-[0.12em] text-text-secondary hover:bg-neutral-200 dark:hover:bg-neutral-700 hover:text-text-primary transition-all focus:outline-none ring-accent focus:ring-2"
            >
                #{order.publicId}
                <Icon name="copy" size={11} class="shrink-0 opacity-50 group-hover:opacity-100 transition-opacity" />
            </button>
            <div class="popover hidden absolute top-full right-0 mt-2 z-[60] flex items-center bg-neutral-950 dark:bg-neutral-100 rounded-xl shadow-[0_12px_40px_rgb(0,0,0,0.25)] dark:shadow-[0_12px_40px_rgb(0,0,0,0.6)] p-1.5 gap-2 min-w-max">
                <span class="text-[12px] font-bold text-neutral-100 dark:text-neutral-900 tracking-[0.12em] uppercase select-all pl-2">
                    #{order.publicId}
                </span>
                <button type="button" class="copy-btn shrink-0 p-1.5 rounded-lg bg-neutral-800 dark:bg-neutral-200 hover:bg-neutral-700 dark:hover:bg-neutral-300 text-neutral-300 dark:text-neutral-700 hover:text-white dark:hover:text-neutral-900 transition-colors focus:outline-none">
                    <Icon name="copy" size={13} class="icon-copy block" />
                    <Icon name="check" size={13} class="icon-check hidden text-green-400 dark:text-green-600" />
                </button>
            </div>
        </order-id-popover>
    </div>

    {/* Collapsible header */}
    <button
        type="button"
        class="order-toggle-btn group w-full flex items-center gap-4 pt-3 pb-4 px-4 md:pt-3 md:pb-5 md:px-5 text-left hover:bg-bg transition-colors duration-200 select-none"
        aria-expanded="false"
        aria-controls={`order-details-${order.orderId}`}
    >
        {/* Thumbnail */}
        <div class="relative flex-shrink-0 w-16 h-16 md:w-[72px] md:h-[72px] rounded-xl overflow-hidden bg-skeleton" data-img-wrap>
            {firstItem?.imageUrl ? (
                <img
                    src={firstItem.imageUrl}
                    alt={firstItem.productTitle}
                    class="w-full h-full object-cover opacity-0 transition-opacity duration-300 group-hover:scale-105"
                    draggable="false"
                    loading="lazy"
                    decoding="async"
                    onload="this.classList.remove('opacity-0'); this.closest('[data-img-wrap]')?.classList.remove('bg-skeleton')"
                    onerror="this.classList.remove('opacity-0'); this.closest('[data-img-wrap]')?.classList.remove('bg-skeleton')"
                />
            ) : (
                <div class="w-full h-full flex items-center justify-center text-text-tertiary">
                    <Icon name="shopping-cart" size={24} />
                </div>
            )}
            {order.items.length > 1 && (
                <div class="absolute inset-0 bg-black/50 flex items-center justify-center">
                    <span class="text-white text-sm font-bold">{itemCount}</span>
                </div>
            )}
        </div>

        {/* Content */}
        <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                    <p class="text-[15px] font-semibold text-text-primary truncate leading-snug">
                        {order.items.length === 1
                            ? `${firstItem?.productTitle}${(firstItem?.quantity ?? 1) > 1 ? ` ×${firstItem?.quantity}` : ''}`
                            : `${itemCount} ${strings.ordersItemsPlural}`}
                    </p>
                    {order.items.length === 1 && firstItem?.variantName && (
                        <p class="text-[12px] text-text-tertiary truncate mt-0.5">
                            {firstItem.variantName}
                        </p>
                    )}
                    <p class="text-[13px] text-text-secondary mt-1">{dateFormatted}</p>
                </div>
                <div class="flex flex-col items-end gap-1.5 flex-shrink-0">
                    <span class="text-[15px] font-bold text-text-primary tabular-nums">
                        {totalFormatted}
                    </span>
                    <span class={`text-[11px] font-semibold px-2 py-0.5 rounded-full ${statusColor}`}>
                        {statusLabel}
                    </span>
                </div>
            </div>
        </div>

        {/* Chevron */}
        <Icon
            name="chevron-down"
            size={18}
            class="toggle-icon flex-shrink-0 text-text-tertiary group-hover:text-text-primary transition-transform duration-200"
        />
    </button>

    {/* Expandable details */}
    <div id={`order-details-${order.orderId}`} class="order-details hidden border-t border-border-light">
        <div class="px-4 py-4 md:px-5 md:py-5 flex flex-col gap-4">
            {/* Items list */}
            <div class="flex flex-col gap-3">
                {order.items.map((item) => (
                    <a
                        href={`/${item.shopSlug}/${item.productSlug}`}
                        class="flex items-center gap-3 rounded-xl border border-border-light bg-bg/50 p-3 hover:border-border hover:bg-bg transition-colors"
                    >
                        <div class="relative flex-shrink-0 w-14 h-14 rounded-lg overflow-hidden bg-border-light">
                            {item.imageUrl ? (
                                <img src={item.imageUrl} alt={item.productTitle} class="w-full h-full object-cover" loading="lazy" />
                            ) : (
                                <div class="w-full h-full flex items-center justify-center text-text-tertiary">
                                    <Icon name="shopping-cart" size={18} />
                                </div>
                            )}
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-semibold text-text-primary truncate leading-snug">
                                {item.productTitle}
                            </p>
                            {item.variantName && (
                                <p class="text-[12px] text-text-secondary truncate mt-0.5">
                                    {item.variantName}
                                </p>
                            )}
                            <p class="text-[12px] font-medium text-text-tertiary mt-0.5">
                                {item.quantity ?? 1} {strings.ordersItemsUnit} · {formatEur(item.unitPrice ?? 0)}
                            </p>
                        </div>
                        <div class="flex-shrink-0">
                            <span class="text-sm font-bold text-text-primary tabular-nums">
                                {formatEur((item.unitPrice ?? 0) * (item.quantity ?? 1))}
                            </span>
                        </div>
                        <Icon name="chevron-right" size={16} class="flex-shrink-0 text-text-tertiary" />
                    </a>
                ))}
            </div>

            {/* Price breakdown */}
            <div class="rounded-xl border border-border-light bg-bg/50 p-4 flex flex-col gap-2">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary">{strings.ordersSubtotal}</span>
                    <span class="font-semibold text-text-primary tabular-nums">{formatEur(order.subtotal)}</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary">{strings.cartShipping}</span>
                    <span class="font-semibold text-text-primary tabular-nums">
                        {order.shipping > 0 ? formatEur(order.shipping) : strings.ordersFreeShipping}
                    </span>
                </div>
                <div class="mt-1 pt-2 border-t border-border-light flex items-center justify-between text-sm">
                    <span class="font-semibold text-text-primary">{strings.cartTotal}</span>
                    <span class="font-bold text-text-primary tabular-nums">{formatEur(order.totalAmount)}</span>
                </div>
            </div>
        </div>
    </div>

    {normalizedStatus === ORDER_STATUS.DELIVERY_FAILED && (
        <div class="px-4 pb-4 -mt-1 md:px-5 md:pb-5">
            <div class="p-4 rounded-2xl bg-rose-50 dark:bg-rose-900/20 border border-rose-100 dark:border-rose-800">
                <p class="text-[11px] font-semibold uppercase tracking-wider text-rose-700 dark:text-rose-400 mb-1">
                    {strings.deliveryFailedBuyerTitle}
                </p>
                <p class="text-sm text-rose-800 dark:text-rose-300 leading-relaxed">
                    {strings.deliveryFailedBuyerNotice}
                </p>
            </div>
        </div>
    )}

    {normalizedStatus === ORDER_STATUS.CANCELLED && order.cancellationReason && (
        <div class="px-4 pb-3 -mt-1 md:px-5 md:pb-4">
            <div class="p-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-100 dark:border-red-800">
                <p class="text-[11px] font-semibold uppercase tracking-wider text-red-700 dark:text-red-400 mb-1">
                    {strings.orderCancellationReason}
                </p>
                <p class="text-sm text-red-800 dark:text-red-300 leading-relaxed">{order.cancellationReason}</p>
            </div>
        </div>
    )}

    {showRefunded && (
        <div class="px-4 pb-4 -mt-1 md:px-5 md:pb-5">
            <div class="p-4 rounded-2xl bg-orange-50 dark:bg-orange-900/20 border border-orange-100 dark:border-orange-800">
                <div class="flex items-start justify-between gap-3 mb-2">
                    <p class="text-[11px] font-semibold uppercase tracking-wider text-orange-700 dark:text-orange-400">
                        {strings.orderRefundedBuyerTitle}
                    </p>
                    <span class="shrink-0 text-base font-bold text-orange-700 dark:text-orange-300 tabular-nums">
                        {refundedAmountFormatted}
                    </span>
                </div>
                <p class="text-sm text-orange-800 dark:text-orange-300 leading-relaxed">
                    {strings.orderRefundedBuyerNotice}
                </p>
                {shippingRetainedFormatted && (
                    <p class="mt-2 text-[11px] text-orange-700/80 dark:text-orange-400/80 tabular-nums">
                        {strings.orderRefundedRetainedLabel}: {shippingRetainedFormatted}
                    </p>
                )}
            </div>
        </div>
    )}

    {showTracking && (
        <div class="flex flex-wrap items-center gap-2 px-4 pb-4 -mt-2 md:px-5 md:pb-5">
            {order.trackingUrl && (
                <>
                    <span class="text-[11px] text-text-secondary">Seguir envío:</span>
                    <a
                        href={order.trackingUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 px-2 py-1 text-[11px] font-semibold rounded-full bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-400 hover:bg-purple-200 dark:hover:bg-purple-900/60 transition-colors"
                    >
                        {order.trackingNumber || 'Seguir'}
                        <Icon name="arrow-up-right" size={10} />
                    </a>
                </>
            )}
        </div>
    )}

    {showActions && (
        <div class="px-4 pb-4 md:px-5 md:pb-5 flex flex-col gap-2">
            <p class="text-xs text-text-tertiary">{strings.orderAutoConfirmHint}</p>
            <div class="flex flex-wrap gap-2">
                <button
                    type="button"
                    class="order-confirm-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400 hover:bg-green-200 dark:hover:bg-green-900/60 transition-colors"
                    data-order-id={order.orderId}
                >
                    <Icon name="check" size={12} />
                    {strings.orderConfirmDelivery}
                </button>
                <button
                    type="button"
                    class="open-incident-modal-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400 hover:bg-red-200 dark:hover:bg-red-900/60 transition-colors"
                    data-order-id={order.orderId}
                >
                    <Icon name="alert-circle" size={12} />
                    {strings.orderReportIncident}
                </button>
            </div>
        </div>
    )}

    {showReview && (
        <div class="px-4 pb-4 md:px-5 md:pb-5 flex flex-col gap-2">
            <button
                type="button"
                class="open-review-modal-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400 hover:bg-amber-200 dark:hover:bg-amber-900/60 transition-colors self-start"
                data-order-id={order.orderId}
            >
                <Icon name={hasAnyReview ? 'pencil' : 'star'} size={12} />
                {hasAnyReview ? strings.reviewEditBtn : strings.reviewAddBtn}
            </button>
        </div>
    )}

    {showHide && (
        <div class="px-4 pb-4 md:px-5 md:pb-5">
            <button
                type="button"
                class="open-hide-order-modal-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-zinc-100 text-zinc-500 dark:bg-zinc-800 dark:text-zinc-400 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors"
                data-order-id={order.orderId}
            >
                <Icon name="trash-2" size={12} />
                {strings.orderHideBtn}
            </button>
        </div>
    )}

    {showIncident && (
        <div class="px-4 pb-4 md:px-5 md:pb-5 flex flex-col gap-4">
            <div class="p-4 rounded-2xl bg-red-50 dark:bg-red-900/20 border border-red-100 dark:border-red-800">
                <p class="text-[11px] font-semibold uppercase tracking-wider text-red-700 dark:text-red-400 mb-2">
                    {strings.orderIncidentReported}
                </p>
                <p class="text-sm text-red-800 dark:text-red-300 leading-relaxed whitespace-pre-line">
                    {order.incidentDescription}
                </p>
            </div>

            {order.incidentPhotos && order.incidentPhotos.length > 0 && (
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-text-secondary mb-2">
                        {strings.incidentPanelPhotosLabel}
                    </p>
                    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-2">
                        {order.incidentPhotos.map((photo) => (
                            <a href={photo} target="_blank" rel="noopener noreferrer" class="block aspect-square rounded-xl overflow-hidden border border-border-light bg-border-light hover:opacity-90 transition-opacity">
                                <img src={photo} alt="Evidencia" class="w-full h-full object-cover" loading="lazy" />
                            </a>
                        ))}
                    </div>
                </div>
            )}

            <div class="p-3 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800">
                <p class="text-xs text-blue-800 dark:text-blue-300 leading-relaxed">
                    {strings.incidentUnderReviewNotice}{' '}
                    {order.sellerEmail ? (
                        <a href={`mailto:${order.sellerEmail}`} class="font-semibold underline hover:no-underline text-blue-900 dark:text-blue-200">
                            {order.sellerEmail}
                        </a>
                    ) : (
                        <span class="font-semibold">el vendedor</span>
                    )}
                    {strings.incidentReturnPolicyNoticeSuffix}
                </p>
            </div>

            {showCancelIncident && (
                <button
                    type="button"
                    class="open-cancel-incident-modal-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors self-start"
                    data-order-id={order.orderId}
                >
                    <Icon name="x" size={12} />
                    {strings.incidentCancelBtn}
                </button>
            )}
        </div>
    )}

    {showHide && <HideOrderModal orderId={order.orderId} />}
    {showCancelIncident && <CancelIncidentModal orderId={order.orderId} />}
    {showActions && <IncidentModal orderId={order.orderId} sellerEmail={order.sellerEmail} />}
    {showReview && <ReviewModal orderId={order.orderId} items={order.items} reviews={order.reviews} />}
</article>

<script>
    import { strings } from '../../lib/core/i18n';
    import { runSubmit, SubmitError } from '../../lib/ui/submit';

    class OrderIdPopover extends HTMLElement {
        constructor() {
            super();

            const btn = this.querySelector('.trigger-btn');
            const popover = this.querySelector('.popover');
            const copyBtn = this.querySelector('.copy-btn');
            const iconCopy = this.querySelector('.icon-copy');
            const iconCheck = this.querySelector('.icon-check');
            const id = this.dataset.id || '';

            if (!btn || !popover || !copyBtn || !iconCopy || !iconCheck) return;

            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                e.preventDefault();
                document.querySelectorAll('order-id-popover .popover:not(.hidden)').forEach(el => {
                    if (el !== popover) el.classList.add('hidden');
                });
                popover.classList.toggle('hidden');
            });

            document.addEventListener('click', (e) => {
                if (!this.contains(e.target as Node) && !popover.classList.contains('hidden')) {
                    popover.classList.add('hidden');
                }
            });

            copyBtn.addEventListener('click', async (e) => {
                e.stopPropagation();
                e.preventDefault();
                try {
                    await navigator.clipboard.writeText(id);
                    iconCopy.classList.replace('block', 'hidden');
                    iconCheck.classList.replace('hidden', 'block');
                    setTimeout(() => {
                        iconCheck.classList.replace('block', 'hidden');
                        iconCopy.classList.replace('hidden', 'block');
                    }, 2000);
                } catch (err) {
                    console.error('Failed to copy text: ', err);
                }
            });
        }
    }

    if (!customElements.get('order-id-popover')) {
        customElements.define('order-id-popover', OrderIdPopover);
    }

    // Delegated listeners for handlers tightly coupled to the card itself
    // (toggle + confirm-delivery). Modal open/close/submit logic lives in each
    // modal component. Must be delegated because DeferredBuyerOrders uses
    // server:defer, injecting HTML after astro:page-load fires.
    if (!(window as unknown as { __orderCardBound?: boolean }).__orderCardBound) {
        (window as unknown as { __orderCardBound?: boolean }).__orderCardBound = true;

        document.addEventListener('click', async (e) => {
            const target = e.target as HTMLElement;
            if (!(target instanceof Element)) return;

            const toggleBtn = target.closest<HTMLButtonElement>('.order-toggle-btn');
            if (toggleBtn) {
                const article = toggleBtn.closest('article');
                const details = article?.querySelector('.order-details') as HTMLElement | null;
                const icon = toggleBtn.querySelector('.toggle-icon') as HTMLElement | null;
                const expanded = toggleBtn.getAttribute('aria-expanded') === 'true';
                details?.classList.toggle('hidden', expanded);
                if (icon) icon.style.transform = expanded ? 'rotate(0deg)' : 'rotate(180deg)';
                toggleBtn.setAttribute('aria-expanded', String(!expanded));
                return;
            }

            const confirmBtn = target.closest<HTMLButtonElement>('.order-confirm-btn');
            if (confirmBtn && !confirmBtn.disabled) {
                e.preventDefault();
                e.stopPropagation();
                const orderId = confirmBtn.dataset.orderId;
                if (!orderId) return;
                if (!confirm('¿Confirmas que has recibido el pedido correctamente?')) return;
                const result = await runSubmit({
                    button: confirmBtn,
                    action: async () => {
                        const res = await fetch('/api/orders/confirm-delivery', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ orderId }),
                        });
                        const data = await res.json() as { success?: boolean; error?: string };
                        if (!data.success) throw new SubmitError(data.error || strings.orderConfirmDeliveryError);
                        return data;
                    },
                    successMsg: strings.orderConfirmedToast,
                });
                if (result.ok) {
                    window.setTimeout(() => window.location.reload(), 800);
                }
                return;
            }
        });
    }
</script>
