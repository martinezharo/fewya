---
import Icon from '../icons/Icon.astro';
import { strings } from '../../lib/core/i18n';

interface Props {
    orderId: string;
}

const { orderId } = Astro.props;
---

<div class="hide-order-modal hidden fixed inset-0 z-[100] flex items-end sm:items-center justify-center bg-black/50 backdrop-blur-sm p-0 sm:p-4" data-order-id={orderId}>
    <div class="w-full max-w-md rounded-t-2xl sm:rounded-2xl border border-border bg-surface p-5 shadow-xl">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-base font-semibold text-text-primary">{strings.orderHideModalTitle}</h3>
            <button type="button" class="close-hide-order-modal-btn p-1.5 rounded-lg hover:bg-border-light transition-colors text-text-secondary">
                <Icon name="x" size={18} />
            </button>
        </div>
        <p class="text-sm text-text-secondary mb-5 leading-relaxed">{strings.orderHideModalBody}</p>
        <div class="flex gap-2 justify-end">
            <button type="button" class="close-hide-order-modal-btn px-3 py-1.5 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors">
                {strings.orderHideDismiss}
            </button>
            <button type="button" class="confirm-hide-order-btn px-3 py-1.5 text-sm font-semibold rounded-lg bg-zinc-800 text-white dark:bg-zinc-200 dark:text-zinc-900 hover:bg-zinc-700 dark:hover:bg-zinc-300 transition-colors disabled:opacity-50 disabled:cursor-not-allowed" data-order-id={orderId}>
                {strings.orderHideConfirm}
            </button>
        </div>
    </div>
</div>

<script>
    import { strings } from '../../lib/core/i18n';
    import { runSubmit, SubmitError } from '../../lib/ui/submit';

    function wireModal(modal: HTMLElement) {
        if (modal.dataset.hideOrderWired === '1') return;
        modal.dataset.hideOrderWired = '1';

        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                modal.classList.add('hidden');
                document.body.style.overflow = '';
            }
        });

        modal.querySelectorAll<HTMLButtonElement>('.close-hide-order-modal-btn').forEach((btn) => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                modal.classList.add('hidden');
                document.body.style.overflow = '';
            });
        });

        const confirmBtn = modal.querySelector<HTMLButtonElement>('.confirm-hide-order-btn');
        confirmBtn?.addEventListener('click', async (e) => {
            e.preventDefault();
            const orderId = confirmBtn.dataset.orderId;
            if (!orderId) return;

            const result = await runSubmit({
                button: confirmBtn,
                action: async () => {
                    const res = await fetch('/api/orders/hide', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ orderId }),
                    });
                    const data = await res.json() as { success?: boolean; error?: string };
                    if (!data.success) throw new SubmitError(data.error || strings.orderHideError);
                    return data;
                },
                successMsg: strings.orderHideSuccess,
            });
            if (result.ok) {
                modal.classList.add('hidden');
                document.body.style.overflow = '';
                const article = document.querySelector(`article[data-order-id="${orderId}"]`);
                article?.remove();
            }
        });
    }

    function wireAll() {
        document.querySelectorAll<HTMLElement>('.hide-order-modal').forEach(wireModal);
    }

    if (!(window as unknown as { __hideOrderModalOpenBound?: boolean }).__hideOrderModalOpenBound) {
        (window as unknown as { __hideOrderModalOpenBound?: boolean }).__hideOrderModalOpenBound = true;
        document.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            if (!target || !(target instanceof Element)) return;
            const openBtn = target.closest<HTMLElement>('.open-hide-order-modal-btn');
            if (!openBtn) return;
            e.preventDefault();
            const orderId = openBtn.dataset.orderId;
            if (!orderId) return;
            const modal = document.querySelector<HTMLElement>(`.hide-order-modal[data-order-id="${orderId}"]`);
            if (!modal) return;
            wireModal(modal);
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        });
    }

    document.addEventListener('astro:page-load', wireAll);
    if (document.readyState !== 'loading') wireAll();
    else document.addEventListener('DOMContentLoaded', wireAll);
</script>
