---
import Icon from '../icons/Icon.astro';
import { strings } from '../../lib/i18n';

export interface SellerOrderItem {
    productTitle: string;
    imageUrl: string;
    productSlug: string | null;
    variantName: string | null;
    quantity: number;
    unitPrice: number;
}

export interface SellerOrderCardData {
    orderId: string;
    publicId: string;
    status: string;
    createdAt: Date;
    buyerEmail: string | null;
    shippingFullName: string | null;
    shippingPhone: string | null;
    shippingAddress: string | null;
    subtotal: number;
    itemsSold: number;
    items: SellerOrderItem[];
    shopSlug: string;
}

interface Props {
    order: SellerOrderCardData;
}

const { order } = Astro.props;

const statusMap: Record<string, string> = {
    pending: strings.orderStatusPending,
    paid: strings.orderStatusPaid,
    processing: strings.orderStatusProcessing,
    shipped: strings.orderStatusShipped,
    delivered: strings.orderStatusDelivered,
    cancelled: strings.orderStatusCancelled,
};

const statusColorMap: Record<string, string> = {
    pending: 'bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400',
    paid: 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400',
    processing: 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400',
    shipped: 'bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-400',
    delivered: 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400',
    cancelled: 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400',
};

const normalizedStatus = order.status?.toLowerCase() ?? 'pending';
const statusLabel = statusMap[normalizedStatus] ?? order.status;
const statusColor = statusColorMap[normalizedStatus] ?? statusColorMap.pending;
const dateFormatted = order.createdAt.toLocaleDateString('es-ES', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
});
const currencyFormatter = new Intl.NumberFormat('es-ES', {
    style: 'currency',
    currency: 'EUR',
});
const customerName = order.shippingFullName || order.buyerEmail || strings.profileAnonymous;
---

<article class="rounded-3xl border border-border bg-surface p-5 sm:p-6 shadow-sm overflow-hidden flex flex-col gap-6">
    <div class="flex items-start justify-between gap-4">
        <div class="min-w-0 flex-1">
            <div class="flex items-center gap-3">
                <span class={`shrink-0 inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold ${statusColor}`}>
                    {statusLabel}
                </span>
                <span class="text-[11px] font-bold uppercase tracking-[0.12em] text-text-tertiary truncate block">
                    #{order.publicId}
                </span>
            </div>
            <p class="mt-3 text-base md:text-lg font-semibold text-text-primary truncate">{customerName}</p>
            <p class="mt-0.5 text-sm text-text-secondary">{dateFormatted}</p>
        </div>

        <div class="shrink-0 text-right">
            <p class="text-xl md:text-2xl font-bold tracking-tight text-text-primary tabular-nums">
                {currencyFormatter.format(order.subtotal)}
            </p>
            <p class="mt-1.5 text-xs font-medium text-text-tertiary tabular-nums">
                {order.itemsSold} {order.itemsSold === 1 ? strings.ordersItemsSingular : strings.ordersItemsPlural}
            </p>
        </div>
    </div>

    <hr class="border-border" />

    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.4fr)_minmax(320px,1fr)]">
        <section>
            <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary mb-5">
                <Icon name="package" size={16} class="text-text-tertiary" />
                <span>{strings.sellerOrdersProductsLabel}</span>
            </div>

            <div class="flex flex-col gap-5">
                {order.items.map((item) => (
                    <div class="flex items-start gap-4">
                        <div class="h-16 w-16 md:h-20 md:w-20 shrink-0 overflow-hidden rounded-2xl border border-border-light bg-bg/50">
                            {item.imageUrl ? (
                                <img
                                    src={item.imageUrl}
                                    alt={item.productTitle}
                                    class="h-full w-full object-cover"
                                    loading="lazy"
                                />
                            ) : (
                                <div class="flex h-full w-full items-center justify-center text-text-tertiary">
                                    <Icon name="package" size={20} />
                                </div>
                            )}
                        </div>

                        <div class="min-w-0 flex-1 pt-0.5">
                            <div class="flex items-start justify-between gap-3">
                                {item.productSlug ? (
                                    <a
                                        href={`/${order.shopSlug}/${item.productSlug}`}
                                        class="block font-semibold text-text-primary transition-colors hover:text-accent leading-tight line-clamp-2"
                                    >
                                        {item.productTitle}
                                    </a>
                                ) : (
                                    <p class="font-semibold text-text-primary leading-tight line-clamp-2">{item.productTitle}</p>
                                )}

                                <span class="shrink-0 text-sm font-bold text-text-primary tabular-nums pt-0.5">
                                    {currencyFormatter.format(item.quantity * item.unitPrice)}
                                </span>
                            </div>

                            {item.variantName && (
                                <p class="mt-1 truncate text-[13px] text-text-secondary">{item.variantName}</p>
                            )}

                            <p class="mt-1.5 text-[12px] font-semibold text-text-tertiary bg-bg inline-flex px-2 py-0.5 rounded-md">
                                {item.quantity} x {currencyFormatter.format(item.unitPrice)}
                            </p>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <section>
            <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary mb-5">
                <Icon name="user" size={16} class="text-text-tertiary" />
                <span>{strings.sellerOrdersCustomerLabel}</span>
            </div>

            <ul class="flex flex-col gap-4 text-[14px]">
                <li class="flex items-start gap-3">
                    <Icon name="user" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                    <span class="font-medium text-text-primary">{customerName}</span>
                </li>

                {order.buyerEmail && (
                    <li class="flex items-start gap-3">
                        <Icon name="mail" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                        <span class="break-all text-text-secondary">{order.buyerEmail}</span>
                    </li>
                )}

                {order.shippingPhone && (
                    <li class="flex items-start gap-3">
                        <Icon name="whatsapp" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                        <span class="text-text-secondary">{order.shippingPhone}</span>
                    </li>
                )}

                {order.shippingAddress && (
                    <li class="flex items-start gap-3">
                        <Icon name="map-pin" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                        <span class="text-text-secondary whitespace-pre-line leading-relaxed">{order.shippingAddress}</span>
                    </li>
                )}
            </ul>
        </section>
    </div>
</article>