---
import Icon from '../icons/Icon.astro';
import RefundOrderModal from './RefundOrderModal.astro';
import { strings } from '../../lib/core/i18n';
import {
    normalizeOrderStatus,
    getStatusBadgeClass,
    getStatusLabel,
    formatOrderDate,
    formatEur,
    getSellerDeliveryFlags,
    getRefundedAmounts,
    formatShippingCell,
} from '../../lib/orders/orderCardModel';

export interface SellerOrderItem {
    productTitle: string;
    imageUrl: string;
    productSlug: string | null;
    variantName: string | null;
    quantity: number;
    unitPrice: number;
    shippingCost: number;
}

export interface SellerOrderCardData {
    orderId: string;
    publicId: string;
    status: string;
    createdAt: Date;
    cancellationReason?: string | null;
    buyerEmail: string | null;
    shippingFullName: string | null;
    shippingPhone: string | null;
    shippingAddress: string | null;
    deliveryType?: 'home' | 'pickup_point' | null;
    pickupPointCarrier?: string | null;
    pickupPointName?: string | null;
    subtotal: number;
    shipping: number;
    itemsSold: number;
    items: SellerOrderItem[];
    shopSlug: string;
    deliveredAt?: Date | null;
    hasShipment?: boolean;
    shipmentId?: string;
    trackingNumber?: string;
    trackingUrl?: string;
    labelUrl?: string;
    carrierName?: string;
    serviceName?: string;
    labelCost?: number | null;
    refundedAmount?: number | null;
    shippingRetained?: number | null;
}

interface Props {
    order: SellerOrderCardData;
}

const { order } = Astro.props;

const normalizedStatus = normalizeOrderStatus(order.status);
const { canSellerConfirm, isRecentlyDelivered } = getSellerDeliveryFlags(normalizedStatus, order.deliveredAt);
const statusLabel = getStatusLabel(normalizedStatus);
const statusColor = getStatusBadgeClass(normalizedStatus);
const dateFormatted = formatOrderDate(order.createdAt);
const customerName = order.shippingFullName || order.buyerEmail || strings.profileAnonymous;
const { showRefunded, refundedAmountFormatted, shippingRetainedFormatted } = getRefundedAmounts(
    normalizedStatus,
    order.refundedAmount,
    order.shippingRetained,
);
---

<article class="rounded-3xl border border-border bg-surface p-5 sm:p-6 shadow-sm flex flex-col gap-6" data-order-status={normalizedStatus}>
    <div class="flex items-start justify-between gap-4">
        <div class="min-w-0 flex-1">
            <div class="flex items-center gap-3 flex-wrap">
                <span class={`shrink-0 inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold ${statusColor}`}>
                    {statusLabel}
                </span>
                {(normalizedStatus === 'paid' || normalizedStatus === 'processing' || normalizedStatus === 'shipped' || normalizedStatus === 'delivered') && (
                    <span class="funds-badge relative shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800 cursor-help" data-tooltip={strings.orderFundsHeldTooltip}>
                        <Icon name="info" size={9} class="mr-1" />
                        {strings.orderFundsHeld}
                        <span class="tooltip absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden z-50 pointer-events-none">
                            <span class="block w-max max-w-[220px] rounded-lg border border-border bg-surface px-3 py-2 text-center text-[11px] font-medium leading-relaxed text-text-primary shadow-lg dark:bg-neutral-800 dark:border-neutral-700">
                                {strings.orderFundsHeldTooltip}
                            </span>
                            <span class="absolute left-1/2 top-full -translate-x-1/2 -mt-px border-4 border-transparent border-t-border dark:border-t-neutral-700"></span>
                        </span>
                    </span>
                )}
                {normalizedStatus === 'confirmed' && (
                    <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800">
                        <Icon name="check" size={9} class="mr-1" />
                        {strings.orderFundsReleased}
                    </span>
                )}
                {normalizedStatus === 'incident' && (
                    <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400 border border-red-200 dark:border-red-800">
                        <Icon name="alert-circle" size={9} class="mr-1" />
                        {strings.orderIncidentReported}
                    </span>
                )}
                {normalizedStatus === 'delivery_failed' && (
                    <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold bg-rose-50 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400 border border-rose-200 dark:border-rose-800">
                        <Icon name="alert-circle" size={9} class="mr-1" />
                        {strings.deliveryFailedSellerTitle}
                    </span>
                )}
                {showRefunded && (
                    <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold bg-orange-50 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400 border border-orange-200 dark:border-orange-800">
                        <Icon name="credit-card" size={9} class="mr-1" />
                        {strings.orderRefundedBadge}
                    </span>
                )}
                {normalizedStatus === 'cancelled' && order.cancellationReason && (
                    <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400 border border-red-200 dark:border-red-800">
                        <Icon name="message-circle" size={9} class="mr-1" />
                        {strings.orderCancellationReason}
                    </span>
                )}
                <order-id-popover class="relative inline-flex min-w-0 max-w-full" data-id={order.publicId}>
                    <button type="button" class="trigger-btn group inline-flex items-center gap-1.5 truncate rounded-md bg-neutral-100 dark:bg-neutral-800 px-2 py-0.5 text-[11px] font-bold uppercase tracking-[0.12em] text-text-secondary hover:bg-neutral-200 dark:hover:bg-neutral-700 hover:text-text-primary transition-all focus:outline-none ring-accent focus:ring-2">
                        #{order.publicId}
                        <Icon name="copy" size={11} class="shrink-0 opacity-50 group-hover:opacity-100 transition-opacity" />
                    </button>
                    <!-- Popover -->
                    <div class="popover hidden absolute bottom-full left-0 sm:left-auto sm:right-0 mb-2.5 z-[60] flex items-center bg-neutral-950 dark:bg-neutral-100 rounded-xl shadow-[0_12px_40px_rgb(0,0,0,0.25)] dark:shadow-[0_12px_40px_rgb(0,0,0,0.6)] p-1.5 gap-2 min-w-max">
                        <span class="text-[12px] font-bold text-neutral-100 dark:text-neutral-900 tracking-[0.12em] uppercase select-all pl-2">
                            #{order.publicId}
                        </span>
                        <button type="button" class="copy-btn shrink-0 p-1.5 rounded-lg bg-neutral-800 dark:bg-neutral-200 hover:bg-neutral-700 dark:hover:bg-neutral-300 text-neutral-300 dark:text-neutral-700 hover:text-white dark:hover:text-neutral-900 transition-colors focus:outline-none">
                            <Icon name="copy" size={13} class="icon-copy block" />
                            <Icon name="check" size={13} class="icon-check hidden text-green-400 dark:text-green-600" />
                        </button>
                    </div>
                </order-id-popover>
            </div>
            <p class="mt-3 text-base md:text-lg font-semibold text-text-primary truncate">{customerName}</p>
            <p class="mt-0.5 text-sm text-text-secondary">{dateFormatted}</p>
        </div>

        <div class="shrink-0 text-right">
            <p class="text-xl md:text-2xl font-bold tracking-tight text-text-primary tabular-nums">
                {formatEur(order.subtotal + order.shipping)}
            </p>
            <p class="mt-1.5 text-xs font-medium text-text-tertiary tabular-nums">
                {order.itemsSold} {order.itemsSold === 1 ? strings.ordersItemsSingular : strings.ordersItemsPlural}
            </p>
        </div>
    </div>

    <hr class="border-border" />

    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.4fr)_minmax(320px,1fr)]">
        <section>
            <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary mb-5">
                <Icon name="package" size={16} class="text-text-tertiary" />
                <span>{strings.sellerOrdersProductsLabel}</span>
            </div>

            <div class="flex flex-col gap-5">
                {order.items.map((item) => (
                    <div class="flex items-start gap-4">
                        <div class="h-16 w-16 md:h-20 md:w-20 shrink-0 overflow-hidden rounded-2xl border border-border-light bg-bg/50">
                            {item.imageUrl ? (
                                <img
                                    src={item.imageUrl}
                                    alt={item.productTitle}
                                    class="h-full w-full object-cover"
                                    loading="lazy"
                                />
                            ) : (
                                <div class="flex h-full w-full items-center justify-center text-text-tertiary">
                                    <Icon name="package" size={20} />
                                </div>
                            )}
                        </div>

                        <div class="min-w-0 flex-1 pt-0.5">
                            <div class="flex items-start justify-between gap-3">
                                {item.productSlug ? (
                                    <a
                                        href={`/${order.shopSlug}/${item.productSlug}`}
                                        class="block font-semibold text-text-primary transition-colors hover:text-accent leading-tight line-clamp-2"
                                    >
                                        {item.productTitle}
                                    </a>
                                ) : (
                                    <p class="font-semibold text-text-primary leading-tight line-clamp-2">{item.productTitle}</p>
                                )}

                                <span class="shrink-0 text-sm font-bold text-text-primary tabular-nums pt-0.5">
                                    {formatEur(item.quantity * item.unitPrice)}
                                </span>
                            </div>

                            {item.variantName && (
                                <p class="mt-1 truncate text-[13px] text-text-secondary">{item.variantName}</p>
                            )}

                            <p class="mt-1.5 text-[12px] font-semibold text-text-tertiary bg-bg inline-flex px-2 py-0.5 rounded-md">
                                {item.quantity} x {formatEur(item.unitPrice)}
                            </p>
                        </div>
                    </div>
                ))}
            </div>

            <div class="mt-2 pt-4 border-t border-border-light space-y-2">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary">{strings.sellerPayoutProducts}</span>
                    <span class="font-medium text-text-primary tabular-nums">
                        {formatEur(order.subtotal)}
                    </span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary">{strings.sellerPayoutShippingCharged}</span>
                    <span class="font-medium text-text-primary tabular-nums">
                        {formatShippingCell(order.shipping)}
                    </span>
                </div>
                {order.labelCost != null && order.labelCost > 0 && (
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-text-secondary">{strings.sellerPayoutLabelCost}</span>
                        <span class="font-medium text-rose-600 dark:text-rose-400 tabular-nums">
                            −{formatEur(order.labelCost)}
                        </span>
                    </div>
                )}
                <div class="flex items-center justify-between text-sm pt-2 mt-1 border-t border-border-light">
                    <span class="font-semibold text-text-primary">{strings.sellerPayoutNet}</span>
                    <span class="text-base font-bold text-text-primary tabular-nums">
                        {formatEur(order.subtotal + order.shipping - (order.labelCost ?? 0))}
                    </span>
                </div>
            </div>
        </section>

        <section>
            <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary mb-5">
                <Icon name="user" size={16} class="text-text-tertiary" />
                <span>{strings.sellerOrdersCustomerLabel}</span>
            </div>

            <ul class="flex flex-col gap-4 text-[14px]">
                <li class="flex items-start gap-3">
                    <Icon name="user" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                    <span class="font-medium text-text-primary">{customerName}</span>
                </li>

                {order.buyerEmail && (
                    <li class="flex items-start gap-3">
                        <Icon name="mail" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                        <span class="break-all text-text-secondary">{order.buyerEmail}</span>
                    </li>
                )}

                {order.shippingPhone && (
                    <li class="flex items-start gap-3">
                        <Icon name="whatsapp" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                        <span class="text-text-secondary">{order.shippingPhone}</span>
                    </li>
                )}

                {order.shippingAddress && (
                    <li class="flex items-start gap-3">
                        <Icon name="map-pin" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                        <span class="text-text-secondary whitespace-pre-line leading-relaxed">{order.shippingAddress}</span>
                    </li>
                )}
            </ul>

            <div class="mt-6 pt-5 border-t border-border">
                <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary mb-4">
                    <Icon name="settings" size={16} class="text-text-tertiary" />
                    <span>{strings.sellerOrderManage}</span>
                </div>

                {order.hasShipment ? (
                    <div class="flex flex-col gap-3">
                        {order.carrierName && (
                            <p class="text-sm text-text-secondary">
                                <span class="font-medium text-text-primary">{strings.shippingCarrier}:</span> {order.carrierName}
                            </p>
                        )}
                        {order.trackingNumber && (
                            <p class="text-sm text-text-secondary">
                                <span class="font-medium text-text-primary">{strings.shippingTrackingNumber}:</span>{' '}
                                <span class="font-mono">{order.trackingNumber}</span>
                            </p>
                        )}
                        <div class="flex flex-wrap gap-2 mt-2">
                            {order.trackingUrl && (
                                <a
                                    href={order.trackingUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-400 hover:bg-purple-200 dark:hover:bg-purple-900/60 transition-colors"
                                >
                                    <Icon name="external-link" size={12} />
                                    {strings.shippingTrackPackage}
                                </a>
                            )}
                            {order.labelUrl && (
                                <a
                                    href={order.labelUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400 hover:bg-green-200 dark:hover:bg-green-900/60 transition-colors"
                                >
                                    <Icon name="file-text" size={12} />
                                    {strings.shippingViewLabel}
                                </a>
                            )}
                        </div>
                    </div>
                ) : (normalizedStatus === 'paid' || normalizedStatus === 'processing') ? (
                    <div class="flex flex-col gap-3">
                        <p class="text-sm text-text-secondary">{strings.sellerOrderMockLabelHint}</p>
                        <div class="flex flex-wrap gap-2">
                            <button
                                type="button"
                                class="mock-label-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400 hover:bg-blue-200 dark:hover:bg-blue-900/60 transition-colors"
                                data-order-id={order.orderId}
                            >
                                <Icon name="truck" size={12} />
                                {strings.sellerOrderCreateLabel}
                            </button>
                            <button
                                type="button"
                                class="open-cancel-modal-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400 hover:bg-red-200 dark:hover:bg-red-900/60 transition-colors"
                                data-order-id={order.orderId}
                            >
                                <Icon name="x" size={12} />
                                {strings.sellerOrderCancelOrder}
                            </button>
                        </div>
                    </div>
                ) : normalizedStatus === 'incident' ? (
                    <div class="flex flex-col gap-3">
                        <p class="text-sm text-text-secondary">{strings.sellerIncidentNoticeForSeller}</p>
                        <a
                            href="/sell/claims"
                            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400 hover:bg-red-200 dark:hover:bg-red-900/60 transition-colors self-start"
                        >
                            <Icon name="alert-circle" size={12} />
                            {strings.incidentViewDetails}
                        </a>
                    </div>
                ) : (
                    <p class="text-sm text-text-secondary">{strings.sellerOrderNoActions}</p>
                )}

                {canSellerConfirm && (
                    <div class="mt-4 pt-4 border-t border-border-light flex flex-col gap-3">
                        <p class="text-sm text-text-secondary">{strings.sellerOrderConfirmDeliveryHint}</p>
                        <button
                            type="button"
                            class="seller-confirm-btn self-start inline-flex items-center gap-1.5 px-4 py-2 text-xs font-semibold rounded-xl bg-emerald-500 text-white hover:bg-emerald-600 active:scale-95 transition-all disabled:opacity-50 disabled:cursor-not-allowed"
                            data-order-id={order.orderId}
                        >
                            <Icon name="check" size={13} />
                            {strings.sellerOrderConfirmDelivery}
                        </button>
                    </div>
                )}
                {isRecentlyDelivered && (
                    <div class="mt-4 pt-4 border-t border-border-light">
                        <p class="text-sm text-text-secondary">{strings.sellerOrderDeliveredWaiting}</p>
                    </div>
                )}
                {normalizedStatus === 'delivery_failed' && (
                    <div class="mt-4 pt-4 border-t border-border-light flex flex-col gap-3">
                        <p class="text-sm text-text-secondary">{strings.deliveryFailedSellerNotice}</p>
                        <button
                            type="button"
                            class="open-refund-modal-btn self-end inline-flex items-center gap-1.5 px-4 py-2 text-xs font-semibold rounded-xl bg-red-600 text-white hover:bg-red-700 active:scale-95 transition-all"
                            data-order-id={order.orderId}
                        >
                            <Icon name="credit-card" size={13} />
                            {strings.sellerIncidentRefundBtn}
                        </button>
                    </div>
                )}
            </div>
        </section>
    </div>

    {normalizedStatus === 'cancelled' && order.cancellationReason && (
        <div class="p-4 rounded-2xl bg-red-50 dark:bg-red-900/20 border border-red-100 dark:border-red-800">
            <p class="text-[11px] font-semibold uppercase tracking-wider text-red-700 dark:text-red-400 mb-1">
                {strings.orderCancellationReason}
            </p>
            <p class="text-sm text-red-800 dark:text-red-300 leading-relaxed">{order.cancellationReason}</p>
        </div>
    )}

    {showRefunded && (
        <div class="p-4 rounded-2xl bg-orange-50 dark:bg-orange-900/20 border border-orange-100 dark:border-orange-800">
            <div class="flex items-start justify-between gap-3 mb-2">
                <p class="text-[11px] font-semibold uppercase tracking-wider text-orange-700 dark:text-orange-400">
                    {strings.orderRefundedSellerTitle}
                </p>
                <span class="shrink-0 text-base font-bold text-orange-700 dark:text-orange-300 tabular-nums">
                    {refundedAmountFormatted}
                </span>
            </div>
            <p class="text-sm text-orange-800 dark:text-orange-300 leading-relaxed">
                {strings.orderRefundedSellerNotice}
            </p>
            <dl class="mt-3 grid grid-cols-2 gap-2 text-[12px] tabular-nums">
                <div class="flex flex-col rounded-lg bg-orange-100/60 dark:bg-orange-900/30 px-3 py-2">
                    <dt class="text-[10px] font-semibold uppercase tracking-wider text-orange-700/80 dark:text-orange-400/80">
                        {strings.orderRefundedAmountLabel}
                    </dt>
                    <dd class="mt-0.5 font-bold text-orange-800 dark:text-orange-200">{refundedAmountFormatted}</dd>
                </div>
                {shippingRetainedFormatted && (
                    <div class="flex flex-col rounded-lg bg-emerald-100/60 dark:bg-emerald-900/30 px-3 py-2">
                        <dt class="text-[10px] font-semibold uppercase tracking-wider text-emerald-700/80 dark:text-emerald-400/80">
                            {strings.orderRefundedRetainedLabel}
                        </dt>
                        <dd class="mt-0.5 font-bold text-emerald-800 dark:text-emerald-200">{shippingRetainedFormatted}</dd>
                    </div>
                )}
            </dl>
        </div>
    )}

    {normalizedStatus === 'delivery_failed' && (
        <RefundOrderModal
            orderId={order.orderId}
            totalAmount={order.subtotal + order.shipping}
            shippingAmount={order.shipping}
            endpoint="/api/orders/resolve-delivery-failure"
            allowPartial={false}
            successMsg={strings.deliveryFailedRefundSuccess}
            errorMsg={strings.deliveryFailedRefundError}
        />
    )}

    {/* Cancel Modal */}
    <div class="cancel-modal hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/40 backdrop-blur-sm p-4" data-order-id={order.orderId}>
        <div class="w-full max-w-sm rounded-2xl border border-border bg-surface p-5 shadow-xl">
            <h3 class="text-base font-semibold text-text-primary">{strings.sellerOrderCancelOrder}</h3>
            <p class="mt-1 text-sm text-text-secondary">{strings.sellerOrderCancelConfirm}</p>
            <div class="mt-4">
                <label for={`cancel-reason-${order.orderId}`} class="block text-sm font-medium text-text-primary mb-1.5">
                    {strings.sellerOrderCancelReasonLabel}
                </label>
                <textarea
                    id={`cancel-reason-${order.orderId}`}
                    class="cancel-reason-input w-full rounded-xl border border-border bg-bg px-3 py-2 text-sm text-text-primary shadow-sm outline-none ring-accent focus:ring-2 transition-shadow resize-none"
                    rows="3"
                    placeholder={strings.sellerOrderCancelReasonPlaceholder}
                    maxlength="500"
                ></textarea>
                <p class="cancel-reason-error hidden mt-1.5 text-xs text-red-600">{strings.sellerOrderCancelReasonRequired}</p>
            </div>
            <div class="mt-5 flex gap-2 justify-end">
                <button type="button" class="close-cancel-modal-btn px-3 py-1.5 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors">
                    {strings.productClose}
                </button>
                <button type="button" class="confirm-cancel-btn px-3 py-1.5 text-sm font-semibold rounded-lg bg-red-600 text-white hover:bg-red-700 transition-colors" data-order-id={order.orderId}>
                    {strings.sellerOrderCancelOrder}
                </button>
            </div>
        </div>
    </div>

    {/* Label cost modal */}
    {(normalizedStatus === 'paid' || normalizedStatus === 'processing') && (
        <div class="label-cost-modal hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/40 backdrop-blur-sm p-4" data-order-id={order.orderId}>
            <div class="w-full max-w-md rounded-2xl border border-border bg-surface p-5 shadow-xl">
                <h3 class="text-base font-semibold text-text-primary">{strings.sellerLabelCostModalTitle}</h3>

                <div class="label-cost-loading mt-5 flex items-center gap-3 text-sm text-text-secondary">
                    <span class="inline-block h-4 w-4 rounded-full border-2 border-border border-t-accent animate-spin" aria-hidden="true" />
                    <span class="label-cost-loading-text">{strings.sellerLabelCostLoading}</span>
                </div>

                <div class="label-cost-error hidden mt-4 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 px-3 py-2.5 text-sm text-red-700 dark:text-red-300">
                    <span class="label-cost-error-msg">{strings.sellerLabelCostError}</span>
                </div>

                <div class="label-cost-ready hidden mt-4 flex flex-col gap-3">
                    <div class="rounded-xl border border-border bg-bg px-3 py-2.5">
                        <p class="text-[10px] font-semibold uppercase tracking-wider text-text-tertiary">{strings.sellerLabelCostCarrierLine}</p>
                        <p class="mt-1 text-sm font-semibold text-text-primary label-cost-carrier" />
                        <p class="mt-0.5 text-xs text-text-tertiary label-cost-service" />
                        <p class="hidden mt-1.5 text-xs text-text-secondary label-cost-pickup-line">
                            <span class="font-medium">{strings.sellerLabelCostPickupPointLine}:</span> <span class="label-cost-pickup-name" />
                        </p>
                    </div>

                    <dl class="rounded-xl border border-border bg-surface divide-y divide-border text-sm">
                        <div class="flex items-center justify-between gap-3 px-3 py-2">
                            <dt class="text-text-secondary">{strings.sellerLabelCostGrossLabel}</dt>
                            <dd class="font-medium text-text-primary tabular-nums label-cost-gross" />
                        </div>
                        <div class="flex items-center justify-between gap-3 px-3 py-2">
                            <dt class="text-text-secondary">{strings.sellerLabelCostSubsidyLabel}</dt>
                            <dd class="font-medium text-emerald-600 dark:text-emerald-400 tabular-nums label-cost-subsidy" />
                        </div>
                        <div class="flex items-center justify-between gap-3 px-3 py-2.5 bg-bg">
                            <dt class="font-semibold text-text-primary">{strings.sellerLabelCostNetLabel}</dt>
                            <dd class="text-base font-bold text-text-primary tabular-nums label-cost-net" />
                        </div>
                    </dl>

                    <p class="text-xs text-text-tertiary label-cost-buyer-paid" />
                    <p class="text-xs text-text-tertiary">{strings.sellerOrderMockLabelHint}</p>
                </div>

                <div class="mt-5 flex gap-2 justify-end">
                    <button type="button" class="close-label-modal-btn px-3 py-1.5 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors">
                        {strings.sellerLabelCostCancel}
                    </button>
                    <button
                        type="button"
                        class="confirm-label-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-semibold rounded-lg bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
                        data-order-id={order.orderId}
                        disabled
                    >
                        <Icon name="truck" size={13} />
                        {strings.sellerLabelCostConfirm}
                    </button>
                </div>
            </div>
        </div>
    )}
</article>

<script>
    import { strings } from '../../lib/core/i18n';
    import { runSubmit, SubmitError } from '../../lib/ui/submit';

    class OrderIdPopover extends HTMLElement {
        constructor() {
            super();
            
            const btn = this.querySelector('.trigger-btn');
            const popover = this.querySelector('.popover');
            const copyBtn = this.querySelector('.copy-btn');
            const iconCopy = this.querySelector('.icon-copy');
            const iconCheck = this.querySelector('.icon-check');
            const id = this.dataset.id || '';

            if (!btn || !popover || !copyBtn || !iconCopy || !iconCheck) return;

            // Toggle visibility
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                
                // Close all other popovers
                document.querySelectorAll('order-id-popover .popover:not(.hidden)').forEach(el => {
                    if (el !== popover) el.classList.add('hidden');
                });

                popover.classList.toggle('hidden');
            });

            // Close when clicking outside
            document.addEventListener('click', (e) => {
                if (!this.contains(e.target as Node) && !popover.classList.contains('hidden')) {
                    popover.classList.add('hidden');
                }
            });

            // Copy logic
            copyBtn.addEventListener('click', async (e) => {
                e.stopPropagation();
                try {
                    await navigator.clipboard.writeText(id);
                    
                    // Show checkmark
                    iconCopy.classList.replace('block', 'hidden');
                    iconCheck.classList.replace('hidden', 'block');
                    
                    // Revert after 2 seconds
                    setTimeout(() => {
                        iconCheck.classList.replace('block', 'hidden');
                        iconCopy.classList.replace('hidden', 'block');
                    }, 2000);
                } catch (err) {
                    console.error('Failed to copy text: ', err);
                }
            });
        }
    }

    if (!customElements.get('order-id-popover')) {
        customElements.define('order-id-popover', OrderIdPopover);
    }

    // Label cost modal — open, fetch cost, confirm
    interface LabelCostResponse {
        carrierKey?: string;
        carrierLabel?: string;
        serviceName?: string | null;
        grossPrice?: number;
        subsidy?: number;
        netDeduction?: number;
        buyerPaidShipping?: number;
        pickupPointName?: string | null;
        currency?: string;
        unavailable?: boolean;
        error?: string;
    }

    const eurFmt = new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' });
    const formatEur = (value: number) => eurFmt.format(value);

    function getLabelModal(orderId: string): HTMLElement | null {
        return document.querySelector<HTMLElement>(`.label-cost-modal[data-order-id="${orderId}"]`);
    }

    function setLabelModalState(modal: HTMLElement, state: 'loading' | 'ready' | 'error') {
        const loading = modal.querySelector<HTMLElement>('.label-cost-loading');
        const ready = modal.querySelector<HTMLElement>('.label-cost-ready');
        const error = modal.querySelector<HTMLElement>('.label-cost-error');
        const confirmBtn = modal.querySelector<HTMLButtonElement>('.confirm-label-btn');

        loading?.classList.toggle('hidden', state !== 'loading');
        ready?.classList.toggle('hidden', state !== 'ready');
        error?.classList.toggle('hidden', state !== 'error');
        if (confirmBtn) confirmBtn.disabled = state !== 'ready';
    }

    function openLabelModal(modal: HTMLElement) {
        setLabelModalState(modal, 'loading');
        modal.classList.remove('hidden');
    }

    function closeLabelModal(modal: HTMLElement) {
        modal.classList.add('hidden');
    }

    function fillLabelModal(modal: HTMLElement, data: LabelCostResponse) {
        const setText = (selector: string, value: string) => {
            const el = modal.querySelector<HTMLElement>(selector);
            if (el) el.textContent = value;
        };

        setText('.label-cost-carrier', data.carrierLabel ?? '');
        setText('.label-cost-service', data.serviceName ?? '');
        setText('.label-cost-gross', data.grossPrice != null ? formatEur(data.grossPrice) : '');
        setText('.label-cost-subsidy', data.subsidy != null ? `−${formatEur(data.subsidy)}` : '');
        setText('.label-cost-net', data.netDeduction != null ? formatEur(data.netDeduction) : '');
        setText(
            '.label-cost-buyer-paid',
            data.buyerPaidShipping != null
                ? strings.sellerLabelCostBuyerPaid.replace('{amount}', formatEur(data.buyerPaidShipping))
                : '',
        );

        const pickupLine = modal.querySelector<HTMLElement>('.label-cost-pickup-line');
        if (data.pickupPointName) {
            setText('.label-cost-pickup-name', data.pickupPointName);
            pickupLine?.classList.remove('hidden');
        } else {
            pickupLine?.classList.add('hidden');
        }

        if (data.netDeduction != null) {
            modal.dataset.labelCost = String(data.netDeduction);
        } else {
            delete modal.dataset.labelCost;
        }
    }

    function showLabelModalError(modal: HTMLElement, message: string) {
        const msgEl = modal.querySelector<HTMLElement>('.label-cost-error-msg');
        if (msgEl) msgEl.textContent = message;
        setLabelModalState(modal, 'error');
    }

    // Single delegated listener on document — works regardless of when elements
    // appear in the DOM. Necessary because DeferredSellerOrders uses server:defer,
    // which streams its HTML in after astro:page-load and DOMContentLoaded have
    // already fired (same pattern as OrderCard.astro).
    let listenersAttached = false;

    function attachDelegatedListeners() {
        if (listenersAttached) return;
        listenersAttached = true;

        // Tooltip hover/focus for funds-badge. mouseenter/mouseleave do not
        // bubble, so we use mouseover/mouseout with .closest() for delegation.
        const setBadgeTooltip = (target: EventTarget | null, visible: boolean) => {
            const badge = (target as HTMLElement | null)?.closest?.('.funds-badge') ?? null;
            const tooltip = badge?.querySelector('.tooltip') as HTMLElement | null;
            if (!tooltip) return;
            tooltip.classList.toggle('hidden', !visible);
        };
        document.addEventListener('mouseover', (e) => setBadgeTooltip(e.target, true));
        document.addEventListener('mouseout', (e) => setBadgeTooltip(e.target, false));
        document.addEventListener('focusin', (e) => setBadgeTooltip(e.target, true));
        document.addEventListener('focusout', (e) => setBadgeTooltip(e.target, false));

        document.addEventListener('click', async (e) => {
            const rawTarget = e.target;
            if (!(rawTarget instanceof Element)) return;
            const target = rawTarget as HTMLElement;

            // Open label-cost modal and fetch quote
            const mockBtn = target.closest<HTMLButtonElement>('.mock-label-btn');
            if (mockBtn) {
                e.preventDefault();
                e.stopPropagation();
                const orderId = mockBtn.dataset.orderId;
                if (!orderId) return;
                const modal = getLabelModal(orderId);
                if (!modal) return;

                openLabelModal(modal);
                try {
                    const res = await fetch(`/api/sendcloud/order-label-cost?orderId=${encodeURIComponent(orderId)}`);
                    const data = await res.json() as LabelCostResponse;
                    if (!res.ok) {
                        showLabelModalError(modal, data.error || strings.sellerLabelCostError);
                        return;
                    }
                    if (data.unavailable) {
                        showLabelModalError(modal, data.error || strings.sellerLabelCostUnavailable);
                        return;
                    }
                    fillLabelModal(modal, data);
                    setLabelModalState(modal, 'ready');
                } catch (err) {
                    console.error('label-cost fetch failed', err);
                    showLabelModalError(modal, strings.sellerLabelCostError);
                }
                return;
            }

            // Close label-cost modal (X button)
            const closeLabelBtn = target.closest<HTMLButtonElement>('.close-label-modal-btn');
            if (closeLabelBtn) {
                e.preventDefault();
                e.stopPropagation();
                const modal = closeLabelBtn.closest<HTMLElement>('.label-cost-modal');
                if (modal) closeLabelModal(modal);
                return;
            }

            // Confirm label generation
            const confirmLabelBtn = target.closest<HTMLButtonElement>('.confirm-label-btn');
            if (confirmLabelBtn) {
                e.preventDefault();
                e.stopPropagation();
                const orderId = confirmLabelBtn.dataset.orderId;
                if (!orderId) return;

                const modal = getLabelModal(orderId);
                const labelCostAttr = modal?.dataset.labelCost;
                const labelCost = labelCostAttr != null ? Number(labelCostAttr) : undefined;

                const result = await runSubmit({
                    button: confirmLabelBtn,
                    busyLabel: strings.shippingCreatingShipment,
                    action: async () => {
                        const res = await fetch('/api/sendcloud/mock-shipment', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ orderId, labelCost }),
                        });
                        const data = await res.json() as { success?: boolean; error?: string };
                        if (!data.success) throw new SubmitError(data.error || strings.sellerOrderLabelError);
                        return data;
                    },
                    successMsg: strings.labelGeneratedToast,
                });
                if (result.ok && modal) {
                    const loadingText = modal.querySelector<HTMLElement>('.label-cost-loading-text');
                    if (loadingText) loadingText.textContent = strings.sellerLabelCostRefreshing;
                    setLabelModalState(modal, 'loading');
                    window.location.reload();
                }
                return;
            }

            // Backdrop click on label-cost modal
            if (target.classList.contains('label-cost-modal')) {
                closeLabelModal(target);
                return;
            }

            // Open cancel-order modal
            const openCancelBtn = target.closest<HTMLElement>('.open-cancel-modal-btn');
            if (openCancelBtn) {
                e.preventDefault();
                e.stopPropagation();
                const orderId = openCancelBtn.dataset.orderId;
                if (!orderId) return;
                document.querySelector(`.cancel-modal[data-order-id="${orderId}"]`)?.classList.remove('hidden');
                return;
            }

            // Close cancel-order modal (X button)
            const closeCancelBtn = target.closest<HTMLElement>('.close-cancel-modal-btn');
            if (closeCancelBtn) {
                e.preventDefault();
                e.stopPropagation();
                closeCancelBtn.closest('.cancel-modal')?.classList.add('hidden');
                return;
            }

            // Backdrop click on cancel-modal
            if (target.classList.contains('cancel-modal')) {
                target.classList.add('hidden');
                return;
            }

            // Seller confirm delivery
            const sellerConfirmBtn = target.closest<HTMLButtonElement>('.seller-confirm-btn');
            if (sellerConfirmBtn) {
                e.preventDefault();
                e.stopPropagation();
                const orderId = sellerConfirmBtn.dataset.orderId;
                if (!orderId) return;

                const result = await runSubmit({
                    button: sellerConfirmBtn,
                    action: async () => {
                        const res = await fetch('/api/orders/seller-confirm', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ orderId }),
                        });
                        const data = await res.json() as { success?: boolean; error?: string };
                        if (!data.success) throw new SubmitError(data.error || strings.sellerOrderConfirmDeliveryError);
                        return data;
                    },
                    successMsg: strings.sellerOrderConfirmDeliverySuccess,
                });
                if (result.ok) {
                    window.setTimeout(() => window.location.reload(), 800);
                }
                return;
            }

            // Confirm cancel order + refund
            const confirmCancelBtn = target.closest<HTMLButtonElement>('.confirm-cancel-btn');
            if (confirmCancelBtn) {
                e.preventDefault();
                e.stopPropagation();
                const orderId = confirmCancelBtn.dataset.orderId;
                if (!orderId) return;

                const modal = confirmCancelBtn.closest('.cancel-modal');
                const textarea = modal?.querySelector('.cancel-reason-input') as HTMLTextAreaElement | null;
                const errorText = modal?.querySelector('.cancel-reason-error') as HTMLElement | null;
                const reason = textarea?.value.trim() ?? '';

                if (!reason) {
                    errorText?.classList.remove('hidden');
                    textarea?.focus();
                    return;
                }
                errorText?.classList.add('hidden');

                const result = await runSubmit({
                    button: confirmCancelBtn,
                    action: async () => {
                        const res = await fetch('/api/orders/refund', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ orderId, cancellationReason: reason }),
                        });
                        const data = await res.json() as { success?: boolean; error?: string };
                        if (!data.success) throw new SubmitError(data.error || strings.sellerOrderRefundError);
                        return data;
                    },
                    successMsg: strings.sellerOrderRefundSuccess,
                });
                if (result.ok) {
                    window.setTimeout(() => window.location.reload(), 800);
                }
                return;
            }
        });
    }

    document.addEventListener('astro:page-load', attachDelegatedListeners);
    if (document.readyState !== 'loading') attachDelegatedListeners();
    else document.addEventListener('DOMContentLoaded', attachDelegatedListeners);
</script>