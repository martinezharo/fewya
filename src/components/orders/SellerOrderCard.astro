---
import Icon from '../icons/Icon.astro';
import { strings } from '../../lib/core/i18n';
import { orderStatusLabels } from '../../lib/orders/orderStatus';

export interface SellerOrderItem {
    productTitle: string;
    imageUrl: string;
    productSlug: string | null;
    variantName: string | null;
    quantity: number;
    unitPrice: number;
    shippingCost: number;
}

export interface SellerOrderCardData {
    orderId: string;
    publicId: string;
    status: string;
    createdAt: Date;
    cancellationReason?: string | null;
    buyerEmail: string | null;
    shippingFullName: string | null;
    shippingPhone: string | null;
    shippingAddress: string | null;
    subtotal: number;
    shipping: number;
    itemsSold: number;
    items: SellerOrderItem[];
    shopSlug: string;
    hasShipment?: boolean;
    shipmentId?: string;
    trackingNumber?: string;
    trackingUrl?: string;
    labelUrl?: string;
    carrierName?: string;
    serviceName?: string;
}

interface Props {
    order: SellerOrderCardData;
}

const { order } = Astro.props;

const statusColorMap: Record<string, string> = {
    pending: 'bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400',
    paid: 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400',
    processing: 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400',
    shipped: 'bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-400',
    delivered: 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400',
    confirmed: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400',
    incident: 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400',
    cancelled: 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400',
};

const normalizedStatus = order.status?.toLowerCase() ?? 'pending';
const statusLabel = orderStatusLabels[normalizedStatus as keyof typeof orderStatusLabels] ?? order.status;
const statusColor = statusColorMap[normalizedStatus] ?? statusColorMap.pending;
const dateFormatted = order.createdAt.toLocaleDateString('es-ES', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
});
const currencyFormatter = new Intl.NumberFormat('es-ES', {
    style: 'currency',
    currency: 'EUR',
});
const customerName = order.shippingFullName || order.buyerEmail || strings.profileAnonymous;
---

<article class="rounded-3xl border border-border bg-surface p-5 sm:p-6 shadow-sm flex flex-col gap-6" data-order-status={normalizedStatus}>
    <div class="flex items-start justify-between gap-4">
        <div class="min-w-0 flex-1">
            <div class="flex items-center gap-3 flex-wrap">
                <span class={`shrink-0 inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold ${statusColor}`}>
                    {statusLabel}
                </span>
                {(normalizedStatus === 'paid' || normalizedStatus === 'processing' || normalizedStatus === 'shipped' || normalizedStatus === 'delivered') && (
                    <span class="funds-badge relative shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800 cursor-help" data-tooltip={strings.orderFundsHeldTooltip}>
                        <Icon name="info" size={9} class="mr-1" />
                        {strings.orderFundsHeld}
                        <span class="tooltip absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden z-50 pointer-events-none">
                            <span class="block w-max max-w-[220px] rounded-lg border border-border bg-surface px-3 py-2 text-center text-[11px] font-medium leading-relaxed text-text-primary shadow-lg dark:bg-neutral-800 dark:border-neutral-700">
                                {strings.orderFundsHeldTooltip}
                            </span>
                            <span class="absolute left-1/2 top-full -translate-x-1/2 -mt-px border-4 border-transparent border-t-border dark:border-t-neutral-700"></span>
                        </span>
                    </span>
                )}
                {normalizedStatus === 'confirmed' && (
                    <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800">
                        <Icon name="check" size={9} class="mr-1" />
                        {strings.orderFundsReleased}
                    </span>
                )}
                {normalizedStatus === 'incident' && (
                    <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400 border border-red-200 dark:border-red-800">
                        <Icon name="alert-circle" size={9} class="mr-1" />
                        {strings.orderIncidentReported}
                    </span>
                )}
                {normalizedStatus === 'cancelled' && order.cancellationReason && (
                    <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400 border border-red-200 dark:border-red-800">
                        <Icon name="message-circle" size={9} class="mr-1" />
                        {strings.orderCancellationReason}
                    </span>
                )}
                <order-id-popover class="relative inline-flex min-w-0 max-w-full" data-id={order.publicId}>
                    <button type="button" class="trigger-btn group inline-flex items-center gap-1.5 truncate rounded-md bg-neutral-100 dark:bg-neutral-800 px-2 py-0.5 text-[11px] font-bold uppercase tracking-[0.12em] text-text-secondary hover:bg-neutral-200 dark:hover:bg-neutral-700 hover:text-text-primary transition-all focus:outline-none ring-accent focus:ring-2">
                        #{order.publicId}
                        <Icon name="copy" size={11} class="shrink-0 opacity-50 group-hover:opacity-100 transition-opacity" />
                    </button>
                    <!-- Popover -->
                    <div class="popover hidden absolute bottom-full left-0 sm:left-auto sm:right-0 mb-2.5 z-[60] flex items-center bg-neutral-950 dark:bg-neutral-100 rounded-xl shadow-[0_12px_40px_rgb(0,0,0,0.25)] dark:shadow-[0_12px_40px_rgb(0,0,0,0.6)] p-1.5 gap-2 min-w-max">
                        <span class="text-[12px] font-bold text-neutral-100 dark:text-neutral-900 tracking-[0.12em] uppercase select-all pl-2">
                            #{order.publicId}
                        </span>
                        <button type="button" class="copy-btn shrink-0 p-1.5 rounded-lg bg-neutral-800 dark:bg-neutral-200 hover:bg-neutral-700 dark:hover:bg-neutral-300 text-neutral-300 dark:text-neutral-700 hover:text-white dark:hover:text-neutral-900 transition-colors focus:outline-none">
                            <Icon name="copy" size={13} class="icon-copy block" />
                            <Icon name="check" size={13} class="icon-check hidden text-green-400 dark:text-green-600" />
                        </button>
                    </div>
                </order-id-popover>
            </div>
            <p class="mt-3 text-base md:text-lg font-semibold text-text-primary truncate">{customerName}</p>
            <p class="mt-0.5 text-sm text-text-secondary">{dateFormatted}</p>
        </div>

        <div class="shrink-0 text-right">
            <p class="text-xl md:text-2xl font-bold tracking-tight text-text-primary tabular-nums">
                {currencyFormatter.format(order.subtotal + order.shipping)}
            </p>
            <p class="mt-1.5 text-xs font-medium text-text-tertiary tabular-nums">
                {order.itemsSold} {order.itemsSold === 1 ? strings.ordersItemsSingular : strings.ordersItemsPlural}
            </p>
        </div>
    </div>

    <hr class="border-border" />

    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.4fr)_minmax(320px,1fr)]">
        <section>
            <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary mb-5">
                <Icon name="package" size={16} class="text-text-tertiary" />
                <span>{strings.sellerOrdersProductsLabel}</span>
            </div>

            <div class="flex flex-col gap-5">
                {order.items.map((item) => (
                    <div class="flex items-start gap-4">
                        <div class="h-16 w-16 md:h-20 md:w-20 shrink-0 overflow-hidden rounded-2xl border border-border-light bg-bg/50">
                            {item.imageUrl ? (
                                <img
                                    src={item.imageUrl}
                                    alt={item.productTitle}
                                    class="h-full w-full object-cover"
                                    loading="lazy"
                                />
                            ) : (
                                <div class="flex h-full w-full items-center justify-center text-text-tertiary">
                                    <Icon name="package" size={20} />
                                </div>
                            )}
                        </div>

                        <div class="min-w-0 flex-1 pt-0.5">
                            <div class="flex items-start justify-between gap-3">
                                {item.productSlug ? (
                                    <a
                                        href={`/${order.shopSlug}/${item.productSlug}`}
                                        class="block font-semibold text-text-primary transition-colors hover:text-accent leading-tight line-clamp-2"
                                    >
                                        {item.productTitle}
                                    </a>
                                ) : (
                                    <p class="font-semibold text-text-primary leading-tight line-clamp-2">{item.productTitle}</p>
                                )}

                                <span class="shrink-0 text-sm font-bold text-text-primary tabular-nums pt-0.5">
                                    {currencyFormatter.format(item.quantity * item.unitPrice)}
                                </span>
                            </div>

                            {item.variantName && (
                                <p class="mt-1 truncate text-[13px] text-text-secondary">{item.variantName}</p>
                            )}

                            <p class="mt-1.5 text-[12px] font-semibold text-text-tertiary bg-bg inline-flex px-2 py-0.5 rounded-md">
                                {item.quantity} x {currencyFormatter.format(item.unitPrice)}
                            </p>
                        </div>
                    </div>
                ))}
            </div>

            <div class="mt-2 pt-4 border-t border-border-light">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary">{strings.cartShipping}</span>
                    <span class="font-semibold text-text-primary tabular-nums">
                        {order.shipping > 0 ? currencyFormatter.format(order.shipping) : 'Gratis'}
                    </span>
                </div>
                <div class="flex items-center justify-between text-sm mt-2">
                    <span class="font-semibold text-text-primary">{strings.cartTotal}</span>
                    <span class="font-bold text-text-primary tabular-nums">
                        {currencyFormatter.format(order.subtotal + order.shipping)}
                    </span>
                </div>
            </div>
        </section>

        <section>
            <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary mb-5">
                <Icon name="user" size={16} class="text-text-tertiary" />
                <span>{strings.sellerOrdersCustomerLabel}</span>
            </div>

            <ul class="flex flex-col gap-4 text-[14px]">
                <li class="flex items-start gap-3">
                    <Icon name="user" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                    <span class="font-medium text-text-primary">{customerName}</span>
                </li>

                {order.buyerEmail && (
                    <li class="flex items-start gap-3">
                        <Icon name="mail" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                        <span class="break-all text-text-secondary">{order.buyerEmail}</span>
                    </li>
                )}

                {order.shippingPhone && (
                    <li class="flex items-start gap-3">
                        <Icon name="whatsapp" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                        <span class="text-text-secondary">{order.shippingPhone}</span>
                    </li>
                )}

                {order.shippingAddress && (
                    <li class="flex items-start gap-3">
                        <Icon name="map-pin" size={18} class="shrink-0 text-text-tertiary mt-0.5" />
                        <span class="text-text-secondary whitespace-pre-line leading-relaxed">{order.shippingAddress}</span>
                    </li>
                )}
            </ul>

            <div class="mt-6 pt-5 border-t border-border">
                <div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-wider text-text-primary mb-4">
                    <Icon name="settings" size={16} class="text-text-tertiary" />
                    <span>{strings.sellerOrderManage}</span>
                </div>

                {order.hasShipment ? (
                    <div class="flex flex-col gap-3">
                        {order.carrierName && (
                            <p class="text-sm text-text-secondary">
                                <span class="font-medium text-text-primary">{strings.shippingCarrier}:</span> {order.carrierName}
                            </p>
                        )}
                        {order.trackingNumber && (
                            <p class="text-sm text-text-secondary">
                                <span class="font-medium text-text-primary">{strings.shippingTrackingNumber}:</span>{' '}
                                <span class="font-mono">{order.trackingNumber}</span>
                            </p>
                        )}
                        <div class="flex flex-wrap gap-2 mt-2">
                            {order.trackingUrl && (
                                <a
                                    href={order.trackingUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-400 hover:bg-purple-200 dark:hover:bg-purple-900/60 transition-colors"
                                >
                                    <Icon name="external-link" size={12} />
                                    {strings.shippingTrackPackage}
                                </a>
                            )}
                            {order.labelUrl && (
                                <a
                                    href={order.labelUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400 hover:bg-green-200 dark:hover:bg-green-900/60 transition-colors"
                                >
                                    <Icon name="file-text" size={12} />
                                    {strings.shippingViewLabel}
                                </a>
                            )}
                        </div>
                    </div>
                ) : (normalizedStatus === 'paid' || normalizedStatus === 'processing') ? (
                    <div class="flex flex-col gap-3">
                        <p class="text-sm text-text-secondary">{strings.sellerOrderMockLabelHint}</p>
                        <div class="flex flex-wrap gap-2">
                            <button
                                type="button"
                                class="mock-label-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400 hover:bg-blue-200 dark:hover:bg-blue-900/60 transition-colors"
                                data-order-id={order.orderId}
                            >
                                <Icon name="truck" size={12} />
                                {strings.sellerOrderCreateLabel}
                            </button>
                            <button
                                type="button"
                                class="open-cancel-modal-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400 hover:bg-red-200 dark:hover:bg-red-900/60 transition-colors"
                                data-order-id={order.orderId}
                            >
                                <Icon name="x" size={12} />
                                {strings.sellerOrderCancelOrder}
                            </button>
                        </div>
                    </div>
                ) : normalizedStatus === 'incident' ? (
                    <div class="flex flex-col gap-3">
                        <p class="text-sm text-text-secondary">Este pedido tiene una incidencia reportada por el comprador.</p>
                        <a
                            href="/sell/claims"
                            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400 hover:bg-red-200 dark:hover:bg-red-900/60 transition-colors self-start"
                        >
                            <Icon name="alert-circle" size={12} />
                            {strings.incidentViewDetails}
                        </a>
                    </div>
                ) : (
                    <p class="text-sm text-text-secondary">No hay acciones disponibles para este pedido.</p>
                )}
            </div>
        </section>
    </div>

    {normalizedStatus === 'cancelled' && order.cancellationReason && (
        <div class="p-4 rounded-2xl bg-red-50 dark:bg-red-900/20 border border-red-100 dark:border-red-800">
            <p class="text-[11px] font-semibold uppercase tracking-wider text-red-700 dark:text-red-400 mb-1">
                {strings.orderCancellationReason}
            </p>
            <p class="text-sm text-red-800 dark:text-red-300 leading-relaxed">{order.cancellationReason}</p>
        </div>
    )}

    {/* Cancel Modal */}
    <div class="cancel-modal hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/40 backdrop-blur-sm p-4" data-order-id={order.orderId}>
        <div class="w-full max-w-sm rounded-2xl border border-border bg-surface p-5 shadow-xl">
            <h3 class="text-base font-semibold text-text-primary">{strings.sellerOrderCancelOrder}</h3>
            <p class="mt-1 text-sm text-text-secondary">{strings.sellerOrderCancelConfirm}</p>
            <div class="mt-4">
                <label for={`cancel-reason-${order.orderId}`} class="block text-sm font-medium text-text-primary mb-1.5">
                    {strings.sellerOrderCancelReasonLabel}
                </label>
                <textarea
                    id={`cancel-reason-${order.orderId}`}
                    class="cancel-reason-input w-full rounded-xl border border-border bg-bg px-3 py-2 text-sm text-text-primary shadow-sm outline-none ring-accent focus:ring-2 transition-shadow resize-none"
                    rows="3"
                    placeholder={strings.sellerOrderCancelReasonPlaceholder}
                    maxlength="500"
                ></textarea>
                <p class="cancel-reason-error hidden mt-1.5 text-xs text-red-600">{strings.sellerOrderCancelReasonRequired}</p>
            </div>
            <div class="mt-5 flex gap-2 justify-end">
                <button type="button" class="close-cancel-modal-btn px-3 py-1.5 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors">
                    {strings.productClose}
                </button>
                <button type="button" class="confirm-cancel-btn px-3 py-1.5 text-sm font-semibold rounded-lg bg-red-600 text-white hover:bg-red-700 transition-colors" data-order-id={order.orderId}>
                    {strings.sellerOrderCancelOrder}
                </button>
            </div>
        </div>
    </div>
</article>

<script>
    import { setBusy } from '../../lib/ui/busy';
    import { toast } from '../../lib/ui/toast';
    import { progress } from '../../lib/ui/progress-bar';
    import { strings } from '../../lib/core/i18n';

    class OrderIdPopover extends HTMLElement {
        constructor() {
            super();
            
            const btn = this.querySelector('.trigger-btn');
            const popover = this.querySelector('.popover');
            const copyBtn = this.querySelector('.copy-btn');
            const iconCopy = this.querySelector('.icon-copy');
            const iconCheck = this.querySelector('.icon-check');
            const id = this.dataset.id || '';

            if (!btn || !popover || !copyBtn || !iconCopy || !iconCheck) return;

            // Toggle visibility
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                
                // Close all other popovers
                document.querySelectorAll('order-id-popover .popover:not(.hidden)').forEach(el => {
                    if (el !== popover) el.classList.add('hidden');
                });

                popover.classList.toggle('hidden');
            });

            // Close when clicking outside
            document.addEventListener('click', (e) => {
                if (!this.contains(e.target as Node) && !popover.classList.contains('hidden')) {
                    popover.classList.add('hidden');
                }
            });

            // Copy logic
            copyBtn.addEventListener('click', async (e) => {
                e.stopPropagation();
                try {
                    await navigator.clipboard.writeText(id);
                    
                    // Show checkmark
                    iconCopy.classList.replace('block', 'hidden');
                    iconCheck.classList.replace('hidden', 'block');
                    
                    // Revert after 2 seconds
                    setTimeout(() => {
                        iconCheck.classList.replace('block', 'hidden');
                        iconCopy.classList.replace('hidden', 'block');
                    }, 2000);
                } catch (err) {
                    console.error('Failed to copy text: ', err);
                }
            });
        }
    }

    if (!customElements.get('order-id-popover')) {
        customElements.define('order-id-popover', OrderIdPopover);
    }

    document.querySelectorAll('.funds-badge').forEach((badge) => {
        const tooltip = badge.querySelector('.tooltip') as HTMLElement | null;
        if (!tooltip) return;

        badge.addEventListener('mouseenter', () => tooltip.classList.remove('hidden'));
        badge.addEventListener('mouseleave', () => tooltip.classList.add('hidden'));
        badge.addEventListener('focus', () => tooltip.classList.remove('hidden'));
        badge.addEventListener('blur', () => tooltip.classList.add('hidden'));
    });

    // Mock label generation
    document.querySelectorAll<HTMLButtonElement>('.mock-label-btn').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
            e.preventDefault();
            e.stopPropagation();
            const orderId = btn.dataset.orderId;
            if (!orderId) return;

            setBusy(btn, true, { label: strings.shippingCreatingShipment });
            progress.start();

            try {
                const res = await fetch('/api/sendcloud/mock-shipment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId }),
                });

                const data = await res.json() as { success?: boolean; error?: string };
                if (data.success) {
                    progress.done();
                    toast.success(strings.labelGeneratedToast);
                    window.setTimeout(() => window.location.reload(), 800);
                } else {
                    progress.fail();
                    toast.error(data.error || strings.sellerOrderLabelError);
                    setBusy(btn, false);
                }
            } catch {
                progress.fail();
                toast.error(strings.toastErrorNetwork);
                setBusy(btn, false);
            }
        });
    });

    // Cancel order modal
    document.querySelectorAll('.open-cancel-modal-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            const orderId = (btn as HTMLElement).dataset.orderId;
            if (!orderId) return;
            const modal = document.querySelector(`.cancel-modal[data-order-id="${orderId}"]`);
            if (modal) modal.classList.remove('hidden');
        });
    });

    document.querySelectorAll('.close-cancel-modal-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            const modal = btn.closest('.cancel-modal');
            if (modal) modal.classList.add('hidden');
        });
    });

    document.querySelectorAll('.cancel-modal').forEach((modal) => {
        modal.addEventListener('click', (e) => {
            if (e.target === modal) modal.classList.add('hidden');
        });
    });

    // Confirm cancel order + refund
    document.querySelectorAll<HTMLButtonElement>('.confirm-cancel-btn').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
            e.preventDefault();
            e.stopPropagation();
            const orderId = btn.dataset.orderId;
            if (!orderId) return;

            const modal = btn.closest('.cancel-modal');
            const textarea = modal?.querySelector('.cancel-reason-input') as HTMLTextAreaElement | null;
            const errorText = modal?.querySelector('.cancel-reason-error') as HTMLElement | null;
            const reason = textarea?.value.trim() ?? '';

            if (!reason) {
                errorText?.classList.remove('hidden');
                textarea?.focus();
                return;
            }
            errorText?.classList.add('hidden');

            setBusy(btn, true, { label: strings.loadingGeneric });
            progress.start();

            try {
                const res = await fetch('/api/orders/refund', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId, cancellationReason: reason }),
                });

                const data = await res.json() as { success?: boolean; error?: string };
                if (data.success) {
                    progress.done();
                    toast.success(strings.sellerOrderRefundSuccess);
                    window.setTimeout(() => window.location.reload(), 800);
                } else {
                    progress.fail();
                    toast.error(data.error || strings.sellerOrderRefundError);
                    setBusy(btn, false);
                }
            } catch {
                progress.fail();
                toast.error(strings.toastErrorNetwork);
                setBusy(btn, false);
            }
        });
    });
</script>