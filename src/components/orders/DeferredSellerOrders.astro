---
import SellerOrderCard from './SellerOrderCard.astro';
import type { SellerOrderCardData, SellerOrderItem } from './SellerOrderCard.astro';
import Icon from '../icons/Icon.astro';
import { createSupabaseAuthClient } from '../../lib/core/auth';
import { strings } from '../../lib/core/i18n';
import { ORDER_STATUS, ORDER_STATUSES, orderStatusLabels } from '../../lib/orders/orderStatus';

interface Props {
    shopId: string;
    shopSlug: string;
}

const { shopId, shopSlug } = Astro.props;

const supabase = createSupabaseAuthClient(Astro.cookies, Astro.request);

const { data: ordersData } = await supabase
    .from('orders')
    .select(`
        id,
        public_id,
        status,
        payment_status,
        total_amount,
        created_at,
        delivered_at,
        cancellation_reason,
        buyer_email,
        shipping_full_name,
        shipping_phone,
        shipping_address,
        delivery_type,
        pickup_point_carrier,
        pickup_point_name,
        order_items (
            quantity,
            price_at_purchase,
            product_variants (
                variant_name,
                variant_image,
                shipping_cost,
                products (
                    title,
                    slug,
                    gallery_images
                )
            )
        ),
        shipments (
            id,
            sendcloud_shipment_id,
            carrier_name,
            service_name,
            status,
            tracking_number,
            tracking_url,
            label_url,
            price
        ),
        refunds (
            amount
        )
    `)
    .eq('shop_id', shopId)
    .order('created_at', { ascending: false });

const orders: SellerOrderCardData[] = (ordersData ?? []).map((order: any) => {
    const rawItems = order.order_items ?? [];
    const items: SellerOrderItem[] = [];
    let subtotal = 0;
    let shipping = 0;
    let itemsSold = 0;

    for (const oi of rawItems) {
        const rawVariant = oi.product_variants;
        const variant = Array.isArray(rawVariant) ? rawVariant[0] : rawVariant;
        if (!variant) continue;

        const rawProduct = variant.products;
        const product = Array.isArray(rawProduct) ? rawProduct[0] : rawProduct;
        if (!product) continue;

        const quantity = Number(oi.quantity ?? 0);
        if (quantity <= 0) continue;

        const unitPrice = Number(oi.price_at_purchase ?? 0);
        const shippingCost = Number(variant.shipping_cost ?? 0);

        items.push({
            productTitle: product.title ?? strings.fallbackProductName,
            imageUrl: variant.variant_image || product.gallery_images?.[0] || '',
            productSlug: product.slug ?? null,
            variantName: variant.variant_name ?? null,
            quantity,
            unitPrice,
            shippingCost,
        });

        subtotal += quantity * unitPrice;
        shipping = Math.max(shipping, shippingCost);
        itemsSold += quantity;
    }

    const rawShipments = order.shipments;
    const shipment = Array.isArray(rawShipments) ? rawShipments[0] : rawShipments;

    const refundsList: any[] = Array.isArray(order.refunds) ? order.refunds : (order.refunds ? [order.refunds] : []);
    const refundedAmount = refundsList.reduce((sum, r) => sum + Number(r?.amount ?? 0), 0);
    const orderTotal = Number(order.total_amount ?? 0);
    const shippingRetained = refundedAmount > 0 ? Math.max(0, orderTotal - refundedAmount) : 0;

    return {
        orderId: order.id,
        publicId: order.public_id,
        status: order.status ?? order.payment_status ?? ORDER_STATUS.PENDING,
        createdAt: new Date(order.created_at),
        cancellationReason: order.cancellation_reason ?? null,
        buyerEmail: order.buyer_email ?? null,
        shippingFullName: order.shipping_full_name ?? null,
        shippingPhone: order.shipping_phone ?? null,
        shippingAddress: order.shipping_address ?? null,
        deliveryType: order.delivery_type ?? null,
        pickupPointCarrier: order.pickup_point_carrier ?? null,
        pickupPointName: order.pickup_point_name ?? null,
        subtotal,
        shipping,
        itemsSold,
        items,
        shopSlug,
        deliveredAt: order.delivered_at ? new Date(order.delivered_at) : null,
        hasShipment: !!shipment,
        shipmentId: shipment?.id,
        trackingNumber: shipment?.tracking_number ?? null,
        trackingUrl: shipment?.tracking_url ?? null,
        labelUrl: shipment?.sendcloud_shipment_id ? `/api/sendcloud/label?shipmentId=${encodeURIComponent(shipment.sendcloud_shipment_id)}` : undefined,
        carrierName: shipment?.carrier_name ?? null,
        serviceName: shipment?.service_name ?? null,
        labelCost: shipment?.price != null ? Number(shipment.price) : null,
        refundedAmount: refundedAmount > 0 ? refundedAmount : null,
        shippingRetained: shippingRetained > 0 ? shippingRetained : null,
    };
});

const totalSales = orders.reduce((sum, order) => sum + order.subtotal + order.shipping, 0);
const totalOrders = orders.length;
const totalItemsSold = orders.reduce((sum, order) => sum + order.itemsSold, 0);
const hasPendingOrders = orders.some((order) => order.status === ORDER_STATUS.PENDING);
const currencyFormatter = new Intl.NumberFormat('es-ES', {
    style: 'currency',
    currency: 'EUR',
});
---

{orders.length > 0 ? (
    <>
        <div class="mt-8 grid gap-3 sm:grid-cols-3">
            <section class="rounded-[28px] border border-border bg-surface p-5 shadow-sm">
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-text-tertiary">
                    {strings.sellerOrdersSummarySales}
                </p>
                <p class="mt-3 text-2xl font-semibold tracking-tight text-text-primary tabular-nums">
                    {currencyFormatter.format(totalSales)}
                </p>
            </section>

            <section class="rounded-[28px] border border-border bg-surface p-5 shadow-sm">
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-text-tertiary">
                    {strings.sellerOrdersSummaryOrders}
                </p>
                <p class="mt-3 text-2xl font-semibold tracking-tight text-text-primary tabular-nums">
                    {totalOrders}
                </p>
            </section>

            <section class="rounded-[28px] border border-border bg-surface p-5 shadow-sm">
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-text-tertiary">
                    {strings.sellerOrdersSummaryItems}
                </p>
                <p class="mt-3 text-2xl font-semibold tracking-tight text-text-primary tabular-nums">
                    {totalItemsSold}
                </p>
            </section>
        </div>

        <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            {hasPendingOrders ? (
                <label class="inline-flex cursor-pointer items-center gap-3 select-none">
                    <div class="relative inline-flex h-6 w-11 shrink-0">
                        <input
                            id="show-pending-toggle"
                            type="checkbox"
                            class="peer sr-only"
                        />
                        <span class="absolute inset-0 rounded-full bg-neutral-200 transition-colors peer-checked:bg-accent dark:bg-neutral-700" />
                        <span class="absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-white shadow-sm transition-transform peer-checked:translate-x-5" />
                    </div>
                    <span class="text-sm font-medium text-text-primary">
                        {strings.sellerOrdersFilterShowPending}
                    </span>
                    <span class="hidden text-xs text-text-tertiary sm:inline">
                        {strings.sellerOrdersFilterShowPendingHint}
                    </span>
                </label>
            ) : (
                <span />
            )}

            <div class="flex items-center gap-2">
                <label for="status-filter" class="text-sm font-medium text-text-secondary">
                    {strings.sellerOrdersFilterStatusLabel}
                </label>
                <div class="relative">
                    <select
                        id="status-filter"
                        class="min-w-[160px] appearance-none rounded-xl border border-border bg-surface px-3 py-2 pr-10 text-sm text-text-primary shadow-sm outline-none ring-accent focus:ring-2 transition-shadow cursor-pointer"
                    >
                        <option value="all">{strings.sellerOrdersFilterStatusAll}</option>
                        {ORDER_STATUSES.map((status) => (
                            <option value={status}>{orderStatusLabels[status]}</option>
                        ))}
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                        <Icon name="chevron-down" size={16} class="text-text-tertiary" />
                    </div>
                </div>
            </div>
        </div>

        <p id="orders-filter-count" class="mt-3 text-xs text-text-tertiary" />

        <div id="orders-list" class="mt-4 flex flex-col gap-4">
            {orders.map((order) => (
                <SellerOrderCard order={order} />
            ))}
        </div>
    </>
) : (
    <section class="mt-8 flex min-h-[360px] flex-col items-center justify-center rounded-[32px] border border-dashed border-border bg-surface px-6 py-12 text-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-full border border-border text-text-tertiary">
            <Icon name="package" size={26} />
        </div>
        <h2 class="mt-5 text-xl font-semibold tracking-tight text-text-primary">
            {strings.sellerOrdersEmpty}
        </h2>
        <p class="mt-2 max-w-md text-sm text-text-secondary">
            {strings.sellerOrdersEmptySub}
        </p>
    </section>
)}

<script>
    function initSellerOrdersFilter() {
        const toggle = document.getElementById('show-pending-toggle') as HTMLInputElement | null;
        const select = document.getElementById('status-filter') as HTMLSelectElement | null;
        const list = document.getElementById('orders-list');
        const countLabel = document.getElementById('orders-filter-count');

        if (!select || !list || !countLabel) return;

        const cards = Array.from(list.querySelectorAll<HTMLElement>('[data-order-status]'));
        const total = cards.length;

        function applyFilters() {
            const selectedStatus = select!.value;
            const showPending = toggle ? toggle.checked : true;

            let visible = 0;
            cards.forEach((card) => {
                const status = card.dataset.orderStatus || '';
                let shouldShow = true;
                if (selectedStatus !== 'all') {
                    shouldShow = status === selectedStatus;
                } else if (!showPending) {
                    shouldShow = status !== 'pending';
                }
                card.style.display = shouldShow ? '' : 'none';
                if (shouldShow) visible++;
            });

            countLabel!.textContent = visible === total
                ? `Mostrando ${total} pedidos`
                : `Mostrando ${visible} de ${total} pedidos`;
        }

        if (toggle) toggle.addEventListener('change', applyFilters);
        select.addEventListener('change', applyFilters);
        applyFilters();
    }

    document.addEventListener('astro:page-load', initSellerOrdersFilter);
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSellerOrdersFilter);
    } else {
        initSellerOrdersFilter();
    }
</script>
