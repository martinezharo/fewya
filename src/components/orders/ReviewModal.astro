---
import Icon from '../icons/Icon.astro';
import { strings } from '../../lib/core/i18n';

interface ReviewModalItem {
    productTitle: string;
    imageUrl: string;
    productId?: string;
}

interface ReviewModalReview {
    rating: number;
    comment: string | null;
}

interface Props {
    orderId: string;
    items: ReviewModalItem[];
    reviews?: Record<string, ReviewModalReview>;
}

const { orderId, items, reviews } = Astro.props;

const reviewableItems = items.filter(item => item.productId);
const hasAnyReview = items.some(item => item.productId && reviews?.[item.productId]);
---

<div class="review-modal hidden fixed inset-0 z-[100] flex items-end sm:items-center justify-center bg-black/50 backdrop-blur-sm p-0 sm:p-4" data-order-id={orderId}>
    <div class="w-full max-w-md rounded-t-2xl sm:rounded-2xl border border-border bg-surface p-5 shadow-xl">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-base font-semibold text-text-primary">
                {hasAnyReview ? strings.reviewModalTitleEdit : strings.reviewModalTitleAdd}
            </h3>
            <button type="button" class="close-review-modal-btn p-1.5 rounded-lg hover:bg-border-light transition-colors text-text-secondary">
                <Icon name="x" size={18} />
            </button>
        </div>

        <div class="review-slides">
            {reviewableItems.map((item, idx) => {
                const existing = item.productId ? reviews?.[item.productId] : undefined;
                return (
                    <div class="review-slide" data-index={idx} data-product-id={item.productId} style={idx === 0 ? '' : 'display:none'}>
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-12 h-12 rounded-lg overflow-hidden bg-border-light flex-shrink-0">
                                {item.imageUrl ? (
                                    <img src={item.imageUrl} alt={item.productTitle} class="w-full h-full object-cover" loading="lazy" />
                                ) : (
                                    <div class="w-full h-full flex items-center justify-center text-text-tertiary">
                                        <Icon name="shopping-cart" size={18} />
                                    </div>
                                )}
                            </div>
                            <p class="text-sm font-semibold text-text-primary truncate">{item.productTitle}</p>
                        </div>

                        <div class="mb-4">
                            <label class="block text-sm font-medium text-text-primary mb-2">
                                {strings.reviewRatingLabel}
                            </label>
                            <div class="review-stars flex gap-1" data-rating={existing?.rating ?? 0}>
                                {[1, 2, 3, 4, 5].map((star) => (
                                    <button
                                        type="button"
                                        class="review-star-btn p-1 rounded-md hover:bg-border-light transition-colors"
                                        data-value={star}
                                        aria-label={`${star} estrellas`}
                                    >
                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={`review-star-icon ${(existing?.rating ?? 0) >= star ? 'text-amber-400' : 'text-text-tertiary'}`} data-filled={(existing?.rating ?? 0) >= star ? 'true' : 'false'}>
                                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill={(existing?.rating ?? 0) >= star ? 'currentColor' : 'none'} stroke="currentColor" />
                                        </svg>
                                    </button>
                                ))}
                            </div>
                            <p class="review-rating-error hidden mt-1.5 text-xs text-red-600">{strings.reviewRatingRequired}</p>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-text-primary mb-1.5">
                                {strings.reviewCommentLabel}
                            </label>
                            <textarea
                                class="review-comment-input w-full rounded-xl border border-border bg-bg px-3 py-2.5 text-sm text-text-primary shadow-sm outline-none ring-accent focus:ring-2 transition-shadow resize-none"
                                rows="3"
                                placeholder={strings.reviewCommentPlaceholder}
                            >{existing?.comment ?? ''}</textarea>
                        </div>
                    </div>
                );
            })}
        </div>

        {reviewableItems.length > 1 && (
            <div class="flex items-center justify-between mt-4">
                <button
                    type="button"
                    class="review-prev-btn p-2 rounded-lg hover:bg-border-light transition-colors text-text-secondary disabled:opacity-30 disabled:cursor-not-allowed"
                    disabled
                >
                    <Icon name="chevron-left" size={20} />
                </button>
                <span class="text-sm text-text-secondary review-counter font-medium">
                    1 / {reviewableItems.length}
                </span>
                <button
                    type="button"
                    class="review-next-btn p-2 rounded-lg hover:bg-border-light transition-colors text-text-secondary disabled:opacity-30 disabled:cursor-not-allowed"
                >
                    <Icon name="chevron-right" size={20} />
                </button>
            </div>
        )}

        <div class="flex gap-2 justify-end pt-4 mt-2 border-t border-border-light">
            <button type="button" class="close-review-modal-btn px-3 py-1.5 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors">
                {strings.incidentCancel}
            </button>
            <button type="button" class="submit-review-btn px-3 py-1.5 text-sm font-semibold rounded-lg bg-accent text-bg hover:bg-accent-hover transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                {strings.reviewSubmit}
            </button>
        </div>
    </div>
</div>

<script>
    import { strings } from '../../lib/core/i18n';
    import { runSubmit, SubmitError } from '../../lib/ui/submit';

    function activeSlideIndex(modal: HTMLElement): number {
        const slides = modal.querySelectorAll<HTMLElement>('.review-slide');
        return Array.from(slides).findIndex(s => s.style.display !== 'none');
    }

    function showSlide(modal: HTMLElement, next: number) {
        const slides = modal.querySelectorAll<HTMLElement>('.review-slide');
        slides.forEach((s, i) => { s.style.display = i === next ? '' : 'none'; });
        const prevBtn = modal.querySelector<HTMLButtonElement>('.review-prev-btn');
        const nextBtn = modal.querySelector<HTMLButtonElement>('.review-next-btn');
        const counter = modal.querySelector<HTMLElement>('.review-counter');
        if (prevBtn) prevBtn.disabled = next === 0;
        if (nextBtn) nextBtn.disabled = next === slides.length - 1;
        if (counter) counter.textContent = `${strings.reviewCounter}`.replace('{current}', String(next + 1)).replace('{total}', String(slides.length));
    }

    function wireModal(modal: HTMLElement) {
        if (modal.dataset.reviewWired === '1') return;
        modal.dataset.reviewWired = '1';

        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                modal.classList.add('hidden');
                document.body.style.overflow = '';
            }
        });

        modal.querySelectorAll<HTMLButtonElement>('.close-review-modal-btn').forEach((btn) => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                modal.classList.add('hidden');
                document.body.style.overflow = '';
            });
        });

        modal.querySelector<HTMLButtonElement>('.review-prev-btn')?.addEventListener('click', (e) => {
            e.preventDefault();
            const active = activeSlideIndex(modal);
            showSlide(modal, Math.max(0, active - 1));
        });

        modal.querySelector<HTMLButtonElement>('.review-next-btn')?.addEventListener('click', (e) => {
            e.preventDefault();
            const slides = modal.querySelectorAll<HTMLElement>('.review-slide');
            const active = activeSlideIndex(modal);
            showSlide(modal, Math.min(slides.length - 1, active + 1));
        });

        modal.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            const starBtn = target.closest<HTMLElement>('.review-star-btn');
            if (!starBtn) return;
            e.preventDefault();
            e.stopPropagation();
            const value = parseInt(starBtn.dataset.value || '0', 10);
            const starsContainer = starBtn.closest('.review-stars') as HTMLElement | null;
            if (!starsContainer) return;
            starsContainer.dataset.rating = String(value);
            starsContainer.querySelectorAll<HTMLElement>('.review-star-icon').forEach((icon, idx) => {
                const filled = idx < value;
                icon.dataset.filled = filled ? 'true' : 'false';
                icon.classList.toggle('text-amber-400', filled);
                icon.classList.toggle('text-text-tertiary', !filled);
                const polygon = icon.querySelector('polygon');
                if (polygon) polygon.setAttribute('fill', filled ? 'currentColor' : 'none');
            });
        });

        const submitBtn = modal.querySelector<HTMLButtonElement>('.submit-review-btn');
        submitBtn?.addEventListener('click', async (e) => {
            e.preventDefault();
            const slides = modal.querySelectorAll<HTMLElement>('.review-slide');
            const reviews: { productId: string; rating: number; comment: string }[] = [];
            let hasError = false;

            slides.forEach((slide) => {
                const productId = slide.dataset.productId;
                if (!productId) return;
                const starsContainer = slide.querySelector('.review-stars') as HTMLElement | null;
                const rating = parseInt(starsContainer?.dataset.rating || '0', 10);
                const commentInput = slide.querySelector('.review-comment-input') as HTMLTextAreaElement | null;
                const comment = commentInput?.value?.trim() ?? '';
                const ratingError = slide.querySelector('.review-rating-error') as HTMLElement | null;

                if (rating < 1 || rating > 5) {
                    ratingError?.classList.remove('hidden');
                    hasError = true;
                } else {
                    ratingError?.classList.add('hidden');
                    reviews.push({ productId, rating, comment });
                }
            });

            if (hasError) return;
            if (reviews.length === 0) return;

            const reviewResult = await runSubmit({
                button: submitBtn,
                busyLabel: strings.reviewSubmitting,
                action: async () => {
                    const res = await fetch('/api/reviews/submit-batch', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ reviews }),
                    });
                    const data = await res.json() as { success?: boolean; error?: string };
                    if (!data.success) throw new SubmitError(data.error || strings.reviewSubmitError);
                    return data;
                },
                successMsg: strings.reviewSubmitSuccess,
            });
            if (reviewResult.ok) {
                modal.classList.add('hidden');
                document.body.style.overflow = '';
                window.setTimeout(() => window.location.reload(), 800);
            }
        });
    }

    function wireAll() {
        document.querySelectorAll<HTMLElement>('.review-modal').forEach(wireModal);
    }

    if (!(window as unknown as { __reviewModalOpenBound?: boolean }).__reviewModalOpenBound) {
        (window as unknown as { __reviewModalOpenBound?: boolean }).__reviewModalOpenBound = true;
        document.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            if (!target || !(target instanceof Element)) return;
            const openBtn = target.closest<HTMLElement>('.open-review-modal-btn');
            if (!openBtn) return;
            e.preventDefault();
            const orderId = openBtn.dataset.orderId;
            if (!orderId) return;
            const modal = document.querySelector<HTMLElement>(`.review-modal[data-order-id="${orderId}"]`);
            if (!modal) return;
            wireModal(modal);
            showSlide(modal, 0);
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        });
    }

    document.addEventListener('astro:page-load', wireAll);
    if (document.readyState !== 'loading') wireAll();
    else document.addEventListener('DOMContentLoaded', wireAll);
</script>
