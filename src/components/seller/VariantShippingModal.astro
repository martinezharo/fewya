---
import Icon from '../icons/Icon.astro';
import ShippingEditorPanel from './ShippingEditorPanel.astro';
const { t } = Astro.locals;

---

<div id="variant-shipping-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="bg-surface rounded-2xl border border-border w-full max-w-md shadow-xl max-h-[90vh] overflow-y-auto">
        <header class="flex items-center justify-between gap-3 px-5 py-4 border-b border-border">
            <div class="min-w-0">
                <h3 class="text-base font-semibold text-text-primary">{t.sellerProductShippingModalTitle}</h3>
                <p class="text-xs text-text-tertiary mt-0.5 truncate">
                    <span>{t.sellerProductShippingModalFor}</span>
                    <span id="variant-shipping-modal-variant-name" class="font-medium text-text-secondary">—</span>
                </p>
            </div>
            <button type="button" id="variant-shipping-modal-close" class="flex items-center justify-center w-8 h-8 rounded-lg text-text-tertiary hover:text-text-primary hover:bg-border-light transition-colors shrink-0" aria-label={t.sellerProductShippingModalClose}>
                <Icon name="x" size={16} />
            </button>
        </header>

        <div class="p-5">
            <ShippingEditorPanel idPrefix="modal" />
        </div>

        <footer class="flex items-center gap-2 px-5 py-4 border-t border-border bg-bg/40 flex-wrap">
            <button type="button" id="variant-shipping-modal-reset" class="text-xs text-text-tertiary hover:text-text-primary underline underline-offset-2">{t.sellerProductShippingModalReset}</button>
            <div class="ml-auto flex items-center gap-2">
                <button type="button" id="variant-shipping-modal-cancel" class="px-4 py-2 rounded-full text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors">{t.sellerProductShippingModalCancel}</button>
                <button type="button" id="variant-shipping-modal-apply" class="px-4 py-2 rounded-full text-sm font-medium bg-accent text-bg hover:scale-[1.02] transition-transform">{t.sellerProductShippingModalApply}</button>
            </div>
        </footer>
    </div>
</div>
