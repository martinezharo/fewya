---
interface Props {
    mode: 'onboarding' | 'edit';
    shopData?: {
        name?: string;
        slug?: string;
        description?: string;
        accent_color?: string;
        contact_email?: string;
        whatsapp?: string;
        location?: string;
    };
}

const { mode, shopData = {} } = Astro.props;
const isEdit = mode === 'edit';

const defaultEmail = shopData.contact_email || '';
---

<div class={isEdit ? "space-y-12" : ""}>
    <!-- Step 1 / Section 1-->
    <div id={!isEdit ? "step-1" : undefined} class={(isEdit ? "w-full" : "step w-full pt-4")}>
        <h2 class:list={[
            "font-medium  text-neutral-900 dark:text-white",
            isEdit ? "text-lg mb-4 border-b border-neutral-200 dark:border-neutral-800 pb-2" : "text-xl mb-6"
        ]}>
            {!isEdit ? "1. Información principal" : "Información principal"}
        </h2>
        <div class="space-y-6 max-w-2xl">
            <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Nombre de la tienda <span class="text-red-500">*</span></label>
                <input type="text" name="name" id="shop-name" required value={shopData.name || ''} class="w-full px-4 py-3 rounded-xl border border-neutral-300 dark:border-neutral-700 bg-transparent dark:text-white focus:ring-2 focus:ring-neutral-900 dark:focus:ring-white outline-none transition" placeholder="P.ej. Awesome Shop" />
            </div>
            <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Identificador (URL) <span class="text-red-500">*</span></label>
                <div class="flex items-center relative">
                    <span class="absolute left-4 text-neutral-500 bg-transparent pointer-events-none">ewya.com/</span>
                    <input type="text" name="slug" id="shop-slug" required value={shopData.slug || ''} class="w-full pl-24 pr-4 py-3 rounded-xl border border-neutral-300 dark:border-neutral-700 bg-transparent dark:text-white focus:ring-2 focus:ring-neutral-900 dark:focus:ring-white outline-none transition" placeholder="awesome-shop" />
                </div>
                <p class="text-xs text-neutral-500 mt-2">Este será tu enlace de tienda único. Usa letras minúsculas, números y guiones.</p>
            </div>
        </div>
        {!isEdit && (
            <div class="mt-8 flex justify-end">
                <button type="button" class="next-btn px-6 py-2.5 bg-neutral-900 text-white dark:bg-white dark:text-neutral-900 font-medium rounded-full shadow-sm hover:scale-105 transition-transform" data-next="2">Siguiente</button>
            </div>
        )}
    </div>

    <!-- Step 2 / Section 2-->
    <div id={!isEdit ? "step-2" : undefined} class={(isEdit ? "w-full" : "step hidden w-full pt-4")}>
        <h2 class:list={[
            "font-medium text-neutral-900 dark:text-white",
            isEdit ? "text-lg mb-4 border-b border-neutral-200 dark:border-neutral-800 pb-2" : "text-xl mb-1"
        ]}>
            {!isEdit ? "2. Personalización" : "Personalización"}
        </h2>
        {!isEdit && <p class="text-sm text-neutral-500 mb-6 font-normal">Puedes cambiar esto más tarde. (Opcional)</p>}
        <div class="space-y-6 max-w-2xl">
            <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Descripción</label>
                <textarea name="description" rows="3" class="w-full px-4 py-3 rounded-xl border border-neutral-300 dark:border-neutral-700 bg-transparent dark:text-white focus:ring-2 focus:ring-neutral-900 dark:focus:ring-white outline-none transition resize-none" placeholder="¿Qué vendes? Cuéntale a tus clientes...">{shopData.description || ''}</textarea>
            </div>
            <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Color destacado</label>
                <div class="flex items-center gap-3">
                    <input type="color" name="accent_color" id="accent-color" value={shopData.accent_color || '#000000'} class="h-10 w-20 rounded cursor-pointer border-0 bg-transparent p-0" />
                    <span class="text-sm text-neutral-500" id="color-hex">{shopData.accent_color || '#000000'}</span>
                </div>
            </div>
        </div>
        {!isEdit && (
            <div class="mt-8 flex justify-between">
                <button type="button" class="prev-btn px-6 py-2.5 bg-neutral-100 text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300 font-medium rounded-full hover:bg-neutral-200 dark:hover:bg-neutral-700 transition" data-prev="1">Volver</button>
                <button type="button" class="next-btn px-6 py-2.5 bg-neutral-900 text-white dark:bg-white dark:text-neutral-900 font-medium rounded-full shadow-sm hover:scale-105 transition-transform" data-next="3">Siguiente</button>
            </div>
        )}
    </div>

    <!-- Step 3 / Section 3-->
    <div id={!isEdit ? "step-3" : undefined} class={(isEdit ? "w-full" : "step hidden w-full pt-4")}>
        <h2 class:list={[
            "font-medium text-neutral-900 dark:text-white",
            isEdit ? "text-lg mb-4 border-b border-neutral-200 dark:border-neutral-800 pb-2" : "text-xl mb-1"
        ]}>
            {!isEdit ? "3. Contacto público" : "Contacto público"}
        </h2>
        {!isEdit && <p class="text-sm text-neutral-500 mb-6 font-normal">Esta información será visible para tus compradores. (Opcional)</p>}
        <div class="space-y-6 max-w-2xl">
            <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Email de contacto</label>
                <input type="email" name="contact_email" value={defaultEmail} class="w-full px-4 py-3 rounded-xl border border-neutral-300 dark:border-neutral-700 bg-transparent dark:text-white focus:ring-2 focus:ring-neutral-900 dark:focus:ring-white outline-none transition" placeholder="contacto@tuempresa.com"/>
            </div>
            <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">WhatsApp</label>
                <input type="tel" name="whatsapp" value={shopData.whatsapp || ''} class="w-full px-4 py-3 rounded-xl border border-neutral-300 dark:border-neutral-700 bg-transparent dark:text-white focus:ring-2 focus:ring-neutral-900 dark:focus:ring-white outline-none transition" placeholder="+34 600 000 000" />
            </div>
            <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Ubicación</label>
                <input type="text" name="location" value={shopData.location || ''} class="w-full px-4 py-3 rounded-xl border border-neutral-300 dark:border-neutral-700 bg-transparent dark:text-white focus:ring-2 focus:ring-neutral-900 dark:focus:ring-white outline-none transition" placeholder="Madrid, España" />
            </div>
        </div>
        {!isEdit ? (
            <div class="mt-8 flex justify-between">
                <button type="button" class="prev-btn px-6 py-2.5 bg-neutral-100 text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300 font-medium rounded-full hover:bg-neutral-200 dark:hover:bg-neutral-700 transition" data-prev="2">Volver</button>
                <button type="submit" id="submit-btn" class="px-6 py-2.5 bg-neutral-900 text-white dark:bg-white dark:text-neutral-900 font-medium rounded-full shadow-sm hover:scale-105 transition-transform flex items-center justify-center min-w-35">
                    <span id="submit-text">Crear tienda</span>
                    <svg id="submit-spinner" class="animate-spin -ml-1 mr-2 h-5 w-5 text-white dark:text-neutral-900 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </button>
            </div>
        ) : (
            <div class="pt-8 flex justify-start">
                <button type="submit" id="submit-btn" class="px-6 py-2.5 bg-neutral-900 text-white dark:bg-white dark:text-neutral-900 font-medium rounded-full shadow-sm hover:scale-105 transition-transform flex items-center justify-center min-w-35">
                    <span id="submit-text">Guardar cambios</span>
                    <svg id="submit-spinner" class="animate-spin -ml-1 mr-2 h-5 w-5 text-white dark:text-neutral-900 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </button>
            </div>
        )}
    </div>
</div>

<script>
    // Component script for shared fields behaviour
    const initShopForm = () => {
        const nameInput = document.getElementById('shop-name') as HTMLInputElement;
        const slugInput = document.getElementById('shop-slug') as HTMLInputElement;
        const accentColorInput = document.getElementById('accent-color') as HTMLInputElement;
        const colorHex = document.getElementById('color-hex');

        if (nameInput && slugInput) {
            nameInput.addEventListener('input', (e) => {
                const val = (e.target as HTMLInputElement).value;
                // Only auto-slugify if we are empty or it was already sync
                if (!slugInput.dataset.manual) {
                    slugInput.value = val.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
                }
            });
            
            slugInput.addEventListener('input', (e) => {
                slugInput.dataset.manual = 'true';
                const val = (e.target as HTMLInputElement).value;
                slugInput.value = val.toLowerCase().replace(/[^a-z0-9]+/g, '-');
            });
        }

        if (accentColorInput && colorHex) {
            accentColorInput.addEventListener('input', (e) => {
                colorHex.textContent = (e.target as HTMLInputElement).value.toUpperCase();
            });
        }
    };

    document.addEventListener('astro:page-load', initShopForm);
    if (document.readyState !== 'loading') initShopForm();
    else document.addEventListener('DOMContentLoaded', initShopForm);
</script>