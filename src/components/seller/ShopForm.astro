---
import Icon from '../icons/Icon.astro';
    import { strings } from '../../lib/core/i18n';

interface Props {
    mode: 'onboarding' | 'edit';
    shopData?: {
        name?: string;
        slug?: string;
        description?: string;
        accent_color?: string;
        contact_email?: string;
        whatsapp?: string;
        location?: string;
        profile_img?: string;
        banner_img?: string;
    };
}

const { mode, shopData = {} } = Astro.props;
const isEdit = mode === 'edit';

const defaultEmail = shopData.contact_email || '';
const profileImg = shopData.profile_img || '';
---

<div class={isEdit ? "space-y-12" : ""}>
    <!-- Step 1 / Section 1-->
    <div id={!isEdit ? "step-1" : undefined} class={(isEdit ? "w-full" : "step w-full pt-4")}>
        <h2 class:list={[
            "font-medium text-text-primary",
            isEdit ? "text-lg mb-4 border-b border-border pb-2" : "text-xl mb-6"
        ]}>
            {!isEdit ? strings.sellerOnboardingStep1Title : strings.sellerShopEditTitle}
        </h2>
        <div class="space-y-6 max-w-2xl">
            <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">{strings.sellerOnboardingShopNameLabel} <span class="text-red-500">*</span></label>
                <input type="text" name="name" id="shop-name" required value={shopData.name || ''} class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition" placeholder={strings.sellerOnboardingShopNamePlaceholder} />
            </div>
            <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">{strings.sellerOnboardingShopSlugLabel} <span class="text-red-500">*</span></label>
                <div class="flex items-stretch rounded-xl border border-border focus-within:ring-2 focus-within:ring-accent transition overflow-hidden">
                    <span class="flex items-center pl-4 pr-2 text-text-tertiary bg-bg whitespace-nowrap select-none text-sm">fewya.com/</span>
                    <input type="text" name="slug" id="shop-slug" required value={shopData.slug || ''} class="w-full px-2 py-3 bg-transparent text-text-primary outline-none" placeholder={strings.sellerOnboardingShopSlugPlaceholder} />
                </div>
                <p class="text-xs text-text-tertiary mt-2">{strings.sellerOnboardingShopSlugNote}</p>
            </div>
        </div>
        {!isEdit && (
            <div class="mt-8 flex justify-end">
                <button type="button" class="next-btn px-6 py-2.5 bg-accent text-bg font-medium rounded-full shadow-sm hover:scale-105 transition-transform" data-next="2">{strings.sellerOnboardingNext}</button>
            </div>
        )}
    </div>

    <!-- Step 2 / Section 2-->
    <div id={!isEdit ? "step-2" : undefined} class={(isEdit ? "w-full" : "step hidden w-full pt-4")}>
        <h2 class:list={[
            "font-medium text-text-primary",
            isEdit ? "text-lg mb-4 border-b border-border pb-2" : "text-xl mb-1"
        ]}>
            {!isEdit ? strings.sellerOnboardingStep2Title : strings.sellerOnboardingStep2Title.replace('2. ', '')}
        </h2>
        {!isEdit && <p class="text-sm text-text-tertiary mb-6 font-normal">{strings.sellerOnboardingStep2Subtitle}</p>}
        <div class="space-y-6 max-w-2xl">
            {!isEdit && (
                <div>
                    <label class="block text-sm font-medium text-text-secondary mb-2">{strings.sellerShopProfileImgLabel}</label>
                    <div class="flex items-center gap-4">
                        <div class="relative w-20 h-20 shrink-0 rounded-full overflow-hidden border-2 border-border bg-bg cursor-pointer group" id="onboarding-profile-upload">
                            <div class="w-full h-full flex items-center justify-center" id="onboarding-profile-preview">
                                {profileImg ? (
                                    <img src={profileImg} alt="" class="w-full h-full object-cover" />
                                ) : (
                                    <Icon name="user" size={28} class="text-text-tertiary" />
                                )}
                            </div>
                            <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                <Icon name="camera" size={20} class="text-white" />
                            </div>
                            <input type="file" id="onboarding-profile-input" accept="image/jpeg,image/png,image/webp,image/gif" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                        </div>
                        <div>
                            <button type="button" id="onboarding-profile-btn" class="px-3 py-1.5 rounded-lg text-xs font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">
                                {profileImg ? strings.sellerShopProfileImgChange : strings.sellerShopProfileImgUpload}
                            </button>
                            <p class="text-xs text-text-tertiary mt-1">{strings.sellerShopProfileImgHint}</p>
                        </div>
                        <input type="hidden" name="profile_img" id="onboarding-profile-value" value={profileImg} />
                    </div>
                </div>
            )}
            <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">{strings.sellerOnboardingDescriptionLabel}</label>
                <textarea name="description" rows="3" class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition resize-none" placeholder={strings.sellerOnboardingDescriptionPlaceholder}>{shopData.description || ''}</textarea>
            </div>
            <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">{strings.sellerOnboardingAccentColorLabel}</label>
                <div class="flex items-center gap-4">
                    <div class="relative group">
                        <div id="color-preview" class="w-12 h-12 rounded-xl border-2 border-border shadow-sm transition-all duration-200 group-hover:scale-105 group-hover:shadow-md cursor-pointer" style={`background-color: ${shopData.accent_color || '#000000'}`}></div>
                        <input type="color" name="accent_color" id="accent-color" value={shopData.accent_color || '#000000'} class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                    </div>
                    <div class="flex items-center bg-surface rounded-lg border border-border overflow-hidden focus-within:ring-2 focus-within:ring-accent transition">
                        <span class="pl-3 text-sm font-mono text-text-tertiary select-none">#</span>
                        <input type="text" id="color-hex" maxlength="6" value={(shopData.accent_color || '#000000').replace('#', '').toUpperCase()} class="w-[5.5rem] px-2 py-1.5 bg-transparent text-sm font-mono text-text-primary outline-none" />
                    </div>
                </div>
                <div class="flex items-center gap-2 mt-3 overflow-x-auto flex-nowrap scrollbar-hide cursor-grab active:cursor-grabbing select-none" id="color-presets">
                    {['#000000', '#1E3A5F', '#2563EB', '#7C3AED', '#DB2777', '#DC2626', '#EA580C', '#CA8A04', '#16A34A', '#0D9488', '#64748B', '#475569'].map((color) => (
                        <button type="button" data-color={color} class="color-preset w-7 h-7 shrink-0 rounded-full border-2 border-transparent hover:scale-110 transition-all duration-150 cursor-pointer" style={`background-color: ${color}`} title={color}></button>
                    ))}
                </div>
            </div>
        </div>
        {!isEdit && (
            <div class="mt-8 flex justify-between">
                <button type="button" class="prev-btn px-6 py-2.5 bg-bg text-text-secondary border border-border font-medium rounded-full hover:bg-border-light transition" data-prev="1">{strings.sellerOnboardingPrev}</button>
                <button type="button" class="next-btn px-6 py-2.5 bg-accent text-bg font-medium rounded-full shadow-sm hover:scale-105 transition-transform" data-next="3">{strings.sellerOnboardingNext}</button>
            </div>
        )}
    </div>

    <!-- Step 3 / Section 3-->
    <div id={!isEdit ? "step-3" : undefined} class={(isEdit ? "w-full" : "step hidden w-full pt-4")}>
        <h2 class:list={[
            "font-medium text-text-primary",
            isEdit ? "text-lg mb-4 border-b border-border pb-2" : "text-xl mb-1"
        ]}>
            {!isEdit ? strings.sellerOnboardingStep3Title : strings.sellerOnboardingStep3Title.replace('3. ', '')}
        </h2>
        {!isEdit && <p class="text-sm text-text-tertiary mb-6 font-normal">{strings.sellerOnboardingStep3Subtitle}</p>}
        <div class="space-y-6 max-w-2xl">
            <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">{strings.sellerOnboardingContactEmailLabel}</label>
                <input type="email" name="contact_email" value={defaultEmail} class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition" placeholder={strings.sellerOnboardingContactEmailPlaceholder}/>
            </div>
            <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">{strings.sellerOnboardingWhatsappLabel}</label>
                <input type="tel" name="whatsapp" value={shopData.whatsapp || ''} class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition" placeholder={strings.sellerOnboardingWhatsappPlaceholder} />
            </div>
            <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">{strings.sellerOnboardingLocationLabel}</label>
                <input type="text" name="location" value={shopData.location || ''} class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition" placeholder={strings.sellerOnboardingLocationPlaceholder} />
            </div>
        </div>
        {!isEdit ? (
            <div class="mt-8 flex justify-between">
                <button type="button" class="prev-btn px-6 py-2.5 bg-bg text-text-secondary border border-border font-medium rounded-full hover:bg-border-light transition" data-prev="2">{strings.sellerOnboardingPrev}</button>
                <button type="submit" id="submit-btn" class="px-6 py-2.5 bg-accent text-bg font-medium rounded-full shadow-sm hover:scale-105 transition-transform flex items-center justify-center min-w-35">
                    <span id="submit-text">{strings.sellerOnboardingNext}</span>
                    <svg id="submit-spinner" class="animate-spin -ml-1 mr-2 h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </button>
            </div>
        ) : (
            <div class="pt-8 flex justify-start">
                <button type="submit" id="submit-btn" class="px-6 py-2.5 bg-accent text-bg font-medium rounded-full shadow-sm hover:scale-105 transition-transform flex items-center justify-center min-w-35">
                    <span id="submit-text">{strings.sellerShopEditSave}</span>
                    <svg id="submit-spinner" class="animate-spin -ml-1 mr-2 h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </button>
            </div>
        )}
    </div>
</div>

<script>
import { strings } from '../../lib/core/i18n';

    const initShopForm = () => {
        const nameInput = document.getElementById('shop-name') as HTMLInputElement;
        const slugInput = document.getElementById('shop-slug') as HTMLInputElement;
        const accentColorInput = document.getElementById('accent-color') as HTMLInputElement;
        const colorHex = document.getElementById('color-hex') as HTMLInputElement | null;

        if (nameInput && slugInput) {
            nameInput.addEventListener('input', (e) => {
                const val = (e.target as HTMLInputElement).value;
                if (!slugInput.dataset.manual) {
                    slugInput.value = val.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
                }
            });
            
            slugInput.addEventListener('input', (e) => {
                slugInput.dataset.manual = 'true';
                const val = (e.target as HTMLInputElement).value;
                slugInput.value = val.toLowerCase().replace(/[^a-z0-9]+/g, '-');
            });
        }

        const colorPreview = document.getElementById('color-preview');

        const isValidHex = (hex: string) => /^[0-9A-Fa-f]{6}$/.test(hex);

        const updateAll = (hex: string) => {
            const full = hex.startsWith('#') ? hex.toUpperCase() : `#${hex}`.toUpperCase();
            if (accentColorInput) accentColorInput.value = full;
            if (colorHex) colorHex.value = full.replace('#', '');
            if (colorPreview) colorPreview.style.backgroundColor = full;
        };

        if (accentColorInput && colorHex) {
            accentColorInput.addEventListener('input', (e) => {
                const val = (e.target as HTMLInputElement).value.toUpperCase();
                colorHex.value = val.replace('#', '');
                if (colorPreview) colorPreview.style.backgroundColor = val;
            });
        }

        if (colorHex) {
            colorHex.addEventListener('input', (e) => {
                let raw = (e.target as HTMLInputElement).value.replace(/[^0-9A-Fa-f]/g, '').toUpperCase().slice(0, 6);
                (e.target as HTMLInputElement).value = raw;
                if (isValidHex(raw)) {
                    const full = `#${raw}`;
                    if (accentColorInput) accentColorInput.value = full;
                    if (colorPreview) colorPreview.style.backgroundColor = full;
                }
            });
        }

        document.querySelectorAll<HTMLElement>('.color-preset').forEach(btn => {
            btn.addEventListener('click', () => {
                if ((btn.closest('#color-presets') as HTMLElement | null)?.dataset.dragged) return;
                const color = btn.dataset.color!;
                updateAll(color);
            });
        });

        // Drag-to-scroll for color presets
        const presetsContainer = document.getElementById('color-presets');
        if (presetsContainer) {
            let isDown = false;
            let startX = 0;
            let scrollLeft = 0;
            let hasMoved = false;

            presetsContainer.addEventListener('mousedown', (e) => {
                isDown = true;
                hasMoved = false;
                presetsContainer.dataset.dragged = '';
                startX = e.pageX - presetsContainer.offsetLeft;
                scrollLeft = presetsContainer.scrollLeft;
            });

            presetsContainer.addEventListener('mouseleave', () => {
                isDown = false;
                delete presetsContainer.dataset.dragged;
            });

            presetsContainer.addEventListener('mouseup', () => {
                isDown = false;
                if (!hasMoved) delete presetsContainer.dataset.dragged;
            });

            presetsContainer.addEventListener('mousemove', (e) => {
                if (!isDown) return;
                e.preventDefault();
                const x = e.pageX - presetsContainer.offsetLeft;
                const walk = x - startX;
                if (Math.abs(walk) > 3) {
                    hasMoved = true;
                    presetsContainer.dataset.dragged = '1';
                }
                presetsContainer.scrollLeft = scrollLeft - walk;
            });
        }

        type UploadResponse = { url: string; path?: string; error?: string };

        // Profile image upload (onboarding mode only)
        const profileUpload = document.getElementById('onboarding-profile-upload');
        const profileInput = document.getElementById('onboarding-profile-input') as HTMLInputElement | null;
        const profileValue = document.getElementById('onboarding-profile-value') as HTMLInputElement | null;
        const profileBtn = document.getElementById('onboarding-profile-btn') as HTMLButtonElement | null;
        const profilePreview = document.getElementById('onboarding-profile-preview');

        if (profileUpload && profileInput && profileValue) {
            const uploadProfileImage = async (file: File) => {
                const formData = new FormData();
                formData.append('file', file);
                formData.append('type', 'profile');

                try {
                    if (profileBtn) {
                        profileBtn.textContent = strings.sellerShopImageUploading;
                        profileBtn.setAttribute('disabled', 'true');
                    }

                    const res = await fetch('/api/sell/shop/upload', { method: 'POST', body: formData });
                    const data = await res.json() as UploadResponse;

                    if (!res.ok) {
                        const errorMsg = 'error' in data ? data.error : strings.sellerOnboardingGenericError;
                        alert(errorMsg);
                        return;
                    }

                    profileValue.value = data.url;
                    if (profilePreview) {
                        profilePreview.innerHTML = `<img src="${data.url}" alt="" class="w-full h-full object-cover" />`;
                    }
                    if (profileBtn) profileBtn.textContent = strings.sellerShopProfileImgChange;
                } catch {
                    alert(strings.sellerOnboardingGenericError);
                } finally {
                    if (profileBtn) profileBtn.removeAttribute('disabled');
                    profileInput.value = '';
                }
            };

            profileInput.addEventListener('change', () => {
                if (profileInput.files && profileInput.files[0]) {
                    uploadProfileImage(profileInput.files[0]);
                }
            });

            profileBtn?.addEventListener('click', () => {
                profileInput.click();
            });
        }
    };

    document.addEventListener('astro:page-load', initShopForm);
    if (document.readyState !== 'loading') initShopForm();
    else document.addEventListener('DOMContentLoaded', initShopForm);
</script>