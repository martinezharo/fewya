---
import Icon from '../icons/Icon.astro';
import { strings } from '../../lib/core/i18n';

interface Props {
    idPrefix: string;
    weight?: number | null;
    length?: number | null;
    width?: number | null;
    height?: number | null;
    shippingCost?: number | null;
}

const { idPrefix, weight, length, width, height, shippingCost } = Astro.props;
const isFree = shippingCost === 0;
---

<div class="shipping-editor-panel space-y-5" data-id-prefix={idPrefix}>
    <!-- Dimensiones -->
    <div class="grid gap-2.5 grid-cols-2 sm:grid-cols-4">
        <div>
            <label for={`${idPrefix}-weight-input`} class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">{strings.sellerProductVariantWeightLabel}</label>
            <input type="number" id={`${idPrefix}-weight-input`} data-field="weight" step="0.001" min="0" class="w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder={strings.sellerProductVariantWeightPlaceholder} value={weight ?? ''} />
        </div>
        <div>
            <label for={`${idPrefix}-length-input`} class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">{strings.sellerProductVariantLengthLabel}</label>
            <input type="number" id={`${idPrefix}-length-input`} data-field="length" step="0.1" min="0" class="w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder={strings.sellerProductVariantLengthPlaceholder} value={length ?? ''} />
        </div>
        <div>
            <label for={`${idPrefix}-width-input`} class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">{strings.sellerProductVariantWidthLabel}</label>
            <input type="number" id={`${idPrefix}-width-input`} data-field="width" step="0.1" min="0" class="w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder={strings.sellerProductVariantWidthPlaceholder} value={width ?? ''} />
        </div>
        <div>
            <label for={`${idPrefix}-height-input`} class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">{strings.sellerProductVariantHeightLabel}</label>
            <input type="number" id={`${idPrefix}-height-input`} data-field="height" step="0.1" min="0" class="w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder={strings.sellerProductVariantHeightPlaceholder} value={height ?? ''} />
        </div>
    </div>

    <!-- Coste de envío -->
    <div id={`${idPrefix}-shipping-cost`} data-shipping-cost-container class="pt-4 border-t border-border" data-free={isFree ? 'true' : 'false'}>
        <div class="flex items-center justify-between gap-3 mb-3 flex-wrap">
            <label class="text-[11px] font-semibold uppercase tracking-[0.14em] text-text-tertiary">{strings.sellerProductVariantBaseShipping}</label>
            <label class="flex items-center gap-2 cursor-pointer select-none">
                <span class="text-[11px] font-medium text-text-secondary">{strings.sellerProductVariantFreeShipping}</span>
                <span class="relative inline-flex shrink-0">
                    <input type="checkbox" id={`${idPrefix}-free-shipping`} data-field="free-shipping" class="sr-only peer" checked={isFree} />
                    <span class="block w-9 h-5 bg-border-light rounded-full peer-focus-visible:ring-2 peer-focus-visible:ring-accent peer-checked:bg-accent transition-colors"></span>
                    <span class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full shadow-sm transition-transform peer-checked:translate-x-4"></span>
                </span>
            </label>
        </div>
        <div id={`${idPrefix}-shipping-input-wrap`} data-shipping-input-wrap class={`flex items-center gap-2 ${isFree ? 'hidden' : ''}`}>
            <input type="number" id={`${idPrefix}-shipping-input`} data-field="shipping-cost" step="0.01" min="0" class="flex-1 px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder={strings.sellerProductVariantShippingPlaceholder} value={shippingCost ?? ''} />
            <span class="text-xs text-text-tertiary shrink-0 px-1">€</span>
        </div>
        <p id={`${idPrefix}-free-shipping-display`} data-shipping-free-display class={`text-xs text-text-secondary ${isFree ? '' : 'hidden'}`}>
            {strings.sellerProductVariantFreeShippingActive}
        </p>
    </div>

    <!-- Live shipping preview -->
    <div id={`${idPrefix}-shipping-live`} class="shipping-live pt-3 border-t border-border">
        <button type="button" class="shipping-toggle flex items-center w-full gap-2 text-left text-xs text-text-secondary hover:text-text-primary transition-colors">
            <Icon name="truck" size={13} class="text-text-tertiary shrink-0" />
            <span class="shipping-summary truncate flex-1 min-w-0">{strings.sellerProductShippingLiveAwaiting}</span>
            <span class="shipping-billable hidden text-[10px] font-medium text-text-tertiary tabular-nums shrink-0"></span>
            <span class="shipping-quotes-cta hidden items-center gap-1 text-[11px] font-medium text-accent shrink-0">
                <span class="shipping-quotes-cta-show">{strings.sellerProductShippingShowQuotes}</span>
                <span class="shipping-quotes-cta-hide hidden">{strings.sellerProductShippingHideQuotes}</span>
            </span>
        </button>
        <div class="shipping-quotes hidden grid gap-2 mt-3"></div>
        <div class="shipping-loading hidden items-center gap-2 py-1.5 text-[11px] text-text-tertiary mt-1">
            <svg class="animate-spin" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56" /></svg>
            <span>{strings.sellerProductShippingLiveLoading}</span>
        </div>
        <p class="shipping-error hidden text-[11px] text-amber-700 dark:text-amber-400 mt-2"></p>
    </div>
</div>
