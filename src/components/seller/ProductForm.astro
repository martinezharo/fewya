---
import Icon from '../icons/Icon.astro';
import { strings, categories } from '../../lib/core/i18n';

interface VariantData {
    id?: string;
    variant_name: string | null;
    price: number;
    stock: number;
    is_default: boolean;
    variant_image: string | null;
    weight_kg?: number | null;
    length_cm?: number | null;
    width_cm?: number | null;
    height_cm?: number | null;
    shipping_cost?: number | null;
}

interface ShippingDefaults {
    weight_kg?: number | null;
    length_cm?: number | null;
    width_cm?: number | null;
    height_cm?: number | null;
    shipping_cost?: number | null;
}

interface Props {
    mode: 'create' | 'edit';
    shopId: string;
    product?: {
        id: string;
        title: string;
        slug: string;
        description: string | null;
        category: string;
        brand: string | null;
        gallery_images: string[];
        is_active: boolean;
        specifications: Record<string, any>;
    };
    variants?: VariantData[];
    shippingDefaults?: ShippingDefaults;
}

const { mode, shopId, product, variants, shippingDefaults } = Astro.props;
const isEdit = mode === 'edit';

const title = product?.title ?? '';
const slug = product?.slug ?? '';
const description = product?.description ?? '';
const category = product?.category ?? '';
const brand = product?.brand ?? '';
const galleryImages: string[] = product?.gallery_images ?? [];
const isActive = product?.is_active ?? true;
const specs = product?.specifications ?? {};

const initialVariants = (variants && variants.length > 0) ? variants : [
    { variant_name: '', price: 0, stock: 0, is_default: true, variant_image: null, weight_kg: shippingDefaults?.weight_kg ?? null, length_cm: shippingDefaults?.length_cm ?? null, width_cm: shippingDefaults?.width_cm ?? null, height_cm: shippingDefaults?.height_cm ?? null, shipping_cost: shippingDefaults?.shipping_cost ?? null }
];

const defaultsJson = JSON.stringify(shippingDefaults ?? {});
---

<div id="product-form-root" data-shop-id={shopId} data-mode={mode} data-gallery={JSON.stringify(galleryImages)} data-shipping-defaults={defaultsJson}>
    <input type="hidden" id="product-id" value={isEdit ? product!.id : ''} />

    <!-- Basic Info -->
    <section class="space-y-6">
        <h2 class="text-lg font-medium text-text-primary border-b border-border pb-2">{strings.sellerProductBasicInfo}</h2>

        <div class="grid gap-6 sm:grid-cols-2 max-w-3xl">
            <div class="sm:col-span-2">
                <label for="product-title" class="block text-sm font-medium text-text-secondary mb-2">
                    {strings.sellerProductTitleLabel} <span class="text-red-500">*</span>
                </label>
                <input
                    type="text"
                    id="product-title"
                    required
                    value={title}
                    class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition"
                    placeholder={strings.sellerProductTitlePlaceholder}
                />
            </div>

            <div>
                <label for="product-slug" class="block text-sm font-medium text-text-secondary mb-2">{strings.sellerProductSlugLabel}</label>
                <div class="flex items-stretch rounded-xl border border-border focus-within:ring-2 focus-within:ring-accent transition overflow-hidden">
                    <span class="flex items-center pl-4 pr-2 text-text-tertiary bg-bg whitespace-nowrap select-none text-sm">{shopId}/</span>
                    <input
                        type="text"
                        id="product-slug"
                        value={slug}
                        class="w-full px-2 py-3 bg-transparent text-text-primary outline-none text-sm"
                        placeholder={strings.sellerProductSlugPlaceholder}
                    />
                </div>
                <p class="text-xs text-text-tertiary mt-1.5">{strings.sellerProductSlugNote}</p>
            </div>

            <div>
                <label for="product-category" class="block text-sm font-medium text-text-secondary mb-2">
                    {strings.sellerProductCategoryLabel} <span class="text-red-500">*</span>
                </label>
                <select
                    id="product-category"
                    required
                    class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition appearance-none"
                >
                    <option value="" disabled selected={category === ''} class="text-text-tertiary">{strings.sellerProductCategoryPlaceholder}</option>
                    {categories.map(cat => (
                        <option value={cat.value} selected={category === cat.value}>{cat.label}</option>
                    ))}
                </select>
            </div>

            <div class="sm:col-span-2">
                <label for="product-description" class="block text-sm font-medium text-text-secondary mb-2">{strings.sellerProductDescriptionLabel}</label>
                <textarea
                    id="product-description"
                    rows="3"
                    class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition resize-none"
                    placeholder={strings.sellerProductDescriptionPlaceholder}
                >{description}</textarea>
            </div>

            <div>
                <label for="product-brand" class="block text-sm font-medium text-text-secondary mb-2">{strings.sellerProductBrandLabel}</label>
                <input
                    type="text"
                    id="product-brand"
                    value={brand}
                    class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition"
                    placeholder={strings.sellerProductBrandPlaceholder}
                />
            </div>
        </div>
    </section>

    <!-- Images -->
    <section class="mt-10 space-y-5">
        <div>
            <h2 class="text-lg font-medium text-text-primary border-b border-border pb-2">{strings.sellerProductImagesLabel}</h2>
            <p class="mt-1.5 text-xs text-text-tertiary">{strings.sellerProductImagesHint}</p>
        </div>

        <div
            id="image-drop-zone"
            class="relative flex flex-col items-center justify-center gap-2 p-8 border-2 border-dashed border-border rounded-2xl bg-bg cursor-pointer hover:border-accent transition-colors"
        >
            <Icon name="upload-cloud" size={32} class="text-text-tertiary" />
            <p class="text-sm text-text-secondary">{strings.sellerProductImagesDragDrop}</p>
            <input type="file" id="image-upload-input" multiple accept="image/jpeg,image/png,image/webp,image/gif" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
        </div>

        <div id="image-gallery" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3">
            {galleryImages.map((url, i) => (
                <div class="image-item relative group rounded-xl overflow-hidden border border-border aspect-square" data-url={url}>
                    <img src={url} alt="" class="w-full h-full object-cover" loading="lazy" />
                    {i === 0 && (
                        <span class="absolute top-1.5 left-1.5 px-1.5 py-0.5 rounded text-[10px] font-medium bg-accent text-bg">Cover</span>
                    )}
                    <button
                        type="button"
                        class="image-remove-btn absolute top-1.5 right-1.5 w-6 h-6 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
                        aria-label={strings.sellerProductImageRemove}
                    >
                        <Icon name="x" size={14} />
                    </button>
                </div>
            ))}
        </div>
    </section>

    <!-- Variants -->
    <section class="mt-10 space-y-5">
        <div>
            <h2 class="text-lg font-medium text-text-primary border-b border-border pb-2">{strings.sellerProductVariantsLabel}</h2>
            <p class="mt-1.5 text-xs text-text-tertiary">{strings.sellerProductVariantsHint}</p>
        </div>

        <div id="variants-container" class="space-y-3">
            {initialVariants.map((v, i) => (
                <div class="variant-row rounded-2xl border border-border bg-surface p-4 space-y-4" data-variant-id={v.id ?? ''} data-is-new={v.id ? 'false' : 'true'} data-variant-image={v.variant_image ?? ''}>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            {i === 0 && (
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-accent text-bg">
                                    {strings.sellerProductVariantDefault}
                                </span>
                            )}
                            <span class="text-sm font-medium text-text-primary">#{i + 1}</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <label class="flex items-center gap-1.5 text-xs text-text-secondary cursor-pointer select-none">
                                <input type="checkbox" class="variant-default-checkbox rounded border-border accent-neutral-900 dark:accent-white" checked={v.is_default} />
                                {strings.sellerProductVariantDefault}
                            </label>
                            {initialVariants.length > 1 && (
                                <button type="button" class="variant-remove-btn flex items-center justify-center w-7 h-7 rounded-lg text-text-tertiary hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" aria-label={strings.sellerProductVariantRemove}>
                                    <Icon name="trash-2" size={14} />
                                </button>
                            )}
                        </div>
                    </div>
                    <div class="grid gap-4 sm:grid-cols-3">
                        <div>
                            <label class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerProductVariantNameLabel}</label>
                            <input
                                type="text"
                                class="variant-name-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition"
                                placeholder={strings.sellerProductVariantNamePlaceholder}
                                value={v.variant_name}
                            />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerProductVariantPriceLabel}</label>
                            <input
                                type="number"
                                step="0.01"
                                min="0"
                                class="variant-price-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                                placeholder={strings.sellerProductVariantPricePlaceholder}
                                value={v.price}
                            />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerProductVariantStockLabel}</label>
                            <input
                                type="number"
                                min="0"
                                class="variant-stock-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                                placeholder={strings.sellerProductVariantStockPlaceholder}
                                value={v.stock}
                            />
                        </div>
                    </div>

                    <div class="border-t border-border pt-4 space-y-4">
                        <div class="flex items-center justify-between">
                            <h3 class="text-xs font-semibold uppercase tracking-wider text-text-secondary">{strings.sellerProductVariantShippingTitle}</h3>
                            <div class="flex items-center gap-2">
                                <button type="button" class="variant-use-defaults-btn px-3 py-1.5 rounded-lg text-[11px] font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">
                                    {strings.sellerProductVariantUseDefaults}
                                </button>
                                <button type="button" class="variant-apply-shipping-btn px-3 py-1.5 rounded-lg text-[11px] font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">
                                    {strings.sellerProductVariantApplyToRest}
                                </button>
                            </div>
                        </div>
                        <div class="grid gap-4 sm:grid-cols-5">
                            <div>
                                <label class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerProductVariantWeightLabel}</label>
                                <input
                                    type="number"
                                    step="0.001"
                                    min="0"
                                    class="variant-weight-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                                    placeholder={strings.sellerProductVariantWeightPlaceholder}
                                    value={v.weight_kg ?? ''}
                                />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerProductVariantLengthLabel}</label>
                                <input
                                    type="number"
                                    step="0.1"
                                    min="0"
                                    class="variant-length-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                                    placeholder={strings.sellerProductVariantLengthPlaceholder}
                                    value={v.length_cm ?? ''}
                                />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerProductVariantWidthLabel}</label>
                                <input
                                    type="number"
                                    step="0.1"
                                    min="0"
                                    class="variant-width-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                                    placeholder={strings.sellerProductVariantWidthPlaceholder}
                                    value={v.width_cm ?? ''}
                                />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerProductVariantHeightLabel}</label>
                                <input
                                    type="number"
                                    step="0.1"
                                    min="0"
                                    class="variant-height-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                                    placeholder={strings.sellerProductVariantHeightPlaceholder}
                                    value={v.height_cm ?? ''}
                                />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerProductVariantShippingLabel}</label>
                                <input
                                    type="number"
                                    step="0.01"
                                    min="0"
                                    class="variant-shipping-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums"
                                    placeholder={strings.sellerProductVariantShippingPlaceholder}
                                    value={v.shipping_cost ?? ''}
                                />
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-text-tertiary mb-1">{strings.sellerProductVariantImage}</label>
                        <div class="flex items-center gap-3">
                            <div class="variant-image-preview w-14 h-14 rounded-lg border border-border bg-bg overflow-hidden flex items-center justify-center">
                                {v.variant_image ? (
                                    <img src={v.variant_image} alt="" class="w-full h-full object-cover" />
                                ) : (
                                    <Icon name="image" size={20} class="text-text-tertiary" />
                                )}
                            </div>
                            <button type="button" class="variant-image-btn px-3 py-1.5 rounded-lg text-xs font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">
                                {v.variant_image ? 'Cambiar' : 'Subir'}
                            </button>
                            <input type="file" accept="image/jpeg,image/png,image/webp,image/gif" class="variant-image-input hidden" />
                        </div>
                    </div>
                </div>
            ))}
        </div>

        <div class="flex items-center gap-3">
            <button
                type="button"
                id="add-variant-btn"
                class="flex items-center gap-2 px-4 py-2.5 rounded-xl border border-dashed border-border text-sm text-text-secondary hover:text-text-primary hover:border-accent transition-colors"
            >
                <Icon name="plus" size={16} />
                {strings.sellerProductAddVariant}
            </button>
        </div>

        {shippingDefaults && (shippingDefaults.weight_kg != null || shippingDefaults.length_cm != null || shippingDefaults.width_cm != null || shippingDefaults.height_cm != null || shippingDefaults.shipping_cost != null) && (
            <p class="text-xs text-text-tertiary">{strings.sellerProductShippingDefaultsHint}</p>
        )}
    </section>

    <!-- Specifications -->
    <section class="mt-10 space-y-5">
        <div>
            <h2 class="text-lg font-medium text-text-primary border-b border-border pb-2">{strings.sellerProductSpecsLabel}</h2>
            <p class="mt-1.5 text-xs text-text-tertiary">{strings.sellerProductSpecsHint}</p>
        </div>

        <div id="specs-container" class="space-y-3 max-w-2xl">
            {Object.entries(specs).map(([key, value]) => (
                <div class="spec-row flex items-center gap-3">
                    <input
                        type="text"
                        class="spec-key-input w-2/5 px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition"
                        placeholder={strings.sellerProductSpecsKeyPlaceholder}
                        value={key}
                    />
                    <input
                        type="text"
                        class="spec-value-input flex-1 px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition"
                        placeholder={strings.sellerProductSpecsValuePlaceholder}
                        value={String(value)}
                    />
                    <button type="button" class="spec-remove-btn flex items-center justify-center w-7 h-7 rounded-lg text-text-tertiary hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors shrink-0" aria-label={strings.sellerCatalogDelete}>
                        <Icon name="x" size={16} />
                    </button>
                </div>
            ))}
        </div>

        <button
            type="button"
            id="add-spec-btn"
            class="flex items-center gap-2 px-4 py-2.5 rounded-xl border border-dashed border-border text-sm text-text-secondary hover:text-text-primary hover:border-accent transition-colors"
        >
            <Icon name="plus" size={16} />
            {strings.sellerProductAddSpec}
        </button>
    </section>

    <!-- Active toggle -->
    <section class="mt-10 flex items-center justify-between max-w-2xl p-5 rounded-2xl border border-border bg-surface">
        <div>
            <p class="text-sm font-medium text-text-primary">{strings.sellerProductActiveLabel}</p>
            <p class="text-xs text-text-tertiary mt-0.5">{strings.sellerProductActiveNote}</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="product-active" class="sr-only peer" checked={isActive} />
            <div class="w-11 h-6 bg-border-light rounded-full peer-focus-visible:ring-2 peer-focus-visible:ring-accent peer-checked:bg-accent transition-colors after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-transform peer-checked:after:translate-x-full"></div>
        </label>
    </section>

    <!-- Submit -->
    <div class="mt-10 flex items-center gap-3">
        <button
            type="button"
            id="save-product-btn"
            class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-accent text-bg font-medium text-sm hover:scale-[1.02] transition-transform"
        >
            <span id="save-product-text">{strings.sellerProductSave}</span>
            <svg id="save-product-spinner" class="animate-spin h-4 w-4 hidden" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
            </svg>
        </button>
        <a href="/sell/catalog" class="px-6 py-2.5 rounded-full border border-border text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors no-underline">
            {strings.sellerProductBackToCatalog}
        </a>
    </div>

    <!-- Messages -->
    <div id="error-message" class="text-red-500 font-medium text-sm mt-6 hidden p-4 bg-red-50 dark:bg-red-900/20 rounded-xl"></div>
    <div id="success-message" class="text-green-600 font-medium text-sm mt-6 hidden p-4 bg-green-50 dark:bg-green-900/20 rounded-xl">{strings.sellerProductSaveSuccess}</div>
</div>

<script>
    import { strings } from '../../lib/core/i18n';

    function initProductForm() {
        const root = document.getElementById('product-form-root');
        if (!root) return;

        const mode = root.dataset.mode || 'create';
        const galleryUrls: string[] = JSON.parse(root.dataset.gallery || '[]');
        const shippingDefaults: Record<string, number | null> = JSON.parse(root.dataset.shippingDefaults || '{}');

        const titleInput = document.getElementById('product-title') as HTMLInputElement;
        const slugInput = document.getElementById('product-slug') as HTMLInputElement;
        const categorySelect = document.getElementById('product-category') as unknown as HTMLSelectElement;
        const descriptionInput = document.getElementById('product-description') as HTMLTextAreaElement;
        const brandInput = document.getElementById('product-brand') as HTMLInputElement;
        const activeCheckbox = document.getElementById('product-active') as HTMLInputElement;
        const saveBtn = document.getElementById('save-product-btn') as HTMLButtonElement;
        const saveText = document.getElementById('save-product-text') as HTMLSpanElement;
        const saveSpinner = document.getElementById('save-product-spinner') as unknown as HTMLElement;
        const errorMsg = document.getElementById('error-message') as HTMLDivElement;
        const successMsg = document.getElementById('success-message') as HTMLDivElement;
        const imageGallery = document.getElementById('image-gallery') as HTMLDivElement;
        const imageUploadInput = document.getElementById('image-upload-input') as HTMLInputElement;
        const variantsContainer = document.getElementById('variants-container') as HTMLDivElement;
        const addVariantBtn = document.getElementById('add-variant-btn') as HTMLButtonElement;
        const specsContainer = document.getElementById('specs-container') as HTMLDivElement;
        const addSpecBtn = document.getElementById('add-spec-btn') as HTMLButtonElement;

        if (!titleInput || !saveBtn) return;

        let slugManual = slugInput.value !== '';
        titleInput.addEventListener('input', () => {
            if (!slugManual) {
                slugInput.value = titleInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
            }
        });
        slugInput.addEventListener('input', () => { slugManual = true; });

        imageUploadInput.addEventListener('change', async () => {
            const files = Array.from(imageUploadInput.files || []);
            if (files.length === 0) return;

            for (const file of files) {
                const formData = new FormData();
                formData.append('file', file);
                try {
                    const res = await fetch('/api/sell/catalog/upload', { method: 'POST', body: formData });
                    const data: { error?: string; url?: string } = await res.json();
                    if (!res.ok) { alert(data.error || 'Upload failed'); continue; }
                    galleryUrls.push(data.url!);
                    renderGallery();
                } catch { alert('Upload failed'); }
            }
            imageUploadInput.value = '';
        });

        function renderGallery() {
            imageGallery.innerHTML = '';
            galleryUrls.forEach((url: string, i: number) => {
                const div = document.createElement('div');
                div.className = 'image-item relative group rounded-xl overflow-hidden border border-border aspect-square';
                div.dataset.url = url;
                const coverBadge = i === 0 ? '<span class="absolute top-1.5 left-1.5 px-1.5 py-0.5 rounded text-[10px] font-medium bg-accent text-bg">Cover</span>' : '';
                div.innerHTML = `<img src="${url}" alt="" class="w-full h-full object-cover" loading="lazy" />${coverBadge}<button type="button" class="image-remove-btn absolute top-1.5 right-1.5 w-6 h-6 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity" aria-label="Remove"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button>`;
                imageGallery.appendChild(div);
            });
        }

        variantsContainer.addEventListener('change', async (e: Event) => {
            const target = e.target as HTMLInputElement;
            if (!target || !target.classList.contains('variant-image-input') || !target.files?.length) return;
            const variantRow = target.closest('.variant-row') as HTMLElement;
            const btn = variantRow.querySelector('.variant-image-btn') as HTMLButtonElement;
            const preview = variantRow.querySelector('.variant-image-preview') as HTMLElement;

            btn.textContent = strings.sellerProductImageUploading;
            btn.disabled = true;

            const formData = new FormData();
            formData.append('file', target.files[0]);
            try {
                const res = await fetch('/api/sell/catalog/upload', { method: 'POST', body: formData });
                const data: { error?: string; url?: string } = await res.json();
                if (res.ok) {
                    variantRow.dataset.variantImage = data.url!;
                    preview.innerHTML = `<img src="${data.url}" alt="" class="w-full h-full object-cover" />`;
                    btn.textContent = 'Cambiar';
                } else {
                    alert(data.error || 'Upload failed');
                    btn.textContent = 'Subir';
                }
            } catch {
                alert('Upload failed');
                btn.textContent = 'Subir';
            } finally {
                btn.disabled = false;
                target.value = '';
            }
        });

        variantsContainer.addEventListener('click', (e: MouseEvent) => {
            const target = e.target as HTMLElement;
            if (target.classList.contains('variant-image-btn') || target.closest('.variant-image-btn')) {
                const btn = (target.classList.contains('variant-image-btn') ? target : target.closest('.variant-image-btn')) as HTMLElement;
                const variantRow = btn.closest('.variant-row') as HTMLElement;
                const fileInput = variantRow.querySelector('.variant-image-input') as HTMLInputElement;
                fileInput.click();
            }
        });

        addVariantBtn.addEventListener('click', () => {
            const row = createVariantRow(false);
            variantsContainer.appendChild(row);
            row.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });

        variantsContainer.addEventListener('click', (e: MouseEvent) => {
            const target = e.target as HTMLElement;

            const useDefaultsBtn = target.closest('.variant-use-defaults-btn') as HTMLElement | null;
            if (useDefaultsBtn) {
                const row = useDefaultsBtn.closest('.variant-row') as HTMLElement;
                const w = row.querySelector('.variant-weight-input') as HTMLInputElement;
                const l = row.querySelector('.variant-length-input') as HTMLInputElement;
                const wi = row.querySelector('.variant-width-input') as HTMLInputElement;
                const h = row.querySelector('.variant-height-input') as HTMLInputElement;
                const s = row.querySelector('.variant-shipping-input') as HTMLInputElement;
                if (w) w.value = shippingDefaults.weight_kg != null ? String(shippingDefaults.weight_kg) : '';
                if (l) l.value = shippingDefaults.length_cm != null ? String(shippingDefaults.length_cm) : '';
                if (wi) wi.value = shippingDefaults.width_cm != null ? String(shippingDefaults.width_cm) : '';
                if (h) h.value = shippingDefaults.height_cm != null ? String(shippingDefaults.height_cm) : '';
                if (s) s.value = shippingDefaults.shipping_cost != null ? String(shippingDefaults.shipping_cost) : '';
                return;
            }

            const applyShippingBtn = target.closest('.variant-apply-shipping-btn') as HTMLElement | null;
            if (applyShippingBtn) {
                const sourceRow = applyShippingBtn.closest('.variant-row') as HTMLElement;
                const weight = (sourceRow.querySelector('.variant-weight-input') as HTMLInputElement)?.value ?? '';
                const length = (sourceRow.querySelector('.variant-length-input') as HTMLInputElement)?.value ?? '';
                const width = (sourceRow.querySelector('.variant-width-input') as HTMLInputElement)?.value ?? '';
                const height = (sourceRow.querySelector('.variant-height-input') as HTMLInputElement)?.value ?? '';
                const shipping = (sourceRow.querySelector('.variant-shipping-input') as HTMLInputElement)?.value ?? '';

                variantsContainer.querySelectorAll('.variant-row').forEach((rowEl) => {
                    if (rowEl === sourceRow) return;
                    const el = rowEl as HTMLElement;
                    const w = el.querySelector('.variant-weight-input') as HTMLInputElement;
                    const l = el.querySelector('.variant-length-input') as HTMLInputElement;
                    const wi = el.querySelector('.variant-width-input') as HTMLInputElement;
                    const h = el.querySelector('.variant-height-input') as HTMLInputElement;
                    const s = el.querySelector('.variant-shipping-input') as HTMLInputElement;
                    if (w) w.value = weight;
                    if (l) l.value = length;
                    if (wi) wi.value = width;
                    if (h) h.value = height;
                    if (s) s.value = shipping;
                });
                return;
            }
        });

        function createVariantRow(isDefault: boolean) {
            const div = document.createElement('div');
            div.className = 'variant-row rounded-2xl border border-border bg-surface p-4 space-y-4';
            div.dataset.variantId = '';
            div.dataset.isNew = 'true';
            div.dataset.variantImage = '';
            const defaultBadge = isDefault ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-accent text-bg">${strings.sellerProductVariantDefault}</span>` : '';
            div.innerHTML = `<div class="flex items-center justify-between"><div class="flex items-center gap-2">${defaultBadge}<span class="text-sm font-medium text-text-primary">#${variantsContainer.children.length + 1}</span></div><div class="flex items-center gap-2"><label class="flex items-center gap-1.5 text-xs text-text-secondary cursor-pointer select-none"><input type="checkbox" class="variant-default-checkbox rounded border-border accent-neutral-900 dark:accent-white" ${isDefault ? 'checked' : ''} />${strings.sellerProductVariantDefault}</label><button type="button" class="variant-remove-btn flex items-center justify-center w-7 h-7 rounded-lg text-text-tertiary hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" aria-label="${strings.sellerProductVariantRemove}"><svg width="14" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg></button></div></div><div class="grid gap-4 sm:grid-cols-3"><div><label class="block text-xs font-medium text-text-tertiary mb-1">${strings.sellerProductVariantNameLabel}</label><input type="text" class="variant-name-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition" placeholder="${strings.sellerProductVariantNamePlaceholder}" /></div><div><label class="block text-xs font-medium text-text-tertiary mb-1">${strings.sellerProductVariantPriceLabel}</label><input type="number" step="0.01" min="0" class="variant-price-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantPricePlaceholder}" /></div><div><label class="block text-xs font-medium text-text-tertiary mb-1">${strings.sellerProductVariantStockLabel}</label><input type="number" min="0" class="variant-stock-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantStockPlaceholder}" /></div></div><div class="border-t border-border pt-4 space-y-4"><div class="flex items-center justify-between"><h3 class="text-xs font-semibold uppercase tracking-wider text-text-secondary">${strings.sellerProductVariantShippingTitle}</h3><div class="flex items-center gap-2"><button type="button" class="variant-use-defaults-btn px-3 py-1.5 rounded-lg text-[11px] font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">${strings.sellerProductVariantUseDefaults}</button><button type="button" class="variant-apply-shipping-btn px-3 py-1.5 rounded-lg text-[11px] font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">${strings.sellerProductVariantApplyToRest}</button></div></div><div class="grid gap-4 sm:grid-cols-5"><div><label class="block text-xs font-medium text-text-tertiary mb-1">${strings.sellerProductVariantWeightLabel}</label><input type="number" step="0.001" min="0" class="variant-weight-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantWeightPlaceholder}" value="${shippingDefaults.weight_kg ?? ''}" /></div><div><label class="block text-xs font-medium text-text-tertiary mb-1">${strings.sellerProductVariantLengthLabel}</label><input type="number" step="0.1" min="0" class="variant-length-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantLengthPlaceholder}" value="${shippingDefaults.length_cm ?? ''}" /></div><div><label class="block text-xs font-medium text-text-tertiary mb-1">${strings.sellerProductVariantWidthLabel}</label><input type="number" step="0.1" min="0" class="variant-width-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantWidthPlaceholder}" value="${shippingDefaults.width_cm ?? ''}" /></div><div><label class="block text-xs font-medium text-text-tertiary mb-1">${strings.sellerProductVariantHeightLabel}</label><input type="number" step="0.1" min="0" class="variant-height-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantHeightPlaceholder}" value="${shippingDefaults.height_cm ?? ''}" /></div><div><label class="block text-xs font-medium text-text-tertiary mb-1">${strings.sellerProductVariantShippingLabel}</label><input type="number" step="0.01" min="0" class="variant-shipping-input w-full px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantShippingPlaceholder}" value="${shippingDefaults.shipping_cost ?? ''}" /></div></div></div><div><label class="block text-xs font-medium text-text-tertiary mb-1">${strings.sellerProductVariantImage}</label><div class="flex items-center gap-3"><div class="variant-image-preview w-14 h-14 rounded-lg border border-border bg-bg overflow-hidden flex items-center justify-center"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-text-tertiary"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg></div><button type="button" class="variant-image-btn px-3 py-1.5 rounded-lg text-xs font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">Subir</button><input type="file" accept="image/jpeg,image/png,image/webp,image/gif" class="variant-image-input hidden" /></div></div>`;

            const removeBtn = div.querySelector('.variant-remove-btn') as HTMLButtonElement;
            removeBtn.addEventListener('click', () => { div.remove(); });

            const defaultCheckbox = div.querySelector('.variant-default-checkbox') as HTMLInputElement;
            defaultCheckbox.addEventListener('change', () => {
                if (defaultCheckbox.checked) {
                    variantsContainer.querySelectorAll('.variant-default-checkbox').forEach((cb) => {
                        if (cb !== defaultCheckbox) (cb as HTMLInputElement).checked = false;
                    });
                }
            });

            return div;
        }

        variantsContainer.addEventListener('click', (e: MouseEvent) => {
            const removeBtn = (e.target as HTMLElement).closest('.variant-remove-btn') as HTMLElement | null;
            if (!removeBtn) return;
            const row = removeBtn.closest('.variant-row') as HTMLElement;
            row.remove();
        });

        variantsContainer.addEventListener('change', (e: Event) => {
            if (!((e.target as HTMLInputElement).classList.contains('variant-default-checkbox'))) return;
            if ((e.target as HTMLInputElement).checked) {
                variantsContainer.querySelectorAll('.variant-default-checkbox').forEach((cb) => {
                    if (cb !== e.target) (cb as HTMLInputElement).checked = false;
                });
            }
        });

        addSpecBtn.addEventListener('click', () => {
            const div = document.createElement('div');
            div.className = 'spec-row flex items-center gap-3';
            div.innerHTML = `<input type="text" class="spec-key-input w-2/5 px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition" placeholder="${strings.sellerProductSpecsKeyPlaceholder}" /><input type="text" class="spec-value-input flex-1 px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition" placeholder="${strings.sellerProductSpecsValuePlaceholder}" /><button type="button" class="spec-remove-btn flex items-center justify-center w-7 h-7 rounded-lg text-text-tertiary hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors shrink-0"><svg width="16" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button>`;
            div.querySelector('.spec-remove-btn')!.addEventListener('click', () => div.remove());
            specsContainer.appendChild(div);
        });

        specsContainer.addEventListener('click', (e: MouseEvent) => {
            const removeBtn = (e.target as HTMLElement).closest('.spec-remove-btn') as HTMLElement | null;
            if (!removeBtn) return;
            removeBtn.closest('.spec-row')!.remove();
        });

        imageGallery.addEventListener('click', (e: MouseEvent) => {
            const removeBtn = (e.target as HTMLElement).closest('.image-remove-btn') as HTMLElement | null;
            if (!removeBtn) return;
            const item = removeBtn.closest('.image-item') as HTMLElement;
            const url = item.dataset.url;
            const idx = galleryUrls.indexOf(url!);
            if (idx > -1) galleryUrls.splice(idx, 1);
            renderGallery();
        });

        saveBtn.addEventListener('click', async () => {
            errorMsg.classList.add('hidden');
            successMsg.classList.add('hidden');

            const title = titleInput.value.trim();
            const slug = slugInput.value.trim();
            const category = categorySelect.value;
            const description = descriptionInput.value.trim();
            const brand = brandInput.value.trim();
            const is_active = activeCheckbox.checked;

            if (!title) {
                errorMsg.textContent = strings.sellerProductTitleRequired;
                errorMsg.classList.remove('hidden');
                return;
            }
            if (!category) {
                errorMsg.textContent = strings.sellerProductCategoryRequired;
                errorMsg.classList.remove('hidden');
                return;
            }

            const variants = Array.from(variantsContainer.querySelectorAll('.variant-row')).map((row: Element) => {
                const el = row as HTMLElement;
                const priceInput = el.querySelector('.variant-price-input') as HTMLInputElement;
                const price = parseFloat(priceInput.value) || 0;
                return {
                    id: el.dataset.variantId || undefined,
                    variant_name: (el.querySelector('.variant-name-input') as HTMLInputElement).value.trim() || null,
                    price,
                    stock: parseInt((el.querySelector('.variant-stock-input') as HTMLInputElement).value) || 0,
                    is_default: (el.querySelector('.variant-default-checkbox') as HTMLInputElement).checked,
                    variant_image: el.dataset.variantImage || (el.querySelector('.variant-image-preview img')?.getAttribute('src')) || null,
                    weight_kg: (el.querySelector('.variant-weight-input') as HTMLInputElement).value === '' ? null : parseFloat((el.querySelector('.variant-weight-input') as HTMLInputElement).value),
                    length_cm: (el.querySelector('.variant-length-input') as HTMLInputElement).value === '' ? null : parseFloat((el.querySelector('.variant-length-input') as HTMLInputElement).value),
                    width_cm: (el.querySelector('.variant-width-input') as HTMLInputElement).value === '' ? null : parseFloat((el.querySelector('.variant-width-input') as HTMLInputElement).value),
                    height_cm: (el.querySelector('.variant-height-input') as HTMLInputElement).value === '' ? null : parseFloat((el.querySelector('.variant-height-input') as HTMLInputElement).value),
                    shipping_cost: (el.querySelector('.variant-shipping-input') as HTMLInputElement).value === '' ? null : parseFloat((el.querySelector('.variant-shipping-input') as HTMLInputElement).value),
                };
            });

            if (variants.length === 0) {
                errorMsg.textContent = strings.sellerProductNoVariantsError;
                errorMsg.classList.remove('hidden');
                return;
            }

            // Completeness validation
            const missingFields: string[] = [];
            if (!title) missingFields.push(strings.sellerProductMissingName);
            if (!description) missingFields.push(strings.sellerProductMissingDescription);
            if (!category) missingFields.push(strings.sellerProductMissingCategory);
            if (!slug) missingFields.push(strings.sellerProductMissingSlug);
            if (galleryUrls.length === 0) missingFields.push(strings.sellerProductMissingPhotos);

            const hasCompleteVariant = variants.some((v: any) =>
                v.price > 0 &&
                v.stock >= 0 &&
                v.weight_kg != null && v.weight_kg > 0 &&
                v.length_cm != null && v.length_cm > 0 &&
                v.width_cm != null && v.width_cm > 0 &&
                v.height_cm != null && v.height_cm > 0 &&
                v.shipping_cost != null && v.shipping_cost >= 0
            );
            if (!hasCompleteVariant) missingFields.push(strings.sellerProductMissingVariantData);

            if (missingFields.length > 0) {
                const list = missingFields.join(', ');
                errorMsg.textContent = strings.sellerProductIncompleteError.replace('{fields}', list);
                errorMsg.classList.remove('hidden');
                return;
            }

            const specs: Record<string, string> = {};
            specsContainer.querySelectorAll('.spec-row').forEach((row: Element) => {
                const key = (row.querySelector('.spec-key-input') as HTMLInputElement).value.trim();
                const value = (row.querySelector('.spec-value-input') as HTMLInputElement).value.trim();
                if (key) specs[key] = value;
            });

            const payload = {
                title,
                slug: slug || undefined,
                description: description || null,
                category,
                brand: brand || null,
                specifications: specs,
                gallery_images: galleryUrls,
                is_active,
                variants,
            };

            saveBtn.disabled = true;
            saveText.textContent = strings.sellerProductSaving;
            saveSpinner.classList.remove('hidden');

            try {
                let url = '/api/sell/catalog/product';
                let method = 'POST';
                const productId = (document.getElementById('product-id') as HTMLInputElement).value;

                if (mode === 'edit' && productId) {
                    url += `?id=${productId}`;
                    method = 'PATCH';
                }

                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                });

                const data: { product?: { id: string }; error?: string } = await res.json();

                if (!res.ok) {
                    throw new Error(data.error || strings.sellerProductSaveError);
                }

                successMsg.classList.remove('hidden');
                setTimeout(() => successMsg.classList.add('hidden'), 4000);

                if (mode === 'create' && data.product?.id) {
                    window.location.href = `/sell/catalog/${data.product.id}`;
                    return;
                }

                if (mode === 'edit') {
                    window.location.href = '/sell/catalog';
                    return;
                }
            } catch (err) {
                errorMsg.textContent = err instanceof Error ? err.message : strings.sellerProductSaveError;
                errorMsg.classList.remove('hidden');
            } finally {
                saveBtn.disabled = false;
                saveText.textContent = strings.sellerProductSave;
                saveSpinner.classList.add('hidden');
            }
        });
    }

    document.addEventListener('astro:page-load', initProductForm);
    if (document.readyState !== 'loading') initProductForm();
    else document.addEventListener('DOMContentLoaded', initProductForm);
</script>
