---
import Icon from '../icons/Icon.astro';
import ShippingEditorPanel from './ShippingEditorPanel.astro';
import VariantRow from './VariantRow.astro';
import VariantShippingModal from './VariantShippingModal.astro';
import { getCategories } from '../../lib/core/i18n';
const { t } = Astro.locals;
const categories = getCategories(t);
interface VariantData {
    id?: string;
    variant_name: string | null;
    price: number;
    stock: number;
    is_default: boolean;
    variant_image: string | null;
    weight_kg?: number | null;
    length_cm?: number | null;
    width_cm?: number | null;
    height_cm?: number | null;
    shipping_cost?: number | null;
}

interface ShippingDefaults {
    weight_kg?: number | null;
    length_cm?: number | null;
    width_cm?: number | null;
    height_cm?: number | null;
    shipping_cost?: number | null;
}

interface Props {
    mode: 'create' | 'edit';
    shopId: string;
    product?: {
        id: string;
        title: string;
        slug: string;
        description: string | null;
        category: string;
        brand: string | null;
        gallery_images: string[];
        is_active: boolean;
        specifications: Record<string, any>;
    };
    variants?: VariantData[];
    shippingDefaults?: ShippingDefaults;
}

const { mode, shopId, product, variants, shippingDefaults } = Astro.props;
const isEdit = mode === 'edit';

const title = product?.title ?? '';
const slug = product?.slug ?? '';
const description = product?.description ?? '';
const category = product?.category ?? '';
const brand = product?.brand ?? '';
const galleryImages: string[] = product?.gallery_images ?? [];
const isActive = product?.is_active ?? true;
const specs = product?.specifications ?? {};

const initialVariants: VariantData[] = (variants && variants.length > 0) ? variants : [
    { variant_name: '', price: 0, stock: 0, is_default: true, variant_image: null, weight_kg: shippingDefaults?.weight_kg ?? null, length_cm: shippingDefaults?.length_cm ?? null, width_cm: shippingDefaults?.width_cm ?? null, height_cm: shippingDefaults?.height_cm ?? null, shipping_cost: shippingDefaults?.shipping_cost ?? null }
];

const defaultsJson = JSON.stringify(shippingDefaults ?? {});
// Central shipping = values from the default variant (or first), with shop defaults as fallback.
const baseVariant: VariantData | undefined = initialVariants.find((v) => v.is_default) ?? initialVariants[0];
const centralShipping = {
    weight_kg: baseVariant?.weight_kg ?? shippingDefaults?.weight_kg ?? null,
    length_cm: baseVariant?.length_cm ?? shippingDefaults?.length_cm ?? null,
    width_cm: baseVariant?.width_cm ?? shippingDefaults?.width_cm ?? null,
    height_cm: baseVariant?.height_cm ?? shippingDefaults?.height_cm ?? null,
    shipping_cost: baseVariant?.shipping_cost ?? shippingDefaults?.shipping_cost ?? null,
};

function variantHasShippingOverride(v: VariantData): boolean {
    if (initialVariants.length <= 1) return false;
    return (
        (v.weight_kg ?? null) !== centralShipping.weight_kg ||
        (v.length_cm ?? null) !== centralShipping.length_cm ||
        (v.width_cm ?? null) !== centralShipping.width_cm ||
        (v.height_cm ?? null) !== centralShipping.height_cm ||
        (v.shipping_cost ?? null) !== centralShipping.shipping_cost
    );
}
---

<div
    id="product-form-root"
    data-shop-id={shopId}
    data-mode={mode}
    data-gallery={JSON.stringify(galleryImages)}
    data-shipping-defaults={defaultsJson}
>
    <input type="hidden" id="product-id" value={isEdit ? product!.id : ''} />

    <!-- Sticky header -->
    <div class="sticky top-0 z-30 -mx-4 sm:-mx-6 lg:-mx-10 px-4 sm:px-6 lg:px-10 mb-6 border-b border-border bg-bg/85 backdrop-blur supports-[backdrop-filter]:bg-bg/70">
        <div class="flex items-center gap-3 py-3 max-w-3xl mx-auto">
            <a
                href="/sell/catalog"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors no-underline shrink-0"
                aria-label={t.sellerProductBackToCatalog}
            >
                <Icon name="arrow-left" size={18} />
            </a>
            <div class="min-w-0 flex-1">
                <p id="header-product-title" class="text-sm font-medium text-text-primary truncate">
                    {title || (isEdit ? t.sellerProductEditTitle : t.sellerProductNewTitle)}
                </p>
                <p id="header-summary" class="text-[11px] mt-0.5 font-medium text-amber-600 dark:text-amber-400">
                    {t.sellerProductHeaderSummaryPendingSingle}
                </p>
            </div>
            <button
                type="button"
                id="save-product-btn"
                class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-accent text-bg font-medium text-sm hover:scale-[1.02] active:scale-[0.99] transition-transform shadow-sm shrink-0"
            >
                <span data-busy-label>{t.sellerProductSave}</span>
                <Icon name="arrow-up-right" size={14} />
            </button>
        </div>
    </div>

    <div class="max-w-3xl mx-auto">
        <div class="bg-surface p-5 sm:p-6 md:p-8 rounded-3xl border border-border shadow-sm space-y-10">

            <!-- Producto -->
            <section class="space-y-5">
                <h2 class="text-lg font-medium text-text-primary border-b border-border pb-2">{t.sellerProductSectionBasicTitle}</h2>
                <div class="space-y-5">
                    <div>
                        <label for="product-title" class="block text-sm font-medium text-text-secondary mb-2">
                            {t.sellerProductTitleLabel} <span class="text-red-500">*</span>
                        </label>
                        <input
                            type="text"
                            id="product-title"
                            required
                            value={title}
                            class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition"
                            placeholder={t.sellerProductTitlePlaceholder}
                        />
                    </div>
                    <div>
                        <label for="product-description" class="block text-sm font-medium text-text-secondary mb-2">{t.sellerProductDescriptionLabel}</label>
                        <textarea
                            id="product-description"
                            rows="4"
                            class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition resize-none"
                            placeholder={t.sellerProductDescriptionPlaceholder}
                        >{description}</textarea>
                    </div>
                    <div class="grid gap-5 sm:grid-cols-2">
                        <div>
                            <label for="product-category" class="block text-sm font-medium text-text-secondary mb-2">
                                {t.sellerProductCategoryLabel} <span class="text-red-500">*</span>
                            </label>
                            <select
                                id="product-category"
                                required
                                class="w-full px-4 py-3 rounded-xl border border-border bg-surface text-text-primary focus:ring-2 focus:ring-accent outline-none transition appearance-none [color-scheme:light] dark:[color-scheme:dark]"
                            >
                                <option value="" disabled selected={category === ''} class="bg-surface text-text-tertiary">{t.sellerProductCategoryPlaceholder}</option>
                                {categories.map(cat => (
                                    <option value={cat.value} selected={category === cat.value} class="bg-surface text-text-primary">{cat.label}</option>
                                ))}
                            </select>
                        </div>
                        <div>
                            <label for="product-brand" class="block text-sm font-medium text-text-secondary mb-2">{t.sellerProductBrandLabel}</label>
                            <input
                                type="text"
                                id="product-brand"
                                value={brand}
                                class="w-full px-4 py-3 rounded-xl border border-border bg-transparent text-text-primary focus:ring-2 focus:ring-accent outline-none transition"
                                placeholder={t.sellerProductBrandPlaceholder}
                            />
                        </div>
                    </div>
                </div>
            </section>

            <!-- Fotos -->
            <section class="space-y-5">
                <div>
                    <h2 class="text-lg font-medium text-text-primary border-b border-border pb-2">{t.sellerProductSectionImagesTitle}</h2>
                    <p class="mt-1.5 text-xs text-text-tertiary">{t.sellerProductSectionImagesSubtitle}</p>
                </div>

                <div
                    id="image-drop-zone"
                    class="relative flex flex-col items-center justify-center gap-1.5 px-6 py-7 border-2 border-dashed border-border rounded-2xl bg-bg cursor-pointer hover:border-accent hover:bg-border-light/50 transition-colors"
                >
                    <Icon name="upload-cloud" size={24} class="text-text-tertiary" />
                    <p class="text-sm text-text-secondary">{t.sellerProductImagesDragDrop}</p>
                    <input type="file" id="image-upload-input" multiple accept="image/jpeg,image/png,image/webp,image/gif" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                </div>

                <div id="image-gallery" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3">
                    {galleryImages.map((url, i) => (
                        <div class="image-item relative group rounded-xl overflow-hidden border border-border aspect-square bg-bg cursor-move" data-url={url}>
                            <img src={url} alt="" class="w-full h-full object-cover" loading="lazy" />
                            {i === 0 && (
                                <span class="absolute top-1.5 left-1.5 px-1.5 py-0.5 rounded-md text-[10px] font-medium bg-accent text-bg shadow-sm">Portada</span>
                            )}
                            <button
                                type="button"
                                class="image-remove-btn absolute top-1.5 right-1.5 w-6 h-6 rounded-full bg-black/65 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
                                aria-label={t.sellerProductImageRemove}
                            >
                                <Icon name="x" size={14} />
                            </button>
                        </div>
                    ))}
                </div>
            </section>

            <!-- Envío y dimensiones (común a todas las variantes) -->
            <section class="space-y-5" id="central-shipping-section">
                <div class="flex items-start justify-between gap-3 flex-wrap border-b border-border pb-3">
                    <div>
                        <h2 class="text-lg font-medium text-text-primary">{t.sellerProductCentralShippingTitle}</h2>
                        <p class="mt-1 text-xs text-text-tertiary">{t.sellerProductCentralShippingSubtitle}</p>
                    </div>
                    <button type="button" id="central-use-defaults-btn" class="shrink-0 flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-text-secondary border border-border hover:bg-border-light hover:text-text-primary transition-colors">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
                        {t.sellerProductCentralUseDefaults}
                    </button>
                </div>

                <ShippingEditorPanel
                    idPrefix="central"
                    weight={centralShipping.weight_kg}
                    length={centralShipping.length_cm}
                    width={centralShipping.width_cm}
                    height={centralShipping.height_cm}
                    shippingCost={centralShipping.shipping_cost}
                />
            </section>

            <!-- Variantes -->
            <section class="space-y-5">
                <div>
                    <h2 class="text-lg font-medium text-text-primary border-b border-border pb-2">{t.sellerProductSectionVariantsTitle}</h2>
                    <p class="mt-1.5 text-xs text-text-tertiary">{t.sellerProductSectionVariantsSubtitle}</p>
                </div>

                <div id="variants-container" class="space-y-2">
                    {initialVariants.map((v) => (
                        <VariantRow variant={v} hasShippingOverride={variantHasShippingOverride(v)} />
                    ))}
                </div>

                <template id="variant-row-template">
                    <VariantRow />
                </template>

                <button
                    type="button"
                    id="add-variant-btn"
                    class="flex items-center gap-2 px-4 py-2.5 rounded-xl border border-dashed border-border text-sm text-text-secondary hover:text-text-primary hover:border-accent transition-colors"
                >
                    <Icon name="plus" size={16} />
                    {t.sellerProductAddVariant}
                </button>
            </section>

            <!-- Opciones avanzadas -->
            <details class="group">
                <summary class="flex items-center gap-2 cursor-pointer list-none border-b border-border pb-2 [&::-webkit-details-marker]:hidden">
                    <svg class="text-text-tertiary transition-transform duration-200 group-open:rotate-90 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
                    <h2 class="text-lg font-medium text-text-primary">{t.sellerProductAdvancedSection}</h2>
                    <span class="hidden sm:inline text-xs text-text-tertiary ml-2 truncate font-normal">{t.sellerProductAdvancedHint}</span>
                </summary>

                <div class="space-y-6 pt-5">
                    <!-- Slug -->
                    <div>
                        <label for="product-slug" class="block text-sm font-medium text-text-secondary mb-2">{t.sellerProductSlugLabel}</label>
                        <div class="flex items-stretch rounded-xl border border-border bg-transparent focus-within:ring-2 focus-within:ring-accent transition overflow-hidden">
                            <span class="flex items-center pl-4 pr-1 text-text-tertiary whitespace-nowrap select-none text-sm">{shopId}/</span>
                            <input
                                type="text"
                                id="product-slug"
                                value={slug}
                                class="w-full px-2 py-3 bg-transparent text-text-primary outline-none text-sm"
                                placeholder={t.sellerProductSlugPlaceholder}
                            />
                        </div>
                        <p class="text-[11px] text-text-tertiary mt-1.5">{t.sellerProductSlugNote}</p>
                    </div>

                    <!-- Especificaciones -->
                    <div>
                        <label class="block text-sm font-medium text-text-secondary mb-2">{t.sellerProductSpecsLabel}</label>
                        <div id="specs-container" class="space-y-2">
                            {Object.entries(specs).map(([key, value]) => (
                                <div class="spec-row flex items-center gap-2">
                                    <input type="text" class="spec-key-input flex-1 min-w-0 px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition" placeholder={t.sellerProductSpecsKeyPlaceholder} value={key} />
                                    <input type="text" class="spec-value-input flex-1 min-w-0 px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition" placeholder={t.sellerProductSpecsValuePlaceholder} value={String(value)} />
                                    <button type="button" class="spec-remove-btn flex items-center justify-center w-8 h-8 rounded-lg text-text-tertiary hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors shrink-0" aria-label={t.sellerCatalogDelete}>
                                        <Icon name="x" size={14} />
                                    </button>
                                </div>
                            ))}
                        </div>
                        <button
                            type="button"
                            id="add-spec-btn"
                            class="mt-3 flex items-center gap-2 px-3 py-1.5 rounded-lg border border-dashed border-border text-xs text-text-secondary hover:text-text-primary hover:border-accent transition-colors"
                        >
                            <Icon name="plus" size={14} />
                            {t.sellerProductAddSpec}
                        </button>
                    </div>

                    <!-- Visibilidad -->
                    <div class="flex items-center justify-between gap-3 pt-2">
                        <div>
                            <label for="product-active" class="text-sm font-medium text-text-primary cursor-pointer select-none">
                                {t.sellerProductActiveInline}
                            </label>
                            <p class="text-[11px] text-text-tertiary mt-0.5">{t.sellerProductActiveNote}</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer shrink-0">
                            <input type="checkbox" id="product-active" class="sr-only peer" checked={isActive} />
                            <div class="w-11 h-6 bg-border-light rounded-full peer-focus-visible:ring-2 peer-focus-visible:ring-accent peer-checked:bg-accent transition-colors after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-transform peer-checked:after:translate-x-full"></div>
                        </label>
                    </div>
                </div>
            </details>
        </div>
    </div>
</div>

<!-- Modal: sin valores por defecto configurados -->
<div id="no-defaults-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4">
    <div class="bg-surface rounded-2xl border border-border p-6 max-w-sm w-full shadow-xl">
        <p class="text-sm font-medium text-text-primary">{t.sellerProductShippingNoDefaultsTitle}</p>
        <p class="mt-2 text-sm text-text-secondary">{t.sellerProductShippingNoDefaultsBody}</p>
        <div class="mt-5 flex justify-end gap-3">
            <button type="button" id="no-defaults-cancel-btn" class="px-4 py-2 rounded-xl text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors">{t.sellerOnboardingPrev}</button>
            <a href="/sell/settings" id="no-defaults-go-btn" class="px-4 py-2 rounded-xl text-sm font-medium bg-accent text-bg hover:bg-accent-hover transition-colors">{t.sellerProductShippingGoToSettings}</a>
        </div>
    </div>
</div>

<VariantShippingModal />

<script>
    import { getClientT } from '../../lib/core/i18n';
    import { toast } from '../../lib/ui/toast';
    import { runSubmit, SubmitError } from '../../lib/ui/submit';
    import {
        readNum,
        renderPreviewForScope,
        applyShippingDefaults,
        initShippingEditor,
    } from '../../lib/ui/shipping-editor';
    import { openVariantShippingModal, type ShippingValues } from '../../lib/ui/variant-shipping-modal';
    import { compressImage, PRODUCT_PRESET } from '../../lib/ui/imageCompress';
    import Sortable from 'sortablejs';
const t = getClientT();

    function valuesEqual(a: number, b: number): boolean {
        const aN = Number.isFinite(a);
        const bN = Number.isFinite(b);
        if (!aN && !bN) return true;
        if (!aN || !bN) return false;
        return Math.abs(a - b) < 0.0001;
    }

    function initProductForm() {
        const root = document.getElementById('product-form-root');
        if (!root) return;

        const mode = root.dataset.mode || 'create';
        const galleryUrls: string[] = JSON.parse(root.dataset.gallery || '[]');
        const shippingDefaults: Record<string, number | null> = JSON.parse(root.dataset.shippingDefaults || '{}');

        const titleInput = document.getElementById('product-title') as HTMLInputElement;
        const slugInput = document.getElementById('product-slug') as HTMLInputElement;
        const categorySelect = document.getElementById('product-category') as unknown as HTMLSelectElement;
        const descriptionInput = document.getElementById('product-description') as HTMLTextAreaElement;
        const brandInput = document.getElementById('product-brand') as HTMLInputElement;
        const activeCheckbox = document.getElementById('product-active') as HTMLInputElement;
        const saveBtn = document.getElementById('save-product-btn') as HTMLButtonElement;
        const imageGallery = document.getElementById('image-gallery') as HTMLDivElement;
        const imageUploadInput = document.getElementById('image-upload-input') as HTMLInputElement;
        const variantsContainer = document.getElementById('variants-container') as HTMLDivElement;
        const variantTemplate = document.getElementById('variant-row-template') as HTMLTemplateElement | null;
        const addVariantBtn = document.getElementById('add-variant-btn') as HTMLButtonElement;
        const specsContainer = document.getElementById('specs-container') as HTMLDivElement;
        const addSpecBtn = document.getElementById('add-spec-btn') as HTMLButtonElement;
        const headerTitle = document.getElementById('header-product-title');
        const headerSummary = document.getElementById('header-summary');

        // Central shipping
        const centralWeight = document.getElementById('central-weight-input') as HTMLInputElement;
        const centralLength = document.getElementById('central-length-input') as HTMLInputElement;
        const centralWidth = document.getElementById('central-width-input') as HTMLInputElement;
        const centralHeight = document.getElementById('central-height-input') as HTMLInputElement;
        const centralShippingInput = document.getElementById('central-shipping-input') as HTMLInputElement;
        const centralShippingLive = document.getElementById('central-shipping-live') as HTMLElement;
        const centralUseDefaultsBtn = document.getElementById('central-use-defaults-btn') as HTMLButtonElement | null;
        const centralPanel = document.querySelector<HTMLElement>('.shipping-editor-panel[data-id-prefix="central"]');

        if (!titleInput || !saveBtn) return;

        // ---- Effective shipping helpers ----

        function getCentralValues(): ShippingValues {
            return {
                weight: readNum(centralWeight),
                length: readNum(centralLength),
                width: readNum(centralWidth),
                height: readNum(centralHeight),
                shipping: readNum(centralShippingInput),
            };
        }

        function variantOverrideContainer(row: HTMLElement) {
            return row.querySelector('.variant-shipping-override') as HTMLElement | null;
        }

        function isVariantOverride(row: HTMLElement): boolean {
            return variantOverrideContainer(row)?.dataset.shippingOverride === 'true';
        }

        function readVariantOverrideValues(row: HTMLElement): ShippingValues | null {
            const c = variantOverrideContainer(row);
            if (!c || c.dataset.shippingOverride !== 'true') return null;
            return {
                weight: readNum(c.querySelector('.variant-weight-input') as HTMLInputElement),
                length: readNum(c.querySelector('.variant-length-input') as HTMLInputElement),
                width: readNum(c.querySelector('.variant-width-input') as HTMLInputElement),
                height: readNum(c.querySelector('.variant-height-input') as HTMLInputElement),
                shipping: readNum(c.querySelector('.variant-shipping-input') as HTMLInputElement),
            };
        }

        function getEffectiveShipping(row: HTMLElement): ShippingValues {
            const ov = readVariantOverrideValues(row);
            return ov ?? getCentralValues();
        }

        function readVariantBasic(row: HTMLElement) {
            return {
                name: (row.querySelector('.variant-name-input') as HTMLInputElement | null)?.value ?? '',
                price: parseFloat((row.querySelector('.variant-price-input') as HTMLInputElement | null)?.value || '') || 0,
                stock: parseInt((row.querySelector('.variant-stock-input') as HTMLInputElement | null)?.value || '0', 10) || 0,
            };
        }

        function isVariantComplete(row: HTMLElement): boolean {
            const basic = readVariantBasic(row);
            const s = getEffectiveShipping(row);
            return basic.price > 0 && basic.stock >= 0 &&
                Number.isFinite(s.weight) && s.weight > 0 &&
                Number.isFinite(s.length) && s.length > 0 &&
                Number.isFinite(s.width) && s.width > 0 &&
                Number.isFinite(s.height) && s.height > 0 &&
                Number.isFinite(s.shipping) && s.shipping >= 0;
        }

        function renderCentralPreview() {
            const v = getCentralValues();
            renderPreviewForScope(centralShippingLive, v.weight, v.length, v.width, v.height);
        }

        function updateVariantHeader(row: HTMLElement) {
            const basic = readVariantBasic(row);
            const eff = getEffectiveShipping(row);
            const nameEl = row.querySelector('.variant-name-display') as HTMLElement | null;
            const priceEl = row.querySelector('.variant-price-display') as HTMLElement | null;
            const stockEl = row.querySelector('.variant-stock-display') as HTMLElement | null;
            const summaryShipping = row.querySelector('.variant-summary-shipping') as HTMLElement | null;
            const summaryWarning = row.querySelector('.variant-summary-warning') as HTMLElement | null;
            const summaryMeta = row.querySelector('.variant-summary-meta') as HTMLElement | null;

            if (nameEl) nameEl.textContent = basic.name.trim() || t.sellerProductVariantPlaceholderName;
            if (priceEl) priceEl.textContent = basic.price > 0 ? `${basic.price.toFixed(2)} €` : '—';
            if (stockEl) stockEl.textContent = t.sellerProductVariantSummaryStock.replace('{count}', String(basic.stock));

            const complete = isVariantComplete(row);
            if (complete) {
                if (summaryWarning) {
                    summaryWarning.classList.add('hidden');
                    summaryWarning.classList.remove('inline-flex');
                }
                if (summaryShipping) {
                    summaryShipping.classList.remove('hidden');
                    const prefix = isVariantOverride(row) ? '✦ ' : '';
                    summaryShipping.textContent = eff.shipping === 0
                        ? prefix + t.sellerProductVariantSummaryFree
                        : prefix + t.sellerProductVariantSummaryShipping.replace('{price}', `${eff.shipping.toFixed(2)} €`);
                }
                if (summaryMeta) summaryMeta.classList.remove('hidden');
            } else {
                if (summaryShipping) {
                    summaryShipping.classList.add('hidden');
                    summaryShipping.textContent = '';
                }
                if (summaryWarning) {
                    summaryWarning.classList.remove('hidden');
                    summaryWarning.classList.add('inline-flex');
                }
                if (summaryMeta) summaryMeta.classList.add('hidden');
            }
        }

        function toggleVariantExpansion(row: HTMLElement, expand: boolean | 'toggle' = 'toggle') {
            const body = row.querySelector('.variant-body') as HTMLElement | null;
            if (!body) return;
            const chevron = row.querySelector('.variant-chevron') as SVGElement | null;
            const currentlyExpanded = !body.classList.contains('hidden');
            const willExpand = expand === 'toggle' ? !currentlyExpanded : expand;

            if (willExpand) {
                variantsContainer.querySelectorAll('.variant-row').forEach((other) => {
                    if (other === row) return;
                    const otherBody = other.querySelector('.variant-body') as HTMLElement | null;
                    const otherChevron = other.querySelector('.variant-chevron') as SVGElement | null;
                    if (otherBody) otherBody.classList.add('hidden');
                    if (otherChevron) otherChevron.style.transform = '';
                });
                body.classList.remove('hidden');
                if (chevron) chevron.style.transform = 'rotate(90deg)';
            } else {
                body.classList.add('hidden');
                if (chevron) chevron.style.transform = '';
            }
        }

        function updateVariantShippingStatus(row: HTMLElement) {
            const isOv = isVariantOverride(row);
            const statusIcon = row.querySelector('.variant-shipping-status-icon') as HTMLElement | null;
            const statusText = row.querySelector('.variant-shipping-status-text') as HTMLElement | null;
            const customizeLabel = row.querySelector('.variant-customize-shipping-label') as HTMLElement | null;
            const status = row.querySelector('.variant-shipping-status') as HTMLElement | null;

            if (statusIcon) statusIcon.textContent = isOv ? '✦' : '·';
            if (statusText) statusText.textContent = isOv ? t.sellerProductVariantUsesCustomShipping : t.sellerProductVariantUsesCommonShipping;
            if (customizeLabel) customizeLabel.textContent = isOv ? t.sellerProductVariantEditShipping : t.sellerProductVariantCustomizeShipping;
            if (status) {
                status.classList.toggle('text-accent', isOv);
                status.classList.toggle('text-text-tertiary', !isOv);
            }

            const existingReset = row.querySelector('.variant-reset-shipping-btn') as HTMLButtonElement | null;
            if (isOv && !existingReset && status) {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'variant-reset-shipping-btn ml-1 text-text-tertiary hover:text-text-primary underline underline-offset-2';
                btn.textContent = t.sellerProductVariantResetShipping;
                status.appendChild(btn);
            } else if (!isOv && existingReset) {
                existingReset.remove();
            }
        }

        function setVariantOverride(row: HTMLElement, v: ShippingValues) {
            const c = variantOverrideContainer(row);
            if (!c) return;
            c.dataset.shippingOverride = 'true';
            (c.querySelector('.variant-weight-input') as HTMLInputElement).value = Number.isFinite(v.weight) ? String(v.weight) : '';
            (c.querySelector('.variant-length-input') as HTMLInputElement).value = Number.isFinite(v.length) ? String(v.length) : '';
            (c.querySelector('.variant-width-input') as HTMLInputElement).value = Number.isFinite(v.width) ? String(v.width) : '';
            (c.querySelector('.variant-height-input') as HTMLInputElement).value = Number.isFinite(v.height) ? String(v.height) : '';
            (c.querySelector('.variant-shipping-input') as HTMLInputElement).value = Number.isFinite(v.shipping) ? String(v.shipping) : '';
            updateVariantShippingStatus(row);
        }

        function clearVariantOverride(row: HTMLElement) {
            const c = variantOverrideContainer(row);
            if (!c) return;
            c.dataset.shippingOverride = 'false';
            (c.querySelector('.variant-weight-input') as HTMLInputElement).value = '';
            (c.querySelector('.variant-length-input') as HTMLInputElement).value = '';
            (c.querySelector('.variant-width-input') as HTMLInputElement).value = '';
            (c.querySelector('.variant-height-input') as HTMLInputElement).value = '';
            (c.querySelector('.variant-shipping-input') as HTMLInputElement).value = '';
            updateVariantShippingStatus(row);
        }

        const refreshChecks = () => {
            const title = titleInput.value.trim();
            const slug = slugInput.value.trim();
            const description = descriptionInput.value.trim();
            const category = categorySelect.value;

            const variantRows = Array.from(variantsContainer.querySelectorAll('.variant-row')) as HTMLElement[];
            const allVariantsComplete = variantRows.length > 0 && variantRows.every(isVariantComplete);

            const checks = {
                title: !!title,
                description: !!description,
                category: !!category,
                slug: !!slug,
                photos: galleryUrls.length > 0,
                variant: allVariantsComplete,
            } as Record<string, boolean>;

            const total = Object.keys(checks).length;
            const done = Object.values(checks).filter(Boolean).length;
            const pending = total - done;

            if (headerSummary) {
                if (pending === 0) {
                    headerSummary.textContent = t.sellerProductHeaderSummaryReady;
                    headerSummary.className = 'text-[11px] mt-0.5 font-medium text-green-700 dark:text-green-400';
                } else if (pending === 1) {
                    headerSummary.textContent = t.sellerProductHeaderSummaryPendingSingle;
                    headerSummary.className = 'text-[11px] mt-0.5 font-medium text-amber-600 dark:text-amber-400';
                } else {
                    headerSummary.textContent = t.sellerProductHeaderSummaryPendingPlural.replace('{count}', String(pending));
                    headerSummary.className = 'text-[11px] mt-0.5 font-medium text-amber-600 dark:text-amber-400';
                }
            }

            variantRows.forEach(updateVariantHeader);
        };

        const refreshHeaderTitle = () => {
            if (headerTitle) {
                headerTitle.textContent = titleInput.value.trim() || (mode === 'edit' ? t.sellerProductEditTitle : t.sellerProductNewTitle);
            }
        };

        let slugManual = slugInput.value !== '';
        titleInput.addEventListener('input', () => {
            if (!slugManual) {
                slugInput.value = titleInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
            }
            refreshHeaderTitle();
            refreshChecks();
        });
        slugInput.addEventListener('input', () => { slugManual = true; refreshChecks(); });
        descriptionInput.addEventListener('input', refreshChecks);
        categorySelect.addEventListener('change', refreshChecks);

        // ---- Central shipping handlers ----

        if (centralPanel) {
            initShippingEditor(centralPanel, { onChange: refreshChecks });
        }

        const noDefaultsModal = document.getElementById('no-defaults-modal') as HTMLElement | null;
        const noDefaultsCancelBtn = document.getElementById('no-defaults-cancel-btn') as HTMLButtonElement | null;

        const hasDefaults = Object.values(shippingDefaults).some(v => v != null);

        centralUseDefaultsBtn?.addEventListener('click', () => {
            if (!hasDefaults) {
                noDefaultsModal?.classList.remove('hidden');
                noDefaultsModal?.classList.add('flex');
                return;
            }
            if (centralPanel) applyShippingDefaults(centralPanel, shippingDefaults);
            renderCentralPreview();
            refreshChecks();
        });

        noDefaultsCancelBtn?.addEventListener('click', () => {
            noDefaultsModal?.classList.add('hidden');
            noDefaultsModal?.classList.remove('flex');
        });

        noDefaultsModal?.addEventListener('click', (e) => {
            if (e.target === noDefaultsModal) {
                noDefaultsModal.classList.add('hidden');
                noDefaultsModal.classList.remove('flex');
            }
        });

        imageUploadInput.addEventListener('change', async () => {
            const files = Array.from(imageUploadInput.files || []);
            if (files.length === 0) return;

            for (const file of files) {
                const compressed = await compressImage(file, PRODUCT_PRESET);
                const formData = new FormData();
                formData.append('file', compressed);
                try {
                    const res = await fetch('/api/sell/catalog/upload', { method: 'POST', body: formData });
                    const data: { error?: string; url?: string } = await res.json();
                    if (!res.ok) { toast.error(data.error || t.incidentUploadError); continue; }
                    galleryUrls.push(data.url!);
                    renderGallery();
                } catch { toast.error(t.incidentUploadError); }
            }
            imageUploadInput.value = '';
            refreshChecks();
        });

        function renderGallery() {
            imageGallery.innerHTML = '';
            galleryUrls.forEach((url: string, i: number) => {
                const div = document.createElement('div');
                div.className = 'image-item relative group rounded-xl overflow-hidden border border-border aspect-square bg-bg cursor-move';
                div.dataset.url = url;
                const coverBadge = i === 0 ? '<span class="absolute top-1.5 left-1.5 px-1.5 py-0.5 rounded-md text-[10px] font-medium bg-accent text-bg shadow-sm">Portada</span>' : '';
                div.innerHTML = `<img src="${url}" alt="" class="w-full h-full object-cover" loading="lazy" />${coverBadge}<button type="button" class="image-remove-btn absolute top-1.5 right-1.5 w-6 h-6 rounded-full bg-black/65 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity" aria-label="Remove"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button>`;
                imageGallery.appendChild(div);
            });
        }

        imageGallery.addEventListener('click', (e: MouseEvent) => {
            const removeBtn = (e.target as HTMLElement).closest('.image-remove-btn') as HTMLElement | null;
            if (!removeBtn) return;
            const item = removeBtn.closest('.image-item') as HTMLElement;
            const url = item.dataset.url;
            const idx = galleryUrls.indexOf(url!);
            if (idx > -1) galleryUrls.splice(idx, 1);
            renderGallery();
            refreshChecks();
        });

        Sortable.create(imageGallery, {
            animation: 150,
            filter: '.image-remove-btn',
            preventOnFilter: false,
            ghostClass: 'opacity-40',
            chosenClass: 'ring-2',
            onEnd: () => {
                const urls = Array.from(imageGallery.querySelectorAll<HTMLElement>('.image-item'))
                    .map((el) => el.dataset.url)
                    .filter((url): url is string => Boolean(url));
                galleryUrls.length = 0;
                galleryUrls.push(...urls);
                renderGallery();
                refreshChecks();
            },
        });

        // ---- Variantes ----

        function openShippingModalForRow(row: HTMLElement) {
            const nameInput = row.querySelector('.variant-name-input') as HTMLInputElement | null;
            const variantName = nameInput?.value.trim() || t.sellerProductVariantPlaceholderName;
            const initial = readVariantOverrideValues(row) ?? getCentralValues();
            openVariantShippingModal({
                variantName,
                initialValues: initial,
                onApply: (values) => {
                    const c = getCentralValues();
                    const same = valuesEqual(values.weight, c.weight)
                        && valuesEqual(values.length, c.length)
                        && valuesEqual(values.width, c.width)
                        && valuesEqual(values.height, c.height)
                        && valuesEqual(values.shipping, c.shipping);
                    if (same) clearVariantOverride(row);
                    else setVariantOverride(row, values);
                    updateVariantHeader(row);
                    refreshChecks();
                },
                onReset: () => {
                    clearVariantOverride(row);
                    updateVariantHeader(row);
                    refreshChecks();
                },
            });
        }

        variantsContainer.addEventListener('click', (e: MouseEvent) => {
            const target = e.target as HTMLElement;

            const imgBtn = target.closest('.variant-image-btn') as HTMLElement | null;
            if (imgBtn) {
                e.stopPropagation();
                const row = imgBtn.closest('.variant-row') as HTMLElement;
                const fileInput = row.querySelector('input.variant-image-input[type="file"]') as HTMLInputElement;
                fileInput?.click();
                return;
            }

            const customizeBtn = target.closest('.variant-customize-shipping-btn') as HTMLElement | null;
            if (customizeBtn) {
                e.stopPropagation();
                const row = customizeBtn.closest('.variant-row') as HTMLElement;
                openShippingModalForRow(row);
                return;
            }

            const resetBtn = target.closest('.variant-reset-shipping-btn') as HTMLElement | null;
            if (resetBtn) {
                e.stopPropagation();
                const row = resetBtn.closest('.variant-row') as HTMLElement;
                clearVariantOverride(row);
                updateVariantHeader(row);
                refreshChecks();
                return;
            }

            const removeBtn = target.closest('.variant-remove-btn') as HTMLElement | null;
            if (removeBtn) {
                e.stopPropagation();
                if (variantsContainer.querySelectorAll('.variant-row').length <= 1) {
                    toast.error(t.sellerProductNoVariantsError);
                    return;
                }
                const row = removeBtn.closest('.variant-row') as HTMLElement;
                row.remove();
                refreshChecks();
                return;
            }

            const header = target.closest('.variant-header') as HTMLElement | null;
            if (header) {
                const row = header.closest('.variant-row') as HTMLElement;
                toggleVariantExpansion(row, 'toggle');
                return;
            }
        });

        variantsContainer.addEventListener('input', (e: Event) => {
            const target = e.target as HTMLElement;
            const row = target.closest('.variant-row') as HTMLElement | null;
            if (!row) return;
            if (
                target.classList.contains('variant-name-input') ||
                target.classList.contains('variant-price-input') ||
                target.classList.contains('variant-stock-input')
            ) {
                refreshChecks();
            }
        });

        variantsContainer.addEventListener('change', async (e: Event) => {
            const target = e.target as HTMLInputElement;
            if (!target) return;

            if (target.classList.contains('variant-image-input') && target.type === 'file' && target.files?.length) {
                const variantRow = target.closest('.variant-row') as HTMLElement;
                const btn = variantRow.querySelector('.variant-image-btn') as HTMLButtonElement;
                const thumb = variantRow.querySelector('.variant-thumb') as HTMLElement;

                btn.disabled = true;
                const originalLabel = btn.innerHTML;
                btn.innerHTML = `<span>${t.sellerProductImageUploading}</span>`;

                const compressed = await compressImage(target.files[0], PRODUCT_PRESET);
                const formData = new FormData();
                formData.append('file', compressed);
                try {
                    const res = await fetch('/api/sell/catalog/upload', { method: 'POST', body: formData });
                    const data: { error?: string; url?: string } = await res.json();
                    if (res.ok) {
                        variantRow.dataset.variantImage = data.url!;
                        thumb.innerHTML = `<img src="${data.url}" alt="" class="w-full h-full object-cover" />`;
                        btn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>Cambiar foto`;
                    } else {
                        toast.error(data.error || t.incidentUploadError);
                        btn.innerHTML = originalLabel;
                    }
                } catch {
                    toast.error(t.incidentUploadError);
                    btn.innerHTML = originalLabel;
                } finally {
                    btn.disabled = false;
                    target.value = '';
                }
                return;
            }

            if (target.classList.contains('variant-default-checkbox')) {
                if (target.checked) {
                    variantsContainer.querySelectorAll('.variant-default-checkbox').forEach((cb) => {
                        if (cb !== target) (cb as HTMLInputElement).checked = false;
                    });
                    variantsContainer.querySelectorAll('.variant-row').forEach((rowEl) => {
                        const row = rowEl as HTMLElement;
                        const checked = (row.querySelector('.variant-default-checkbox') as HTMLInputElement).checked;
                        const pill = row.querySelector('.variant-default-pill');
                        if (checked && !pill) {
                            const nameDisplay = row.querySelector('.variant-name-display');
                            if (nameDisplay) {
                                const span = document.createElement('span');
                                span.className = 'variant-default-pill inline-flex items-center px-1.5 py-0.5 rounded-md text-[10px] font-medium bg-accent text-bg shrink-0';
                                span.textContent = t.sellerProductVariantDefault;
                                nameDisplay.insertAdjacentElement('afterend', span);
                            }
                        } else if (!checked && pill) {
                            pill.remove();
                        }
                    });
                }
                return;
            }
        });

        addVariantBtn.addEventListener('click', () => {
            if (!variantTemplate) return;
            const row = variantTemplate.content.firstElementChild?.cloneNode(true) as HTMLElement | null;
            if (!row) return;
            variantsContainer.appendChild(row);
            toggleVariantExpansion(row, true);
            row.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            refreshChecks();
        });

        // ---- Specs ----

        addSpecBtn.addEventListener('click', () => {
            const div = document.createElement('div');
            div.className = 'spec-row flex items-center gap-2';
            div.innerHTML = `<input type="text" class="spec-key-input flex-1 min-w-0 px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition" placeholder="${t.sellerProductSpecsKeyPlaceholder}" /><input type="text" class="spec-value-input flex-1 min-w-0 px-3 py-2 rounded-lg border border-border bg-transparent text-text-primary text-sm focus:ring-2 focus:ring-accent outline-none transition" placeholder="${t.sellerProductSpecsValuePlaceholder}" /><button type="button" class="spec-remove-btn flex items-center justify-center w-8 h-8 rounded-lg text-text-tertiary hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors shrink-0"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button>`;
            specsContainer.appendChild(div);
        });

        specsContainer.addEventListener('click', (e: MouseEvent) => {
            const removeBtn = (e.target as HTMLElement).closest('.spec-remove-btn') as HTMLElement | null;
            if (!removeBtn) return;
            removeBtn.closest('.spec-row')!.remove();
        });

        // ---- Save ----

        saveBtn.addEventListener('click', async () => {
            const title = titleInput.value.trim();
            const slug = slugInput.value.trim();
            const category = categorySelect.value;
            const description = descriptionInput.value.trim();
            const brand = brandInput.value.trim();
            const is_active = activeCheckbox.checked;

            if (!title) { toast.error(t.sellerProductTitleRequired); return; }
            if (!category) { toast.error(t.sellerProductCategoryRequired); return; }

            const variants = Array.from(variantsContainer.querySelectorAll('.variant-row')).map((row: Element) => {
                const el = row as HTMLElement;
                const eff = getEffectiveShipping(el);
                return {
                    id: el.dataset.variantId || undefined,
                    variant_name: (el.querySelector('.variant-name-input') as HTMLInputElement).value.trim() || null,
                    price: parseFloat((el.querySelector('.variant-price-input') as HTMLInputElement).value) || 0,
                    stock: parseInt((el.querySelector('.variant-stock-input') as HTMLInputElement).value) || 0,
                    is_default: (el.querySelector('.variant-default-checkbox') as HTMLInputElement).checked,
                    variant_image: el.dataset.variantImage || (el.querySelector('.variant-thumb img')?.getAttribute('src')) || null,
                    weight_kg: Number.isFinite(eff.weight) ? eff.weight : null,
                    length_cm: Number.isFinite(eff.length) ? eff.length : null,
                    width_cm: Number.isFinite(eff.width) ? eff.width : null,
                    height_cm: Number.isFinite(eff.height) ? eff.height : null,
                    shipping_cost: Number.isFinite(eff.shipping) ? eff.shipping : null,
                };
            });

            if (variants.length === 0) { toast.error(t.sellerProductNoVariantsError); return; }

            const missingFields: string[] = [];
            if (!title) missingFields.push(t.sellerProductMissingName);
            if (!description) missingFields.push(t.sellerProductMissingDescription);
            if (!category) missingFields.push(t.sellerProductMissingCategory);
            if (!slug) missingFields.push(t.sellerProductMissingSlug);
            if (galleryUrls.length === 0) missingFields.push(t.sellerProductMissingPhotos);

            const allVariantsComplete = variants.every((v: any) =>
                v.price > 0 && v.stock >= 0 &&
                v.weight_kg != null && v.weight_kg > 0 &&
                v.length_cm != null && v.length_cm > 0 &&
                v.width_cm != null && v.width_cm > 0 &&
                v.height_cm != null && v.height_cm > 0 &&
                v.shipping_cost != null && v.shipping_cost >= 0
            );
            if (!allVariantsComplete) missingFields.push(t.sellerProductMissingVariantData);

            if (missingFields.length > 0) {
                toast.error(t.sellerProductIncompleteError.replace('{fields}', missingFields.join(', ')));
                const variantRows = Array.from(variantsContainer.querySelectorAll('.variant-row')) as HTMLElement[];
                const firstIncomplete = variantRows.find((row) => !isVariantComplete(row));
                if (firstIncomplete) toggleVariantExpansion(firstIncomplete, true);
                return;
            }

            if (is_active) {
                const underpriced = variants.find((v: any) => (v.price ?? 0) < 1);
                if (underpriced) {
                    const variantName = underpriced.variant_name?.trim() || t.sellerProductPricingVariantFallbackName;
                    toast.error(t.sellerProductPricingPriceBelowMin.replace('{variant}', variantName));
                    return;
                }
            }

            const specs: Record<string, string> = {};
            specsContainer.querySelectorAll('.spec-row').forEach((row: Element) => {
                const key = (row.querySelector('.spec-key-input') as HTMLInputElement).value.trim();
                const value = (row.querySelector('.spec-value-input') as HTMLInputElement).value.trim();
                if (key) specs[key] = value;
            });

            const payload = {
                title,
                slug: slug || undefined,
                description: description || null,
                category,
                brand: brand || null,
                specifications: specs,
                gallery_images: galleryUrls,
                is_active,
                variants,
            };

            let url = '/api/sell/catalog/product';
            let method = 'POST';
            const productId = (document.getElementById('product-id') as HTMLInputElement).value;
            if (mode === 'edit' && productId) {
                url += `?id=${productId}`;
                method = 'PATCH';
            }

            const result = await runSubmit({
                button: saveBtn,
                busyLabel: t.sellerProductSaving,
                action: async () => {
                    const res = await fetch(url, {
                        method,
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload),
                    });
                    const data: { product?: { id: string }; error?: string } = await res.json();
                    if (!res.ok) throw new SubmitError(data.error || t.sellerProductSaveError);
                    return data;
                },
                successMsg: t.productSavedToast,
            });

            if (result.ok) {
                window.location.href = '/sell/catalog';
            }
        });

        // ---- Initial render ----

        const variantRows = Array.from(variantsContainer.querySelectorAll('.variant-row')) as HTMLElement[];
        variantRows.forEach((row) => {
            updateVariantShippingStatus(row);
            updateVariantHeader(row);
        });
        renderCentralPreview();
        refreshChecks();
        refreshHeaderTitle();

        const firstIncomplete = variantRows.find((row) => !isVariantComplete(row));
        const initialExpand = firstIncomplete ?? variantRows[0];
        if (initialExpand) {
            toggleVariantExpansion(initialExpand, true);
        }
    }

    document.addEventListener('astro:page-load', initProductForm);
</script>
