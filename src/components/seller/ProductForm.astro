---
import Icon from '../icons/Icon.astro';
import { strings, categories } from '../../lib/core/i18n';

interface VariantData {
    id?: string;
    variant_name: string | null;
    price: number;
    stock: number;
    is_default: boolean;
    variant_image: string | null;
    weight_kg?: number | null;
    length_cm?: number | null;
    width_cm?: number | null;
    height_cm?: number | null;
    shipping_cost?: number | null;
}

interface ShippingDefaults {
    weight_kg?: number | null;
    length_cm?: number | null;
    width_cm?: number | null;
    height_cm?: number | null;
    shipping_cost?: number | null;
}

interface Props {
    mode: 'create' | 'edit';
    shopId: string;
    product?: {
        id: string;
        title: string;
        slug: string;
        description: string | null;
        category: string;
        brand: string | null;
        gallery_images: string[];
        is_active: boolean;
        specifications: Record<string, any>;
    };
    variants?: VariantData[];
    shippingDefaults?: ShippingDefaults;
}

const { mode, shopId, product, variants, shippingDefaults } = Astro.props;
const isEdit = mode === 'edit';

const title = product?.title ?? '';
const slug = product?.slug ?? '';
const description = product?.description ?? '';
const category = product?.category ?? '';
const brand = product?.brand ?? '';
const galleryImages: string[] = product?.gallery_images ?? [];
const isActive = product?.is_active ?? true;
const specs = product?.specifications ?? {};

const initialVariants = (variants && variants.length > 0) ? variants : [
    { variant_name: '', price: 0, stock: 0, is_default: true, variant_image: null, weight_kg: shippingDefaults?.weight_kg ?? null, length_cm: shippingDefaults?.length_cm ?? null, width_cm: shippingDefaults?.width_cm ?? null, height_cm: shippingDefaults?.height_cm ?? null, shipping_cost: shippingDefaults?.shipping_cost ?? null }
];

const defaultsJson = JSON.stringify(shippingDefaults ?? {});
const hasDefaults = !!shippingDefaults && (
    shippingDefaults.weight_kg != null ||
    shippingDefaults.length_cm != null ||
    shippingDefaults.width_cm != null ||
    shippingDefaults.height_cm != null ||
    shippingDefaults.shipping_cost != null
);
---

<div
    id="product-form-root"
    data-shop-id={shopId}
    data-mode={mode}
    data-gallery={JSON.stringify(galleryImages)}
    data-shipping-defaults={defaultsJson}
>
    <input type="hidden" id="product-id" value={isEdit ? product!.id : ''} />

    <!-- Sticky action bar -->
    <div class="sticky top-0 z-30 -mx-4 sm:-mx-6 lg:-mx-10 px-4 sm:px-6 lg:px-10 mb-8 border-b border-border bg-bg/85 backdrop-blur supports-[backdrop-filter]:bg-bg/70">
        <div class="flex items-center gap-3 py-3">
            <a
                href="/sell/catalog"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors no-underline"
                aria-label={strings.sellerProductBackToCatalog}
            >
                <Icon name="arrow-left" size={18} />
            </a>
            <div class="min-w-0 flex-1">
                <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-text-tertiary truncate">
                    {isEdit ? strings.sellerProductEditTitle : strings.sellerProductNewTitle}
                </p>
                <p id="header-product-title" class="text-sm font-medium text-text-primary truncate">
                    {title || strings.sellerProductTitlePlaceholder}
                </p>
            </div>
            <div class="hidden md:flex items-center gap-2">
                <span
                    id="status-badge"
                    class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-medium border"
                >
                    <span id="status-badge-dot" class="inline-block w-1.5 h-1.5 rounded-full bg-text-tertiary"></span>
                    <span id="status-badge-text">{strings.sellerProductFormIncompleteBadge}</span>
                </span>
            </div>
            <a
                href="/sell/catalog"
                class="hidden sm:inline-flex items-center px-4 py-2 rounded-full text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors no-underline"
            >
                {strings.sellerProductFormSaveAndExit}
            </a>
            <button
                type="button"
                id="save-product-btn"
                class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-accent text-bg font-medium text-sm hover:scale-[1.02] active:scale-[0.99] transition-transform shadow-sm"
            >
                <span data-busy-label>{strings.sellerProductSave}</span>
                <Icon name="arrow-up-right" size={14} />
            </button>
        </div>
        <div class="h-0.5 w-full bg-border-light rounded-full overflow-hidden -mb-px">
            <div id="completion-bar" class="h-full bg-accent transition-all duration-300" style="width: 0%"></div>
        </div>
    </div>

    <div class="max-w-3xl mx-auto">
        <div class="space-y-6 min-w-0">
            <!-- Basic info -->
            <section class="rounded-3xl border border-border bg-surface p-5 sm:p-6 lg:p-7">
                <header class="flex items-start gap-3 mb-6">
                    <span class="flex items-center justify-center w-9 h-9 rounded-xl bg-bg border border-border text-text-secondary shrink-0">
                        <Icon name="file-text" size={16} />
                    </span>
                    <div>
                        <h2 class="text-base font-semibold text-text-primary">{strings.sellerProductSectionBasicTitle}</h2>
                        <p class="text-xs text-text-tertiary mt-0.5">{strings.sellerProductSectionBasicSubtitle}</p>
                    </div>
                </header>

                <div class="grid gap-5 sm:grid-cols-2">
                    <div class="sm:col-span-2">
                        <label for="product-title" class="block text-xs font-medium text-text-secondary mb-1.5">
                            {strings.sellerProductTitleLabel} <span class="text-red-500">*</span>
                        </label>
                        <input
                            type="text"
                            id="product-title"
                            required
                            value={title}
                            class="w-full px-4 py-3 rounded-xl border border-border bg-bg text-text-primary focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition"
                            placeholder={strings.sellerProductTitlePlaceholder}
                        />
                    </div>

                    <div class="sm:col-span-2">
                        <label for="product-description" class="block text-xs font-medium text-text-secondary mb-1.5">{strings.sellerProductDescriptionLabel}</label>
                        <textarea
                            id="product-description"
                            rows="4"
                            class="w-full px-4 py-3 rounded-xl border border-border bg-bg text-text-primary focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition resize-none"
                            placeholder={strings.sellerProductDescriptionPlaceholder}
                        >{description}</textarea>
                    </div>

                    <div>
                        <label for="product-category" class="block text-xs font-medium text-text-secondary mb-1.5">
                            {strings.sellerProductCategoryLabel} <span class="text-red-500">*</span>
                        </label>
                        <select
                            id="product-category"
                            required
                            class="w-full px-4 py-3 rounded-xl border border-border bg-bg text-text-primary focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition appearance-none"
                        >
                            <option value="" disabled selected={category === ''} class="text-text-tertiary">{strings.sellerProductCategoryPlaceholder}</option>
                            {categories.map(cat => (
                                <option value={cat.value} selected={category === cat.value}>{cat.label}</option>
                            ))}
                        </select>
                    </div>

                    <div>
                        <label for="product-brand" class="block text-xs font-medium text-text-secondary mb-1.5">{strings.sellerProductBrandLabel}</label>
                        <input
                            type="text"
                            id="product-brand"
                            value={brand}
                            class="w-full px-4 py-3 rounded-xl border border-border bg-bg text-text-primary focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition"
                            placeholder={strings.sellerProductBrandPlaceholder}
                        />
                    </div>

                    <div class="sm:col-span-2">
                        <label for="product-slug" class="block text-xs font-medium text-text-secondary mb-1.5">{strings.sellerProductSlugLabel}</label>
                        <div class="flex items-stretch rounded-xl border border-border bg-bg focus-within:ring-2 focus-within:ring-accent focus-within:border-transparent transition overflow-hidden">
                            <span class="flex items-center pl-4 pr-1 text-text-tertiary whitespace-nowrap select-none text-sm">{shopId}/</span>
                            <input
                                type="text"
                                id="product-slug"
                                value={slug}
                                class="w-full px-2 py-3 bg-transparent text-text-primary outline-none text-sm"
                                placeholder={strings.sellerProductSlugPlaceholder}
                            />
                        </div>
                        <p class="text-[11px] text-text-tertiary mt-1.5">{strings.sellerProductSlugNote}</p>
                    </div>
                </div>
            </section>

            <!-- Images -->
            <section class="rounded-3xl border border-border bg-surface p-5 sm:p-6 lg:p-7">
                <header class="flex items-start gap-3 mb-6">
                    <span class="flex items-center justify-center w-9 h-9 rounded-xl bg-bg border border-border text-text-secondary shrink-0">
                        <Icon name="image" size={16} />
                    </span>
                    <div>
                        <h2 class="text-base font-semibold text-text-primary">{strings.sellerProductSectionImagesTitle}</h2>
                        <p class="text-xs text-text-tertiary mt-0.5">{strings.sellerProductSectionImagesSubtitle}</p>
                    </div>
                </header>

                <div
                    id="image-drop-zone"
                    class="relative flex flex-col items-center justify-center gap-2 px-6 py-10 border-2 border-dashed border-border rounded-2xl bg-bg cursor-pointer hover:border-accent hover:bg-border-light/50 transition-colors"
                >
                    <Icon name="upload-cloud" size={28} class="text-text-tertiary" />
                    <p class="text-sm text-text-secondary">{strings.sellerProductImagesDragDrop}</p>
                    <input type="file" id="image-upload-input" multiple accept="image/jpeg,image/png,image/webp,image/gif" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                </div>

                <div id="image-gallery" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3 mt-4">
                    {galleryImages.map((url, i) => (
                        <div class="image-item relative group rounded-xl overflow-hidden border border-border aspect-square bg-bg" data-url={url}>
                            <img src={url} alt="" class="w-full h-full object-cover" loading="lazy" />
                            {i === 0 && (
                                <span class="absolute top-1.5 left-1.5 px-1.5 py-0.5 rounded-md text-[10px] font-medium bg-accent text-bg shadow-sm">Portada</span>
                            )}
                            <button
                                type="button"
                                class="image-remove-btn absolute top-1.5 right-1.5 w-6 h-6 rounded-full bg-black/65 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
                                aria-label={strings.sellerProductImageRemove}
                            >
                                <Icon name="x" size={14} />
                            </button>
                        </div>
                    ))}
                </div>
            </section>

            <!-- Variants -->
            <section class="rounded-3xl border border-border bg-surface p-5 sm:p-6 lg:p-7">
                <header class="flex items-start gap-3 mb-2">
                    <span class="flex items-center justify-center w-9 h-9 rounded-xl bg-bg border border-border text-text-secondary shrink-0">
                        <Icon name="package" size={16} />
                    </span>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between gap-2">
                            <h2 class="text-base font-semibold text-text-primary">{strings.sellerProductSectionVariantsTitle}</h2>
                            <span id="variants-count" class="text-[11px] text-text-tertiary tabular-nums shrink-0"></span>
                        </div>
                        <p class="text-xs text-text-tertiary mt-0.5">{strings.sellerProductSectionVariantsSubtitle}</p>
                    </div>
                </header>

                {hasDefaults && (
                    <div class="mt-4 flex items-start gap-2 px-3 py-2 rounded-xl bg-bg border border-border text-[11px] text-text-tertiary">
                        <Icon name="info" size={13} class="mt-0.5 shrink-0" />
                        <span>{strings.sellerProductShippingDefaultsHint}</span>
                    </div>
                )}

                <div id="variants-container" class="space-y-3 mt-5">
                    {initialVariants.map((v) => (
                        <article
                            class="variant-row rounded-2xl border border-border bg-bg overflow-hidden"
                            data-variant-id={v.id ?? ''}
                            data-is-new={v.id ? 'false' : 'true'}
                            data-variant-image={v.variant_image ?? ''}
                        >
                            <!-- Variant header (always visible) -->
                            <div class="flex items-center gap-3 px-4 py-3 border-b border-border">
                                <div class="variant-thumb w-10 h-10 rounded-lg border border-border bg-surface overflow-hidden flex items-center justify-center shrink-0">
                                    {v.variant_image ? (
                                        <img src={v.variant_image} alt="" class="w-full h-full object-cover" />
                                    ) : (
                                        <Icon name="image" size={16} class="text-text-tertiary" />
                                    )}
                                </div>
                                <div class="min-w-0 flex-1">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span class="text-sm font-medium text-text-primary truncate">
                                            <span class="variant-name-display">{v.variant_name || strings.sellerProductVariantPlaceholderName}</span>
                                        </span>
                                        {v.is_default && (
                                            <span class="variant-default-pill inline-flex items-center px-1.5 py-0.5 rounded-md text-[10px] font-medium bg-accent text-bg">{strings.sellerProductVariantDefault}</span>
                                        )}
                                    </div>
                                    <p class="text-[11px] text-text-tertiary mt-0.5 tabular-nums">
                                        <span class="variant-price-display">{v.price ? `${v.price.toFixed(2)} €` : '—'}</span>
                                        <span class="mx-1.5 opacity-50">·</span>
                                        <span class="variant-stock-display">{v.stock ?? 0} uds</span>
                                    </p>
                                </div>
                                <button
                                    type="button"
                                    class="variant-toggle-btn flex items-center justify-center w-8 h-8 rounded-lg text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors"
                                    aria-label={strings.sellerProductVariantCollapse}
                                    aria-expanded="true"
                                >
                                    <Icon name="chevron-down" size={16} />
                                </button>
                                {initialVariants.length > 1 && (
                                    <button
                                        type="button"
                                        class="variant-remove-btn flex items-center justify-center w-8 h-8 rounded-lg text-text-tertiary hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
                                        aria-label={strings.sellerProductVariantRemove}
                                    >
                                        <Icon name="trash-2" size={14} />
                                    </button>
                                )}
                            </div>

                            <!-- Variant body -->
                            <div class="variant-body p-4 space-y-5">
                                <div class="grid gap-4 sm:grid-cols-12">
                                    <div class="sm:col-span-5">
                                        <label class="block text-[11px] font-medium text-text-tertiary mb-1">{strings.sellerProductVariantNameLabel}</label>
                                        <input
                                            type="text"
                                            class="variant-name-input w-full px-3 py-2 rounded-lg border border-border bg-surface text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition"
                                            placeholder={strings.sellerProductVariantNamePlaceholder}
                                            value={v.variant_name}
                                        />
                                    </div>
                                    <div class="sm:col-span-4">
                                        <label class="block text-[11px] font-medium text-text-tertiary mb-1">{strings.sellerProductVariantPriceLabel}</label>
                                        <input
                                            type="number"
                                            step="0.01"
                                            min="0"
                                            class="variant-price-input w-full px-3 py-2 rounded-lg border border-border bg-surface text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums"
                                            placeholder={strings.sellerProductVariantPricePlaceholder}
                                            value={v.price}
                                        />
                                    </div>
                                    <div class="sm:col-span-3">
                                        <label class="block text-[11px] font-medium text-text-tertiary mb-1">{strings.sellerProductVariantStockLabel}</label>
                                        <input
                                            type="number"
                                            min="0"
                                            class="variant-stock-input w-full px-3 py-2 rounded-lg border border-border bg-surface text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums"
                                            placeholder={strings.sellerProductVariantStockPlaceholder}
                                            value={v.stock}
                                        />
                                    </div>
                                </div>

                                <div class="flex flex-wrap items-center gap-3 pt-1">
                                    <label class="flex items-center gap-2 text-xs text-text-secondary cursor-pointer select-none">
                                        <input type="checkbox" class="variant-default-checkbox rounded border-border accent-neutral-900 dark:accent-white" checked={v.is_default} />
                                        {strings.sellerProductVariantDefaultNote}
                                    </label>
                                    <div class="ml-auto flex items-center gap-2">
                                        <button type="button" class="variant-image-btn flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">
                                            <Icon name="camera" size={12} />
                                            {v.variant_image ? 'Cambiar foto' : 'Foto'}
                                        </button>
                                        <input type="file" accept="image/jpeg,image/png,image/webp,image/gif" class="variant-image-input hidden" />
                                    </div>
                                </div>

                                <!-- Shipping subsection -->
                                <div class="rounded-2xl border border-border bg-surface p-4 space-y-4">
                                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                                        <div>
                                            <h3 class="text-[11px] font-semibold uppercase tracking-[0.14em] text-text-secondary">{strings.sellerProductVariantSizeWeight}</h3>
                                            <p class="text-[11px] text-text-tertiary mt-0.5">{strings.sellerProductVariantSizeWeightHint}</p>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <button type="button" class="variant-use-defaults-btn px-2.5 py-1 rounded-lg text-[11px] font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">
                                                {strings.sellerProductVariantUseDefaults}
                                            </button>
                                            <button type="button" class="variant-apply-shipping-btn px-2.5 py-1 rounded-lg text-[11px] font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">
                                                {strings.sellerProductVariantApplyToRest}
                                            </button>
                                        </div>
                                    </div>
                                    <div class="grid gap-3 grid-cols-2 sm:grid-cols-4">
                                        <div>
                                            <label class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">{strings.sellerProductVariantWeightLabel}</label>
                                            <input type="number" step="0.001" min="0" class="variant-weight-input w-full px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder={strings.sellerProductVariantWeightPlaceholder} value={v.weight_kg ?? ''} />
                                        </div>
                                        <div>
                                            <label class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">{strings.sellerProductVariantLengthLabel}</label>
                                            <input type="number" step="0.1" min="0" class="variant-length-input w-full px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder={strings.sellerProductVariantLengthPlaceholder} value={v.length_cm ?? ''} />
                                        </div>
                                        <div>
                                            <label class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">{strings.sellerProductVariantWidthLabel}</label>
                                            <input type="number" step="0.1" min="0" class="variant-width-input w-full px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder={strings.sellerProductVariantWidthPlaceholder} value={v.width_cm ?? ''} />
                                        </div>
                                        <div>
                                            <label class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">{strings.sellerProductVariantHeightLabel}</label>
                                            <input type="number" step="0.1" min="0" class="variant-height-input w-full px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder={strings.sellerProductVariantHeightPlaceholder} value={v.height_cm ?? ''} />
                                        </div>
                                    </div>

                                    <div class="variant-shipping-cost border-t border-border pt-3" data-free={v.shipping_cost === 0 ? 'true' : 'false'}>
                                        <div class="flex items-center justify-between gap-3 mb-2">
                                            <label class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary">{strings.sellerProductVariantBaseShipping}</label>
                                            <label class="flex items-center gap-2 cursor-pointer select-none">
                                                <span class="text-[11px] font-medium text-text-secondary">{strings.sellerProductVariantFreeShipping}</span>
                                                <span class="relative inline-flex shrink-0">
                                                    <input type="checkbox" class="variant-free-shipping-checkbox sr-only peer" checked={v.shipping_cost === 0} />
                                                    <span class="block w-9 h-5 bg-border-light rounded-full peer-focus-visible:ring-2 peer-focus-visible:ring-accent peer-checked:bg-green-500 transition-colors"></span>
                                                    <span class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full shadow-sm transition-transform peer-checked:translate-x-4"></span>
                                                </span>
                                            </label>
                                        </div>
                                        <div class={`variant-shipping-input-wrap flex items-center gap-2 ${v.shipping_cost === 0 ? 'hidden' : ''}`}>
                                            <input type="number" step="0.01" min="0" class="variant-shipping-input flex-1 px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder={strings.sellerProductVariantShippingPlaceholder} value={v.shipping_cost ?? ''} />
                                            <span class="text-xs text-text-tertiary shrink-0">{strings.sellerProductVariantBaseShippingHint}</span>
                                        </div>
                                        <div class={`variant-free-shipping-display ${v.shipping_cost === 0 ? '' : 'hidden'} flex items-center gap-2 px-3 py-2.5 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200/70 dark:border-green-800/60`}>
                                            <span class="flex items-center justify-center w-5 h-5 rounded-full bg-green-500 text-white shrink-0">
                                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                            </span>
                                            <span class="text-[11px] font-medium text-green-700 dark:text-green-400">{strings.sellerProductVariantFreeShippingActive}</span>
                                        </div>
                                    </div>

                                    <!-- Live shipping preview -->
                                    <div class="shipping-live rounded-xl border border-border bg-bg p-3.5 mt-3">
                                        <div class="flex items-start gap-2 mb-3">
                                            <Icon name="truck" size={14} class="text-text-secondary mt-0.5" />
                                            <div class="flex-1 min-w-0">
                                                <p class="text-xs font-semibold text-text-primary">{strings.sellerProductShippingLiveTitle}</p>
                                                <p class="text-[10px] text-text-tertiary mt-0.5">{strings.sellerProductShippingLiveSubtitle}</p>
                                            </div>
                                            <span class="shipping-billable hidden text-[10px] font-medium text-text-tertiary tabular-nums shrink-0"></span>
                                        </div>
                                        <div class="shipping-quotes hidden grid gap-2"></div>
                                        <p class="shipping-empty text-[11px] text-text-tertiary text-center py-2">{strings.sellerProductShippingLiveAwaiting}</p>
                                        <div class="shipping-loading hidden flex items-center justify-center gap-2 py-3 text-[11px] text-text-tertiary">
                                            <svg class="animate-spin" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56" /></svg>
                                            <span>{strings.sellerProductShippingLiveLoading}</span>
                                        </div>
                                        <p class="shipping-error hidden text-[11px] text-amber-700 dark:text-amber-400 text-center py-2"></p>
                                    </div>
                                </div>
                            </div>
                        </article>
                    ))}
                </div>

                <button
                    type="button"
                    id="add-variant-btn"
                    class="mt-4 flex items-center gap-2 px-4 py-2.5 rounded-xl border border-dashed border-border text-sm text-text-secondary hover:text-text-primary hover:border-accent transition-colors"
                >
                    <Icon name="plus" size={16} />
                    {strings.sellerProductAddVariant}
                </button>
            </section>

            <!-- Specifications -->
            <section class="rounded-3xl border border-border bg-surface p-5 sm:p-6 lg:p-7">
                <header class="flex items-start gap-3 mb-6">
                    <span class="flex items-center justify-center w-9 h-9 rounded-xl bg-bg border border-border text-text-secondary shrink-0">
                        <Icon name="sliders" size={16} />
                    </span>
                    <div>
                        <h2 class="text-base font-semibold text-text-primary">{strings.sellerProductSectionSpecsTitle}</h2>
                        <p class="text-xs text-text-tertiary mt-0.5">{strings.sellerProductSectionSpecsSubtitle}</p>
                    </div>
                </header>

                <div id="specs-container" class="space-y-2.5 max-w-2xl">
                    {Object.entries(specs).map(([key, value]) => (
                        <div class="spec-row flex items-center gap-2">
                            <input type="text" class="spec-key-input flex-1 min-w-0 px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition" placeholder={strings.sellerProductSpecsKeyPlaceholder} value={key} />
                            <input type="text" class="spec-value-input flex-1 min-w-0 px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition" placeholder={strings.sellerProductSpecsValuePlaceholder} value={String(value)} />
                            <button type="button" class="spec-remove-btn flex items-center justify-center w-8 h-8 rounded-lg text-text-tertiary hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors shrink-0" aria-label={strings.sellerCatalogDelete}>
                                <Icon name="x" size={14} />
                            </button>
                        </div>
                    ))}
                </div>

                <button
                    type="button"
                    id="add-spec-btn"
                    class="mt-3 flex items-center gap-2 px-4 py-2 rounded-xl border border-dashed border-border text-sm text-text-secondary hover:text-text-primary hover:border-accent transition-colors"
                >
                    <Icon name="plus" size={14} />
                    {strings.sellerProductAddSpec}
                </button>
            </section>

            <!-- Visibility -->
            <section class="rounded-3xl border border-border bg-surface p-5 sm:p-6 lg:p-7">
                <div class="flex items-start gap-3">
                    <span class="flex items-center justify-center w-9 h-9 rounded-xl bg-bg border border-border text-text-secondary shrink-0">
                        <Icon name="eye-off" size={16} />
                    </span>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <h2 class="text-base font-semibold text-text-primary">{strings.sellerProductSectionStatusTitle}</h2>
                                <p class="text-xs text-text-tertiary mt-0.5">{strings.sellerProductActiveNote}</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer shrink-0">
                                <input type="checkbox" id="product-active" class="sr-only peer" checked={isActive} />
                                <div class="w-11 h-6 bg-border-light rounded-full peer-focus-visible:ring-2 peer-focus-visible:ring-accent peer-checked:bg-accent transition-colors after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-transform peer-checked:after:translate-x-full"></div>
                            </label>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

<script>
    import { strings } from '../../lib/core/i18n';
    import { toast } from '../../lib/ui/toast';
    import { runSubmit, SubmitError } from '../../lib/ui/submit';

    interface RemoteEstimate {
        key: string;
        label: string;
        sublabel: string;
        price: number | null;
        currency: string;
        serviceName: string | null;
    }

    function fmtCurrency(value: number, currency: string = 'EUR'): string {
        return value.toLocaleString('es-ES', { style: 'currency', currency });
    }

    function fmtWeight(value: number): string {
        if (value >= 1) return `${value.toFixed(2)} kg`;
        return `${Math.round(value * 1000)} g`;
    }

    const shippingTimers = new WeakMap<HTMLElement, ReturnType<typeof setTimeout>>();
    const shippingRequestIds = new WeakMap<HTMLElement, number>();
    const SHIPPING_DEBOUNCE_MS = 600;

    function setShippingState(row: HTMLElement, state: 'empty' | 'loading' | 'error' | 'ready', payload?: { estimates?: RemoteEstimate[]; billable?: number; errorMsg?: string }) {
        const container = row.querySelector('.shipping-live') as HTMLElement | null;
        if (!container) return;
        const quotesEl = container.querySelector('.shipping-quotes') as HTMLElement;
        const emptyEl = container.querySelector('.shipping-empty') as HTMLElement;
        const loadingEl = container.querySelector('.shipping-loading') as HTMLElement;
        const errorEl = container.querySelector('.shipping-error') as HTMLElement;
        const billableEl = container.querySelector('.shipping-billable') as HTMLElement;

        quotesEl.classList.add('hidden');
        emptyEl.classList.add('hidden');
        loadingEl.classList.add('hidden');
        errorEl.classList.add('hidden');
        billableEl.classList.add('hidden');

        if (state === 'empty') {
            emptyEl.classList.remove('hidden');
            quotesEl.innerHTML = '';
            return;
        }
        if (state === 'loading') {
            loadingEl.classList.remove('hidden');
            return;
        }
        if (state === 'error') {
            errorEl.textContent = payload?.errorMsg || strings.sellerProductShippingLiveError;
            errorEl.classList.remove('hidden');
            return;
        }
        // ready
        const estimates = payload?.estimates ?? [];
        const billable = payload?.billable ?? 0;
        if (billable > 0) {
            billableEl.textContent = `${strings.sellerProductShippingLiveBillable}: ${fmtWeight(billable)}`;
            billableEl.classList.remove('hidden');
        }
        quotesEl.classList.remove('hidden');
        quotesEl.innerHTML = estimates.map((e) => {
            const available = e.price != null;
            const dotClass = available ? 'bg-green-500' : 'bg-amber-500';
            const valueHtml = available
                ? `<span class="text-sm font-semibold text-text-primary tabular-nums">${fmtCurrency(e.price!, e.currency)}</span>`
                : `<span class="text-[11px] font-medium text-amber-700 dark:text-amber-400">${strings.sellerProductShippingLiveUnavailable}</span>`;
            return `
                <div class="flex items-center gap-2.5 px-3 py-2 rounded-lg bg-surface border border-border">
                    <span class="inline-block w-1.5 h-1.5 rounded-full ${dotClass} shrink-0"></span>
                    <div class="min-w-0 flex-1">
                        <p class="text-xs font-medium text-text-primary truncate">${e.label}</p>
                        <p class="text-[10px] text-text-tertiary truncate">${e.serviceName || e.sublabel}</p>
                    </div>
                    ${valueHtml}
                </div>`;
        }).join('');
    }

    async function fetchShippingPreview(row: HTMLElement, weight: number, length: number | null, width: number | null, height: number | null) {
        const reqId = (shippingRequestIds.get(row) ?? 0) + 1;
        shippingRequestIds.set(row, reqId);

        try {
            const res = await fetch('/api/sendcloud/preview-quote', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    weight_kg: weight,
                    length_cm: length,
                    width_cm: width,
                    height_cm: height,
                }),
            });
            // Drop response if a newer request started after this one
            if (shippingRequestIds.get(row) !== reqId) return;

            const data = await res.json() as { estimates?: RemoteEstimate[]; billableWeightKg?: number; error?: string };
            if (!res.ok) {
                setShippingState(row, 'error', { errorMsg: strings.sellerProductShippingLiveError });
                return;
            }
            setShippingState(row, 'ready', {
                estimates: data.estimates ?? [],
                billable: data.billableWeightKg ?? weight,
            });
        } catch {
            if (shippingRequestIds.get(row) !== reqId) return;
            setShippingState(row, 'error');
        }
    }

    function renderShippingPreview(row: HTMLElement) {
        const w = (row.querySelector('.variant-weight-input') as HTMLInputElement | null)?.value;
        const l = (row.querySelector('.variant-length-input') as HTMLInputElement | null)?.value;
        const wd = (row.querySelector('.variant-width-input') as HTMLInputElement | null)?.value;
        const h = (row.querySelector('.variant-height-input') as HTMLInputElement | null)?.value;

        const weight = w ? parseFloat(w) : NaN;
        const length = l ? parseFloat(l) : NaN;
        const width = wd ? parseFloat(wd) : NaN;
        const height = h ? parseFloat(h) : NaN;

        const existing = shippingTimers.get(row);
        if (existing) clearTimeout(existing);

        if (!Number.isFinite(weight) || weight <= 0) {
            // Invalidate any pending response
            shippingRequestIds.set(row, (shippingRequestIds.get(row) ?? 0) + 1);
            setShippingState(row, 'empty');
            return;
        }

        setShippingState(row, 'loading');
        const timer = setTimeout(() => {
            void fetchShippingPreview(
                row,
                weight,
                Number.isFinite(length) ? length : null,
                Number.isFinite(width) ? width : null,
                Number.isFinite(height) ? height : null,
            );
        }, SHIPPING_DEBOUNCE_MS);
        shippingTimers.set(row, timer);
    }

    function updateVariantSummary(row: HTMLElement) {
        const nameEl = row.querySelector('.variant-name-display') as HTMLElement;
        const priceEl = row.querySelector('.variant-price-display') as HTMLElement;
        const stockEl = row.querySelector('.variant-stock-display') as HTMLElement;
        const name = (row.querySelector('.variant-name-input') as HTMLInputElement)?.value.trim();
        const price = parseFloat((row.querySelector('.variant-price-input') as HTMLInputElement)?.value || '');
        const stock = parseInt((row.querySelector('.variant-stock-input') as HTMLInputElement)?.value || '0');
        if (nameEl) nameEl.textContent = name || strings.sellerProductVariantPlaceholderName;
        if (priceEl) priceEl.textContent = Number.isFinite(price) && price > 0 ? `${price.toFixed(2)} €` : '—';
        if (stockEl) stockEl.textContent = `${Number.isFinite(stock) ? stock : 0} uds`;
    }

    function initProductForm() {
        const root = document.getElementById('product-form-root');
        if (!root) return;

        const mode = root.dataset.mode || 'create';
        const galleryUrls: string[] = JSON.parse(root.dataset.gallery || '[]');
        const shippingDefaults: Record<string, number | null> = JSON.parse(root.dataset.shippingDefaults || '{}');

        const titleInput = document.getElementById('product-title') as HTMLInputElement;
        const slugInput = document.getElementById('product-slug') as HTMLInputElement;
        const categorySelect = document.getElementById('product-category') as unknown as HTMLSelectElement;
        const descriptionInput = document.getElementById('product-description') as HTMLTextAreaElement;
        const brandInput = document.getElementById('product-brand') as HTMLInputElement;
        const activeCheckbox = document.getElementById('product-active') as HTMLInputElement;
        const saveBtn = document.getElementById('save-product-btn') as HTMLButtonElement;
        const imageGallery = document.getElementById('image-gallery') as HTMLDivElement;
        const imageUploadInput = document.getElementById('image-upload-input') as HTMLInputElement;
        const variantsContainer = document.getElementById('variants-container') as HTMLDivElement;
        const addVariantBtn = document.getElementById('add-variant-btn') as HTMLButtonElement;
        const specsContainer = document.getElementById('specs-container') as HTMLDivElement;
        const addSpecBtn = document.getElementById('add-spec-btn') as HTMLButtonElement;
        const headerTitle = document.getElementById('header-product-title');
        const variantsCountEl = document.getElementById('variants-count');
        const completionBar = document.getElementById('completion-bar');
        const statusBadge = document.getElementById('status-badge');
        const statusBadgeDot = document.getElementById('status-badge-dot');
        const statusBadgeText = document.getElementById('status-badge-text');

        if (!titleInput || !saveBtn) return;

        const refreshChecks = () => {
            const title = titleInput.value.trim();
            const slug = slugInput.value.trim();
            const description = descriptionInput.value.trim();
            const category = categorySelect.value;

            const variantRows = Array.from(variantsContainer.querySelectorAll('.variant-row')) as HTMLElement[];
            const hasCompleteVariant = variantRows.some((row) => {
                const price = parseFloat((row.querySelector('.variant-price-input') as HTMLInputElement).value) || 0;
                const stock = parseInt((row.querySelector('.variant-stock-input') as HTMLInputElement).value) || 0;
                const w = parseFloat((row.querySelector('.variant-weight-input') as HTMLInputElement).value);
                const l = parseFloat((row.querySelector('.variant-length-input') as HTMLInputElement).value);
                const wi = parseFloat((row.querySelector('.variant-width-input') as HTMLInputElement).value);
                const h = parseFloat((row.querySelector('.variant-height-input') as HTMLInputElement).value);
                const s = parseFloat((row.querySelector('.variant-shipping-input') as HTMLInputElement).value);
                return price > 0 && stock >= 0 && w > 0 && l > 0 && wi > 0 && h > 0 && Number.isFinite(s) && s >= 0;
            });

            const checks = {
                title: !!title,
                description: !!description,
                category: !!category,
                slug: !!slug,
                photos: galleryUrls.length > 0,
                variant: hasCompleteVariant,
            } as Record<string, boolean>;

            const total = Object.keys(checks).length;
            const done = Object.values(checks).filter(Boolean).length;
            const pct = Math.round((done / total) * 100);
            if (completionBar) completionBar.style.width = `${pct}%`;

            const allDone = done === total;
            if (statusBadge && statusBadgeDot && statusBadgeText) {
                if (allDone) {
                    statusBadgeText.textContent = strings.sellerProductFormReadyBadge;
                    statusBadge.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-medium border border-green-200 dark:border-green-800 bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400';
                    statusBadgeDot.className = 'inline-block w-1.5 h-1.5 rounded-full bg-green-500';
                } else {
                    statusBadgeText.textContent = strings.sellerProductFormIncompleteBadge;
                    statusBadge.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-medium border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-400';
                    statusBadgeDot.className = 'inline-block w-1.5 h-1.5 rounded-full bg-amber-500';
                }
            }

            if (variantsCountEl) {
                const c = variantRows.length;
                variantsCountEl.textContent = c === 1 ? strings.sellerProductVariantsCountSingle : strings.sellerProductVariantsCount.replace('{count}', String(c));
            }
        };

        const refreshHeaderTitle = () => {
            if (headerTitle) headerTitle.textContent = titleInput.value.trim() || strings.sellerProductTitlePlaceholder;
        };

        let slugManual = slugInput.value !== '';
        titleInput.addEventListener('input', () => {
            if (!slugManual) {
                slugInput.value = titleInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
            }
            refreshHeaderTitle();
            refreshChecks();
        });
        slugInput.addEventListener('input', () => { slugManual = true; refreshChecks(); });
        descriptionInput.addEventListener('input', refreshChecks);
        categorySelect.addEventListener('change', refreshChecks);

        imageUploadInput.addEventListener('change', async () => {
            const files = Array.from(imageUploadInput.files || []);
            if (files.length === 0) return;

            for (const file of files) {
                const formData = new FormData();
                formData.append('file', file);
                try {
                    const res = await fetch('/api/sell/catalog/upload', { method: 'POST', body: formData });
                    const data: { error?: string; url?: string } = await res.json();
                    if (!res.ok) { toast.error(data.error || strings.incidentUploadError); continue; }
                    galleryUrls.push(data.url!);
                    renderGallery();
                } catch { toast.error(strings.incidentUploadError); }
            }
            imageUploadInput.value = '';
            refreshChecks();
        });

        function renderGallery() {
            imageGallery.innerHTML = '';
            galleryUrls.forEach((url: string, i: number) => {
                const div = document.createElement('div');
                div.className = 'image-item relative group rounded-xl overflow-hidden border border-border aspect-square bg-bg';
                div.dataset.url = url;
                const coverBadge = i === 0 ? '<span class="absolute top-1.5 left-1.5 px-1.5 py-0.5 rounded-md text-[10px] font-medium bg-accent text-bg shadow-sm">Portada</span>' : '';
                div.innerHTML = `<img src="${url}" alt="" class="w-full h-full object-cover" loading="lazy" />${coverBadge}<button type="button" class="image-remove-btn absolute top-1.5 right-1.5 w-6 h-6 rounded-full bg-black/65 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity" aria-label="Remove"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button>`;
                imageGallery.appendChild(div);
            });
        }

        variantsContainer.addEventListener('change', async (e: Event) => {
            const target = e.target as HTMLInputElement;
            if (!target || !target.classList.contains('variant-image-input') || !target.files?.length) return;
            const variantRow = target.closest('.variant-row') as HTMLElement;
            const btn = variantRow.querySelector('.variant-image-btn') as HTMLButtonElement;
            const thumb = variantRow.querySelector('.variant-thumb') as HTMLElement;

            btn.disabled = true;
            const originalLabel = btn.innerHTML;
            btn.innerHTML = `<span>${strings.sellerProductImageUploading}</span>`;

            const formData = new FormData();
            formData.append('file', target.files[0]);
            try {
                const res = await fetch('/api/sell/catalog/upload', { method: 'POST', body: formData });
                const data: { error?: string; url?: string } = await res.json();
                if (res.ok) {
                    variantRow.dataset.variantImage = data.url!;
                    thumb.innerHTML = `<img src="${data.url}" alt="" class="w-full h-full object-cover" />`;
                    btn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>Cambiar foto`;
                } else {
                    toast.error(data.error || strings.incidentUploadError);
                    btn.innerHTML = originalLabel;
                }
            } catch {
                toast.error(strings.incidentUploadError);
                btn.innerHTML = originalLabel;
            } finally {
                btn.disabled = false;
                target.value = '';
            }
        });

        // Click delegate: image button + use-defaults + apply-to-rest + toggle collapse + remove
        variantsContainer.addEventListener('click', (e: MouseEvent) => {
            const target = e.target as HTMLElement;

            const imgBtn = target.closest('.variant-image-btn') as HTMLElement | null;
            if (imgBtn) {
                const variantRow = imgBtn.closest('.variant-row') as HTMLElement;
                const fileInput = variantRow.querySelector('.variant-image-input') as HTMLInputElement;
                fileInput.click();
                return;
            }

            const toggleBtn = target.closest('.variant-toggle-btn') as HTMLElement | null;
            if (toggleBtn) {
                const row = toggleBtn.closest('.variant-row') as HTMLElement;
                const body = row.querySelector('.variant-body') as HTMLElement;
                const icon = toggleBtn.querySelector('svg');
                const expanded = toggleBtn.getAttribute('aria-expanded') === 'true';
                if (expanded) {
                    body.style.display = 'none';
                    toggleBtn.setAttribute('aria-expanded', 'false');
                    if (icon) (icon as SVGElement).style.transform = 'rotate(-90deg)';
                } else {
                    body.style.display = '';
                    toggleBtn.setAttribute('aria-expanded', 'true');
                    if (icon) (icon as SVGElement).style.transform = '';
                }
                return;
            }

            const useDefaultsBtn = target.closest('.variant-use-defaults-btn') as HTMLElement | null;
            if (useDefaultsBtn) {
                const row = useDefaultsBtn.closest('.variant-row') as HTMLElement;
                const w = row.querySelector('.variant-weight-input') as HTMLInputElement;
                const l = row.querySelector('.variant-length-input') as HTMLInputElement;
                const wi = row.querySelector('.variant-width-input') as HTMLInputElement;
                const h = row.querySelector('.variant-height-input') as HTMLInputElement;
                const s = row.querySelector('.variant-shipping-input') as HTMLInputElement;
                if (w) w.value = shippingDefaults.weight_kg != null ? String(shippingDefaults.weight_kg) : '';
                if (l) l.value = shippingDefaults.length_cm != null ? String(shippingDefaults.length_cm) : '';
                if (wi) wi.value = shippingDefaults.width_cm != null ? String(shippingDefaults.width_cm) : '';
                if (h) h.value = shippingDefaults.height_cm != null ? String(shippingDefaults.height_cm) : '';
                if (s) s.value = shippingDefaults.shipping_cost != null ? String(shippingDefaults.shipping_cost) : '';
                renderShippingPreview(row);
                refreshChecks();
                return;
            }

            const applyShippingBtn = target.closest('.variant-apply-shipping-btn') as HTMLElement | null;
            if (applyShippingBtn) {
                const sourceRow = applyShippingBtn.closest('.variant-row') as HTMLElement;
                const weight = (sourceRow.querySelector('.variant-weight-input') as HTMLInputElement)?.value ?? '';
                const length = (sourceRow.querySelector('.variant-length-input') as HTMLInputElement)?.value ?? '';
                const width = (sourceRow.querySelector('.variant-width-input') as HTMLInputElement)?.value ?? '';
                const height = (sourceRow.querySelector('.variant-height-input') as HTMLInputElement)?.value ?? '';
                const shipping = (sourceRow.querySelector('.variant-shipping-input') as HTMLInputElement)?.value ?? '';

                variantsContainer.querySelectorAll('.variant-row').forEach((rowEl) => {
                    if (rowEl === sourceRow) return;
                    const el = rowEl as HTMLElement;
                    (el.querySelector('.variant-weight-input') as HTMLInputElement).value = weight;
                    (el.querySelector('.variant-length-input') as HTMLInputElement).value = length;
                    (el.querySelector('.variant-width-input') as HTMLInputElement).value = width;
                    (el.querySelector('.variant-height-input') as HTMLInputElement).value = height;
                    (el.querySelector('.variant-shipping-input') as HTMLInputElement).value = shipping;
                    renderShippingPreview(el);
                });
                refreshChecks();
                return;
            }

            const removeBtn = target.closest('.variant-remove-btn') as HTMLElement | null;
            if (removeBtn) {
                const row = removeBtn.closest('.variant-row') as HTMLElement;
                row.remove();
                refreshChecks();
                return;
            }

        });

        // Input delegate: live shipping preview + summary update + checks
        variantsContainer.addEventListener('input', (e: Event) => {
            const target = e.target as HTMLElement;
            const row = target.closest('.variant-row') as HTMLElement | null;
            if (!row) return;
            if (
                target.classList.contains('variant-weight-input') ||
                target.classList.contains('variant-length-input') ||
                target.classList.contains('variant-width-input') ||
                target.classList.contains('variant-height-input')
            ) {
                renderShippingPreview(row);
            }
            if (
                target.classList.contains('variant-name-input') ||
                target.classList.contains('variant-price-input') ||
                target.classList.contains('variant-stock-input')
            ) {
                updateVariantSummary(row);
            }
            refreshChecks();
        });

        variantsContainer.addEventListener('change', (e: Event) => {
            const target = e.target as HTMLInputElement;
            if (target.classList.contains('variant-default-checkbox')) {
                if (target.checked) {
                    variantsContainer.querySelectorAll('.variant-default-checkbox').forEach((cb) => {
                        if (cb !== target) (cb as HTMLInputElement).checked = false;
                    });
                    // update pill display
                    variantsContainer.querySelectorAll('.variant-row').forEach((rowEl) => {
                        const row = rowEl as HTMLElement;
                        const checked = (row.querySelector('.variant-default-checkbox') as HTMLInputElement).checked;
                        const headerCell = row.querySelector('.variant-row > div') as HTMLElement;
                        const namePill = row.querySelector('.variant-default-pill');
                        if (checked && !namePill && headerCell) {
                            const span = document.createElement('span');
                            span.className = 'variant-default-pill inline-flex items-center px-1.5 py-0.5 rounded-md text-[10px] font-medium bg-accent text-bg';
                            span.textContent = strings.sellerProductVariantDefault;
                            const titleWrap = row.querySelector('.variant-name-display')?.parentElement;
                            if (titleWrap) titleWrap.appendChild(span);
                        } else if (!checked && namePill) {
                            namePill.remove();
                        }
                    });
                }
            }

            if (target.classList.contains('variant-free-shipping-checkbox')) {
                const row = target.closest('.variant-row') as HTMLElement;
                const wrap = row.querySelector('.variant-shipping-cost') as HTMLElement;
                const inputWrap = row.querySelector('.variant-shipping-input-wrap') as HTMLElement;
                const display = row.querySelector('.variant-free-shipping-display') as HTMLElement;
                const input = row.querySelector('.variant-shipping-input') as HTMLInputElement;
                if (target.checked) {
                    if (input.value !== '0') input.dataset.prevValue = input.value;
                    input.value = '0';
                    inputWrap.classList.add('hidden');
                    display.classList.remove('hidden');
                    wrap.dataset.free = 'true';
                } else {
                    input.value = input.dataset.prevValue ?? '';
                    inputWrap.classList.remove('hidden');
                    display.classList.add('hidden');
                    wrap.dataset.free = 'false';
                    input.focus();
                }
                refreshChecks();
            }
        });

        addVariantBtn.addEventListener('click', () => {
            const row = createVariantRow(false);
            variantsContainer.appendChild(row);
            renderShippingPreview(row);
            row.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            refreshChecks();
        });

        function createVariantRow(isDefault: boolean): HTMLElement {
            const wrap = document.createElement('div');
            wrap.innerHTML = `
                <article class="variant-row rounded-2xl border border-border bg-bg overflow-hidden" data-variant-id="" data-is-new="true" data-variant-image="">
                    <div class="flex items-center gap-3 px-4 py-3 border-b border-border">
                        <div class="variant-thumb w-10 h-10 rounded-lg border border-border bg-surface overflow-hidden flex items-center justify-center shrink-0">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-text-tertiary"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                        </div>
                        <div class="min-w-0 flex-1">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="text-sm font-medium text-text-primary truncate"><span class="variant-name-display">${strings.sellerProductVariantPlaceholderName}</span></span>
                                ${isDefault ? `<span class="variant-default-pill inline-flex items-center px-1.5 py-0.5 rounded-md text-[10px] font-medium bg-accent text-bg">${strings.sellerProductVariantDefault}</span>` : ''}
                            </div>
                            <p class="text-[11px] text-text-tertiary mt-0.5 tabular-nums"><span class="variant-price-display">—</span><span class="mx-1.5 opacity-50">·</span><span class="variant-stock-display">0 uds</span></p>
                        </div>
                        <button type="button" class="variant-toggle-btn flex items-center justify-center w-8 h-8 rounded-lg text-text-secondary hover:text-text-primary hover:bg-border-light transition-colors" aria-expanded="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></button>
                        <button type="button" class="variant-remove-btn flex items-center justify-center w-8 h-8 rounded-lg text-text-tertiary hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" aria-label="${strings.sellerProductVariantRemove}"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
                    </div>
                    <div class="variant-body p-4 space-y-5">
                        <div class="grid gap-4 sm:grid-cols-12">
                            <div class="sm:col-span-5">
                                <label class="block text-[11px] font-medium text-text-tertiary mb-1">${strings.sellerProductVariantNameLabel}</label>
                                <input type="text" class="variant-name-input w-full px-3 py-2 rounded-lg border border-border bg-surface text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition" placeholder="${strings.sellerProductVariantNamePlaceholder}" />
                            </div>
                            <div class="sm:col-span-4">
                                <label class="block text-[11px] font-medium text-text-tertiary mb-1">${strings.sellerProductVariantPriceLabel}</label>
                                <input type="number" step="0.01" min="0" class="variant-price-input w-full px-3 py-2 rounded-lg border border-border bg-surface text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantPricePlaceholder}" />
                            </div>
                            <div class="sm:col-span-3">
                                <label class="block text-[11px] font-medium text-text-tertiary mb-1">${strings.sellerProductVariantStockLabel}</label>
                                <input type="number" min="0" class="variant-stock-input w-full px-3 py-2 rounded-lg border border-border bg-surface text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantStockPlaceholder}" />
                            </div>
                        </div>
                        <div class="flex flex-wrap items-center gap-3 pt-1">
                            <label class="flex items-center gap-2 text-xs text-text-secondary cursor-pointer select-none">
                                <input type="checkbox" class="variant-default-checkbox rounded border-border accent-neutral-900 dark:accent-white" ${isDefault ? 'checked' : ''} />
                                ${strings.sellerProductVariantDefaultNote}
                            </label>
                            <div class="ml-auto flex items-center gap-2">
                                <button type="button" class="variant-image-btn flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] font-medium text-text-secondary border border-border hover:bg-border-light transition-colors"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>Foto</button>
                                <input type="file" accept="image/jpeg,image/png,image/webp,image/gif" class="variant-image-input hidden" />
                            </div>
                        </div>
                        <div class="rounded-2xl border border-border bg-surface p-4 space-y-4">
                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                                <div>
                                    <h3 class="text-[11px] font-semibold uppercase tracking-[0.14em] text-text-secondary">${strings.sellerProductVariantSizeWeight}</h3>
                                    <p class="text-[11px] text-text-tertiary mt-0.5">${strings.sellerProductVariantSizeWeightHint}</p>
                                </div>
                                <div class="flex items-center gap-2">
                                    <button type="button" class="variant-use-defaults-btn px-2.5 py-1 rounded-lg text-[11px] font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">${strings.sellerProductVariantUseDefaults}</button>
                                    <button type="button" class="variant-apply-shipping-btn px-2.5 py-1 rounded-lg text-[11px] font-medium text-text-secondary border border-border hover:bg-border-light transition-colors">${strings.sellerProductVariantApplyToRest}</button>
                                </div>
                            </div>
                            <div class="grid gap-3 grid-cols-2 sm:grid-cols-4">
                                <div><label class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">${strings.sellerProductVariantWeightLabel}</label><input type="number" step="0.001" min="0" class="variant-weight-input w-full px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantWeightPlaceholder}" value="${shippingDefaults.weight_kg ?? ''}" /></div>
                                <div><label class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">${strings.sellerProductVariantLengthLabel}</label><input type="number" step="0.1" min="0" class="variant-length-input w-full px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantLengthPlaceholder}" value="${shippingDefaults.length_cm ?? ''}" /></div>
                                <div><label class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">${strings.sellerProductVariantWidthLabel}</label><input type="number" step="0.1" min="0" class="variant-width-input w-full px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantWidthPlaceholder}" value="${shippingDefaults.width_cm ?? ''}" /></div>
                                <div><label class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary mb-1">${strings.sellerProductVariantHeightLabel}</label><input type="number" step="0.1" min="0" class="variant-height-input w-full px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantHeightPlaceholder}" value="${shippingDefaults.height_cm ?? ''}" /></div>
                            </div>
                            <div class="variant-shipping-cost border-t border-border pt-3" data-free="false">
                                <div class="flex items-center justify-between gap-3 mb-2">
                                    <label class="block text-[10px] font-medium uppercase tracking-wider text-text-tertiary">${strings.sellerProductVariantBaseShipping}</label>
                                    <label class="flex items-center gap-2 cursor-pointer select-none">
                                        <span class="text-[11px] font-medium text-text-secondary">${strings.sellerProductVariantFreeShipping}</span>
                                        <span class="relative inline-flex shrink-0">
                                            <input type="checkbox" class="variant-free-shipping-checkbox sr-only peer" />
                                            <span class="block w-9 h-5 bg-border-light rounded-full peer-focus-visible:ring-2 peer-focus-visible:ring-accent peer-checked:bg-green-500 transition-colors"></span>
                                            <span class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full shadow-sm transition-transform peer-checked:translate-x-4"></span>
                                        </span>
                                    </label>
                                </div>
                                <div class="variant-shipping-input-wrap flex items-center gap-2">
                                    <input type="number" step="0.01" min="0" class="variant-shipping-input flex-1 px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition tabular-nums" placeholder="${strings.sellerProductVariantShippingPlaceholder}" value="${shippingDefaults.shipping_cost ?? ''}" />
                                    <span class="text-xs text-text-tertiary shrink-0">${strings.sellerProductVariantBaseShippingHint}</span>
                                </div>
                                <div class="variant-free-shipping-display hidden flex items-center gap-2 px-3 py-2.5 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200/70 dark:border-green-800/60">
                                    <span class="flex items-center justify-center w-5 h-5 rounded-full bg-green-500 text-white shrink-0"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                                    <span class="text-[11px] font-medium text-green-700 dark:text-green-400">${strings.sellerProductVariantFreeShippingActive}</span>
                                </div>
                            </div>

                            <!-- Live shipping preview -->
                            <div class="shipping-live rounded-xl border border-border bg-bg p-3.5 mt-3">
                                <div class="flex items-start gap-2 mb-3">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary mt-0.5"><path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5v8h1"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-xs font-semibold text-text-primary">${strings.sellerProductShippingLiveTitle}</p>
                                        <p class="text-[10px] text-text-tertiary mt-0.5">${strings.sellerProductShippingLiveSubtitle}</p>
                                    </div>
                                    <span class="shipping-billable hidden text-[10px] font-medium text-text-tertiary tabular-nums shrink-0"></span>
                                </div>
                                <div class="shipping-quotes hidden grid gap-2"></div>
                                <p class="shipping-empty text-[11px] text-text-tertiary text-center py-2">${strings.sellerProductShippingLiveAwaiting}</p>
                                <div class="shipping-loading hidden flex items-center justify-center gap-2 py-3 text-[11px] text-text-tertiary">
                                    <svg class="animate-spin" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56" /></svg>
                                    <span>${strings.sellerProductShippingLiveLoading}</span>
                                </div>
                                <p class="shipping-error hidden text-[11px] text-amber-700 dark:text-amber-400 text-center py-2"></p>
                            </div>
                        </div>
                    </div>
                </article>`;
            return wrap.firstElementChild as HTMLElement;
        }

        addSpecBtn.addEventListener('click', () => {
            const div = document.createElement('div');
            div.className = 'spec-row flex items-center gap-2';
            div.innerHTML = `<input type="text" class="spec-key-input flex-1 min-w-0 px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition" placeholder="${strings.sellerProductSpecsKeyPlaceholder}" /><input type="text" class="spec-value-input flex-1 min-w-0 px-3 py-2 rounded-lg border border-border bg-bg text-text-primary text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition" placeholder="${strings.sellerProductSpecsValuePlaceholder}" /><button type="button" class="spec-remove-btn flex items-center justify-center w-8 h-8 rounded-lg text-text-tertiary hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors shrink-0"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button>`;
            specsContainer.appendChild(div);
        });

        specsContainer.addEventListener('click', (e: MouseEvent) => {
            const removeBtn = (e.target as HTMLElement).closest('.spec-remove-btn') as HTMLElement | null;
            if (!removeBtn) return;
            removeBtn.closest('.spec-row')!.remove();
        });

        imageGallery.addEventListener('click', (e: MouseEvent) => {
            const removeBtn = (e.target as HTMLElement).closest('.image-remove-btn') as HTMLElement | null;
            if (!removeBtn) return;
            const item = removeBtn.closest('.image-item') as HTMLElement;
            const url = item.dataset.url;
            const idx = galleryUrls.indexOf(url!);
            if (idx > -1) galleryUrls.splice(idx, 1);
            renderGallery();
            refreshChecks();
        });

        saveBtn.addEventListener('click', async () => {
            const title = titleInput.value.trim();
            const slug = slugInput.value.trim();
            const category = categorySelect.value;
            const description = descriptionInput.value.trim();
            const brand = brandInput.value.trim();
            const is_active = activeCheckbox.checked;

            if (!title) { toast.error(strings.sellerProductTitleRequired); return; }
            if (!category) { toast.error(strings.sellerProductCategoryRequired); return; }

            const variants = Array.from(variantsContainer.querySelectorAll('.variant-row')).map((row: Element) => {
                const el = row as HTMLElement;
                const price = parseFloat((el.querySelector('.variant-price-input') as HTMLInputElement).value) || 0;
                return {
                    id: el.dataset.variantId || undefined,
                    variant_name: (el.querySelector('.variant-name-input') as HTMLInputElement).value.trim() || null,
                    price,
                    stock: parseInt((el.querySelector('.variant-stock-input') as HTMLInputElement).value) || 0,
                    is_default: (el.querySelector('.variant-default-checkbox') as HTMLInputElement).checked,
                    variant_image: el.dataset.variantImage || (el.querySelector('.variant-thumb img')?.getAttribute('src')) || null,
                    weight_kg: (el.querySelector('.variant-weight-input') as HTMLInputElement).value === '' ? null : parseFloat((el.querySelector('.variant-weight-input') as HTMLInputElement).value),
                    length_cm: (el.querySelector('.variant-length-input') as HTMLInputElement).value === '' ? null : parseFloat((el.querySelector('.variant-length-input') as HTMLInputElement).value),
                    width_cm: (el.querySelector('.variant-width-input') as HTMLInputElement).value === '' ? null : parseFloat((el.querySelector('.variant-width-input') as HTMLInputElement).value),
                    height_cm: (el.querySelector('.variant-height-input') as HTMLInputElement).value === '' ? null : parseFloat((el.querySelector('.variant-height-input') as HTMLInputElement).value),
                    shipping_cost: (el.querySelector('.variant-shipping-input') as HTMLInputElement).value === '' ? null : parseFloat((el.querySelector('.variant-shipping-input') as HTMLInputElement).value),
                };
            });

            if (variants.length === 0) { toast.error(strings.sellerProductNoVariantsError); return; }

            const missingFields: string[] = [];
            if (!title) missingFields.push(strings.sellerProductMissingName);
            if (!description) missingFields.push(strings.sellerProductMissingDescription);
            if (!category) missingFields.push(strings.sellerProductMissingCategory);
            if (!slug) missingFields.push(strings.sellerProductMissingSlug);
            if (galleryUrls.length === 0) missingFields.push(strings.sellerProductMissingPhotos);

            const hasCompleteVariant = variants.some((v: any) =>
                v.price > 0 && v.stock >= 0 &&
                v.weight_kg != null && v.weight_kg > 0 &&
                v.length_cm != null && v.length_cm > 0 &&
                v.width_cm != null && v.width_cm > 0 &&
                v.height_cm != null && v.height_cm > 0 &&
                v.shipping_cost != null && v.shipping_cost >= 0
            );
            if (!hasCompleteVariant) missingFields.push(strings.sellerProductMissingVariantData);

            if (missingFields.length > 0) {
                toast.error(strings.sellerProductIncompleteError.replace('{fields}', missingFields.join(', ')));
                return;
            }

            const specs: Record<string, string> = {};
            specsContainer.querySelectorAll('.spec-row').forEach((row: Element) => {
                const key = (row.querySelector('.spec-key-input') as HTMLInputElement).value.trim();
                const value = (row.querySelector('.spec-value-input') as HTMLInputElement).value.trim();
                if (key) specs[key] = value;
            });

            const payload = {
                title,
                slug: slug || undefined,
                description: description || null,
                category,
                brand: brand || null,
                specifications: specs,
                gallery_images: galleryUrls,
                is_active,
                variants,
            };

            let url = '/api/sell/catalog/product';
            let method = 'POST';
            const productId = (document.getElementById('product-id') as HTMLInputElement).value;
            if (mode === 'edit' && productId) {
                url += `?id=${productId}`;
                method = 'PATCH';
            }

            const result = await runSubmit({
                button: saveBtn,
                busyLabel: strings.sellerProductSaving,
                action: async () => {
                    const res = await fetch(url, {
                        method,
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload),
                    });
                    const data: { product?: { id: string }; error?: string } = await res.json();
                    if (!res.ok) throw new SubmitError(data.error || strings.sellerProductSaveError);
                    return data;
                },
                successMsg: strings.productSavedToast,
            });

            if (result.ok) {
                const data = result.value as { product?: { id: string } };
                if (mode === 'create' && data?.product?.id) {
                    window.location.href = `/sell/catalog/${data.product.id}`;
                } else if (mode === 'edit') {
                    window.location.href = '/sell/catalog';
                }
            }
        });

        // Initial render of live shipping preview + summaries
        variantsContainer.querySelectorAll('.variant-row').forEach((rowEl) => {
            const row = rowEl as HTMLElement;
            renderShippingPreview(row);
            updateVariantSummary(row);
        });
        refreshChecks();
        refreshHeaderTitle();
    }

    document.addEventListener('astro:page-load', initProductForm);
    if (document.readyState !== 'loading') initProductForm();
    else document.addEventListener('DOMContentLoaded', initProductForm);
</script>
