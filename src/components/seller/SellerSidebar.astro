---
import Icon from '../icons/Icon.astro';
import { sellerNavItems, sellerFooterNavItem } from '../../lib/ui/seller-nav';
import { strings } from '../../lib/core/i18n';

interface Props {
    currentPath: string;
    shopSlug?: string;
    stripeStatus?: 'not_connected' | 'pending' | 'ready';
    activeIncidents?: number;
    pendingOrdersCount?: number;
    deliveryFailedCount?: number;
    incompleteProductsCount?: number;
}

const { currentPath, shopSlug, stripeStatus = 'not_connected', activeIncidents = 0, pendingOrdersCount = 0, deliveryFailedCount = 0, incompleteProductsCount = 0 } = Astro.props;

function isActive(href: string) {
    if (href === '/sell') return currentPath === '/sell';
    return currentPath === href || currentPath.startsWith(href + '/');
}
---

<!-- Mobile backdrop -->
<div
    id="seller-sidebar-backdrop"
    class="fixed inset-0 z-40 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
    aria-hidden="true"
></div>

<aside
    id="seller-sidebar"
    aria-label={strings.sellerSidebarLabel}
    class="
        fixed inset-y-0 left-0 z-50 flex flex-col shrink-0
        bg-surface border-r border-border
        -translate-x-full transition-transform duration-300 ease-in-out
        lg:sticky lg:top-0 lg:h-dvh lg:translate-x-0
    "
>
    <!-- Header -->
    <div class="sidebar-header flex items-center h-16 px-4 border-b border-border shrink-0 overflow-hidden">
        <a
            href="/sell"
            class="sidebar-brand flex-1 min-w-0 font-semibold text-sm text-text-primary tracking-tight truncate"
        >
            {strings.sellerBrandName}
        </a>

        <!-- Desktop: collapse/expand toggle -->
        <button
            id="seller-sidebar-collapse-btn"
            class="hidden lg:flex shrink-0 items-center justify-center w-8 h-8 rounded-lg text-text-tertiary hover:text-text-primary hover:bg-border-light transition-colors"
            aria-label={strings.sellerSidebarCollapseLabel}
        >
            <Icon name="panel-left" size={16} />
        </button>

        <!-- Mobile: close button -->
        <button
            id="seller-sidebar-close-btn"
            class="flex lg:hidden shrink-0 items-center justify-center w-8 h-8 rounded-lg text-text-tertiary hover:text-text-primary hover:bg-border-light transition-colors"
            aria-label={strings.sellerSidebarCloseLabel}
        >
            <Icon name="x" size={18} />
        </button>
    </div>

    <!-- Main navigation -->
    <nav class="flex-1 overflow-y-auto overflow-x-hidden px-2 py-3" aria-label={strings.sellerSidebarLabel}>
        <ul class="space-y-0.5" role="list">
            {sellerNavItems.map(item => (
                <li>
                    <a
                        href={item.href}
                        class:list={[
                            'sidebar-link relative flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium outline-none transition-colors focus-visible:ring-2 focus-visible:ring-accent',
                            isActive(item.href)
                                ? 'bg-accent text-bg'
                                : 'text-text-secondary hover:text-text-primary hover:bg-border-light',
                        ]}
                        aria-current={isActive(item.href) ? 'page' : undefined}
                    >
                        <Icon name={item.icon} size={20} class="shrink-0" />
                        <span class="sidebar-label truncate">{item.label}</span>
                        {item.href === '/sell/orders' && (pendingOrdersCount > 0 || deliveryFailedCount > 0) && (
                            <span class="sidebar-label ml-auto inline-flex items-center gap-1">
                                {pendingOrdersCount > 0 && (
                                    <span class:list={[
                                        'inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full text-[10px] font-bold leading-none',
                                        isActive(item.href) ? 'bg-bg text-accent' : 'bg-accent text-bg',
                                    ]}>
                                        {pendingOrdersCount}
                                    </span>
                                )}
                                {deliveryFailedCount > 0 && (
                                    <span class="inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-red-500 text-white text-[10px] font-bold leading-none">
                                        {deliveryFailedCount}
                                    </span>
                                )}
                            </span>
                        )}
                        {item.href === '/sell/catalog' && incompleteProductsCount > 0 && (
                            <span class="sidebar-label ml-auto inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-red-500 text-white text-[10px] font-bold leading-none">
                                {incompleteProductsCount}
                            </span>
                        )}
                        {item.href === '/sell/claims' && activeIncidents > 0 && (
                            <span class="sidebar-label ml-auto inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-red-500 text-white text-[10px] font-bold leading-none">
                                {activeIncidents}
                            </span>
                        )}
                        <span class="sidebar-tooltip" role="tooltip" aria-hidden="true">{item.label}</span>
                    </a>
                </li>
            ))}
            <li>
                <button
                    type="button"
                    id="stripe-nav-btn"
                    data-stripe-status={stripeStatus}
                    class:list={[
                        'sidebar-link relative flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium outline-none transition-colors focus-visible:ring-2 focus-visible:ring-accent w-full text-left',
                        stripeStatus === 'ready'
                            ? 'text-text-secondary hover:text-text-primary hover:bg-border-light'
                            : 'text-amber-600 dark:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-900/10',
                    ]}
                >
                    <span class="relative shrink-0">
                        <Icon name="credit-card" size={20} />
                        {stripeStatus !== 'ready' && (
                            <span class="absolute -top-0.5 -right-0.5 flex h-2 w-2">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
                            </span>
                        )}
                    </span>
                    <span id="stripe-nav-label" class="sidebar-label truncate">{strings.sellerNavStripe}</span>
                    <span id="stripe-nav-spinner" class="hidden shrink-0">
                        <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </span>
                    {stripeStatus !== 'ready' && (
                        <span id="stripe-nav-badge" class="sidebar-label ml-auto text-[10px] font-semibold uppercase tracking-wider text-amber-500 dark:text-amber-400">{strings.sellerNavStripeWarning}</span>
                    )}
                    <span class="sidebar-tooltip" role="tooltip" aria-hidden="true">{strings.sellerNavStripe}</span>
                </button>
            </li>
        </ul>
    </nav>

    <!-- Footer: view shop + settings -->
    <div class="px-2 py-3 border-t border-border shrink-0 flex flex-col gap-0.5">
        {shopSlug && (
            <a
                href={`/${shopSlug}`}
                target="_blank"
                rel="noopener noreferrer"
                class="sidebar-link relative flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium outline-none transition-colors focus-visible:ring-2 focus-visible:ring-accent text-text-secondary hover:text-text-primary hover:bg-border-light"
            >
                <Icon name="external-link" size={20} class="shrink-0" />
                <span class="sidebar-label truncate">{strings.sellerSidebarViewShop}</span>
                <span class="sidebar-tooltip" role="tooltip" aria-hidden="true">{strings.sellerSidebarViewShop}</span>
            </a>
        )}
        <a
            href={sellerFooterNavItem.href}
            class:list={[
                'sidebar-link relative flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium outline-none transition-colors focus-visible:ring-2 focus-visible:ring-accent',
                isActive(sellerFooterNavItem.href)
                    ? 'bg-accent text-bg'
                    : 'text-text-secondary hover:text-text-primary hover:bg-border-light',
            ]}
            aria-current={isActive(sellerFooterNavItem.href) ? 'page' : undefined}
        >
            <Icon name={sellerFooterNavItem.icon} size={20} class="shrink-0" />
            <span class="sidebar-label truncate">{sellerFooterNavItem.label}</span>
            <span class="sidebar-tooltip" role="tooltip" aria-hidden="true">{sellerFooterNavItem.label}</span>
        </a>
    </div>
</aside>

<style>
    /* ─── Desktop: width & collapse transition ─── */
    @media (min-width: 1024px) {
        #seller-sidebar {
            width: 240px;
            transition: width 220ms cubic-bezier(0.4, 0, 0.2, 1);
        }

        #seller-sidebar[data-collapsed] {
            width: 64px;
        }

        /* Hide text in collapsed state */
        #seller-sidebar[data-collapsed] .sidebar-brand,
        #seller-sidebar[data-collapsed] .sidebar-label {
            display: none;
        }

        /* Center header when collapsed */
        #seller-sidebar[data-collapsed] .sidebar-header {
            justify-content: center;
            padding-inline: 0;
        }

        /* Center nav links when collapsed */
        #seller-sidebar[data-collapsed] .sidebar-link {
            justify-content: center;
            gap: 0;
            padding-inline: 0;
            width: 40px;
            margin-inline: auto;
        }
    }

    /* ─── Tooltip: visible only when desktop + collapsed ─── */
    .sidebar-tooltip {
        display: none;
        position: absolute;
        left: calc(100% + 10px);
        top: 50%;
        transform: translateY(-50%);
        padding: 4px 10px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
        border-radius: 6px;
        pointer-events: none;
        z-index: 60;
        background-color: var(--color-text-primary-val);
        color: var(--color-bg-val);
        opacity: 0;
        transition: opacity 120ms ease;
    }

    @media (min-width: 1024px) {
        #seller-sidebar[data-collapsed] .sidebar-tooltip {
            display: block;
        }

        #seller-sidebar[data-collapsed] .sidebar-link:hover .sidebar-tooltip {
            opacity: 1;
        }
    }
</style>

<script>
    declare global {
        interface Window {
            openSellerSidebar: () => void;
            closeSellerSidebar: () => void;
        }
    }

    function initSellerSidebar() {
        const sidebar = document.getElementById('seller-sidebar') as HTMLElement | null;
        const backdrop = document.getElementById('seller-sidebar-backdrop') as HTMLElement | null;
        const collapseBtn = document.getElementById('seller-sidebar-collapse-btn');
        const closeBtn = document.getElementById('seller-sidebar-close-btn');

        if (!sidebar) return;

        // Restore desktop preference
        if (window.innerWidth >= 1024 && localStorage.getItem('fewya-seller-sidebar') === 'collapsed') {
            sidebar.dataset.collapsed = '';
            collapseBtn?.setAttribute('aria-label', 'Expandir menú');
        }

        // Desktop: toggle collapsed
        collapseBtn?.addEventListener('click', () => {
            const isCollapsed = 'collapsed' in sidebar.dataset;
            if (isCollapsed) {
                delete sidebar.dataset.collapsed;
                localStorage.setItem('fewya-seller-sidebar', 'expanded');
                collapseBtn.setAttribute('aria-label', 'Contraer menú');
            } else {
                sidebar.dataset.collapsed = '';
                localStorage.setItem('fewya-seller-sidebar', 'collapsed');
                collapseBtn.setAttribute('aria-label', 'Expandir menú');
            }
        });

        // Mobile: open
        window.openSellerSidebar = () => {
            sidebar.classList.remove('-translate-x-full');
            if (backdrop) {
                backdrop.classList.remove('pointer-events-none', 'opacity-0');
                backdrop.classList.add('opacity-100');
            }
        };

        // Mobile: close
        window.closeSellerSidebar = () => {
            sidebar.classList.add('-translate-x-full');
            if (backdrop) {
                backdrop.classList.add('pointer-events-none', 'opacity-0');
                backdrop.classList.remove('opacity-100');
            }
        };

        closeBtn?.addEventListener('click', window.closeSellerSidebar);
        backdrop?.addEventListener('click', window.closeSellerSidebar);

        // On resize: reset mobile open state when going to desktop
        const onResize = () => {
            if (window.innerWidth >= 1024) {
                sidebar.classList.remove('-translate-x-full');
                if (backdrop) {
                    backdrop.classList.add('pointer-events-none', 'opacity-0');
                    backdrop.classList.remove('opacity-100');
                }
            }
        };
        window.addEventListener('resize', onResize, { passive: true });

        // Stripe nav button
        const stripeNavBtn = document.getElementById('stripe-nav-btn');
        const stripeNavLabel = document.getElementById('stripe-nav-label');
        const stripeNavSpinner = document.getElementById('stripe-nav-spinner');
        const stripeNavBadge = document.getElementById('stripe-nav-badge');
        if (stripeNavBtn) {
            stripeNavBtn.addEventListener('click', async () => {
                const status = stripeNavBtn.dataset.stripeStatus;

                if (status === 'ready') {
                    stripeNavBtn.setAttribute('disabled', 'true');
                    if (stripeNavLabel) stripeNavLabel.textContent = 'Abriendo…';
                    if (stripeNavSpinner) stripeNavSpinner.classList.remove('hidden');
                    if (stripeNavBadge) stripeNavBadge.classList.add('hidden');
                    try {
                        const res = await fetch('/api/sell/stripe/connect', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ action: 'dashboard' })
                        });
                        const data = await res.json().catch(() => ({})) as { url?: string; error?: string };
                        if (data.url) {
                            window.location.href = data.url;
                        } else {
                            window.location.href = '/sell/onboarding';
                        }
                    } catch {
                        window.location.href = '/sell/onboarding';
                    }
                } else {
                    window.location.href = '/sell/onboarding';
                }
            });
        }
    }

    document.addEventListener('astro:page-load', initSellerSidebar);
    if (document.readyState !== 'loading') initSellerSidebar();
    else document.addEventListener('DOMContentLoaded', initSellerSidebar);
</script>
