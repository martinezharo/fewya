---
import { strings } from "../lib/i18n";

interface Props {
  isLoggedIn?: boolean;
}

const { isLoggedIn = false } = Astro.props;
---

{!isLoggedIn && (
  <section class="px-4 pt-8 pb-6 md:px-10 md:pt-12 md:pb-8 md:max-w-[1400px] md:mx-auto">
    <div class="max-w-[560px]">
      <div class="hero-text">
        <h1 class="text-[26px] md:text-4xl font-bold tracking-[-0.5px] leading-[1.15] mb-2.5 text-text-primary">{strings.heroTitle}</h1>
        <p class="text-[15px] md:text-[17px] leading-[1.5] text-text-secondary m-0">{strings.heroSubtitle}</p>
      </div>
      <a
        href="/api/auth/login"
        class="hero-signin-btn inline-flex items-center gap-2.5 mt-5 px-5 py-2.5 bg-bg border border-border-light rounded-full text-[14px] font-semibold text-text-primary no-underline transition-colors duration-150 hover:bg-surface shadow-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="18" height="18" aria-hidden="true">
          <path fill="#EA4335" d="M24 9.5c3.14 0 5.95 1.08 8.17 2.86l6.08-6.08C34.46 3.1 29.5 1 24 1 14.82 1 7.01 6.49 3.46 14.3l7.09 5.51C12.27 13.38 17.67 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.52 24.5c0-1.64-.15-3.22-.42-4.74H24v8.98h12.67c-.55 2.94-2.2 5.43-4.68 7.1l7.2 5.6C43.38 37.26 46.52 31.34 46.52 24.5z"/>
          <path fill="#FBBC05" d="M10.55 28.19A14.57 14.57 0 0 1 9.5 24c0-1.45.2-2.86.55-4.19l-7.09-5.51A22.98 22.98 0 0 0 1 24c0 3.73.9 7.25 2.46 10.38l7.09-6.19z"/>
          <path fill="#34A853" d="M24 47c5.5 0 10.12-1.82 13.49-4.93l-7.2-5.6c-1.83 1.23-4.18 1.95-6.29 1.95-6.33 0-11.73-3.88-13.45-9.23l-7.09 6.19C7.01 41.51 14.82 47 24 47z"/>
          <path fill="none" d="M1 1h46v46H1z"/>
        </svg>
        {strings.heroGoogleSignIn}
      </a>
    </div>
  </section>
)}

<style>
  @media (display-mode: standalone) {
    .hero-text {
      display: none;
    }
    .hero-signin-btn {
      margin-top: 0;
    }
  }
</style>
