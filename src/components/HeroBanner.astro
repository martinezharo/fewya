---
import { strings } from "../lib/strings";

interface Props {
  isPwa?: boolean;
  isLoggedIn?: boolean;
}

const { isPwa = false, isLoggedIn = false } = Astro.props;

const showBanner = !isLoggedIn;
const showPwaBanner = showBanner && isPwa;
const showWebBanner = showBanner && !isPwa;
---

{
  showPwaBanner && (
    <section class="flex items-center justify-between gap-3 mx-4 mb-2 p-[14px_18px] bg-surface border border-border-light rounded-lg">
      <p class="text-[13px] text-text-secondary leading-[1.4] m-0">{strings.pwaSignupMessage}</p>
      <button class="shrink-0 px-4 py-2 text-[13px] font-semibold font-sans text-white bg-accent border-none rounded-full cursor-pointer transition-colors duration-150 hover:bg-accent-hover" disabled>
        {strings.pwaSignupCta}
      </button>
    </section>
  )
}

{
  showWebBanner && (
    <section class="px-4 pt-8 pb-6 md:px-10 md:pt-12 md:pb-8 md:max-w-[1400px] md:mx-auto">
      <div class="max-w-[560px]">
        <h1 class="text-[26px] md:text-4xl font-bold tracking-[-0.5px] leading-[1.15] mb-2.5 text-text-primary">{strings.heroTitle}</h1>
        <p class="text-[15px] md:text-[17px] leading-[1.5] text-text-secondary m-0">{strings.heroSubtitle}</p>
      </div>
    </section>
  )
}
