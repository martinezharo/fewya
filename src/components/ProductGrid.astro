---
import ProductCard from "./ProductCard.astro";
import type { Product } from "../lib/types";

interface Props {
    products: Product[];
}

const { products } = Astro.props;
---

<section class="grid grid-cols-2 gap-2.5 px-4 pb-[120px] md:grid-cols-5 md:gap-4 md:px-10 md:pb-[60px] md:max-w-[1400px] md:mx-auto">
    {products.map((product) => <ProductCard product={product} />)}
</section>
