---
import ProductCard from "./ProductCard.astro";
import type { Product } from "../lib/core/types";

interface Props {
    products: Product[];
    wishedProductIds?: Set<string>;
}

const { products, wishedProductIds = new Set() } = Astro.props;
---

<section class="grid grid-cols-1 gap-3 px-4 pb-[120px] md:grid-cols-4 lg:grid-cols-5 md:gap-3 md:px-10 md:pb-[60px] md:max-w-[1400px] md:mx-auto">
    {products.map((product) => <ProductCard product={product} isWished={wishedProductIds.has(product.id)} />)}
</section>
