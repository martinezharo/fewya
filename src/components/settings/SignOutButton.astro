---
import Icon from '../icons/Icon.astro';
import { strings } from '../../lib/i18n';
---

<div class="bg-surface border border-border-light rounded-2xl overflow-hidden">
    <button
        type="button"
        data-sign-out-btn
        class="w-full flex items-center gap-3 px-5 py-4 hover:bg-border-light transition-colors"
    >
        <Icon name="log-out" size={20} class="text-text-secondary" />
        <span class="text-[15px] font-medium text-text-primary">
            {strings.settingsSignOut}
        </span>
    </button>
</div>

<script>
    function init() {
        const btn = document.querySelector<HTMLButtonElement>('[data-sign-out-btn]');
        btn?.addEventListener('click', () => {
            window.location.href = '/api/auth/logout';
        });
    }
    document.addEventListener('astro:page-load', init);
    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
</script>
