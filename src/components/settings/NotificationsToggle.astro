---
// Self-contained push notification toggle. Renders a card with an action button
// whose label/state is resolved client-side from the current subscription state.
// Works in both buyer (/me/settings) and seller (/sell/settings) pages.
const { t } = Astro.locals;
---

<div class="bg-surface border border-border-light rounded-2xl p-5" data-notif-toggle>
    <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
            <p class="text-sm font-medium text-text-primary">{t.notifSettingsTitle}</p>
            <p class="mt-1 text-[13px] text-text-secondary" data-notif-help>{t.notifSettingsHelp}</p>
        </div>
        <button
            type="button"
            data-notif-action
            hidden
            class="shrink-0 rounded-lg border border-border-light px-3 py-1.5 text-sm font-medium text-text-primary transition hover:bg-border-light/40 disabled:opacity-60"
        >
            {t.notifSettingsEnable}
        </button>
    </div>
</div>

<script>
    import { isPushSupported, currentState, subscribe, unsubscribe } from '../../lib/ui/push-subscribe';
    import { toast } from '../../lib/ui/toast';
    import { getClientT } from '../../lib/core/i18n';
const t = getClientT();

    async function init() {
        const root = document.querySelector('[data-notif-toggle]');
        if (!root) return;
        const help = root.querySelector('[data-notif-help]') as HTMLElement | null;
        const btn = root.querySelector('[data-notif-action]') as HTMLButtonElement | null;
        if (!btn || !help) return;

        if (!isPushSupported()) {
            help.textContent = t.notifSettingsUnsupported;
            return;
        }

        const render = async () => {
            const state = await currentState();
            if (state === 'denied') {
                help.textContent = t.notifSettingsBlocked;
                btn.hidden = true;
                return;
            }
            btn.hidden = false;
            btn.disabled = false;
            if (state === 'granted-subscribed') {
                btn.textContent = t.notifSettingsDisable;
                help.textContent = t.notifSettingsEnabled;
            } else {
                btn.textContent = t.notifSettingsEnable;
                help.textContent = t.notifSettingsHelp;
            }
        };

        btn.addEventListener('click', async () => {
            btn.disabled = true;
            const state = await currentState();
            try {
                if (state === 'granted-subscribed') {
                    await unsubscribe();
                    toast.success(t.notifToastDisabled);
                } else {
                    const ok = await subscribe();
                    if (ok) toast.success(t.notifToastEnabled);
                    else toast.error(t.notifToastError);
                }
            } catch {
                toast.error(t.notifToastError);
            }
            await render();
        });

        await render();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
</script>
