# ─── Modo de la aplicación ─────────────────────────────────────────────
# Valores: development | production
# Si se omite, el default es "development" (más seguro: nunca toca Stripe/Sendcloud reales sin intención).
# En el Worker desplegado, este valor también está fijado en wrangler.jsonc.
APP_MODE=development

# ─── Supabase (build-time, públicos en el cliente) ────────────────────
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_KEY=<supabase-anon-public-key>

# ─── Supabase service role (runtime secret, bypassa RLS) ──────────────
# Formato: sb_secret_...
SUPABASE_SECRET_KEY=sb_secret_<service-role-key>

# ─── Stripe ───────────────────────────────────────────────────────────
# Las dos parejas pueden coexistir. APP_MODE decide cuál se usa.
# Test keys (https://dashboard.stripe.com/test/apikeys):
STRIPE_SECRET_KEY_TEST=sk_test_<your-test-secret-key>
STRIPE_WEBHOOK_SECRET_TEST=whsec_<your-test-webhook-signing-secret>
# Live keys (https://dashboard.stripe.com/apikeys):
STRIPE_SECRET_KEY_LIVE=sk_live_<your-live-secret-key>
STRIPE_WEBHOOK_SECRET_LIVE=whsec_<your-live-webhook-signing-secret>

# ─── Sendcloud ────────────────────────────────────────────────────────
# En APP_MODE=development NO se llama a Sendcloud: se generan etiquetas
# mock localmente (PDF falso). Estas claves solo se usan en APP_MODE=production.
SENDCLOUD_API_KEY=<sendcloud-public-key>
SENDCLOUD_API_SECRET=<sendcloud-private-secret>
SENDCLOUD_WEBHOOK_SECRET=<sendcloud-webhook-signing-secret>

# ─── Cron (jobs internos protegidos por header X-Cron-Secret) ─────────
CRON_SECRET=<cualquier-string-fuerte-y-aleatoria>
