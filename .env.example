# ─── Application mode ──────────────────────────────────────────────────
# Values: development | production
# Defaults to "development" if omitted (safer: never touches real Stripe/Sendcloud without intent).
# On the deployed Worker, this value is also set in wrangler.jsonc.
APP_MODE=development

# ─── Supabase (build-time, public on client) ──────────────────────────
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_KEY=<supabase-anon-public-key>

# ─── Supabase service role (runtime secret, bypasses RLS) ─────────────
# Format: sb_secret_...
SUPABASE_SECRET_KEY=sb_secret_<service-role-key>

# ─── Stripe ───────────────────────────────────────────────────────────
# Both pairs can coexist. APP_MODE decides which one is used.
# Test keys (https://dashboard.stripe.com/test/apikeys):
STRIPE_SECRET_KEY_TEST=sk_test_<your-test-secret-key>
STRIPE_WEBHOOK_SECRET_TEST=whsec_<your-test-webhook-signing-secret>
# Live keys (https://dashboard.stripe.com/apikeys):
STRIPE_SECRET_KEY_LIVE=sk_live_<your-live-secret-key>
STRIPE_WEBHOOK_SECRET_LIVE=whsec_<your-live-webhook-signing-secret>

# ─── Sendcloud ────────────────────────────────────────────────────────
# In APP_MODE=development, Sendcloud is NOT called: labels are mocked
# locally (fake PDF). These keys are only used in APP_MODE=production.
SENDCLOUD_API_KEY=<sendcloud-public-key>
SENDCLOUD_API_SECRET=<sendcloud-private-secret>
SENDCLOUD_WEBHOOK_SECRET=<sendcloud-webhook-signing-secret>

# ─── Cron (internal jobs protected by X-Cron-Secret header) ───────────
CRON_SECRET=<any-strong-random-string>

# ─── Notifications: Resend (email) ────────────────────────────────────
# If the API key is missing, the email channel is silently skipped (no errors).
RESEND_API_KEY=re_<resend-api-key>
# Optional (have defaults):
# RESEND_FROM=Fewya <no-reply@fewya.com>      # must be @fewya.com
# APP_BASE_URL=https://fewya.com              # base for links in emails/push

# ─── Notifications: Web Push (VAPID) ──────────────────────────────────
# Generate the pair with: bunx web-push generate-vapid-keys
# The public key is NOT secret (goes to the browser); the private one is.
# ⚠️ Do NOT rotate keys once there are subscribers: it would invalidate all subscriptions.
VAPID_PUBLIC_KEY=<vapid-public-key-base64url-87-chars>
VAPID_PRIVATE_KEY=<vapid-private-key-base64url-43-chars>
# Optional (default: mailto:no-reply@fewya.com):
# VAPID_SUBJECT=mailto:no-reply@fewya.com
